/-- If two irrational parameters have the same `A`-set, then they belong to
the same explicit symmetry orbit. -/
theorem mem_symmetryClass_of_A_eq {α β : ℝ}
    (hαirr : IsIrrational α) (hA : A β = A α) :
    β ∈ symmetryClass α := by
  have hβirr : IsIrrational β :=
    irrational_of_A_eq_irrational hαirr hA
  rcases exists_normalized_representative α hαirr with
    ⟨α₀, hα₀I, hAα₀, hαorbit⟩
  rcases exists_normalized_representative β hβirr with
    ⟨β₀, hβ₀I, hAβ₀, hβorbit⟩
  have hα₀irr : IsIrrational α₀ :=
    irrational_of_A_eq_irrational hαirr hAα₀
  have hβ₀_eq_α₀ : β₀ = α₀ := by
    exact (equivalence_class_problem_normalized_iff hα₀irr hα₀I hβ₀I).mp
      (by
        calc
          A β₀ = A β := hAβ₀
          _ = A α := hA
          _ = A α₀ := hAα₀.symm)
  subst β₀
  have hα₀_mem_α : α₀ ∈ symmetryClass α :=
    symmetryClass_symm hαorbit
  exact symmetryClass_trans hα₀_mem_α hβorbit

/-- The equivalence class problem, unnormalized form. -/
theorem equivalence_class_problem {α β : ℝ} (hαirr : IsIrrational α) :
    A β = A α ↔ β ∈ symmetryClass α := by
  constructor
  · exact mem_symmetryClass_of_A_eq hαirr
  · intro hβ
    exact A_eq_of_mem_symmetryClass hαirr hβ

/-- Set-valued version of the equivalence class theorem. -/
theorem AEquivClass_eq_symmetryClass {α : ℝ} (hαirr : IsIrrational α) :
    AEquivClass α = symmetryClass α := by
  ext β
  exact equivalence_class_problem hαirr

