/-! ## Primitive data for one ordered endpoint closure certificate -/

/-- Primitive input data from which
`orderedEndpointClosureCertificate_of_orderedEndpointClosure` constructs an
`OrderedEndpointClosureCertificate`. -/
structure OrderedEndpointClosurePrimitiveWitness
    (Hlog u vseq H V : ℕ → ℝ) (tau x : ℝ) : Type where
  S : ℕ → ℝ
  r : ℕ → ℝ
  err : ℕ → ℝ
  clipErr : ℕ → ℝ
  closureInput : OrderedEndpointBudgetClosureInput tau x S r err clipErr
  nonnegativeRHS : EventuallyNonnegativeClipRHS tau x clipErr
  representsShadow :
    ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) m
  activeCover :
    ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r)
  activeSublinear : ActiveShadowCountSublinear (normalizedShadowLeft S)
  errorSublinear : EventuallySublinearCountError clipErr
  actualCover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x

/-- Primitive ordered-endpoint closure data gives the compact certificate. -/
theorem orderedEndpointClosureCertificate_of_primitiveWitness
    {Hlog u vseq H V : ℕ → ℝ} {tau x : ℝ}
    (W : OrderedEndpointClosurePrimitiveWitness Hlog u vseq H V tau x) :
    OrderedEndpointClosureCertificate Hlog u vseq H V tau x := by
  exact orderedEndpointClosureCertificate_of_orderedEndpointClosure
    (Hlog := Hlog) (u := u) (vseq := vseq) (Hheight := H) (V := V)
    (tau := tau) (x := x)
    (S := W.S) (r := W.r) (err := W.err) (clipErr := W.clipErr)
    W.closureInput W.nonnegativeRHS W.representsShadow
    W.activeCover W.activeSublinear W.errorSublinear W.actualCover

