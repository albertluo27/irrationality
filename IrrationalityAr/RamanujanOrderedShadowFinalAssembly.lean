/-!
# Canonical scalar algebra closure

This closes the pure scalar target used by the clipped zero-live route.  The
remaining endpoint geometry is deliberately left in the existing geometry data
targets.
-/

/-- The square-root term in the canonical one-threshold optimizer. -/
def canonicalScalarSqrt (B : ℝ) : ℝ :=
  Real.sqrt ((B - 2) * (B + 4))

/-- Closed form of the canonical trial exponent. -/
theorem oneThresholdStrictSlackTrialNu_eq_closedForm (B : ℝ) :
    oneThresholdStrictSlackTrialNu B =
      (B + 4 + canonicalScalarSqrt B) / 3 := by
  unfold oneThresholdStrictSlackTrialNu oneThresholdBootstrapOptimizer
    canonicalScalarSqrt
  ring_nf

/-- Positivity of the square-root radicand in the range `B > 4`. -/
theorem canonicalScalarSqrt_radicand_pos {B : ℝ} (hB : 4 < B) :
    0 < (B - 2) * (B + 4) := by
  nlinarith

/-- The canonical square root is positive for `B > 4`. -/
theorem canonicalScalarSqrt_pos {B : ℝ} (hB : 4 < B) :
    0 < canonicalScalarSqrt B := by
  unfold canonicalScalarSqrt
  exact Real.sqrt_pos.2 (canonicalScalarSqrt_radicand_pos hB)

/-- The canonical square root lies below `2B - 4`. -/
theorem canonicalScalarSqrt_lt_two_mul_sub_four {B : ℝ} (hB : 4 < B) :
    canonicalScalarSqrt B < 2 * B - 4 := by
  unfold canonicalScalarSqrt
  have hright_pos : 0 < 2 * B - 4 := by nlinarith
  rw [Real.sqrt_lt' hright_pos]
  nlinarith

/-- The canonical square root lies above `(B + 4) / 2`. -/
theorem half_base_plus_four_lt_canonicalScalarSqrt {B : ℝ} (hB : 4 < B) :
    (B + 4) / 2 < canonicalScalarSqrt B := by
  unfold canonicalScalarSqrt
  have hleft_nonneg : 0 ≤ (B + 4) / 2 := by nlinarith
  rw [Real.lt_sqrt hleft_nonneg]
  nlinarith

/-- The canonical trial exponent is greater than `2`. -/
theorem oneThresholdStrictSlackTrialNu_gt_two_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    2 < oneThresholdStrictSlackTrialNu B := by
  rw [oneThresholdStrictSlackTrialNu_eq_closedForm]
  have hs_nonneg : 0 ≤ canonicalScalarSqrt B :=
    le_of_lt (canonicalScalarSqrt_pos hB)
  nlinarith

/-- The canonical trial exponent is at most the input bound. -/
theorem oneThresholdStrictSlackTrialNu_le_base_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    oneThresholdStrictSlackTrialNu B ≤ B := by
  rw [oneThresholdStrictSlackTrialNu_eq_closedForm]
  have hs_lt := canonicalScalarSqrt_lt_two_mul_sub_four hB
  linarith

/-- The canonical trial exponent is strictly below the input bound. -/
theorem oneThresholdStrictSlackTrialNu_lt_base_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    oneThresholdStrictSlackTrialNu B < B := by
  rw [oneThresholdStrictSlackTrialNu_eq_closedForm]
  have hs_lt := canonicalScalarSqrt_lt_two_mul_sub_four hB
  linarith

/-- The canonical trial exponent is above the one-threshold improvement line. -/
theorem oneThresholdStrictSlackTrialNu_gt_two_add_half_base_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    2 + B / 2 < oneThresholdStrictSlackTrialNu B := by
  rw [oneThresholdStrictSlackTrialNu_eq_closedForm]
  have hs_gt := half_base_plus_four_lt_canonicalScalarSqrt hB
  linarith

/-- The endpoint delta at the canonical trial exponent is below `1`. -/
theorem oneThresholdEndpointDelta_trial_lt_one_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    oneThresholdEndpointDelta B (oneThresholdStrictSlackTrialNu B) < 1 := by
  have hnu2 := oneThresholdStrictSlackTrialNu_gt_two_of_four_lt hB
  have hline := oneThresholdStrictSlackTrialNu_gt_two_add_half_base_of_four_lt hB
  unfold oneThresholdEndpointDelta genericEndpointAverageDelta
  have hden : 0 < 2 * (oneThresholdStrictSlackTrialNu B - 2) := by
    nlinarith
  rw [div_lt_one hden]
  linarith

/-- The rational closed output agrees with the endpoint-density output form. -/
theorem oneThresholdBootstrapOutputClosed_eq_output
    {B nu : ℝ}
    (hnu2 : nu ≠ 2) :
    oneThresholdBootstrapOutputClosed B nu =
      oneThresholdBootstrapOutput B nu := by
  unfold oneThresholdBootstrapOutputClosed oneThresholdBootstrapOutput
    oneThresholdBootstrapDelta
  field_simp [hnu2]
  ring

/-- The canonical zero-live inequality at the input bound `B`. -/
theorem canonicalScalar_zeroLive_gain_at_base_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    oneThresholdEndpointDelta B (oneThresholdStrictSlackTrialNu B) +
        oneThresholdStrictSlackTrialNu B / B < 1 := by
  have hnu2 := oneThresholdStrictSlackTrialNu_gt_two_of_four_lt hB
  have hnuB := oneThresholdStrictSlackTrialNu_lt_base_of_four_lt hB
  have hline := oneThresholdStrictSlackTrialNu_gt_two_add_half_base_of_four_lt hB
  have hiff := (oneThresholdImprovementAlgebraTarget_proved B
    (oneThresholdStrictSlackTrialNu B)) ⟨hnu2, hnuB⟩
  exact hiff.2 hline

/-- The optimized one-threshold map is below `B` at the canonical trial
exponent. -/
theorem oneThresholdBootstrapMap_lt_base_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    oneThresholdBootstrapMap B < B := by
  let nu := oneThresholdStrictSlackTrialNu B
  let delta := oneThresholdEndpointDelta B nu
  have hnu2 : 2 < nu := by
    simpa [nu] using oneThresholdStrictSlackTrialNu_gt_two_of_four_lt hB
  have hopt_ne_two : oneThresholdBootstrapOptimizer B ≠ 2 := by
    have hopt_gt_two : 2 < oneThresholdBootstrapOptimizer B := by
      simpa [nu, oneThresholdStrictSlackTrialNu] using hnu2
    linarith
  have hdelta_lt_one : delta < 1 := by
    simpa [nu, delta] using
      oneThresholdEndpointDelta_trial_lt_one_of_four_lt (B := B) hB
  have hbase : delta + nu / B < 1 := by
    simpa [nu, delta] using
      canonicalScalar_zeroLive_gain_at_base_of_four_lt (B := B) hB
  have hdenpos : 0 < 1 - delta := by linarith
  have hBpos : 0 < B := by linarith
  have hmap_eq : oneThresholdBootstrapMap B = nu / (1 - delta) := by
    unfold oneThresholdBootstrapMap
    rw [oneThresholdBootstrapOutputClosed_eq_output
      (B := B) (nu := oneThresholdBootstrapOptimizer B) hopt_ne_two]
    simp [oneThresholdBootstrapOutput, oneThresholdBootstrapDelta, nu, delta,
      oneThresholdStrictSlackTrialNu, oneThresholdEndpointDelta,
      genericEndpointAverageDelta]
  rw [hmap_eq]
  rw [div_lt_iff₀ hdenpos]
  have hbase' : nu / B < 1 - delta := by linarith
  have hmul := (div_lt_iff₀ hBpos).mp hbase'
  nlinarith

/-- The optimized one-threshold map is above the trial exponent. -/
theorem oneThresholdStrictSlackTrialNu_lt_bootstrapMap_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    oneThresholdStrictSlackTrialNu B < oneThresholdBootstrapMap B := by
  let nu := oneThresholdStrictSlackTrialNu B
  let delta := oneThresholdEndpointDelta B nu
  have hnu2 : 2 < nu := by
    simpa [nu] using oneThresholdStrictSlackTrialNu_gt_two_of_four_lt hB
  have hopt_ne_two : oneThresholdBootstrapOptimizer B ≠ 2 := by
    have hopt_gt_two : 2 < oneThresholdBootstrapOptimizer B := by
      simpa [nu, oneThresholdStrictSlackTrialNu] using hnu2
    linarith
  have hdelta_pos : 0 < delta := by
    unfold delta oneThresholdEndpointDelta genericEndpointAverageDelta
    have hnuB : nu < B := by
      simpa [nu] using oneThresholdStrictSlackTrialNu_lt_base_of_four_lt hB
    have hden : 0 < 2 * (nu - 2) := by nlinarith
    exact div_pos (by linarith) hden
  have hdelta_lt_one : delta < 1 := by
    simpa [nu, delta] using
      oneThresholdEndpointDelta_trial_lt_one_of_four_lt (B := B) hB
  have hdenpos : 0 < 1 - delta := by linarith
  have hmap_eq : oneThresholdBootstrapMap B = nu / (1 - delta) := by
    unfold oneThresholdBootstrapMap
    rw [oneThresholdBootstrapOutputClosed_eq_output
      (B := B) (nu := oneThresholdBootstrapOptimizer B) hopt_ne_two]
    simp [oneThresholdBootstrapOutput, oneThresholdBootstrapDelta, nu, delta,
      oneThresholdStrictSlackTrialNu, oneThresholdEndpointDelta,
      genericEndpointAverageDelta]
  rw [hmap_eq]
  rw [lt_div_iff₀ hdenpos]
  nlinarith

/-- The relaxed map lies strictly between the optimized map and the original
input bound. -/
theorem oneThresholdBootstrapMap_lt_relaxedMap_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    oneThresholdBootstrapMap B < oneThresholdBootstrapRelaxedMap B := by
  unfold oneThresholdBootstrapRelaxedMap
  have hmapB := oneThresholdBootstrapMap_lt_base_of_four_lt hB
  linarith

/-- The canonical trial exponent lies below the relaxed map. -/
theorem oneThresholdStrictSlackTrialNu_lt_relaxedMap_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    oneThresholdStrictSlackTrialNu B < oneThresholdBootstrapRelaxedMap B := by
  have h1 := oneThresholdStrictSlackTrialNu_lt_bootstrapMap_of_four_lt hB
  have h2 := oneThresholdBootstrapMap_lt_relaxedMap_of_four_lt hB
  exact lt_trans h1 h2

/-- Zero-live strict gain at the relaxed output. -/
theorem canonicalScalar_zeroLive_gain_at_relaxedMap_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    oneThresholdStrictSlackTrialNu B / oneThresholdBootstrapRelaxedMap B +
        oneThresholdEndpointDelta B (oneThresholdStrictSlackTrialNu B) < 1 := by
  let nu := oneThresholdStrictSlackTrialNu B
  let delta := oneThresholdEndpointDelta B nu
  have hnu2 : 2 < nu := by
    simpa [nu] using oneThresholdStrictSlackTrialNu_gt_two_of_four_lt hB
  have hopt_ne_two : oneThresholdBootstrapOptimizer B ≠ 2 := by
    have hopt_gt_two : 2 < oneThresholdBootstrapOptimizer B := by
      simpa [nu, oneThresholdStrictSlackTrialNu] using hnu2
    linarith
  have hnu_pos : 0 < nu := by linarith
  have hdelta_lt_one : delta < 1 := by
    simpa [nu, delta] using
      oneThresholdEndpointDelta_trial_lt_one_of_four_lt (B := B) hB
  have hdenpos : 0 < 1 - delta := by linarith
  have hmap_eq : oneThresholdBootstrapMap B = nu / (1 - delta) := by
    unfold oneThresholdBootstrapMap
    rw [oneThresholdBootstrapOutputClosed_eq_output
      (B := B) (nu := oneThresholdBootstrapOptimizer B) hopt_ne_two]
    simp [oneThresholdBootstrapOutput, oneThresholdBootstrapDelta, nu, delta,
      oneThresholdStrictSlackTrialNu, oneThresholdEndpointDelta,
      genericEndpointAverageDelta]
  have hboundary : delta + nu / oneThresholdBootstrapMap B = 1 := by
    rw [hmap_eq]
    field_simp [ne_of_gt hnu_pos, ne_of_gt hdenpos]
    ring
  have hmap_lt_relaxed :=
    oneThresholdBootstrapMap_lt_relaxedMap_of_four_lt (B := B) hB
  have hmap_pos : 0 < oneThresholdBootstrapMap B := by
    rw [hmap_eq]
    exact div_pos hnu_pos hdenpos
  have hfrac_lt :
      nu / oneThresholdBootstrapRelaxedMap B <
        nu / oneThresholdBootstrapMap B := by
    exact div_lt_div_of_pos_left hnu_pos hmap_pos hmap_lt_relaxed
  linarith

/-- Canonical scalar algebra data for every `B > 4`. -/
def clippedZeroLiveCanonicalScalarAlgebraData_of_four_lt
    {B : ℝ} (hB : 4 < B) :
    ClippedZeroLiveCanonicalScalarAlgebraData B := {
  nu_gt_two := oneThresholdStrictSlackTrialNu_gt_two_of_four_lt hB
  nu_le_B := oneThresholdStrictSlackTrialNu_le_base_of_four_lt hB
  nu_lt_output := oneThresholdStrictSlackTrialNu_lt_relaxedMap_of_four_lt hB
  gain_surplus_zero := canonicalScalar_zeroLive_gain_at_relaxedMap_of_four_lt hB
}

/-- The canonical scalar algebra target is fully closed. -/
theorem clippedZeroLiveCanonicalScalarAlgebraTarget_proved :
    ClippedZeroLiveCanonicalScalarAlgebraTarget := by
  intro B hB
  exact ⟨clippedZeroLiveCanonicalScalarAlgebraData_of_four_lt hB⟩

/-- Consequently the zero-live scalar optimizer target is closed. -/
theorem clippedZeroLiveScalarOptimizerDataTarget_of_canonicalScalarAlgebra :
    ClippedZeroLiveScalarOptimizerDataTarget := by
