  relaxedSeqConverges : OneThresholdBootstrapRelaxedSeqConvergesToFour B0

/-- Final package implies the non-strict bound `4`. -/
theorem oneOverPiMeasureAtMost_four_of_cutoffBudgetFinalPackage
    {B0 : ℝ}
    (P : ClippedCanonicalLiveLossCutoffBudgetFinalPackage B0) :
    OneOverPiMeasureAtMost 4 := by
  have hstep : OneThresholdBootstrapStrictSlackStepRealized :=
