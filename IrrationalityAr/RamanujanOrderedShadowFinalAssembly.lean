  closureCert := D.closureCert
  activeData := D.activeData
  split := D.split
  deltaeps_nonneg := D.deltaeps_nonneg
  gain_surplus := D.gain_surplus
}

/-- Build the packaged strict-slack data from the raw components. -/
def clippedActiveMassLiveLossStrictSlackStepData_of_rawData
    {B : ℝ} (D : ClippedActiveMassLiveLossStrictSlackRawData B) :
    ClippedActiveMassLiveLossStrictSlackStepData B := {
  nu := D.nu
