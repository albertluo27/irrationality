  rcases h with ⟨B0, P⟩
  exact oneOverPiMeasureAtMost_four_of_clippedIntervalBudgetFinalPackage P

/-!
# Relevant clipped interval-budget repair

The broad clipped interval-budget API still pays for every interval whose left
endpoint is below the cutoff.  The endpoint closed/live split only needs
intervals that are actually relevant for shells below the cutoff, so this layer
introduces a relevance-filtered interval-counting API.
-/

/-! ## Relevant real-interval unions -/

/-- A shell `m` lies in a real interval whose index is relevant for `m`. -/
def RelevantNatInRealIntervalUnion
    (S E : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) (m : ℕ) : Prop :=
  ∃ i : ℕ, Relevant m i ∧ NatInRealInterval m (S i) (E i)

/-- Relevant active indices below the cutoff `M`.  These are precisely the
indices from the finite range that occur as a relevant real-interval witness for
some shell `m ≤ M`. -/
def RelevantActiveShadowIndexFinset
    (S E : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun i =>
    ∃ m : ℕ, m ≤ M ∧ Relevant m i ∧ NatInRealInterval m (S i) (E i)

/-- Relevant active interval count. -/
def RelevantActiveShadowCount
    (S E : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) (M : ℕ) : ℕ :=
  (RelevantActiveShadowIndexFinset S E Relevant M).card

/-- Integer shells up to `M` lying in the relevant interval union. -/
def RelevantIntegerShadowUnionFinset
    (S E : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun m =>
    RelevantNatInRealIntervalUnion S E Relevant m

/-- Count of integer shells up to `M` in the relevant interval union. -/
def RelevantIntegerShadowUnionCount
    (S E : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) (M : ℕ) : ℕ :=
  (RelevantIntegerShadowUnionFinset S E Relevant M).card

@[simp] theorem RelevantIntegerShadowUnionCount_eq_natInitialSegmentCount
    (S E : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) (M : ℕ) :
    RelevantIntegerShadowUnionCount S E Relevant M =
      natInitialSegmentCount
        (RelevantNatInRealIntervalUnion S E Relevant) M := by
  rfl

/-- The relevant finite active-index list covers all relevant witnesses below a
cutoff. -/
def RelevantActiveShadowIndicesCoverUnion
    (S E : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) : Prop :=
  ∀ M m : ℕ, m ≤ M → RelevantNatInRealIntervalUnion S E Relevant m →
    ∃ i : ℕ,
      i ∈ RelevantActiveShadowIndexFinset S E Relevant M ∧
      Relevant m i ∧ NatInRealInterval m (S i) (E i)

/-- Sublinearity of the relevant active interval count. -/
def RelevantActiveShadowCountSublinear
    (S E : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) : Prop :=
  ∀ ε : ℝ, 0 < ε →
    ∀ᶠ M : ℕ in atTop,
      (RelevantActiveShadowCount S E Relevant M : ℝ)
        ≤ ε * ((M : ℝ) + 1)

/-- A clipped real-length budget for relevant active intervals only. -/
def RelevantClippedRealShadowLengthBudget
    (S E : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop)
    (δ : ℝ) (Err : ℕ → ℝ) : Prop :=
  ∀ᶠ M : ℕ in atTop,
    (∑ i ∈ RelevantActiveShadowIndexFinset S E Relevant M,
      clippedRealIntervalLength (S i) (E i) M)
      ≤ δ * ((M : ℝ) + 1) + Err M

/-- Relevant active-count error is sublinear. -/
theorem relevantActiveShadowCount_error_sublinear
    {S E : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    (hS : RelevantActiveShadowCountSublinear S E Relevant) :
    EventuallySublinearCountError
      (fun M : ℕ => 2 * (RelevantActiveShadowCount S E Relevant M : ℝ)) := by
  simpa [RelevantActiveShadowCountSublinear, EventuallySublinearCountError] using
    EventuallySublinearCountError.const_mul
      (E := fun M : ℕ => (RelevantActiveShadowCount S E Relevant M : ℝ))
      (C := 2) (by norm_num) hS

/-- The total relevant rounding/endpoint error is sublinear. -/
theorem relevantIntervalCounting_totalError_sublinear
    {S E : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop} {Err : ℕ → ℝ}
    (hErr : EventuallySublinearCountError Err)
    (hS : RelevantActiveShadowCountSublinear S E Relevant) :
    EventuallySublinearCountError
      (fun M : ℕ => Err M +
        2 * (RelevantActiveShadowCount S E Relevant M : ℝ)) := by
  exact EventuallySublinearCountError.add hErr
    (relevantActiveShadowCount_error_sublinear hS)

/-! ## Relevant integer counting from clipped lengths -/

/-- Relevant interval-union count is bounded by the sum of one-interval counts
over the relevant active-index finset. -/
theorem relevantIntegerShadowUnionCount_le_sum_interval_counts
    {S E : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    (hcover : RelevantActiveShadowIndicesCoverUnion S E Relevant)
    (M : ℕ) :
    (RelevantIntegerShadowUnionCount S E Relevant M : ℝ)
      ≤ ∑ i ∈ RelevantActiveShadowIndexFinset S E Relevant M,
          ((IntegerIntervalPointFinset (S i) (E i) M).card : ℝ) := by
  classical
  let U : Finset ℕ := RelevantIntegerShadowUnionFinset S E Relevant M
  let F : ℕ → Finset ℕ := fun i => IntegerIntervalPointFinset (S i) (E i) M
  have hU : U ⊆ (RelevantActiveShadowIndexFinset S E Relevant M).biUnion F := by
    intro m hm
    dsimp [U, RelevantIntegerShadowUnionFinset] at hm
    rw [Finset.mem_filter] at hm
    have hmleM : m ≤ M := by
      rw [Finset.mem_range] at hm
      omega
    rcases hcover M m hmleM hm.2 with ⟨i, hi, _hRel, hInt⟩
    rw [Finset.mem_biUnion]
    refine ⟨i, hi, ?_⟩
    dsimp [F, IntegerIntervalPointFinset]
    rw [Finset.mem_filter]
    exact ⟨hm.1, hInt⟩
  calc
    (RelevantIntegerShadowUnionCount S E Relevant M : ℝ)
        = (U.card : ℝ) := rfl
    _ ≤ (((RelevantActiveShadowIndexFinset S E Relevant M).biUnion F).card : ℝ) := by
          exact_mod_cast Finset.card_le_card hU
    _ ≤ (∑ i ∈ RelevantActiveShadowIndexFinset S E Relevant M, (F i).card : ℕ) := by
          exact_mod_cast Finset.card_biUnion_le
    _ = ∑ i ∈ RelevantActiveShadowIndexFinset S E Relevant M,
          ((IntegerIntervalPointFinset (S i) (E i) M).card : ℝ) := by
          simp [F]

/-- Relevant interval-union count using clipped interval lengths. -/
theorem relevantIntegerShadowUnionCount_budget_of_clippedRealLengthBudget
    {S E : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    {δ : ℝ} {Err : ℕ → ℝ}
    (hcover : RelevantActiveShadowIndicesCoverUnion S E Relevant)
    (hLength : RelevantClippedRealShadowLengthBudget S E Relevant δ Err) :
    ∀ᶠ M : ℕ in atTop,
      (RelevantIntegerShadowUnionCount S E Relevant M : ℝ)
        ≤ δ * ((M : ℝ) + 1) +
          (Err M + 2 * (RelevantActiveShadowCount S E Relevant M : ℝ)) := by
  classical
  filter_upwards [hLength] with M hLen
  calc
    (RelevantIntegerShadowUnionCount S E Relevant M : ℝ)
        ≤ ∑ i ∈ RelevantActiveShadowIndexFinset S E Relevant M,
            ((IntegerIntervalPointFinset (S i) (E i) M).card : ℝ) :=
          relevantIntegerShadowUnionCount_le_sum_interval_counts hcover M
    _ ≤ ∑ i ∈ RelevantActiveShadowIndexFinset S E Relevant M,
            (clippedRealIntervalLength (S i) (E i) M + 2) := by
          exact Finset.sum_le_sum (fun i _hi =>
            integerIntervalPointFinset_card_le_clippedLength_add_two)
    _ = (∑ i ∈ RelevantActiveShadowIndexFinset S E Relevant M,
            clippedRealIntervalLength (S i) (E i) M)
          + 2 * (RelevantActiveShadowCount S E Relevant M : ℝ) := by
          rw [Finset.sum_add_distrib]
          simp [RelevantActiveShadowCount, mul_comm]
    _ ≤ δ * ((M : ℝ) + 1) + Err M +
          2 * (RelevantActiveShadowCount S E Relevant M : ℝ) := by
          linarith
    _ = δ * ((M : ℝ) + 1) +
          (Err M + 2 * (RelevantActiveShadowCount S E Relevant M : ℝ)) := by
          ring

/-- A relevant clipped real-length budget proves upper density for the relevant
interval union. -/
theorem upperDensityAtMost_of_relevantClippedRealShadowLengthBudget
    {S E : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    {δ : ℝ} {Err : ℕ → ℝ}
    (hcover : RelevantActiveShadowIndicesCoverUnion S E Relevant)
    (hLength : RelevantClippedRealShadowLengthBudget S E Relevant δ Err)
    (hActive : RelevantActiveShadowCountSublinear S E Relevant)
    (hErr : EventuallySublinearCountError Err) :
    UpperNatDensityAtMost (RelevantNatInRealIntervalUnion S E Relevant) δ := by
  have hCount := relevantIntegerShadowUnionCount_budget_of_clippedRealLengthBudget
    (S := S) (E := E) (Relevant := Relevant) (δ := δ) (Err := Err)
    hcover hLength
  have hTotalErr : EventuallySublinearCountError
      (fun M : ℕ => Err M +
        2 * (RelevantActiveShadowCount S E Relevant M : ℝ)) :=
    relevantIntervalCounting_totalError_sublinear hErr hActive
  apply upperNatDensityAtMost_of_countBudget_sublinearError
    (B := RelevantNatInRealIntervalUnion S E Relevant)
    (δ := δ)
    (E := fun M : ℕ => Err M +
      2 * (RelevantActiveShadowCount S E Relevant M : ℝ))
  · filter_upwards [hCount] with M hM
    simpa [RelevantIntegerShadowUnionCount_eq_natInitialSegmentCount] using hM
  · exact hTotalErr

/-! ## Endpoint-subwindow control with relevant interval budgets -/

/-- Endpoint subwindows are dominated by the relevant real-interval union, not
only by the union of all real intervals. -/
theorem endpointSubwindowUnion_dominated_relevantRealIntervalUnion
    {X : ℕ → ℝ} {nu x : ℝ} {Relevant : ℕ → ℕ → Prop}
    (hnu : 0 < nu)
    (hRelUpper : EndpointSubwindowRelevanceUpperBound X nu Relevant) :
    Criteria.dominated
      (EndpointSubwindowUnion nu x X Relevant)
      (RelevantNatInRealIntervalUnion
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        Relevant) := by
  intro m hm
  rcases hm with ⟨j, hRel, hSub⟩
  exact ⟨j, hRel,
    endpointSubwindow_mem_realInterval_of_relevanceUpper
      (X := X) (nu := nu) (x := x) (Relevant := Relevant)
      hnu hRelUpper hRel hSub⟩

/-- Endpoint-subwindow data with a relevant clipped interval-length budget. -/
structure EndpointSubwindowRelevantClippedIntervalBudgetData
    (X : ℕ → ℝ) (nu x delta : ℝ)
    (Relevant : ℕ → ℕ → Prop) : Type where
  Err : ℕ → ℝ
  nu_pos : 0 < nu
  relevanceUpper : EndpointSubwindowRelevanceUpperBound X nu Relevant
  relevantActiveCover : RelevantActiveShadowIndicesCoverUnion
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    Relevant
  relevantActiveSublinear : RelevantActiveShadowCountSublinear
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    Relevant
  errSublinear : EventuallySublinearCountError Err
  relevantClippedLengthBudget :
    ClippedEndpointWeightedAverageBound X nu delta →
      RelevantClippedRealShadowLengthBudget
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        Relevant delta Err

/-- Relevant clipped interval-budget data proves endpoint-subwindow union
control. -/
theorem clippedEndpointSubwindowUnionControls_of_relevantClippedIntervalBudgetData
    {X : ℕ → ℝ} {nu x delta : ℝ} {Relevant : ℕ → ℕ → Prop}
    (D : EndpointSubwindowRelevantClippedIntervalBudgetData X nu x delta Relevant) :
    ClippedEndpointSubwindowUnionControls X nu x delta Relevant := by
  intro havg
  have hRelevantDensity : UpperNatDensityAtMost
      (RelevantNatInRealIntervalUnion
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        Relevant) delta :=
    upperDensityAtMost_of_relevantClippedRealShadowLengthBudget
      (S := endpointSubwindowIntervalLeft nu X)
      (E := endpointSubwindowIntervalRight X)
      (Relevant := Relevant)
      (δ := delta) (Err := D.Err)
      D.relevantActiveCover (D.relevantClippedLengthBudget havg)
      D.relevantActiveSublinear D.errSublinear
  exact Criteria.upperDensityAtMost_mono
    (endpointSubwindowUnion_dominated_relevantRealIntervalUnion
      (X := X) (nu := nu) (x := x) (Relevant := Relevant)
      D.nu_pos D.relevanceUpper)
    hRelevantDensity

/-- A broad clipped interval-budget package can be converted to the relevant API
when the relevant cover, relevant sublinearity, and relevant budget are supplied. -/
def endpointSubwindowRelevantClippedIntervalBudgetData_of_broad
    {X : ℕ → ℝ} {nu x delta : ℝ} {Relevant : ℕ → ℕ → Prop}
    (D : EndpointSubwindowClippedIntervalBudgetData X nu x delta Relevant)
