    (endpointSubwindowIntervalRight X)
    (CutoffPrefixClosedRelevantAt K BaseRelevant)
  delta_nonneg : 0 ≤ delta
  K_tendsto : Tendsto K atTop atTop
  scaleBound : ∀ᶠ M : ℕ in atTop,
    endpointRatioScale X (K M) / ramanujanKappa
