/-!
# Actual-qlog average route: eventual-tail reduction

The previous actual-qlog average reduction required endpoint closure and
geometric-core data for every finite tail shift.  The direct clipped endpoint
average is reconstructed only after choosing one sufficiently far qlog tail, so
it is enough for the shifted endpoint data to exist eventually in the tail
parameter.
-/

/-! ## Eventual global tail positivity and ratio cap -/

/-- Eventual positivity and an eventual ratio cap hold globally on every
sufficiently far tail. -/
theorem eventually_tailShiftSeq_pos_and_ratioBoundedBy
    {X : ℕ → ℝ} {R : ℝ}
    (hpos : ∀ᶠ j in Filter.atTop, 0 < X j)
    (hcap : EventuallyRatioBoundedBy X R) :
    ∀ᶠ s in Filter.atTop,
      (∀ j : ℕ, 0 < tailShiftSeq X s j) ∧
        RatioBoundedBy (tailShiftSeq X s) R := by
  rcases (Filter.eventually_atTop.1 hpos) with ⟨Npos, hNpos⟩
  rcases (Filter.eventually_atTop.1 hcap) with ⟨Ncap, hNcap⟩
  refine Filter.eventually_atTop.2 ⟨max Npos Ncap, ?_⟩
  intro s hs
  constructor
  · intro j
    unfold tailShiftSeq
    exact hNpos (s + j)
      (le_trans (le_trans (Nat.le_max_left Npos Ncap) hs)
        (Nat.le_add_right s j))
  · intro j
    rw [logJumpRatio_tailShiftSeq]
    exact hNcap (s + j)
      (le_trans (le_trans (Nat.le_max_right Npos Ncap) hs)
        (Nat.le_add_right s j))

