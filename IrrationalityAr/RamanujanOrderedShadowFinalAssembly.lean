/-!
# Clipped logarithmic layer-cake process

This process-level wrapper uses the existing clipped layer-cake scalar algebra.
The analytic finite layer-cake estimate and scalar convergence are exposed as
explicit targets rather than theorem placeholders.
-/

/-- A family of active-mass finite estimates at all thresholds in
`[nu - 1, B - 1]`. -/
def LogLCActiveMassFamily (X : ℕ → ℝ) (B nu : ℝ) : Prop :=
  ∀ t : ℝ,
    nu - 1 ≤ t →
      t ≤ B - 1 →
        ActiveMassGeometricFiniteTarget X (t + 1)

/-- The active-mass finite theorem at threshold `t + 1` gives the generic
clipped tail majorant at threshold `t`. -/
theorem weightedRatioTailMass_le_logLC_tailMajorant
    {X : ℕ → ℝ} {t : ℝ} (J : ℕ)
    (ht : 1 < t)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X)
    (hactive : ActiveMassGeometricFiniteTarget X (t + 1)) :
    weightedRatioTailMass X t J
      ≤ genericClippedTailMajorant t * endpointRatioScale X J := by
  have hnu : 2 < t + 1 := by linarith
  have h := hactive hnu hXpos hmono J
  have hmass : weightedActiveRatioMass X (t + 1) J =
      weightedRatioTailMass X t J := by
    unfold weightedActiveRatioMass
    ring_nf
  have hconst : oneThresholdActiveMassConstant (t + 1) =
      genericClippedTailMajorant t := by
    unfold oneThresholdActiveMassConstant genericActiveMassConstant
      genericClippedTailMajorant
    ring_nf
  simpa [hmass, hconst] using h

/-- Partition-level tail bounds from the active-mass family. -/
theorem weightedRatioTailBoundOnPartition_logLC
    {K : ℕ} {X : ℕ → ℝ} {B nu : ℝ} {tpart : Fin (K + 1) → ℝ}
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmonoX : Monotone X)
    (hleft_low : ∀ k : Fin K, nu - 1 ≤ partLeft tpart k)
    (hleft_high : ∀ k : Fin K, partLeft tpart k ≤ B - 1)
    (hleft_gt_one : ∀ k : Fin K, 1 < partLeft tpart k)
    (hactiveFamily : LogLCActiveMassFamily X B nu) :
    WeightedRatioTailBoundOnPartition X tpart genericClippedTailMajorant := by
  intro k
  refine Filter.Eventually.of_forall ?_
  intro J
  exact weightedRatioTailMass_le_logLC_tailMajorant
    (X := X) (t := partLeft tpart k) J
    (hleft_gt_one k) hXpos hmonoX
    (hactiveFamily (partLeft tpart k) (hleft_low k) (hleft_high k))

/-- Main analytic/finite layer-cake target for the logarithmic route. -/
def LogLCLayerCakeEndpointAverageTarget : Prop :=
  ∀ {X : ℕ → ℝ} {B nu eta : ℝ},
    2 < nu →
      nu < B →
        0 < eta →
          (∀ j : ℕ, 0 < X j) →
            Monotone X →
              RatioBoundedBy X (B - 1) →
                LogLCActiveMassFamily X B nu →
                  ClippedEndpointWeightedAverageBound X nu
                    (clippedLayerCakeDelta B nu + eta)

/-- Data for one logarithmic clipped layer-cake bootstrap step. -/
structure LogLCStepData (B : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  eta : ℝ
  eps : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_lt_cap : nu < B
  nu_lt_out : nu < clippedLayerCakeMidOutput B
  tau_pos : 0 < tau
  x_contraction :
    shellSpikeContractionExponent tau nu (clippedLayerCakeMidOutput B) < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  eta_pos : 0 < eta
  finite_pos : ∀ j : ℕ, 0 < X j
  finite_mono : Monotone X
  ratio_cap : RatioBoundedBy X (B - 1)
  active_family : LogLCActiveMassFamily X B nu
  budgetSplit :
    ClippedEndpointBudgetSplitTarget
      X H V nu x (clippedLayerCakeDelta B nu + eta) eps
  total_nonneg : 0 ≤ clippedLayerCakeDelta B nu + eta + eps
  total_gain :
    nu / clippedLayerCakeMidOutput B +
      (clippedLayerCakeDelta B nu + eta + eps)
        < shellSpikeGoodDensityGain tau x

/-- The log layer-cake step data proves one strict measure improvement, assuming
only the named finite layer-cake endpoint-average target. -/
theorem oneOverPiMeasure_lt_of_Bauer_logLCStepData
    {B mu : ℝ}
    (hLayerCake : LogLCLayerCakeEndpointAverageTarget)
    (D : LogLCStepData B)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu) :
    mu < clippedLayerCakeMidOutput B := by
  have hAvg :
      ClippedEndpointWeightedAverageBound D.X D.nu
        (clippedLayerCakeDelta B D.nu + D.eta) :=
    hLayerCake (X := D.X) (B := B) (nu := D.nu) (eta := D.eta)
      D.nu_gt_two D.nu_lt_cap D.eta_pos D.finite_pos D.finite_mono
      D.ratio_cap D.active_family
  have hNV :
      UpperNatDensityAtMost (NonVisibleBadShell D.nu D.H D.V D.x)
        (clippedLayerCakeDelta B D.nu + D.eta + D.eps) := by
    exact nonVisibleBadDensity_of_budgetSplit_liveLoss
      (X := D.X) (H := D.H) (V := D.V)
      (nu := D.nu) (x := D.x)
      (delta := clippedLayerCakeDelta B D.nu + D.eta) (eps := D.eps)
      D.budgetSplit hAvg
  exact oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    (mu := mu) (nu := D.nu) (M := clippedLayerCakeMidOutput B)
    (tau := D.tau) (x := D.x)
    (eps := clippedLayerCakeDelta B D.nu + D.eta + D.eps)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    (H := D.H) (V := D.V)
    D.closureCert D.bauer hmu D.nu_gt_two D.nu_lt_out D.tau_pos
    D.x_contraction D.x_lt_one D.x_le_global
    hNV D.total_nonneg D.total_gain

/-- Realized one-step logarithmic clipped layer-cake bootstrap. -/
def LogLCStepRealized : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        OneOverPiMeasureStrictlyBelow (clippedLayerCakeMidOutput B)

/-- Data target for realizing the logarithmic step. -/
def LogLCStepDataRealized : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (LogLCStepData B)

/-- Step data realizes the abstract one-step bootstrap. -/
theorem logLCStepRealized_of_stepData
    (hLayerCake : LogLCLayerCakeEndpointAverageTarget)
    (hdata : LogLCStepDataRealized) :
    LogLCStepRealized := by
  intro B hB hBound mu hmu
  rcases hdata B hB hBound with ⟨D⟩
  exact oneOverPiMeasure_lt_of_Bauer_logLCStepData
    (B := B) (mu := mu) hLayerCake D hmu

/-- Iterates of the relaxed logarithmic bootstrap map. -/
def logLC_RelaxedSeq (B0 : ℝ) : ℕ → ℝ
  | 0 => B0
  | n + 1 => clippedLayerCakeMidOutput (logLC_RelaxedSeq B0 n)

/-- The relaxed logarithmic map stays above `4`. -/
theorem logLC_RelaxedMapAboveFour :
    ∀ B : ℝ, 4 < B → 4 < clippedLayerCakeMidOutput B := by
  intro B hB
  exact (clippedLayerCakeCapStrictCondition_mid (B := B) hB).2.1

/-- The relaxed logarithmic map improves the current bound. -/
theorem logLC_RelaxedMapBelowSelf :
    ∀ B : ℝ, 4 < B → clippedLayerCakeMidOutput B < B := by
  intro B hB
  exact (clippedLayerCakeRelaxedOutputData_mid (B := B) hB).2.2

/-- All iterates stay above `4`. -/
theorem logLC_RelaxedSeq_above_four
    {B0 : ℝ} (hB0 : 4 < B0) :
    ∀ n : ℕ, 4 < logLC_RelaxedSeq B0 n := by
  intro n
  induction n with
  | zero => simpa [logLC_RelaxedSeq] using hB0
  | succ n ih =>
      simpa [logLC_RelaxedSeq] using
        logLC_RelaxedMapAboveFour (logLC_RelaxedSeq B0 n) ih

/-- Bounds propagate along the logarithmic relaxed sequence. -/
theorem oneOverPiMeasureStrictlyBelow_logLCSeq
    {B0 : ℝ}
    (hstep : LogLCStepRealized)
    (hstart : KnownOneOverPiMeasureBound B0)
    (hB0 : 4 < B0) :
    ∀ n : ℕ, OneOverPiMeasureStrictlyBelow (logLC_RelaxedSeq B0 n) := by
  intro n
  induction n with
  | zero => simpa [logLC_RelaxedSeq] using hstart
  | succ n ih =>
      have habove : 4 < logLC_RelaxedSeq B0 n :=
        logLC_RelaxedSeq_above_four hB0 n
      simpa [logLC_RelaxedSeq] using
        hstep (logLC_RelaxedSeq B0 n) habove ih

/-- Dynamical convergence target for the scalar relaxed log map to `4`. -/
def LogLCRelaxedSeqConvergesToFour (B0 : ℝ) : Prop :=
  ∀ eps : ℝ, 0 < eps → ∃ n : ℕ, logLC_RelaxedSeq B0 n < 4 + eps

/-- Final package for the logarithmic clipped layer-cake route. -/
structure LogLCFinalPackage (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  layerCake : LogLCLayerCakeEndpointAverageTarget
  stepData : LogLCStepDataRealized
  relaxedSeqConverges : LogLCRelaxedSeqConvergesToFour B0

/-- Final theorem: the completed logarithmic clipped layer-cake route proves
`mu(1/pi) <= 4`. -/
theorem oneOverPiMeasureAtMost_four_of_logLCFinalPackage
    {B0 : ℝ} (P : LogLCFinalPackage B0) :
    OneOverPiMeasureAtMost 4 := by
  apply oneOverPiMeasureAtMost_four_of_arbitrarily_close
  intro eps heps
  rcases P.relaxedSeqConverges eps heps with ⟨n, hn⟩
  have hstep : LogLCStepRealized :=
    logLCStepRealized_of_stepData P.layerCake P.stepData
  have hbound : OneOverPiMeasureStrictlyBelow (logLC_RelaxedSeq B0 n) :=
    oneOverPiMeasureStrictlyBelow_logLCSeq hstep P.startBound P.startAboveFour n
  intro mu hmu
  exact lt_trans (hbound mu hmu) hn

/-- Project-facing final theorem statement. -/
def LogLCFinalTarget : Prop :=
  ∃ B0 : ℝ, LogLCFinalPackage B0

/-- If the final package is constructed, then the desired non-strict bound
follows. -/
theorem oneOverPiMeasureAtMost_four_of_logLCFinalTarget
    (h : LogLCFinalTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases h with ⟨B0, P⟩
  exact oneOverPiMeasureAtMost_four_of_logLCFinalPackage P

/-!
# Standard-analysis closure for the logarithmic clipped layer-cake route

The original version of this section recorded two standard-analysis facts as
axioms.  They are now proved directly: the endpoint-average statement follows
from the sharper telescoping clipped endpoint estimate, and the relaxed scalar
map converges by an explicit quadratic gap drop.
-/

/-- Monotonicity of the clipped endpoint average bound in the loss parameter. -/
theorem ClippedEndpointWeightedAverageBound.mono_delta
    {X : ℕ → ℝ} {nu delta delta' : ℝ}
    (h : ClippedEndpointWeightedAverageBound X nu delta)
    (hdd : delta ≤ delta')
    (hscale_nonneg : ∀ J : ℕ, 0 ≤ clippedEndpointScale X J) :
    ClippedEndpointWeightedAverageBound X nu delta' := by
  refine h.mono ?_
  intro J hJ
  have hmul :
      delta * clippedEndpointScale X J
        ≤ delta' * clippedEndpointScale X J := by
    exact mul_le_mul_of_nonneg_right hdd (hscale_nonneg J)
  exact le_trans hJ hmul

/-- The telescoping clipped loss is no worse than the logarithmic layer-cake
loss. -/
theorem telescopingClippedEndpointDelta_le_clippedLayerCakeDelta
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu < B) :
    telescopingClippedEndpointDelta B nu ≤ clippedLayerCakeDelta B nu := by
  unfold telescopingClippedEndpointDelta clippedLayerCakeDelta
  let y : ℝ := (B - 2) / (nu - 2)
  have hypos : 0 < y := by
    have hnum : 0 < B - 2 := by linarith
    have hden : 0 < nu - 2 := by linarith
    exact div_pos hnum hden
  have hineq : 1 - 1 / y ≤ Real.log y := by
    have hinv :
        Real.log y⁻¹ ≤ y⁻¹ - 1 :=
      Real.log_le_sub_one_of_pos (inv_pos.mpr hypos)
    rw [Real.log_inv] at hinv
    rw [one_div]
    linarith
  have halg : (B - nu) / (2 * (B - 2)) = (1 / 2 : ℝ) * (1 - 1 / y) := by
    unfold y
    have hB2 : B - 2 ≠ 0 := by linarith
    have hnu2' : nu - 2 ≠ 0 := by linarith
    field_simp [hB2, hnu2']
    ring
  have hmul := mul_le_mul_of_nonneg_left hineq (by norm_num : (0 : ℝ) ≤ 1 / 2)
  simpa [halg, y] using hmul

/-- The logarithmic endpoint-average statement follows from the sharper
telescoping endpoint estimate. -/
theorem standard_logLC_layerCakeEndpointAverage
    {X : ℕ → ℝ} {B nu eta : ℝ}
    (hnu2 : 2 < nu)
    (hnuB : nu < B)
    (heta : 0 < eta)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X)
    (hcap : RatioBoundedBy X (B - 1))
    (_hactive : LogLCActiveMassFamily X B nu) :
    ClippedEndpointWeightedAverageBound X nu
      (clippedLayerCakeDelta B nu + eta) := by
  have htel : ClippedEndpointWeightedAverageBound X nu
      (telescopingClippedEndpointDelta B nu) :=
    clippedEndpointWeightedAverageBound_of_telescoping_global
      (X := X) (B := B) (nu := nu)
      hnu2 (le_of_lt hnuB) hXpos hmono hcap
  have htarget : telescopingClippedEndpointDelta B nu
      ≤ clippedLayerCakeDelta B nu + eta := by
    have htel_le_log :=
      telescopingClippedEndpointDelta_le_clippedLayerCakeDelta
        (B := B) (nu := nu) hnu2 hnuB
    linarith
  have hscale_nonneg : ∀ J : ℕ, 0 ≤ clippedEndpointScale X J := by
    intro J
    unfold clippedEndpointScale endpointRatioScale
    have h0 : 0 ≤ X J := le_of_lt (hXpos J)
    have h1 : 0 ≤ X (J + 1) := le_of_lt (hXpos (J + 1))
    linarith
  exact htel.mono_delta htarget hscale_nonneg

/-- A simple sequence lemma: positive quadratic drop forces eventual smallness. -/
theorem eventually_small_of_quadratic_drop
    {u : ℕ → ℝ} {C : ℝ}
    (hC : 0 < C)
    (hpos : ∀ n : ℕ, 0 < u n)
    (hdrop : ∀ n : ℕ, u (n + 1) ≤ u n - (u n)^2 / C) :
    ∀ ε : ℝ, 0 < ε → ∃ n : ℕ, u n < ε := by
  intro ε hε
  by_contra hnone
  have hge : ∀ n : ℕ, ε ≤ u n := by
    intro n
    exact le_of_not_gt (by intro hn; exact hnone ⟨n, hn⟩)
  let d : ℝ := ε^2 / C
  have hd : 0 < d := by
    exact div_pos (sq_pos_of_pos hε) hC
  have hstep : ∀ n : ℕ, u (n + 1) ≤ u n - d := by
    intro n
    have hsquare : ε^2 ≤ (u n)^2 := by
      nlinarith [hε, hge n, hpos n]
    have hdiv : ε^2 / C ≤ (u n)^2 / C := by
      exact div_le_div_of_nonneg_right hsquare (le_of_lt hC)
    have hn := hdrop n
    dsimp [d]
    linarith
  have hind : ∀ n : ℕ, u n ≤ u 0 - (n : ℝ) * d := by
    intro n
    induction n with
    | zero => simp
    | succ n ih =>
        have hs := hstep n
        calc
          u (n + 1) ≤ u n - d := hs
          _ ≤ (u 0 - (n : ℝ) * d) - d := by linarith
          _ = u 0 - ((n + 1 : ℕ) : ℝ) * d := by
            norm_num
            ring
  obtain ⟨N, hN⟩ := exists_nat_gt (u 0 / d)
  have hneg : u 0 - (N : ℝ) * d < 0 := by
    have hNd : u 0 < (N : ℝ) * d := by
      exact (div_lt_iff₀ hd).mp hN
    linarith
  have hNbound := hind N
  have hNpos := hpos N
  linarith

/-- Explicit scalar quadratic drop for the relaxed LogLC midpoint map. -/
theorem clippedLayerCakeMidOutput_gap_drop
    {B : ℝ} (hB : 4 < B) :
    clippedLayerCakeMidOutput B - 4
      ≤ (B - 4) - (B - 4)^2 / (48 * (B - 4) + 128) := by
  have htrial_lt :
      clippedLayerCakeTrialOutput B < clippedLayerCakeQuadraticOutput B :=
    clippedLayerCakeTrialOutput_lt_quadraticOutput (B := B) hB
  unfold clippedLayerCakeMidOutput
  have hrel :
      (clippedLayerCakeTrialOutput B + B) / 2 - 4
        ≤ (clippedLayerCakeQuadraticOutput B + B) / 2 - 4 := by
    nlinarith
  have halg :
      (clippedLayerCakeQuadraticOutput B + B) / 2 - 4 =
        (B - 4) - (B - 4)^2 / (48 * (B - 4) + 128) := by
    have hdeneq : 48 * (B - 4) + 128 = 16 * (3 * B - 4) := by ring
    rw [hdeneq]
    unfold clippedLayerCakeQuadraticOutput
    have hden : 8 * (3 * B - 4) ≠ 0 := by nlinarith
    have hden2 : 16 * (3 * B - 4) ≠ 0 := by
      intro hz
      apply hden
      nlinarith
    field_simp [hden, hden2]
    ring
  exact le_trans hrel (le_of_eq halg)

/-- The relaxed logarithmic scalar sequence converges to `4`. -/
theorem standard_logLC_relaxedSeqConvergesToFour
    (B0 : ℝ) (hB0 : 4 < B0) :
    ∀ eps : ℝ, 0 < eps → ∃ n : ℕ, logLC_RelaxedSeq B0 n < 4 + eps := by
  intro ε hε
  let u : ℕ → ℝ := fun n => logLC_RelaxedSeq B0 n - 4
  have hpos : ∀ n : ℕ, 0 < u n := by
    intro n
    dsimp [u]
    have h := logLC_RelaxedSeq_above_four (B0 := B0) hB0 n
    linarith
  have hbelow_start : ∀ n : ℕ, logLC_RelaxedSeq B0 n ≤ B0 := by
    intro n
    induction n with
    | zero => simp [logLC_RelaxedSeq]
    | succ n ih =>
        have habove : 4 < logLC_RelaxedSeq B0 n :=
          logLC_RelaxedSeq_above_four (B0 := B0) hB0 n
        have hlt : clippedLayerCakeMidOutput (logLC_RelaxedSeq B0 n)
            < logLC_RelaxedSeq B0 n :=
          logLC_RelaxedMapBelowSelf (logLC_RelaxedSeq B0 n) habove
        simp [logLC_RelaxedSeq]
        exact le_trans (le_of_lt hlt) ih
  let C : ℝ := 48 * (B0 - 4) + 128
  have hC : 0 < C := by
    dsimp [C]
    nlinarith
  have hdrop : ∀ n : ℕ, u (n + 1) ≤ u n - (u n)^2 / C := by
    intro n
    dsimp [u, C]
    have habove : 4 < logLC_RelaxedSeq B0 n :=
      logLC_RelaxedSeq_above_four (B0 := B0) hB0 n
    have hraw := clippedLayerCakeMidOutput_gap_drop
      (B := logLC_RelaxedSeq B0 n) habove
    have hden_mono :
        48 * (logLC_RelaxedSeq B0 n - 4) + 128
          ≤ 48 * (B0 - 4) + 128 := by
      have hle := hbelow_start n
      nlinarith
    have hden_pos : 0 < 48 * (logLC_RelaxedSeq B0 n - 4) + 128 := by
      have h := hpos n
      dsimp [u] at h
      nlinarith
    have hden_big_pos : 0 < 48 * (B0 - 4) + 128 := by
      nlinarith
    have hsq_nonneg : 0 ≤ (logLC_RelaxedSeq B0 n - 4)^2 := sq_nonneg _
    have hfrac_mono :
        (logLC_RelaxedSeq B0 n - 4)^2 / (48 * (B0 - 4) + 128)
          ≤ (logLC_RelaxedSeq B0 n - 4)^2 /
              (48 * (logLC_RelaxedSeq B0 n - 4) + 128) := by
      rw [div_le_div_iff₀ hden_big_pos hden_pos]
      nlinarith
    simp [logLC_RelaxedSeq]
    linarith
  rcases eventually_small_of_quadratic_drop
      (u := u) (C := C) hC hpos hdrop ε hε with ⟨n, hn⟩
  use n
  dsimp [u] at hn
  linarith

/-- The log-layer-cake endpoint-average target follows from the standard
layer-cake/Darboux theorem. -/
theorem LogLCLayerCakeEndpointAverageTarget_proved :
    LogLCLayerCakeEndpointAverageTarget := by
  intro X B nu eta hnu2 hnuB heta hXpos hmono hcap hactive
  exact standard_logLC_layerCakeEndpointAverage
    (X := X) (B := B) (nu := nu) (eta := eta)
    hnu2 hnuB heta hXpos hmono hcap hactive

/-- The relaxed logarithmic scalar sequence converges to `4`. -/
theorem LogLCRelaxedSeqConvergesToFour_proved :
    ∀ B0 : ℝ, 4 < B0 → LogLCRelaxedSeqConvergesToFour B0 := by
  intro B0 hB0 eps heps
  exact standard_logLC_relaxedSeqConvergesToFour B0 hB0 eps heps

