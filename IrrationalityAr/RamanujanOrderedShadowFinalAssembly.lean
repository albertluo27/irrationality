/-!
# Actual-qlog cofinal-tail reduction

The eventual-tail target asks that the endpoint geometry/counting payload hold
for all sufficiently large tails of the actual one-over-pi denominator-log
sequence.  The downstream proof only uses one tail, chosen far enough for
positivity and the ratio cap.

This layer therefore weakens the endpoint input from eventual tail data to
cofinal tail data: for every lower cutoff `N`, there is some tail `s >= N` with
the required endpoint payload.
-/

/-! ## Cofinal-tail target -/

/-- Cofinal-tail actual-qlog endpoint target. -/
def ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalTailTarget :
    Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelow B →
        ∀ N : ℕ,
          ∃ s : ℕ,
            N ≤ s ∧
              Nonempty
                (ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
                  B hB s)

/-- From eventual positivity, eventual ratio cap, and cofinal endpoint geometry,
choose one tail satisfying all requirements. -/
def activeLogCountControlledPrefixEndpointOnlyData_of_actualQlogCofinalTail
    {B : ℝ} {hB : 4 < B}
    (hBound : OneOverPiMeasureStrictlyBelow B)
    (hGeom :
      ∀ N : ℕ,
        ∃ s : ℕ,
          N ≤ s ∧
            Nonempty
              (ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
                B hB s)) :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixEndpointOnlyData
      B hB := by
  classical
  have hPosEv : ∀ᶠ j : ℕ in atTop, 0 < oneOverPiShiftedQlog 0 j :=
    oneOverPiShiftedQlog_eventuallyPositiveLogScale 0
  have hCapEv : EventuallyRatioBoundedBy (oneOverPiShiftedQlog 0) (B - 1) :=
    eventuallyRatioBoundedBy_actual_oneOverPiQlog_of_strictCap
      (B := B) hBound
  let Npos : ℕ := Classical.choose (Filter.eventually_atTop.1 hPosEv)
  have hNpos : ∀ b ≥ Npos, 0 < oneOverPiShiftedQlog 0 b :=
    Classical.choose_spec (Filter.eventually_atTop.1 hPosEv)
  let Ncap : ℕ := Classical.choose (Filter.eventually_atTop.1 hCapEv)
  have hNcap : ∀ b ≥ Ncap, logJumpRatio (oneOverPiShiftedQlog 0) b ≤ B - 1 :=
    Classical.choose_spec (Filter.eventually_atTop.1 hCapEv)
  let hChoice := hGeom (max Npos Ncap)
  let s : ℕ := Classical.choose hChoice
  have hsPack : max Npos Ncap ≤ s ∧
      Nonempty
        (ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
          B hB s) := Classical.choose_spec hChoice
  let D := Classical.choice hsPack.2
  have hpos_s0 : Npos ≤ s := by
    exact le_trans (Nat.le_max_left Npos Ncap) hsPack.1
  have hcap_s0 : Ncap ≤ s := by
    exact le_trans (Nat.le_max_right Npos Ncap) hsPack.1
  have hspos : ∀ j : ℕ, 0 < tailShiftSeq (oneOverPiShiftedQlog 0) s j := by
    intro j
    unfold tailShiftSeq
    exact hNpos (s + j)
      (le_trans hpos_s0 (Nat.le_add_right s j))
  have hscap : RatioBoundedBy (tailShiftSeq (oneOverPiShiftedQlog 0) s) (B - 1) := by
    intro j
    rw [logJumpRatio_tailShiftSeq]
    exact hNcap (s + j)
      (le_trans hcap_s0 (Nat.le_add_right s j))
  exact
    clippedCanonicalControlledPrefixEndpointOnlyData_of_actualQlogShiftData
      (B := B) (hB := hB) (s := s) D hspos hscap

/-- The cofinal-tail actual-qlog target implies the Bauer-free controlled-prefix
endpoint target. -/
theorem activeLogCountControlledPrefixEndpointOnlyTarget_of_actualQlogCofinalTailTarget
    (h :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalTailTarget) :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixEndpointOnlyTarget := by
  intro B hB hBound
  exact ⟨activeLogCountControlledPrefixEndpointOnlyData_of_actualQlogCofinalTail
    (B := B) (hB := hB) hBound (h B hB hBound)⟩

/-! ## Compatibility with the previous eventual-tail target -/

/-- The previous eventual-tail target implies the weaker cofinal-tail target. -/
theorem actualQlogCofinalTailTarget_of_actualQlogEventuallyTailTarget
    (h :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogEventuallyTailTarget) :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalTailTarget := by
  intro B hB hBound N
  rcases Filter.eventually_atTop.1 (h B hB hBound) with ⟨Ngeom, hNgeom⟩
  refine ⟨max N Ngeom, ?_, ?_⟩
  · exact Nat.le_max_left N Ngeom
  · exact hNgeom (max N Ngeom) (Nat.le_max_right N Ngeom)

