/-!
# Active-log-count controlled-prefix bridge

The previous bridge required both a logarithmic below-left active count and a
separate logarithmic prefix-depth bound for `K`.  This layer replaces the second
input by a more geometric one: `K M` is controlled by the below-left active
count plus a logarithmic buffer.
-/

/-! ## Prefix depth controlled by the active count -/

/-- The prefix depth `K M` is controlled by the below-left ratio-active count,
up to a logarithmic buffer. -/
structure EndpointPrefixControlledByBelowLeftActiveCountData
    (nu : ℝ) (X : ℕ → ℝ) (K : ℕ → ℕ) : Type where
  A : ℝ
  Cerr : ℝ
  A_nonneg : 0 ≤ A
  Cerr_nonneg : 0 ≤ Cerr
  prefix_le_count_plus_log : ∀ᶠ M : ℕ in atTop,
    (K M : ℝ) ≤
      A * (EndpointRatioActiveBelowLeftCount nu X M : ℝ) +
        Cerr * orderedShadowLogError M

/-- If the prefix depth is controlled by the below-left active count, and that
active count is logarithmic, then the prefix depth is logarithmic. -/
theorem eventualPrefixLogBound_of_prefixControlledByBelowLeftActiveCount
    {nu : ℝ} {X : ℕ → ℝ} {K : ℕ → ℕ}
    (D : EndpointPrefixControlledByBelowLeftActiveCountData nu X K)
    (L : EndpointRatioActiveBelowLeftLogCountData nu X) :
    EventualPrefixLogBound K := by
  refine ⟨D.A * L.C + D.Cerr, ?_, ?_⟩
  · have hprod : 0 ≤ D.A * L.C := mul_nonneg D.A_nonneg L.C_nonneg
    nlinarith [hprod, D.Cerr_nonneg]
  · filter_upwards [D.prefix_le_count_plus_log, L.countBound] with M hK hCount
    have hCount' :
        (EndpointRatioActiveBelowLeftCount nu X M : ℝ) ≤
          L.C * orderedShadowLogError M := by
      simpa [orderedShadowLogError] using hCount
    have hMul :
        D.A * (EndpointRatioActiveBelowLeftCount nu X M : ℝ) ≤
          D.A * (L.C * orderedShadowLogError M) := by
      exact mul_le_mul_of_nonneg_left hCount' D.A_nonneg
    calc
      (K M : ℝ)
          ≤ D.A * (EndpointRatioActiveBelowLeftCount nu X M : ℝ) +
              D.Cerr * orderedShadowLogError M := hK
      _ ≤ D.A * (L.C * orderedShadowLogError M) +
              D.Cerr * orderedShadowLogError M := by
            linarith
      _ = (D.A * L.C + D.Cerr) * orderedShadowLogError M := by
            ring

