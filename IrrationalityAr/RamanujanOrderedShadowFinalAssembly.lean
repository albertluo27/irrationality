/-!
# Active-relevant direct-cover reduction

The active-relevant route previously asked for two pointwise facts:
every bad shell has an active-relevant witness, and every sufficiently low
active-relevant witness forces visibility.  Those facts are only used to show
that a non-visible bad shell has an endpoint-subwindow witness.  This layer
records that direct conclusion as the endpoint input.
-/

/-- Direct endpoint-subwindow cover for non-visible bad shells, using the fixed
endpoint-active relevance relation. -/
def NonVisibleBadActiveRelevantSubwindowCover
    (nu x : ℝ) (X H V : ℕ → ℝ) : Prop :=
  ∀ m : ℕ,
    NonVisibleBadShell nu H V x m →
      ∃ j : ℕ,
        EndpointActiveRelevant nu X m j ∧
          EndpointSubwindow nu x X j m

/-- Direct non-visible cover gives the cutoff closed/live initial-segment cover
for the canonical prefix split. -/
theorem cutoffClosedLiveInitialSegmentCover_of_activeRelevantDirectCover
    {X H V : ℕ → ℝ} {nu x : ℝ} {K : ℕ → ℕ}
    (hnu : 0 < nu)
    (hCover : NonVisibleBadActiveRelevantSubwindowCover nu x X H V) :
    CutoffClosedLiveInitialSegmentCover
      (NonVisibleBadShell nu H V x)
      (endpointSubwindowIntervalLeft nu X)
      (endpointSubwindowIntervalRight X)
      (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X))
      (CutoffPrefixLiveAt nu x X K (EndpointActiveRelevant nu X)) := by
  intro M m _hmM hNV
  rcases hCover m hNV with ⟨j, hRel, hSub⟩
  by_cases hClosed : j < K M ∧ j ≤ M
  · left
    refine ⟨j, ?_, ?_⟩
    · exact ⟨hRel, hClosed.1, hClosed.2⟩
    · exact endpointSubwindow_mem_realInterval_of_relevanceUpper
        (X := X) (nu := nu) (x := x)
        (Relevant := EndpointActiveRelevant nu X)
        hnu (endpointActiveRelevant_relevanceUpper nu X) hRel hSub
  · right
    exact ⟨j, hRel, hClosed, hSub⟩

/-- Prefix endpoint data with active-witness/low-visibility replaced by a direct
cover of non-visible bad shells.  The active-count sublinearity is inserted
from the proved geometric below-left count. -/
structure EndpointSubwindowCutoffPrefixActiveRelevantDirectCoverData
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Type where
  K : ℕ → ℕ
  scaleErr : ℕ → ℝ
  LiveErr : ℕ → ℝ
  nu_pos : 0 < nu
  directCover : NonVisibleBadActiveRelevantSubwindowCover nu x X H V
  delta_nonneg : 0 ≤ delta
  K_tendsto : Tendsto K atTop atTop
  scaleBound : ∀ᶠ M : ℕ in atTop,
    endpointRatioScale X (K M) / ramanujanKappa
      ≤ ((M : ℝ) + 1) + scaleErr M
  scaleErrSublinear : EventuallySublinearCountError scaleErr
  liveErrSublinear : EventuallySublinearCountError LiveErr
  liveBudget : CutoffLiveBoundaryCountBudget
    (CutoffPrefixLiveAt nu x X K (EndpointActiveRelevant nu X)) eps LiveErr

/-- Direct-cover data constructs the older prefix-index endpoint package. -/
def endpointSubwindowCutoffPrefixIndexData_of_activeRelevantDirectCoverData
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (hnu_two : 2 < nu)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hXmono : Monotone X)
    (D : EndpointSubwindowCutoffPrefixActiveRelevantDirectCoverData
      X H V nu x delta eps) :
    EndpointSubwindowCutoffPrefixIndexData X H V nu x delta eps := {
  RelevantAt := CutoffPrefixClosedRelevantAt D.K (EndpointActiveRelevant nu X)
  LiveAt := CutoffPrefixLiveAt nu x X D.K (EndpointActiveRelevant nu X)
  LiveErr := D.LiveErr
  cover := cutoffClosedLiveInitialSegmentCover_of_activeRelevantDirectCover
    (X := X) (H := H) (V := V) (nu := nu) (x := x) (K := D.K)
    D.nu_pos D.directCover
  indexLeCutoff := cutoffPrefixClosed_indexLeCutoff
    (S := endpointSubwindowIntervalLeft nu X)
    (E := endpointSubwindowIntervalRight X)
    (K := D.K) (BaseRelevant := EndpointActiveRelevant nu X)
  activeSublinear := by
    let L : EndpointRatioActiveBelowLeftLogCountData nu X :=
      endpointRatioActiveBelowLeftLogCountData_of_geometric
        (nu := nu) (X := X) hnu_two hXpos hXmono
    let C : EndpointRatioActiveBelowLeftCountDirectData nu X :=
      endpointRatioActiveBelowLeftCountDirectData_of_logCountData L
    exact cutoffRelevantActiveShadowCountSublinear_of_directData
      (cutoffRelevantActiveCountDirectData_of_endpointRatioActiveBelowLeftData
        (nu := nu) (X := X) (K := D.K) D.nu_pos C)
  scaleMap := {
    K := D.K
    scaleErr := D.scaleErr
    delta_nonneg := D.delta_nonneg
    K_tendsto := D.K_tendsto
    relevantIndexLtPrefix := cutoffPrefixClosed_indexLtPrefix
      (K := D.K) (BaseRelevant := EndpointActiveRelevant nu X)
    scaleBound := D.scaleBound
    scaleErrSublinear := D.scaleErrSublinear
  }
  liveErrSublinear := D.liveErrSublinear
  liveBudget := D.liveBudget
}

