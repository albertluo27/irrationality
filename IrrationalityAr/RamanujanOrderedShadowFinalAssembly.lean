  intro B hB hBound
  rcases h B hB hBound with ⟨D⟩
  exact ⟨clippedCanonicalLiveLossSubwindowData_of_clippedIntervalBudgetData D⟩

/-- A full interval-budget target implies the clipped interval-budget target. -/
