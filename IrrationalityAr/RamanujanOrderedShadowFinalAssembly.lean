/-! ## 1. Abstract schedules -/

/-- A normalized shadow schedule.  `S n` is the start of the `n`-th active
shadow and `r n = v/u` is its block ratio.

The recurrence `S(n+1) >= (1+r(n))S(n)` is the normalized form of
`u_{next} >= u+v` after dividing by `1-x`.
-/
def AdmissibleNormalizedShadowSchedule
    (tau : ℝ) (S r : ℕ → ℝ) : Prop :=
  (∀ n : ℕ, 0 ≤ S n) ∧
  (∀ n : ℕ, r n ≤ tau) ∧
  (∀ n : ℕ, (1 + r n) * S n ≤ S (n + 1))

/-- Real length of the `n`-th normalized shadow. -/
noncomputable def normalizedShadowLengthAt
    (x : ℝ) (S r : ℕ → ℝ) (n : ℕ) : ℝ :=
  shellSpikeNormalizedLength (r n) x * S n

/-- Right endpoint of the `n`-th normalized shadow. -/
noncomputable def normalizedShadowEndAt
    (x : ℝ) (S r : ℕ → ℝ) (n : ℕ) : ℝ :=
  shellSpikeNormalizedEnd (r n) x * S n

/-- Cumulative real shadow length before index `n`. -/
noncomputable def cumulativeNormalizedShadowLength
    (x : ℝ) (S r : ℕ → ℝ) (n : ℕ) : ℝ :=
  ∑ i ∈ Finset.range n, normalizedShadowLengthAt x S r i

/-! ## 2. Iterated carry invariant -/

/-- The one-step carry invariant iterates over every finite initial segment of
an admissible normalized shadow schedule. -/
theorem cumulativeNormalizedShadowLength_le_carry_start
    {tau x : ℝ} {S r : ℕ → ℝ}
    (htau : 0 < tau)
    (hx0 : 0 < x)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hsched : AdmissibleNormalizedShadowSchedule tau S r) :
    ∀ n : ℕ,
      cumulativeNormalizedShadowLength x S r n ≤
        shellSpikeCarry tau x * S n := by
  have hcarry : 0 ≤ shellSpikeCarry tau x :=
    shellSpikeCarry_nonneg htau hx0 hxθ
  intro n
  induction n with
  | zero =>
      simp [cumulativeNormalizedShadowLength]
      exact mul_nonneg hcarry (hsched.1 0)
  | succ n ih =>
      have hstep := shellSpike_budget_step
        (tau := tau) (x := x) (r := r n)
        (C := cumulativeNormalizedShadowLength x S r n)
        (S := S n) (Snext := S (n + 1))
        htau hx0 hcarry (hsched.1 n) (hsched.2.1 n)
        ih (hsched.2.2 n)
      simpa [cumulativeNormalizedShadowLength,
        normalizedShadowLengthAt, Finset.sum_range_succ] using hstep

/-- At the endpoint of the `n`-th active shadow, the total real length of all
shadows through `n` is bounded by the predicted bad-density coefficient times
that endpoint. -/
theorem cumulativeNormalizedShadowLength_succ_le_badDensity_mul_endpoint
    {tau x : ℝ} {S r : ℕ → ℝ}
    (htau : 0 < tau)
    (hx0 : 0 < x)
    (hxsep : shellSpikeSeparationThreshold tau < x)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hsched : AdmissibleNormalizedShadowSchedule tau S r)
    (n : ℕ) :
    cumulativeNormalizedShadowLength x S r (n + 1) ≤
      shellSpikeBadDensity tau x * normalizedShadowEndAt x S r n := by
  have hprev :
      cumulativeNormalizedShadowLength x S r n ≤
      shellSpikeCarry tau x * S n :=
    cumulativeNormalizedShadowLength_le_carry_start
      htau hx0 hxθ hsched n
  have hx1 : x < 1 := by
    have hden : 0 < tau + 1 := by linarith
    have hglobal_lt_one : shellSpikeGlobalExponent tau < 1 := by
      rw [shellSpikeGlobalExponent]
      exact (div_lt_one hden).2 (by linarith)
    exact lt_of_le_of_lt hxθ hglobal_lt_one
  have hend := shellSpike_budget_at_endpoint
    (tau := tau) (x := x) (r := r n)
    (C := cumulativeNormalizedShadowLength x S r n)
    (S := S n)
    htau hx0 hxsep hx1 (hsched.1 n) (hsched.2.1 n) hprev
  simpa [cumulativeNormalizedShadowLength,
    normalizedShadowLengthAt, normalizedShadowEndAt,
    Finset.sum_range_succ] using hend

/-! ## 3. Ratio form and exact predicted coefficient -/

/-- Ratio form of the cumulative endpoint estimate. -/
theorem cumulativeNormalizedShadowLength_ratio_le_badDensity
    {tau x : ℝ} {S r : ℕ → ℝ}
    (htau : 0 < tau)
    (hx0 : 0 < x)
    (hxsep : shellSpikeSeparationThreshold tau < x)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hsched : AdmissibleNormalizedShadowSchedule tau S r)
    {n : ℕ}
    (hendPos : 0 < normalizedShadowEndAt x S r n) :
    cumulativeNormalizedShadowLength x S r (n + 1) /
        normalizedShadowEndAt x S r n ≤
      shellSpikeBadDensity tau x := by
  rw [div_le_iff₀ hendPos]
  exact cumulativeNormalizedShadowLength_succ_le_badDensity_mul_endpoint
    htau hx0 hxsep hxθ hsched n

/-- The bad-density coefficient is exactly `1 - Gamma_tau(x)`. -/
theorem cumulativeNormalizedShadowLength_succ_le_one_sub_gain_mul_endpoint
    {tau x : ℝ} {S r : ℕ → ℝ}
    (htau : 0 < tau)
    (hx0 : 0 < x)
    (hxsep : shellSpikeSeparationThreshold tau < x)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hsched : AdmissibleNormalizedShadowSchedule tau S r)
    (n : ℕ) :
    cumulativeNormalizedShadowLength x S r (n + 1) ≤
      (1 - shellSpikeGoodDensityGain tau x) *
        normalizedShadowEndAt x S r n := by
  simpa [shellSpikeBadDensity] using
    cumulativeNormalizedShadowLength_succ_le_badDensity_mul_endpoint
      htau hx0 hxsep hxθ hsched n

/-! ## 4. Extremal equality diagnostics -/

/-- In the extremal schedule `r_n = tau` and
`S_{n+1} = (1+tau)S_n`, the carry step has zero slack.  This records that the
predicted density coefficient is sharp for the abstract recurrence model. -/
theorem shellSpikeCarry_step_extremal_identity
    {tau x : ℝ}
    (htau : tau ≠ 0) (hx : x ≠ 0) :
    shellSpikeCarry tau x * (1 + tau) -
      (shellSpikeCarry tau x + shellSpikeNormalizedLength tau x) = 0 := by
  have h := shellSpikeCarry_step_identity
    (tau := tau) (x := x) htau hx
  simpa using h

/-- The endpoint slack also vanishes at the extremal ratio `r = tau`. -/
theorem shellSpike_endpoint_extremal_identity
    {tau x : ℝ}
    (htau : tau ≠ 0) (hx : x ≠ 0) (hx1 : x ≠ 1) :
    shellSpikeBadDensity tau x * shellSpikeNormalizedEnd tau x -
      (shellSpikeCarry tau x + shellSpikeNormalizedLength tau x) = 0 := by
  have h := shellSpike_endpoint_slack_identity
    (tau := tau) (x := x) htau hx hx1
  simpa using h


/-!
# Integer shell counting from real spike-shadow length budgets

This is the next finite bridge in the shell-spike program.

The previous unified layer proves the real normalized shadow-length budget.  This
file isolates the remaining elementary counting conversion:

```text
real interval length budget + sublinear number of active intervals
  ==> integer shell count budget
  ==> predicted spike-shadow upper density.
```

The finite union bound needs one honest bookkeeping hypothesis:
`ActiveShadowIndicesCoverUnion S E` says that every covered integer shell below a
cutoff has a witness in the finite active-index set used by the budget.  This is
the place where later schedule-specific work proves that sparse active shadow
lists include every interval that can meet `[0,M]`.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanShellSpikeIntegerCounting.lean -/

/-! ## 1. Integer shells inside real intervals -/

/-- A natural shell index `m` lies in the real interval `[S,E]`. -/
def NatInRealInterval (m : ℕ) (S E : ℝ) : Prop :=
  S ≤ (m : ℝ) ∧ (m : ℝ) ≤ E

/-- A natural shell index lies in at least one interval from a real interval family. -/
def NatInRealIntervalUnion (S E : ℕ → ℝ) (m : ℕ) : Prop :=
  ∃ i : ℕ, NatInRealInterval m (S i) (E i)

/-- Active interval indices whose left endpoint is at most the integer cutoff `M`. -/
def ActiveShadowIndexFinset (S : ℕ → ℝ) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun i => S i ≤ (M : ℝ)

/-- Active interval count up to integer shell cutoff `M`. -/
def ActiveShadowCount (S : ℕ → ℝ) (M : ℕ) : ℕ :=
  (ActiveShadowIndexFinset S M).card

/-- Integer shell indices up to `M` lying in one interval `[S,E]`. -/
def IntegerIntervalPointFinset (S E : ℝ) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun m => NatInRealInterval m S E

/-- Integer shell indices up to `M` lying in the interval union. -/
def IntegerShadowUnionFinset (S E : ℕ → ℝ) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun m => NatInRealIntervalUnion S E m

/-- Count of integer shells up to `M` lying in the real interval union. -/
def IntegerShadowUnionCount (S E : ℕ → ℝ) (M : ℕ) : ℕ :=
  (IntegerShadowUnionFinset S E M).card

@[simp] theorem IntegerShadowUnionCount_eq_natInitialSegmentCount
    (S E : ℕ → ℝ) (M : ℕ) :
    IntegerShadowUnionCount S E M =
      natInitialSegmentCount (NatInRealIntervalUnion S E) M := by
  rfl

/-- The finite active-index list covers all interval witnesses relevant below
the cutoff `M`.  Later schedule-specific modules should prove this from the
chosen active shadow enumeration. -/
def ActiveShadowIndicesCoverUnion (S E : ℕ → ℝ) : Prop :=
  ∀ M m : ℕ, m ≤ M → NatInRealIntervalUnion S E m →
    ∃ i : ℕ, i ∈ ActiveShadowIndexFinset S M ∧
      NatInRealInterval m (S i) (E i)

/-! ## 2. Sublinear active interval counts and real-length budgets -/

/-- The number of active shadows up to `M` is sublinear in `M`. -/
def ActiveShadowCountSublinear (S : ℕ → ℝ) : Prop :=
  ∀ ε : ℝ, 0 < ε →
    ∀ᶠ M : ℕ in atTop,
      (ActiveShadowCount S M : ℝ) ≤ ε * ((M : ℝ) + 1)

/-- A real-length shadow budget up to integer cutoff.  This is the finite form
expected from the cumulative real-length theorem plus endpoint clipping. -/
def RealShadowLengthBudget
    (S E : ℕ → ℝ) (δ : ℝ) (Err : ℕ → ℝ) : Prop :=
  ∀ᶠ M : ℕ in atTop,
    (∑ i ∈ ActiveShadowIndexFinset S M, max 0 (E i - S i))
      ≤ δ * ((M : ℝ) + 1) + Err M

/-- Active count times a fixed factor is a sublinear error. -/
theorem activeShadowCount_error_sublinear
    {S : ℕ → ℝ} (hS : ActiveShadowCountSublinear S) :
    EventuallySublinearCountError
      (fun M : ℕ => 2 * (ActiveShadowCount S M : ℝ)) := by
  simpa [ActiveShadowCountSublinear, EventuallySublinearCountError] using
    EventuallySublinearCountError.const_mul
      (E := fun M : ℕ => (ActiveShadowCount S M : ℝ))
      (C := 2) (by norm_num) hS

/-- The total rounding/endpoint error `Err + 2 * activeCount` is sublinear. -/
theorem intervalCounting_totalError_sublinear
    {S : ℕ → ℝ} {Err : ℕ → ℝ}
    (hErr : EventuallySublinearCountError Err)
    (hS : ActiveShadowCountSublinear S) :
    EventuallySublinearCountError
      (fun M : ℕ => Err M + 2 * (ActiveShadowCount S M : ℝ)) := by
  exact hErr.add (activeShadowCount_error_sublinear hS)

/-! ## 3. Finite interval counting lemmas -/

/-- Integer points in one real interval are bounded by interval length plus two.

The `+2` buffer avoids exact floor/ceiling endpoint bookkeeping. -/
theorem integerIntervalPointFinset_card_le_length_add_two
    {S E : ℝ} {M : ℕ} :
    ((IntegerIntervalPointFinset S E M).card : ℝ)
      ≤ max 0 (E - S) + 2 := by
  classical
  let F : Finset ℕ := IntegerIntervalPointFinset S E M
  by_cases hF : F.Nonempty
  · let a : ℕ := F.min' hF
    let b : ℕ := F.max' hF
    have hsubset : F ⊆ Finset.Icc a b := by
      intro m hm
      dsimp [a, b]
      rw [Finset.mem_Icc]
      exact ⟨Finset.min'_le F m hm, Finset.le_max' F m hm⟩
    have hcardNat0 : F.card ≤ (Finset.Icc a b).card :=
      Finset.card_le_card hsubset
    have hIcc : (Finset.Icc a b).card = b + 1 - a := by
      simp
    have hab : a ≤ b := by
      dsimp [a, b]
      exact Finset.min'_le_max' F hF
    have hcardNat : F.card ≤ b - a + 1 := by
      rw [hIcc] at hcardNat0
      omega
    have ha_mem : a ∈ F := by
      dsimp [a]
      exact Finset.min'_mem F hF
    have hb_mem : b ∈ F := by
      dsimp [b]
      exact Finset.max'_mem F hF
    have haS : S ≤ (a : ℝ) := by
      dsimp [F, IntegerIntervalPointFinset] at ha_mem
      rw [Finset.mem_filter] at ha_mem
      exact ha_mem.2.1
    have hbE : (b : ℝ) ≤ E := by
      dsimp [F, IntegerIntervalPointFinset] at hb_mem
      rw [Finset.mem_filter] at hb_mem
      exact hb_mem.2.2
    have hcardReal : (F.card : ℝ) ≤ (b : ℝ) - (a : ℝ) + 1 := by
      have htmp : (F.card : ℝ) ≤ ((b - a + 1 : ℕ) : ℝ) := by
        exact_mod_cast hcardNat
      have hcast : ((b - a + 1 : ℕ) : ℝ) = (b : ℝ) - (a : ℝ) + 1 := by
        rw [Nat.cast_add, Nat.cast_one, Nat.cast_sub hab]
      rwa [hcast] at htmp
    have hlen : (b : ℝ) - (a : ℝ) ≤ E - S := by
      linarith
    have hmax : E - S ≤ max 0 (E - S) := le_max_right _ _
    have hgoal : (F.card : ℝ) ≤ max 0 (E - S) + 2 := by
      linarith
    simpa [F] using hgoal
  · have hcard0 : F.card = 0 := by
      rw [Finset.card_eq_zero]
      exact Finset.not_nonempty_iff_eq_empty.mp hF
    have hnonneg : 0 ≤ max 0 (E - S) + 2 := by
      have hmax0 : (0 : ℝ) ≤ max 0 (E - S) := le_max_left _ _
      linarith
    have hgoal : (F.card : ℝ) ≤ max 0 (E - S) + 2 := by
      rw [hcard0]
      simpa using hnonneg
    simpa [F] using hgoal

/-- Union bound for integer shell counts.  The active-cover hypothesis supplies
the finite active witness needed for sparse interval schedules. -/
theorem integerShadowUnionCount_le_sum_interval_counts
    {S E : ℕ → ℝ}
    (hcover : ActiveShadowIndicesCoverUnion S E)
    (M : ℕ) :
    (IntegerShadowUnionCount S E M : ℝ)
      ≤
    ∑ i ∈ ActiveShadowIndexFinset S M,
      ((IntegerIntervalPointFinset (S i) (E i) M).card : ℝ) := by
  classical
  let U : Finset ℕ := IntegerShadowUnionFinset S E M
  let B : Finset ℕ := (ActiveShadowIndexFinset S M).biUnion
    (fun i => IntegerIntervalPointFinset (S i) (E i) M)
  have hsubset : U ⊆ B := by
    intro m hm
    dsimp [U, IntegerShadowUnionFinset] at hm
    rw [Finset.mem_filter] at hm
    rcases hm with ⟨hmrange, hmem⟩
    have hmleM : m ≤ M := by
      rw [Finset.mem_range] at hmrange
      omega
    rcases hcover M m hmleM hmem with ⟨i, hi, him⟩
    dsimp [B]
    rw [Finset.mem_biUnion]
    refine ⟨i, hi, ?_⟩
    dsimp [IntegerIntervalPointFinset]
    rw [Finset.mem_filter]
    exact ⟨hmrange, him⟩
  have hcardU : U.card ≤ B.card := Finset.card_le_card hsubset
  have hcardB : B.card ≤ ∑ i ∈ ActiveShadowIndexFinset S M,
      (IntegerIntervalPointFinset (S i) (E i) M).card := by
    dsimp [B]
    exact Finset.card_biUnion_le
  have hnat : IntegerShadowUnionCount S E M ≤
      ∑ i ∈ ActiveShadowIndexFinset S M,
        (IntegerIntervalPointFinset (S i) (E i) M).card := by
    dsimp [IntegerShadowUnionCount, U] at hcardU
    exact hcardU.trans hcardB
  exact_mod_cast hnat

/-- Finite integer shell budget from real length budget and active-count error. -/
theorem integerShadowUnionCount_budget
    {S E : ℕ → ℝ} {δ : ℝ} {Err : ℕ → ℝ}
    (hcover : ActiveShadowIndicesCoverUnion S E)
    (hLength : RealShadowLengthBudget S E δ Err) :
    ∀ᶠ M : ℕ in atTop,
      (IntegerShadowUnionCount S E M : ℝ)
        ≤ δ * ((M : ℝ) + 1) +
          (Err M + 2 * (ActiveShadowCount S M : ℝ)) := by
  classical
  filter_upwards [hLength] with M hLen
  calc
    (IntegerShadowUnionCount S E M : ℝ)
        ≤ ∑ i ∈ ActiveShadowIndexFinset S M,
            ((IntegerIntervalPointFinset (S i) (E i) M).card : ℝ) :=
          integerShadowUnionCount_le_sum_interval_counts hcover M
    _ ≤ ∑ i ∈ ActiveShadowIndexFinset S M,
            (max 0 (E i - S i) + 2) := by
          gcongr with i hi
          exact integerIntervalPointFinset_card_le_length_add_two
    _ = (∑ i ∈ ActiveShadowIndexFinset S M, max 0 (E i - S i)) +
          2 * (ActiveShadowCount S M : ℝ) := by
          rw [Finset.sum_add_distrib]
          simp [ActiveShadowCount, add_comm, mul_comm]
    _ ≤ δ * ((M : ℝ) + 1) + Err M +
          2 * (ActiveShadowCount S M : ℝ) := by
          linarith
    _ = δ * ((M : ℝ) + 1) +
          (Err M + 2 * (ActiveShadowCount S M : ℝ)) := by
          ring

/-! ## 4. Density consequence -/

/-- Real shadow budget plus sublinear active count gives upper density at most
`δ` for the integer shell union. -/
theorem upperDensityAtMost_of_realShadowLengthBudget
    {S E : ℕ → ℝ} {δ : ℝ} {Err : ℕ → ℝ}
    (hcover : ActiveShadowIndicesCoverUnion S E)
    (hLength : RealShadowLengthBudget S E δ Err)
    (hActive : ActiveShadowCountSublinear S)
    (hErr : EventuallySublinearCountError Err) :
    UpperNatDensityAtMost (NatInRealIntervalUnion S E) δ := by
  have hBudgetEvent := integerShadowUnionCount_budget
    (S := S) (E := E) (δ := δ) (Err := Err) hcover hLength
  have hTotalErr : EventuallySublinearCountError
      (fun M : ℕ => Err M + 2 * (ActiveShadowCount S M : ℝ)) :=
    intervalCounting_totalError_sublinear hErr hActive
  apply upperNatDensityAtMost_of_countBudget_sublinearError
    (B := NatInRealIntervalUnion S E)
    (δ := δ)
    (E := fun M : ℕ => Err M + 2 * (ActiveShadowCount S M : ℝ))
  · filter_upwards [hBudgetEvent] with M hM
    simpa [UpperCountBudgetWithError, IntegerShadowUnionCount_eq_natInitialSegmentCount]
      using hM
  · exact hTotalErr

/-- Project-facing finite interval-counting bridge to the predicted shadow-density
predicate. -/
theorem predictedSpikeShadowDensity_of_realIntervalBudget
    {Hlog u v : ℕ → ℝ} {tau x : ℝ}
    {S E : ℕ → ℝ} {Err : ℕ → ℝ}
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u v x m → NatInRealIntervalUnion S E m)
    (hcover : ActiveShadowIndicesCoverUnion S E)
    (hLength : RealShadowLengthBudget S E
      (1 - shellSpikeGoodDensityGain tau x) Err)
    (hActive : ActiveShadowCountSublinear S)
    (hErr : EventuallySublinearCountError Err) :
    PredictedSpikeShadowDensity Hlog u v tau x := by
  unfold PredictedSpikeShadowDensity
  have hDens := upperDensityAtMost_of_realShadowLengthBudget
    (S := S) (E := E)
    (δ := 1 - shellSpikeGoodDensityGain tau x)
    (Err := Err) hcover hLength hActive hErr
  exact Criteria.upperDensityAtMost_mono hRepresent hDens


/-!
# Ordered shadow schedules for the shell-spike covering program

This module is the next bridge after `RamanujanShellSpikeIntegerCounting`.

The integer-counting module proves:

```text
real length budget + sublinear active interval count
  ==> predicted spike-shadow density.
```

This file packages the ordered-schedule bookkeeping needed to feed that bridge.
The genuinely analytic growth facts are kept as explicit hypotheses:

* `EventuallyGeometricStarts` includes the sublinear active-count conclusion it
  is meant to provide in later work;
* `OrderedRealLengthLogBudget` includes sublinearity of its logarithmic error.

This keeps the module axiom-free while making the remaining analytic proof
obligations visible at the interface.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanShellSpikeOrderedSchedule.lean -/

/-! ## 1. Ordered shadow schedules -/

/-- A real interval schedule used to model shell spike shadows.

`left i` and `right i` are the endpoints of the `i`-th active shadow interval.
The `index_le_left` field ensures that any interval that hits a shell `m ≤ M`
is already indexed by an active index `≤ M`.
-/
structure OrderedShadowSchedule where
  left : ℕ → ℝ
  right : ℕ → ℝ
  /-- interval starts are nonnegative, convenient for geometric counting -/
  left_nonneg : ∀ i : ℕ, 0 ≤ left i
  /-- indexing is not faster than the shell coordinate; this gives active cover -/
  index_le_left : ∀ i : ℕ, (i : ℝ) ≤ left i

/-- Local active-cover condition for the integer-counting bridge. -/
def OrderedActiveIndicesCoverUnion (S : OrderedShadowSchedule) : Prop :=
  ∀ M m i : ℕ,
    m ≤ M →
    NatInRealInterval m (S.left i) (S.right i) →
    i ∈ ActiveShadowIndexFinset S.left M

/-- The schedule bookkeeping hypothesis `i ≤ left i` implies the local active
cover condition. -/
theorem OrderedShadowSchedule.activeCover (S : OrderedShadowSchedule) :
    OrderedActiveIndicesCoverUnion S := by
  intro M m i hm hmem
  dsimp [ActiveShadowIndexFinset]
  simp only [Finset.mem_filter, Finset.mem_range]
  constructor
  · have him_real : (i : ℝ) ≤ (m : ℝ) := le_trans (S.index_le_left i) hmem.1
    have hmM_real : (m : ℝ) ≤ (M : ℝ) := by exact_mod_cast hm
    have hiM_real : (i : ℝ) ≤ (M : ℝ) := le_trans him_real hmM_real
    have hiM : i ≤ M := by exact_mod_cast hiM_real
    omega
  · have hmM_real : (m : ℝ) ≤ (M : ℝ) := by exact_mod_cast hm
    exact le_trans hmem.1 hmM_real

/-- The same active cover in the exact form expected by
`RamanujanShellSpikeIntegerCounting`. -/
theorem OrderedShadowSchedule.activeCoverUnion (S : OrderedShadowSchedule) :
    ActiveShadowIndicesCoverUnion S.left S.right := by
  intro M m hm hmem
  rcases hmem with ⟨i, hmi⟩
  exact ⟨i, S.activeCover M m i hm hmi, hmi⟩

/-! ## 2. Geometric growth and active-count sublinearity -/

/-- Eventual geometric growth of starts, bundled with the sublinear active-count
conclusion that later analysis should prove from it.

The first component records the intended geometric lower bound.  The second
component is the exact input required by the integer-counting bridge. -/
def EventuallyGeometricStarts (S : OrderedShadowSchedule) : Prop :=
  (∃ r C : ℝ,
    1 < r ∧ 0 < C ∧
      ∀ᶠ i : ℕ in atTop, C * r ^ i ≤ S.left i) ∧
  ActiveShadowCountSublinear S.left

/-- Projection of the sublinear active-count input from the ordered growth
package. -/
theorem activeShadowCountSublinear_of_eventuallyGeometricStarts
    (S : OrderedShadowSchedule)
    (hgeom : EventuallyGeometricStarts S) :
    ActiveShadowCountSublinear S.left := by
  exact hgeom.2

/-! ## 3. Ordered length budgets -/

/-- Real-length budget with a logarithmic endpoint error, together with the
sublinearity of that error. -/
def OrderedRealLengthLogBudget
    (S : OrderedShadowSchedule) (δ : ℝ) : Prop :=
  RealShadowLengthBudget S.left S.right δ
      (fun M : ℕ => Real.log ((M : ℝ) + 2)) ∧
    EventuallySublinearCountError
      (fun M : ℕ => Real.log ((M : ℝ) + 2))

/-- Ordered real-length budget plus geometric starts gives upper density for the
integer interval union. -/
theorem upperDensityAtMost_of_orderedSchedule
    (S : OrderedShadowSchedule) {δ : ℝ}
    (hLen : OrderedRealLengthLogBudget S δ)
    (hGeom : EventuallyGeometricStarts S) :
    UpperNatDensityAtMost (NatInRealIntervalUnion S.left S.right) δ := by
  exact upperDensityAtMost_of_realShadowLengthBudget
    (S := S.left) (E := S.right)
    (δ := δ) (Err := fun M : ℕ => Real.log ((M : ℝ) + 2))
    S.activeCoverUnion
    hLen.1
    (activeShadowCountSublinear_of_eventuallyGeometricStarts S hGeom)
    hLen.2

/-! ## 4. Project-facing predicted shadow density wrapper -/

/-- The ordered-schedule bridge to `PredictedSpikeShadowDensity`. -/
theorem predictedSpikeShadowDensity_of_orderedSchedule
    {Hlog u vseq : ℕ → ℝ} {tau x : ℝ}
    (S : OrderedShadowSchedule)
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion S.left S.right m)
    (hLen : OrderedRealLengthLogBudget S
      (1 - shellSpikeGoodDensityGain tau x))
    (hGeom : EventuallyGeometricStarts S) :
    PredictedSpikeShadowDensity Hlog u vseq tau x := by
  exact predictedSpikeShadowDensity_of_realIntervalBudget
    (Hlog := Hlog) (u := u) (v := vseq)
    (tau := tau) (x := x)
    (S := S.left) (E := S.right)
    (Err := fun M : ℕ => Real.log ((M : ℝ) + 2))
    hRepresent S.activeCoverUnion hLen.1
    (activeShadowCountSublinear_of_eventuallyGeometricStarts S hGeom)
    hLen.2

/-! ## 5. Connecting cumulative normalized schedules to ordered schedules -/

/-- Build the ordered shadow schedule from normalized starts and ratios.

Here `S n` is the normalized start and `r n = v_n/u_n`.  The right endpoint is
`normalizedShadowEndAt x S r n`.
-/
def normalizedOrderedShadowSchedule
    (x : ℝ) (S r : ℕ → ℝ)
    (hS_nonneg : ∀ i : ℕ, 0 ≤ S i)
    (hindex : ∀ i : ℕ, (i : ℝ) ≤ S i) :
    OrderedShadowSchedule where
  left := S
  right := normalizedShadowEndAt x S r
  left_nonneg := hS_nonneg
  index_le_left := hindex

/-- Endpoint clipping plus a sublinear logarithmic-error proof gives the
ordered real-length budget for the corresponding normalized schedule. -/
theorem orderedRealLengthLogBudget_of_normalizedSchedule
    {tau x : ℝ} {S r : ℕ → ℝ}
    (_htau : 0 < tau)
    (_hx0 : 0 < x)
    (_hxsep : shellSpikeSeparationThreshold tau < x)
    (_hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hsched : AdmissibleNormalizedShadowSchedule tau S r)
    (hindex : ∀ i : ℕ, (i : ℝ) ≤ S i)
    (hLogSublinear :
      EventuallySublinearCountError
        (fun M : ℕ => Real.log ((M : ℝ) + 2)))
    (hEndpointClip :
      ∀ᶠ M : ℕ in atTop,
        (∑ i ∈ ActiveShadowIndexFinset S M,
          max 0 (normalizedShadowEndAt x S r i - S i))
          ≤ (1 - shellSpikeGoodDensityGain tau x) * ((M : ℝ) + 1) +
              Real.log ((M : ℝ) + 2)) :
    OrderedRealLengthLogBudget
      (normalizedOrderedShadowSchedule x S r hsched.1 hindex)
      (1 - shellSpikeGoodDensityGain tau x) := by
  constructor
  · simpa [OrderedRealLengthLogBudget, normalizedOrderedShadowSchedule,
      RealShadowLengthBudget] using hEndpointClip
  · exact hLogSublinear

/-- Final ordered normalized schedule wrapper to predicted shadow density. -/
theorem predictedSpikeShadowDensity_of_normalizedOrderedSchedule
    {Hlog u vseq : ℕ → ℝ} {tau x : ℝ} {S r : ℕ → ℝ}
    (htau : 0 < tau)
    (hx0 : 0 < x)
    (hxsep : shellSpikeSeparationThreshold tau < x)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hsched : AdmissibleNormalizedShadowSchedule tau S r)
    (hindex : ∀ i : ℕ, (i : ℝ) ≤ S i)
    (hGeom : EventuallyGeometricStarts
      (normalizedOrderedShadowSchedule x S r hsched.1 hindex))
    (hLogSublinear :
      EventuallySublinearCountError
        (fun M : ℕ => Real.log ((M : ℝ) + 2)))
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion S (normalizedShadowEndAt x S r) m)
    (hEndpointClip :
      ∀ᶠ M : ℕ in atTop,
        (∑ i ∈ ActiveShadowIndexFinset S M,
          max 0 (normalizedShadowEndAt x S r i - S i))
          ≤ (1 - shellSpikeGoodDensityGain tau x) * ((M : ℝ) + 1) +
              Real.log ((M : ℝ) + 2)) :
    PredictedSpikeShadowDensity Hlog u vseq tau x := by
  let OS := normalizedOrderedShadowSchedule x S r hsched.1 hindex
  have hLen : OrderedRealLengthLogBudget OS
      (1 - shellSpikeGoodDensityGain tau x) := by
    simpa [OS] using
      orderedRealLengthLogBudget_of_normalizedSchedule
        htau hx0 hxsep hxθ hsched hindex hLogSublinear hEndpointClip
  exact predictedSpikeShadowDensity_of_orderedSchedule
    (Hlog := Hlog) (u := u) (vseq := vseq)
    (tau := tau) (x := x)
    OS hRepresent hLen hGeom


/-!
# Bad Ramanujan truncations to visible shell spikes

This scaffold pushes the remaining implication

  `BadRamanujanTruncation ν m → VisibleBlockSpikeShell H V x m`.

The main output is a precise algebraic diagnosis.

* From the existing upper-spike window alone, a bad truncation can force a
  visible block spike only after expanding the height scale to

      h(m) = κ m / (ν (1 - x)).

* The largest exponent obtained from the generic argument is

      x < (ν β / κ - 2) / (ν β / κ - 1),

  where `β < κ` is the rigorous upper-window width exponent.

* With only a known bound `μ ≤ M` and `τ = M - 2`, this exponent is at or below
  the contraction exponent.  Thus the generic bad-to-visible implication alone
  cannot bootstrap the irrationality-measure bound.  A genuine improvement must
  come from a new arithmetic input that reduces the effective `2X_j` loss.

The file intentionally separates completed algebra/wrappers from the two hard
project-specific bridges:

1. converting upper-spike windows into the logarithmic block certificate; and
2. converting block certificates into actual visible canonical block spikes
   with a small exponent slack.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanBadTruncationToVisibleSpike.lean -/

/-! ## 1. Generic exponent algebra -/

/-- The generic exponent produced by an upper-spike window of width exponent
`β`.  Put `R = νβ/κ`.  The visible-spike exponent is `(R - 2)/(R - 1)`.
The `2` is the current loss coming from `X_{j+1} ≤ X_j + v_j + O(1)` together
with the upper-window term `X_j + X_{j+1}`. -/
def badToVisibleExponent (κ ν β : ℝ) : ℝ :=
  (ν * β / κ - 2) / (ν * β / κ - 1)

/-- More general exponent if the effective loss is `L` instead of `2`.
The current generic proof has `L = 2`.  Any uniform theorem giving `L < 2`
would create a real self-improvement route. -/
def lossToVisibleExponent (κ ν β L : ℝ) : ℝ :=
  (ν * β / κ - L) / (ν * β / κ - L + 1)

@[simp] theorem lossToVisibleExponent_two
    (κ ν β : ℝ) :
    lossToVisibleExponent κ ν β 2 = badToVisibleExponent κ ν β := by
  simp [lossToVisibleExponent, badToVisibleExponent]
  ring

/-- Logarithmic height expansion needed to turn a denominator threshold
`exp(κm/ν)` into the stronger condition `q_j ≤ H^{1-x}`. -/
def badToVisibleHeightLog (κ ν x : ℝ) (m : ℕ) : ℝ :=
  (κ * (m : ℝ) / ν) / (1 - x)

/-- The positive margin left after demanding a visible `H^x` block from an
upper-spike window. -/
def badToVisibleMargin (κ ν β x : ℝ) : ℝ :=
  β - 2 * κ / ν - x * κ / (ν * (1 - x))

/-- Algebraic equivalence between being below the generic exponent and having
positive visible margin.  This is the main usable scalar criterion. -/
theorem badToVisibleMargin_pos_of_lt_exponent
    {κ ν β x : ℝ}
    (hκ : 0 < κ) (hν : 0 < ν)
    (hR : 2 < ν * β / κ)
    (_hx0 : 0 ≤ x) (hx1 : x < 1)
    (hx : x < badToVisibleExponent κ ν β) :
    0 < badToVisibleMargin κ ν β x := by
  set R : ℝ := ν * β / κ with hRdef
  have hRgt2 : 2 < R := by
    rw [hRdef]
    exact hR
  have hRden : 0 < R - 1 := by linarith
  have hxden : 0 < 1 - x := by linarith
  have hxR : x * (R - 1) < R - 2 := by
    have hx' : x < (R - 2) / (R - 1) := by
      rw [badToVisibleExponent] at hx
      rwa [← hRdef] at hx
    exact (lt_div_iff₀ hRden).mp hx'
  have hxfrac : x / (1 - x) < R - 2 := by
    rw [div_lt_iff₀ hxden]
    nlinarith
  have hscaled : 0 < R - 2 - x / (1 - x) := by linarith
  have hmargin_scaled :
      badToVisibleMargin κ ν β x = (κ / ν) * (R - 2 - x / (1 - x)) := by
    rw [badToVisibleMargin]
    rw [hRdef]
    field_simp [hκ.ne', hν.ne', hxden.ne']
  rw [hmargin_scaled]
  exact mul_pos (div_pos hκ hν) hscaled

/-- Converse algebra: positive margin implies the exponent inequality. -/
theorem lt_exponent_of_badToVisibleMargin_pos
    {κ ν β x : ℝ}
    (hκ : 0 < κ) (hν : 0 < ν)
    (hR : 2 < ν * β / κ)
    (_hx0 : 0 ≤ x) (hx1 : x < 1)
    (hmargin : 0 < badToVisibleMargin κ ν β x) :
    x < badToVisibleExponent κ ν β := by
  set R : ℝ := ν * β / κ with hRdef
  have hRgt2 : 2 < R := by
    rw [hRdef]
    exact hR
  have hRden : 0 < R - 1 := by linarith
  have hxden : 0 < 1 - x := by linarith
  have hmargin_scaled :
      badToVisibleMargin κ ν β x = (κ / ν) * (R - 2 - x / (1 - x)) := by
    rw [badToVisibleMargin]
    rw [hRdef]
    field_simp [hκ.ne', hν.ne', hxden.ne']
  have hscaled : 0 < R - 2 - x / (1 - x) := by
    have hpos := hmargin
    rw [hmargin_scaled] at hpos
    have hfactor : 0 < κ / ν := div_pos hκ hν
    by_contra hnot
    have hnonpos : (κ / ν) * (R - 2 - x / (1 - x)) ≤ 0 := by
      exact mul_nonpos_of_nonneg_of_nonpos (le_of_lt hfactor) (le_of_not_gt hnot)
    linarith
  have hxfrac : x / (1 - x) < R - 2 := by linarith
  have hxR : x * (R - 1) < R - 2 := by
    rw [div_lt_iff₀ hxden] at hxfrac
    nlinarith
  have hx' : x < (R - 2) / (R - 1) := (lt_div_iff₀ hRden).mpr hxR
  rw [badToVisibleExponent]
  rwa [← hRdef]

/-! ## 2. Upper spike windows produce block certificates at expanded height -/

/-- Abstract logarithmic upper recurrence for continued-fraction denominators.
For actual continuants one expects this with `C = log 2`:

  log q_{j+1} ≤ log q_j + log a_{j+1} + log 2.
-/
def CFLogStepUpperWithError (X v : ℕ → ℝ) (C : ℝ) : Prop :=
  ∀ j : ℕ, X (j + 1) ≤ X j + v j + C

/-- An upper spike window gives the local `BlockCanSpikeAt` certificate at the
expanded height, provided the fixed error is dominated by the positive margin.

This is the exact analytic place where the generic proof loses `2X_j`. -/
theorem BlockCanSpikeAt_of_UpperSpikeWindow_with_error
    {X v : ℕ → ℝ} {κ ν β x C : ℝ} {j m : ℕ}
    (hκ : 0 < κ) (hν : 0 < ν) (hβ : 0 < β)
    (_hx0 : 0 ≤ x) (hx1 : x < 1)
    (hstep : CFLogStepUpperWithError X v C)
    (hwin : UpperSpikeWindow X κ ν β j m)
    (herror : C + Real.log 2 ≤ badToVisibleMargin κ ν β x * (m : ℝ)) :
    BlockCanSpikeAt (X j) (v j)
      (badToVisibleHeightLog κ ν x m) x := by
  rcases hwin with ⟨hleft, hright⟩
  constructor
  · -- `X_j ≤ κm/ν = (1-x) * h`.
    have hden : 0 < 1 - x := by linarith
    have hX : X j ≤ κ * (m : ℝ) / ν := by
      have hmul : (ν * X j / κ) * κ ≤ (m : ℝ) * κ :=
        mul_le_mul_of_nonneg_right hleft (le_of_lt hκ)
      have hνX : ν * X j ≤ κ * (m : ℝ) := by
        field_simp [hκ.ne'] at hmul
        linarith
      exact (le_div_iff₀ hν).mpr (by simpa [mul_comm, mul_left_comm, mul_assoc] using hνX)
    have hheight :
        (1 - x) * badToVisibleHeightLog κ ν x m = κ * (m : ℝ) / ν := by
      rw [badToVisibleHeightLog]
      field_simp [hden.ne']
    exact hX.trans_eq hheight.symm
  · -- Use the upper endpoint and `X_{j+1} ≤ X_j + v_j + C`.
    have hX : X j ≤ κ * (m : ℝ) / ν := by
      have hmul : (ν * X j / κ) * κ ≤ (m : ℝ) * κ :=
        mul_le_mul_of_nonneg_right hleft (le_of_lt hκ)
      have hνX : ν * X j ≤ κ * (m : ℝ) := by
        field_simp [hκ.ne'] at hmul
        linarith
      exact (le_div_iff₀ hν).mpr (by simpa [mul_comm, mul_left_comm, mul_assoc] using hνX)
    have hupper : β * (m : ℝ) ≤ X j + X (j + 1) + Real.log 2 := by
      have hmul : β * (m : ℝ) ≤ β * ((X j + X (j + 1) + Real.log 2) / β) :=
        mul_le_mul_of_nonneg_left hright (le_of_lt hβ)
      field_simp [hβ.ne'] at hmul ⊢
      linarith
    have hstepj := hstep j
    have hv_lower :
        (β - 2 * κ / ν) * (m : ℝ) - (C + Real.log 2) ≤ v j := by
      have hsum :
          X j + X (j + 1) + Real.log 2 ≤
            X j + (X j + v j + C) + Real.log 2 := by
        nlinarith
      have htwice :
          X j + X j ≤ 2 * (κ * (m : ℝ) / ν) := by
        nlinarith
      have hbound :
          β * (m : ℝ) ≤
            2 * (κ * (m : ℝ) / ν) + v j + C + Real.log 2 := by
        nlinarith
      have hnorm :
          2 * (κ * (m : ℝ) / ν) = 2 * κ / ν * (m : ℝ) := by
        ring
      nlinarith
    have hneed :
        x * badToVisibleHeightLog κ ν x m ≤
          (β - 2 * κ / ν) * (m : ℝ) - (C + Real.log 2) := by
      have hden : 0 < 1 - x := by linarith
      have hheight :
          x * badToVisibleHeightLog κ ν x m =
            x * κ * (m : ℝ) / (ν * (1 - x)) := by
        rw [badToVisibleHeightLog]
        field_simp [hden.ne', hν.ne']
      have hmargin :
          badToVisibleMargin κ ν β x * (m : ℝ) =
            (β - 2 * κ / ν) * (m : ℝ) -
              x * κ * (m : ℝ) / (ν * (1 - x)) := by
        rw [badToVisibleMargin]
        field_simp [hden.ne', hν.ne']
      rw [hmargin] at herror
      rw [hheight]
      linarith
    exact hneed.trans hv_lower

/-- Eventual version: if bad truncations are eventually covered by upper spike
windows and the margin is positive, then they eventually give block certificates
at the expanded logarithmic height. -/
theorem eventually_BlockCanSpikeAt_of_eventual_UpperSpikeShadow
    {Bad : ℕ → Prop} {X v : ℕ → ℝ} {κ ν β x C : ℝ}
    (hκ : 0 < κ) (hν : 0 < ν) (hβ : 0 < β)
    (hx0 : 0 ≤ x) (hx1 : x < 1)
    (hstep : CFLogStepUpperWithError X v C)
    (hmargin : 0 < badToVisibleMargin κ ν β x)
    (hcover : ∀ᶠ m : ℕ in atTop,
      Bad m → UpperSpikeShadow X κ ν β m) :
    ∀ᶠ m : ℕ in atTop,
      Bad m →
        ∃ j : ℕ,
          BlockCanSpikeAt (X j) (v j)
            (badToVisibleHeightLog κ ν x m) x := by
  have herr : ∀ᶠ m : ℕ in atTop,
      C + Real.log 2 ≤ badToVisibleMargin κ ν β x * (m : ℝ) := by
    -- Positive linear functions eventually dominate any fixed constant.
    exact eventually_const_le_pos_mul_natCast
      (A := C + Real.log 2) (δ := badToVisibleMargin κ ν β x) hmargin
  filter_upwards [hcover, herr] with m hmcover hmerr hbad
  rcases hmcover hbad with ⟨j, hj⟩
  exact ⟨j, BlockCanSpikeAt_of_UpperSpikeWindow_with_error
    hκ hν hβ hx0 hx1 hstep hj hmerr⟩

/-! ## 3. From block certificates to actual visible spikes, with exponent slack -/

/-- The remaining canonical-block realization lemma.

If a block satisfies `BlockCanSpikeAt u_j v_j h z`, then for every smaller
exponent `x < z`, the actual visible canonical block maximum at height
`ceil(exp h)` is eventually larger than `H^x`.

This is where constants from parity selection, the shift by `q_{j-1}`, and the
integer ceiling are absorbed by the strict exponent slack `x < z`. -/
def BlockCertificateRealizesVisibleSpikeWithSlack
    (a : ℕ → ℕ) (H : ℕ → ℕ) (Hlog : ℕ → ℝ)
    (z x : ℝ) : Prop :=
  ∀ᶠ m : ℕ in atTop,
    (∃ j : ℕ,
      BlockCanSpikeAt (continuantQlog a j) (partialQuotientLog a j)
        (Hlog m) z) →
      VisibleBlockSpikeShell
        (natShellHeightReal H)
        (visibleCanonicalBlockMaxAtNatHeight a H)
        x m

/-- Bad truncations force actual visible shell spikes once three ingredients are
available:

1. upper spike shadow cover for bad truncations;
2. the generic window-to-block-certificate algebra above;
3. the canonical realization lemma with exponent slack.
-/
theorem eventually_BadRamanujanTruncation_to_visibleSpikeShell
    {a : ℕ → ℕ} {H : ℕ → ℕ}
    {κ ν β z x C : ℝ}
    (hκ : 0 < κ) (hν : 0 < ν) (hβ : 0 < β)
    (hz0 : 0 ≤ z) (hz1 : z < 1)
    (_hxz : x < z)
    (hstep : CFLogStepUpperWithError (continuantQlog a) (partialQuotientLog a) C)
    (hmargin : 0 < badToVisibleMargin κ ν β z)
    (hcover : ∀ᶠ m : ℕ in atTop,
      BadRamanujanTruncation ν m →
        UpperSpikeShadow (continuantQlog a) κ ν β m)
    (hrealize : BlockCertificateRealizesVisibleSpikeWithSlack
      a H (fun m => badToVisibleHeightLog κ ν z m) z x) :
    ∀ᶠ m : ℕ in atTop,
      BadRamanujanTruncation ν m →
        VisibleBlockSpikeShell
          (natShellHeightReal H)
          (visibleCanonicalBlockMaxAtNatHeight a H)
          x m := by
  have hcert := eventually_BlockCanSpikeAt_of_eventual_UpperSpikeShadow
    (Bad := BadRamanujanTruncation ν)
    (X := continuantQlog a) (v := partialQuotientLog a)
    (κ := κ) (ν := ν) (β := β) (x := z) (C := C)
    hκ hν hβ hz0 hz1 hstep hmargin hcover
  filter_upwards [hcert, hrealize] with m hmcert hmreal hbad
  exact hmreal (hmcert hbad)

/-! ## 4. The no-bootstrap barrier for the generic implication -/

/-- The idealized bad-to-visible exponent with `β = κ`. -/
def idealBadToVisibleExponent (ν : ℝ) : ℝ :=
  (ν - 2) / (ν - 1)

/-- If `β ≤ κ`, the rigorous generic exponent is at most the ideal one. -/
theorem badToVisibleExponent_le_ideal
    {κ ν β : ℝ}
    (hκ : 0 < κ) (hν : 2 < ν)
    (_hβpos : 0 < β) (hβle : β ≤ κ)
    (hR : 2 < ν * β / κ) :
    badToVisibleExponent κ ν β ≤ idealBadToVisibleExponent ν := by
  set R : ℝ := ν * β / κ with hRdef
  have hRgt2 : 2 < R := by
    rw [hRdef]
    exact hR
  have hRden : 0 < R - 1 := by linarith
  have hνden : 0 < ν - 1 := by linarith
  have hRleν : R ≤ ν := by
    rw [hRdef]
    rw [div_le_iff₀ hκ]
    have hmul : ν * β ≤ ν * κ :=
      mul_le_mul_of_nonneg_left hβle (by linarith)
    nlinarith
  have hmain : (R - 2) / (R - 1) ≤ (ν - 2) / (ν - 1) := by
    rw [div_le_div_iff₀ hRden hνden]
    nlinarith
  rw [badToVisibleExponent, idealBadToVisibleExponent]
  rwa [← hRdef]

/-- The exact gap between the contraction exponent and the ideal generic
bad-to-visible exponent.  With `τ=M-2` and `ν≤M`, this gap is nonnegative and is
zero only in the limiting case `ν=M`.

Algebraically, for `n=ν-2` and `t=M-2`,

  x_contr - x_ideal = (t-n)(3t+2) /
    ((n+1)(n t^2 + 4t^2 + 5t + 2)).
-/
theorem idealBadToVisibleExponent_le_contractionExponent
    {ν M : ℝ}
    (hν : 2 < ν) (hνM : ν ≤ M) :
    idealBadToVisibleExponent ν ≤
      shellSpikeContractionExponent (M - 2) ν M := by
  have hM : 0 < M := by linarith
  have htau : 0 < M - 2 := by linarith
  have hleftden : 0 < ν - 1 := by linarith
  have hrightden :
      0 < 2 * (M - 2) + 1 + (ν / M) * (M - 2) ^ 2 := by
    have hnuMpos : 0 < ν / M := div_pos (by linarith) hM
    have htau2_nonneg : 0 ≤ (M - 2) ^ 2 := sq_nonneg (M - 2)
    nlinarith [mul_nonneg (le_of_lt hnuMpos) htau2_nonneg]
  rw [idealBadToVisibleExponent, shellSpikeContractionExponent,
    shellSpikeExponentForGain, shellSpikeContractionGoodDensity]
  rw [div_le_div_iff₀ hleftden hrightden]
  field_simp [hM.ne']
  nlinarith [hνM]

/-- Therefore the generic bad-to-visible implication cannot by itself cross the
contraction threshold.  This theorem is the formal no-bootstrap diagnosis. -/
theorem badToVisibleExponent_le_contractionExponent
    {κ ν β M : ℝ}
    (hκ : 0 < κ) (hν : 2 < ν) (hνM : ν ≤ M)
    (hβpos : 0 < β) (hβle : β ≤ κ)
    (hR : 2 < ν * β / κ) :
    badToVisibleExponent κ ν β ≤
      shellSpikeContractionExponent (M - 2) ν M := by
  exact (badToVisibleExponent_le_ideal hκ hν hβpos hβle hR).trans
    (idealBadToVisibleExponent_le_contractionExponent hν hνM)

/-! ## 5. What new information would break the barrier? -/

/-- A strengthened bad-to-visible input with effective loss `L < 2`. -/
def EffectiveLossBadToVisibleInput
    (κ ν β L : ℝ) : Prop :=
  L < 2 ∧ 0 < lossToVisibleExponent κ ν β L

/-- If the effective loss is strictly less than `2`, the available visible-spike
exponent is strictly larger than the generic `L=2` exponent. -/
theorem lossToVisibleExponent_gt_badToVisibleExponent_of_loss_lt_two
    {κ ν β L : ℝ}
    (hκ : 0 < κ) (hν : 0 < ν)
    (hR : 2 < ν * β / κ)
    (hL : L < 2) :
    badToVisibleExponent κ ν β < lossToVisibleExponent κ ν β L := by
  have _hκne : κ ≠ 0 := hκ.ne'
  have _hνne : ν ≠ 0 := hν.ne'
  set R : ℝ := ν * β / κ with hRdef
  have hRgt2 : 2 < R := by
    rw [hRdef]
    exact hR
  have hden2 : 0 < R - 1 := by linarith
  have hdenL : 0 < R - L + 1 := by linarith
  have hmain :
      (R - 2) / (R - 1) < (R - L) / (R - L + 1) := by
    rw [div_lt_div_iff₀ hden2 hdenL]
    nlinarith
  rw [badToVisibleExponent, lossToVisibleExponent]
  rwa [← hRdef]

/-- Project-facing description of the missing arithmetic gain.  Any proof of
this predicate, with `L < 2`, is the kind of new information needed to obtain a
strict measure improvement from the shell-spike contraction wrappers. -/
def BadTruncationEffectiveLossGain
    (κ ν β L : ℝ) (X v : ℕ → ℝ) : Prop :=
  ∀ᶠ m : ℕ in atTop,
    BadRamanujanTruncation ν m →
      ∃ j : ℕ,
        UpperSpikeWindow X κ ν β j m ∧
        -- The effective lower bound on `v_j` has loss `L * κm/ν` instead of
        -- the generic `2 * κm/ν`.
        β * (m : ℝ) - L * κ * (m : ℝ) / ν ≤ v j


/-!
# Effective-loss improvement diagnostics

This file answers the scalar question behind the bad-truncation-to-visible-spike
bridge: how much improvement over the generic effective loss `L = 2` is needed
to beat the shell-spike contraction exponent?

The key quantity is the critical loss

```text
νβ/κ - x/(1-x),
```

where `x` is the shell contraction exponent.  Any effective loss below this
threshold gives a visible-spike exponent above the contraction threshold.
-/

open Filter
open scoped Topology


/-! ## Merged from IrrationalityAr/RamanujanEffectiveLossImprovement.lean -/

/-! ## Scalar diagnostics -/

/-- Critical loss: losses smaller than this beat the contraction exponent. -/
def criticalEffectiveLoss (kappa nu beta tau M : ℝ) : ℝ :=
  let x := shellSpikeContractionExponent tau nu M
  nu * beta / kappa - x / (1 - x)

/-- Required gain over the generic loss `2`. -/
def requiredEffectiveGain (kappa nu beta tau M : ℝ) : ℝ :=
  2 - criticalEffectiveLoss kappa nu beta tau M

/-- Ideal critical loss when `beta = kappa`. -/
def idealCriticalEffectiveLoss (nu tau M : ℝ) : ℝ :=
  criticalEffectiveLoss 1 nu 1 tau M

/-- Ideal required gain when `beta = kappa`. -/
def idealRequiredEffectiveGain (nu tau M : ℝ) : ℝ :=
  requiredEffectiveGain 1 nu 1 tau M

/-- Endpoint avoidance by a factor `sigma` means bad hits occur with
`X_j <= (1 - sigma) * kappa*m/nu` along the chosen upper-spike witness.
This turns the scalar loss `2` into `2*(1-sigma)` at the height scale. -/
def EndpointAvoidanceFactor
    (Bad : ℕ → Prop) (X : ℕ → ℝ) (kappa nu sigma : ℝ) : Prop :=
  ∀ᶠ m : ℕ in atTop,
    Bad m → ∃ j : ℕ, X j ≤ (1 - sigma) * (kappa * (m : ℝ) / nu)

/-- A refined upper-window inequality with loss `L`: this is the exact
arithmetic input needed in place of the generic `2X_j` loss. -/
def RefinedBadWindowLoss
    (Bad : ℕ → Prop) (X v : ℕ → ℝ) (beta L : ℝ) : Prop :=
  ∀ᶠ m : ℕ in atTop,
    Bad m → ∃ j : ℕ, beta * (m : ℝ) ≤ L * X j + v j

/-! ## Beating the contraction threshold -/

/-- If `L` is smaller than the critical effective loss, the visible-spike
exponent beats the contraction exponent. -/
theorem lossToVisibleExponent_gt_contraction_of_loss_lt_critical
    {kappa nu beta tau M L : ℝ}
    (_hkappa : 0 < kappa)
    (hxlt : shellSpikeContractionExponent tau nu M < 1)
    (hden : 0 < nu * beta / kappa - L + 1)
    (hL : L < criticalEffectiveLoss kappa nu beta tau M) :
    shellSpikeContractionExponent tau nu M
      < lossToVisibleExponent kappa nu beta L := by
  set x : ℝ := shellSpikeContractionExponent tau nu M with hxdef
  set A : ℝ := nu * beta / kappa with hAdef
  have hxlt' : x < 1 := by simpa [hxdef] using hxlt
  have hxden : 0 < 1 - x := by linarith
  have hden' : 0 < A - L + 1 := by simpa [hAdef] using hden
  have hL' : L < A - x / (1 - x) := by
    simpa [criticalEffectiveLoss, hxdef, hAdef] using hL
  have hfrac : x / (1 - x) < A - L := by linarith
  have hmul : x < (A - L) * (1 - x) := by
    exact (div_lt_iff₀ hxden).mp hfrac
  have hcross : x * (A - L + 1) < A - L := by
    nlinarith
  rw [lossToVisibleExponent]
  rw [← hAdef]
  exact (lt_div_iff₀ hden').mpr hcross

/-- The ratio `x/(1-x)` for the ideal contraction exponent, in the natural
range where the inverse-gain denominator is positive. -/
private theorem ideal_contraction_ratio_eq
    {M nu : ℝ}
    (hM : 2 < M) (hnu : 0 ≤ nu) :
    shellSpikeContractionExponent (M - 2) nu M /
        (1 - shellSpikeContractionExponent (M - 2) nu M)
      = ((M - 2) + (nu / M) * (M - 2) ^ 2) / (M - 1) := by
  have hM1 : M ≠ 1 := by nlinarith
  have hDpos : 0 < 2 * (M - 2) + 1 + (nu / M) * (M - 2) ^ 2 := by
    have hbase : 0 < 2 * (M - 2) + 1 := by nlinarith
    have hMpos : 0 < M := by nlinarith
    have htail : 0 ≤ (nu / M) * (M - 2) ^ 2 := by
      exact mul_nonneg (div_nonneg hnu (le_of_lt hMpos)) (sq_nonneg (M - 2))
    nlinarith
  have hD : 2 * (M - 2) + 1 + (nu / M) * (M - 2) ^ 2 ≠ 0 :=
    ne_of_gt hDpos
  set N : ℝ := (M - 2) + (nu / M) * (M - 2) ^ 2 with hN
  set D : ℝ := 2 * (M - 2) + 1 + (nu / M) * (M - 2) ^ 2 with hDdef
  have hDne : D ≠ 0 := by simpa [hDdef] using hD
  have hDsub : D - N = M - 1 := by
    rw [hDdef, hN]
    ring
  have hx : shellSpikeContractionExponent (M - 2) nu M = N / D := by
    rw [shellSpikeContractionExponent, shellSpikeExponentForGain,
      shellSpikeContractionGoodDensity, hN, hDdef]
  rw [hx]
  have hone : 1 - N / D = (D - N) / D := by
    field_simp [hDne]
  rw [hone, hDsub]
  field_simp [hDne, hM1]

/-- Ideal simplification when `tau = M - 2` and `beta = kappa`:
the required gain equals `(M-nu)*(3*M-4)/(M*(M-1))`.

The assumptions `2 < M` and `0 ≤ nu` are the natural contraction range and make
the inverse-gain denominator positive. -/
theorem idealRequiredGain_eq
    {M nu : ℝ}
    (hM : 2 < M) (hnu : 0 ≤ nu) :
    idealRequiredEffectiveGain nu (M - 2) M
      = (M - nu) * (3 * M - 4) / (M * (M - 1)) := by
  have hM0 : M ≠ 0 := by nlinarith
  have hM1 : M ≠ 1 := by nlinarith
  have hfrac := ideal_contraction_ratio_eq (M := M) (nu := nu) hM hnu
  rw [idealRequiredEffectiveGain, requiredEffectiveGain, criticalEffectiveLoss]
  rw [hfrac]
  field_simp [hM0, hM1]
  ring

/-- If endpoint avoidance gives gain `Delta`, i.e. effective loss `2-Delta`,
and that gain exceeds the required gain, then the contraction exponent is
beaten. -/
theorem endpointAvoidanceGain_beats_contraction
    {kappa nu beta tau M Delta : ℝ}
    (hkappa : 0 < kappa)
    (hxlt : shellSpikeContractionExponent tau nu M < 1)
    (hden : 0 < nu * beta / kappa - (2 - Delta) + 1)
    (hgain : requiredEffectiveGain kappa nu beta tau M < Delta) :
    shellSpikeContractionExponent tau nu M
      < lossToVisibleExponent kappa nu beta (2 - Delta) := by
  apply lossToVisibleExponent_gt_contraction_of_loss_lt_critical
    (kappa := kappa) (nu := nu) (beta := beta)
    (tau := tau) (M := M) (L := 2 - Delta)
    hkappa hxlt hden
  unfold requiredEffectiveGain at hgain
  linarith

/-- Strategic target: existence of any positive endpoint-avoidance gain beyond
the required gain. -/
def EffectiveLossImprovementTarget
    (kappa nu beta tau M : ℝ) : Prop :=
  ∃ Delta : ℝ,
    requiredEffectiveGain kappa nu beta tau M < Delta ∧
    Delta < 2


/-!
# Big ordered-shadow shell-spike wrapper

This module collects the ordered-shadow density branch into one proof-facing
certificate.  It does not introduce new axioms or hide any of the remaining
mathematical inputs.  Instead it packages the already-built bridge:

```text
ordered finite shadow budget
  -> predicted shadow density
  -> visible-spike density deficit
  -> Bauer/Ramanujan measure-improvement wrapper.
```

The project does not currently have a separate
`RamanujanOrderedShadowDensityBridge` module.  The small compatibility layer
below exposes the planned names in terms of the already-integrated real-interval
budget and integer-counting APIs.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanOrderedShadowBig.lean -/

/-! ## 1. Ordered-shadow density input -/

/-- A bundled ordered-shadow density input.

It records the real interval model, the representation of abstract shadow
shells by that model, the active-index cover needed for finite union counting,
the real length budget, active-count sublinearity, and a sublinear error term.
-/
structure OrderedShadowDensityInput
    (Hlog u v : ℕ → ℝ) (tau x : ℝ) where
  S : ℕ → ℝ
  E : ℕ → ℝ
  Err : ℕ → ℝ
  represent : ∀ m : ℕ,
    spikeShadowShellUnion Hlog u v x m → NatInRealIntervalUnion S E m
  activeCover : ActiveShadowIndicesCoverUnion S E
  lengthBudget : RealShadowLengthBudget S E
    (1 - shellSpikeGoodDensityGain tau x) Err
  active : ActiveShadowCountSublinear S
  error : EventuallySublinearCountError Err

/-- The bundled ordered-shadow input gives the predicted shadow density. -/
theorem predictedSpikeShadowDensity_of_orderedInput
    {Hlog u v : ℕ → ℝ} {tau x : ℝ}
    (I : OrderedShadowDensityInput Hlog u v tau x) :
    PredictedSpikeShadowDensity Hlog u v tau x := by
  exact predictedSpikeShadowDensity_of_realIntervalBudget
    I.represent I.activeCover I.lengthBudget I.active I.error

/-- The left endpoints of a normalized shadow schedule. -/
def normalizedShadowLeft (S : ℕ → ℝ) : ℕ → ℝ := S

/-- The right endpoints of a normalized shadow schedule. -/
noncomputable def normalizedShadowRight
    (x : ℝ) (S r : ℕ → ℝ) : ℕ → ℝ :=
  normalizedShadowEndAt x S r

/-- A normalized ordered-shadow length budget in the form needed by the finite
integer-counting bridge.  The first component is the active-cover bookkeeping
for sparse interval schedules; the second component is the real length budget.
-/
def NormalizedOrderedShadowLengthBudget
    (tau x : ℝ) (S r err : ℕ → ℝ) : Prop :=
  ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r) ∧
    RealShadowLengthBudget
      (normalizedShadowLeft S) (normalizedShadowRight x S r)
      (1 - shellSpikeGoodDensityGain tau x) err

/-- Build an ordered-shadow density input from a practical normalized budget. -/
def orderedInput_of_normalizedBudget
    {Hlog u v : ℕ → ℝ} {tau x : ℝ}
    {S r err : ℕ → ℝ}
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u v x m →
        NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) m)
    (hBudget : NormalizedOrderedShadowLengthBudget tau x S r err)
    (hActive : ActiveShadowCountSublinear (normalizedShadowLeft S))
    (hErr : EventuallySublinearCountError err) :
    OrderedShadowDensityInput Hlog u v tau x where
  S := normalizedShadowLeft S
  E := normalizedShadowRight x S r
  Err := err
  represent := hRepresent
  activeCover := hBudget.1
  lengthBudget := hBudget.2
  active := hActive
  error := hErr

/-- Build an ordered-shadow density input from the ordered-schedule API already
present in `RamanujanShellSpikeOrderedSchedule`. -/
def orderedInput_of_orderedSchedule
    {Hlog u v : ℕ → ℝ} {tau x : ℝ}
    (S : OrderedShadowSchedule)
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u v x m →
        NatInRealIntervalUnion S.left S.right m)
    (hLen : OrderedRealLengthLogBudget S
      (1 - shellSpikeGoodDensityGain tau x))
    (hGeom : EventuallyGeometricStarts S) :
    OrderedShadowDensityInput Hlog u v tau x where
  S := S.left
  E := S.right
  Err := fun M : ℕ => Real.log ((M : ℝ) + 2)
  represent := hRepresent
  activeCover := S.activeCoverUnion
  lengthBudget := hLen.1
  active := activeShadowCountSublinear_of_eventuallyGeometricStarts S hGeom
  error := hLen.2

/-! ## 2. One bundled ordered-shadow certificate -/

/-- A full ordered-shadow certificate for visible spike shells.

`ordered` proves the predicted density of the abstract spike-shadow union.
`actualCover` proves that the actual visible spike shells are contained in that
shadow union.
