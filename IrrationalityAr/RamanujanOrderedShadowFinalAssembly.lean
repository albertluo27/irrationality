  exact ⟨clippedLayerCakeEffectiveStepData_of_quadraticActiveMassCoreData
    (B := B) hB D⟩

/-- Final wrapper: active-mass core data for every strict cap above `4` implies
`mu(1/pi) ≤ 4` for every project-level irrationality-measure value. -/
theorem oneOverPi_irratMeasure_le_four_of_quadraticActiveMassCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticActiveMassCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ mu : ℝ,
      HasIrrationalityMeasure (1 / Real.pi) mu → mu ≤ 4 := by
