/-- The previous all-cap cofinal-tail final target implies the weaker
sequence-only final target. -/
theorem actualQlogCofinalRelaxedSeqFinalTarget_of_actualQlogCofinalTailFinalTarget
    (h :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalTailFinalTarget) :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalTarget := by
