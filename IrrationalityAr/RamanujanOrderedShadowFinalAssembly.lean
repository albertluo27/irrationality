/-!
# Post-combined field attack

This layer pushes the post-combined field targets down to raw estimates.  The
two hard arithmetic statements are kept as target predicates:

* a raw logarithmic bound for below-left active endpoint indices;
* a raw live-boundary budget witness with strict slack.

All surrounding declarations are proved adapters into the already-integrated
post-combined source and field targets.
-/

namespace FieldAttack

/-! ## Raw below-left logarithmic count obligation -/

/-- Raw logarithmic below-left count bound.

This removes the record wrapper `EndpointRatioActiveBelowLeftLogCountData` and
asks directly for an explicit eventual `O(log M)` estimate. -/
def EndpointBelowLeftRawLogBoundTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelow B →
        ∀ S : EndpointPrefixLogCountSkeleton B hB,
          ∃ C : ℝ,
            0 ≤ C ∧
              ∀ᶠ M : ℕ in atTop,
                (EndpointRatioActiveBelowLeftCount
                    (canonicalNu B hB) S.X M : ℝ)
                  ≤ C * Real.log ((M : ℝ) + 2)

/-- Project-facing name for the entropy/reciprocal proof of the raw
below-left logarithmic count estimate. -/
def EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget : Prop :=
  EndpointBelowLeftRawLogBoundTarget

/-- Pack a raw logarithmic below-left count bound into the existing V2 endpoint
log-count target. -/
theorem endpointBelowLeftLogCountTarget_of_rawLogBound
    (hRaw : EndpointBelowLeftRawLogBoundTarget) :
    EndpointBelowLeftLogCountFromEntropyReciprocalTarget := by
  intro B hB hBound S
  rcases hRaw B hB hBound S with ⟨C, hCnonneg, hCbound⟩
  exact ⟨{
    C := C
    C_nonneg := hCnonneg
    countBound := hCbound
  }⟩

/-- Endpoint field target from deterministic endpoint skeleton plus a raw
entropy/reciprocal logarithmic count estimate. -/
theorem endpointEntropyReciprocalPrefixTarget_of_skeleton_and_rawLogBound
    (hSkel : EndpointPrefixSkeletonTarget)
    (hRaw : EndpointBelowLeftRawLogBoundTarget) :
    EndpointEntropyReciprocalPrefixTarget := by
  exact endpointEntropyReciprocalPrefixTarget_of_skeleton_and_logCount
    hSkel
    (endpointBelowLeftLogCountTarget_of_rawLogBound hRaw)

/-- Endpoint route assembled from current deterministic geometry and the raw
log-count target. -/
theorem endpointEntropyReciprocalPrefixTarget_from_current_skeleton_and_rawLogBound
    (hSkel : EndpointPrefixSkeletonTarget)
    (hRaw : EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget) :
    EndpointEntropyReciprocalPrefixTarget := by
  exact endpointEntropyReciprocalPrefixTarget_of_skeleton_and_rawLogBound
    hSkel hRaw

/-! ## Raw small-live budget obligation -/

/-- Raw small-live budget target.

This is the concrete witness form of
`EntropyReciprocalSmallLiveBudgetBridgeTarget`: produce a nonnegative
`liveLoss`, prove it is below the scalar slack, and prove the endpoint
count-budget split. -/
def SmallLiveRawBudgetTarget : Prop :=
  ∀ B : ℝ,
    ∀ _hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData
                B baseShift,
              ∀ s : ℕ,
                ∃ liveLoss : ℝ,
                  0 ≤ liveLoss ∧
                  liveLoss < clippedLayerCakeQuadraticEffectiveSlack B ∧
                  ClippedEndpointCountBudgetSplitWithLiveLoss
                    (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
                    (tailShiftSeq G.H s) (tailShiftSeq G.V s)
                    (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
                    (clippedLayerCakeQuadraticEffectiveDelta B) liveLoss

/-- Project-facing name for the entropy/reciprocal proof of the raw small-live
budget estimate. -/
def SmallLiveRawBudgetFromEntropyReciprocalTarget : Prop :=
  SmallLiveRawBudgetTarget

/-- Pack a raw small-live budget witness into the V2 budget certificate target. -/
theorem entropyReciprocalSmallLiveBudgetBridgeTarget_of_rawBudget
    (hRaw : SmallLiveRawBudgetTarget) :
    EntropyReciprocalSmallLiveBudgetBridgeTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hRaw B hB hBound baseShift hCap G s with
    ⟨liveLoss, hnonneg, hlt, hsplit⟩
  exact ⟨{
    liveLoss := liveLoss
    liveLoss_nonneg := hnonneg
    liveLoss_lt_slack := hlt
    budgetSplit := hsplit
  }⟩

/-- Small-live bridge assembled from the raw budget target. -/
theorem entropyReciprocalSmallLiveBudgetBridgeTarget_from_raw
    (hRaw : SmallLiveRawBudgetFromEntropyReciprocalTarget) :
    EntropyReciprocalSmallLiveBudgetBridgeTarget := by
  exact entropyReciprocalSmallLiveBudgetBridgeTarget_of_rawBudget hRaw

/-! ## Recommended route assembled from raw obligations -/

/-- Live-loss route assembled from deterministic live-loss skeleton and the
budget target. -/
theorem liveLossStrictSlackConcreteTarget_from_live_skeleton_and_budget
    (hStep : LiveLossStepSkeletonTarget)
    (hBudget : LiveLossBudgetFromEntropyReciprocalTarget) :
    LiveLossStrictSlackConcreteTarget := by
  exact liveLossStrictSlackConcreteTarget_of_skeleton_and_budget hStep hBudget

/-- Source-level recommended target from the minimized raw obligations. -/
theorem recommendedPostCombinedSourceTarget_from_rawEntropyReciprocalAttack
    (hSkel : EndpointPrefixSkeletonTarget)
    (hStep : LiveLossStepSkeletonTarget)
    (hBudget : LiveLossBudgetFromEntropyReciprocalTarget)
    (hRawLog : EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget)
    (hRawBudget : SmallLiveRawBudgetFromEntropyReciprocalTarget) :
    RecommendedPostCombinedSourceTarget := by
  exact {
    endpoint :=
      endpointEntropyReciprocalPrefixTarget_from_current_skeleton_and_rawLogBound
        hSkel hRawLog
    smallLiveBudget :=
      entropyReciprocalSmallLiveBudgetBridgeTarget_from_raw hRawBudget
    liveLoss :=
      liveLossStrictSlackConcreteTarget_from_live_skeleton_and_budget
        hStep hBudget
  }

/-- Direct adapter to the integrated recommended field target. -/
theorem recommendedPostCombinedFieldTargets_from_rawEntropyReciprocalAttack
    (hSkel : EndpointPrefixSkeletonTarget)
    (hStep : LiveLossStepSkeletonTarget)
    (hBudget : LiveLossBudgetFromEntropyReciprocalTarget)
    (hRawLog : EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget)
    (hRawBudget : SmallLiveRawBudgetFromEntropyReciprocalTarget) :
    RecommendedPostCombinedFieldTargets := by
  exact ⟨
    ⟨hSkel, endpointBelowLeftLogCountTarget_of_rawLogBound hRawLog⟩,
    ⟨entropyReciprocalSmallLiveBudgetBridgeTarget_from_raw hRawBudget,
      ⟨hStep, hBudget⟩⟩
  ⟩

/-!
# Raw entropy/reciprocal attack decomposition

This layer pushes the two raw field-attack predicates one step lower.  The
below-left raw logarithmic count is now reduced to the already-proved generic
geometric counting theorem.  The small-live target is split into closed
localization plus the genuine live-boundary density saving target.
-/

namespace RawEntropyReciprocal

/-! ## Generic geometric logarithmic count target -/

/-- Generic logarithmic counting theorem for below-left ratio-active indices.

This is the pointwise statement that positivity and monotonicity of `X`, plus
`nu > 2`, force below-left ratio-active indices to be logarithmically many in
the shell cutoff. -/
def EndpointRatioActiveBelowLeftGeometricCountTarget : Prop :=
  ∀ {nu : ℝ} {X : ℕ → ℝ},
    2 < nu →
      (∀ j : ℕ, 0 < X j) →
        Monotone X →
          ∃ C : ℝ,
            0 ≤ C ∧
              ∀ᶠ M : ℕ in atTop,
                (EndpointRatioActiveBelowLeftCount nu X M : ℝ)
                  ≤ C * Real.log ((M : ℝ) + 2)

/-- The project-specific endpoint raw target follows from the generic geometric
counting theorem, because the endpoint skeleton already contains positivity and
monotonicity of `X`, and the canonical scalar datum contains `nu > 2`. -/
theorem endpointBelowLeftRawLogBoundFromEntropyReciprocalTarget_of_geometricCount
    (hGeom : EndpointRatioActiveBelowLeftGeometricCountTarget) :
    EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget := by
  intro B hB hBound S
  exact hGeom
    (nu := canonicalNu B hB)
    (X := S.X)
    (clippedCanonicalStrictSlackScalarData B hB).nu_gt_two
    S.X_pos S.X_mono

/-- The generic below-left geometric count theorem is already closed by the
global active-count closure. -/
theorem endpointRatioActiveBelowLeftGeometricCountTarget_from_growth :
    EndpointRatioActiveBelowLeftGeometricCountTarget := by
  intro nu X hnu hXpos hmono
  rcases IrrationalityAr.endpointRatioActiveBelowLeftGeometricCountTarget_proved
      (nu := nu) (X := X) hnu hXpos hmono with ⟨D⟩
  exact ⟨D.C, D.C_nonneg, D.countBound⟩

/-- Closed endpoint raw target using the generic geometric count theorem. -/
theorem endpointBelowLeftRawLogBoundFromEntropyReciprocalTarget_from_geometricGrowth :
    EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget := by
  exact endpointBelowLeftRawLogBoundFromEntropyReciprocalTarget_of_geometricCount
    endpointRatioActiveBelowLeftGeometricCountTarget_from_growth

/-! ## Small-live split expanded into primitive fields -/

/-- A primitive closed/live witness for one shifted endpoint geometry system.

This is the existential content of
`ClippedEndpointCountBudgetSplitWithLiveLoss`, with the live loss and the three
components named separately. -/
structure SmallLiveClosedLiveWitness
    (B : ℝ) (hB : 4 < B)
    (baseShift : ℕ)
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)
    (s : ℕ) : Type where
  Closed : ℕ → Prop
  Live : ℕ → Prop
  liveLoss : ℝ
  liveLoss_nonneg : 0 ≤ liveLoss
  liveLoss_lt_slack : liveLoss < clippedLayerCakeQuadraticEffectiveSlack B
  cover :
    NonVisibleBadClosedLiveCover
      (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (tailShiftSeq G.H s) (tailShiftSeq G.V s) Closed Live
  closedBudget :
    ClippedClosedEndpointCountBudget
      (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
      (clippedLayerCakeTrialNu B)
      (clippedLayerCakeQuadraticEffectiveDelta B) Closed
  liveDensity : LiveBoundaryDensityTarget Live liveLoss

/-- Primitive closed/live witness target. -/
def SmallLiveClosedLiveWitnessTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                Nonempty (SmallLiveClosedLiveWitness B hB baseShift G s)

/-- Pure adapter from a primitive closed/live witness to the raw small-live
budget target integrated in the field-attack layer. -/
theorem smallLiveRawBudgetFromEntropyReciprocalTarget_of_closedLiveWitness
    (hWitness : SmallLiveClosedLiveWitnessTarget) :
    SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hWitness B hB hBound baseShift hCap G s with ⟨W⟩
  refine ⟨W.liveLoss, W.liveLoss_nonneg, W.liveLoss_lt_slack, ?_⟩
  exact ⟨W.Closed, W.Live, W.cover, W.closedBudget, W.liveDensity⟩

/-- The closed/localization part of the small-live split.

This target asks for the closed/live predicates, their cover, and the closed
endpoint count budget, but not for a live-boundary saving. -/
def SmallLiveClosedLocalizationTarget : Prop :=
  ∀ B : ℝ,
    ∀ _hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                ∃ Closed Live : ℕ → Prop,
                  NonVisibleBadClosedLiveCover
                    (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
                    (tailShiftSeq G.H s) (tailShiftSeq G.V s) Closed Live ∧
                  ClippedClosedEndpointCountBudget
                    (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
                    (clippedLayerCakeTrialNu B)
                    (clippedLayerCakeQuadraticEffectiveDelta B) Closed

/-- The entropy/reciprocal saving target for the live boundary. -/
def SmallLiveBoundaryDensitySavingTarget : Prop :=
  ∀ B : ℝ,
    ∀ _hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                ∀ Closed Live : ℕ → Prop,
                  NonVisibleBadClosedLiveCover
                    (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
                    (tailShiftSeq G.H s) (tailShiftSeq G.V s) Closed Live →
                  ClippedClosedEndpointCountBudget
                    (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
                    (clippedLayerCakeTrialNu B)
                    (clippedLayerCakeQuadraticEffectiveDelta B) Closed →
                    ∃ liveLoss : ℝ,
                      0 ≤ liveLoss ∧
                      liveLoss < clippedLayerCakeQuadraticEffectiveSlack B ∧
                      LiveBoundaryDensityTarget Live liveLoss

/-- Pure assembly: closed localization plus live-boundary saving gives the
primitive closed/live witness target. -/
theorem smallLiveClosedLiveWitnessTarget_of_localization_and_saving
    (hClosed : SmallLiveClosedLocalizationTarget)
    (hSaving : SmallLiveBoundaryDensitySavingTarget) :
    SmallLiveClosedLiveWitnessTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hClosed B hB hBound baseShift hCap G s with
    ⟨Closed, Live, hcover, hclosedBudget⟩
  rcases hSaving B hB hBound baseShift hCap G s Closed Live hcover hclosedBudget with
    ⟨liveLoss, hlive_nonneg, hlive_lt, hliveDensity⟩
  exact ⟨{
    Closed := Closed
    Live := Live
    liveLoss := liveLoss
    liveLoss_nonneg := hlive_nonneg
    liveLoss_lt_slack := hlive_lt
    cover := hcover
    closedBudget := hclosedBudget
    liveDensity := hliveDensity
  }⟩

/-- Remaining primitive small-live attack target. -/
def SmallLivePrimitiveAttackTarget : Prop :=
  SmallLiveClosedLocalizationTarget ∧
    SmallLiveBoundaryDensitySavingTarget

/-- Pure adapter from the primitive small-live attack target to the raw
small-live budget target. -/
theorem smallLiveRawBudgetFromEntropyReciprocalTarget_of_primitiveAttack
    (h : SmallLivePrimitiveAttackTarget) :
    SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  rcases h with ⟨hClosed, hSaving⟩
  exact smallLiveRawBudgetFromEntropyReciprocalTarget_of_closedLiveWitness
    (smallLiveClosedLiveWitnessTarget_of_localization_and_saving hClosed hSaving)

/-! ## Recommended minimized attack package -/

/-- Recommended minimized attack target after splitting the endpoint raw log
count from the small-live primitive localization/saving split. -/
structure RawEntropyReciprocalRecommendedTarget : Prop where
  endpointGeometricCount : EndpointRatioActiveBelowLeftGeometricCountTarget
  smallLiveLocalization : SmallLiveClosedLocalizationTarget
  smallLiveSaving : SmallLiveBoundaryDensitySavingTarget

/-- Pure adapter from the minimized attack package to the two raw targets
already integrated in the field-attack layer. -/
theorem rawTargets_of_rawEntropyReciprocalRecommendedTarget
    (T : RawEntropyReciprocalRecommendedTarget) :
    EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget ∧
      SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  constructor
  · exact endpointBelowLeftRawLogBoundFromEntropyReciprocalTarget_of_geometricCount
      T.endpointGeometricCount
  · exact smallLiveRawBudgetFromEntropyReciprocalTarget_of_primitiveAttack
      ⟨T.smallLiveLocalization, T.smallLiveSaving⟩

/-!
## Small-live chosen split

The earlier primitive small-live target asks for a live-density saving for
every closed/live split satisfying the abstract cover and closed budget.  This
chosen-split layer records the safer target actually needed downstream: choose
one concrete endpoint-subwindow closed set and prove the live saving for the
corresponding live predicate.
-/

namespace SmallLiveChosenSplit

/-! ### Chosen endpoint-subwindow split -/

/-- Chosen small-live split for one shifted endpoint closure geometry system.

The closed predicate is fixed to be the explicit endpoint-subwindow union for
the chosen relevance relation.  The live predicate is the remaining terminal
boundary supplied by the endpoint localization. -/
structure SmallLiveChosenSubwindowWitness
    (B : ℝ) (hB : 4 < B)
    (baseShift : ℕ)
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)
    (s : ℕ) : Type where
  Relevant : ℕ → ℕ → Prop
  Live : ℕ → Prop
  liveLoss : ℝ
  liveLoss_nonneg : 0 ≤ liveLoss
  liveLoss_lt_slack : liveLoss < clippedLayerCakeQuadraticEffectiveSlack B
  offsetOrLive :
    ∀ m : ℕ,
      NonVisibleBadShell
          (clippedLayerCakeTrialNu B)
          (tailShiftSeq G.H s) (tailShiftSeq G.V s)
          (clippedLayerCakeCanonicalX B) m →
        EndpointExceptionalByOffset
          (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
          (tailShiftSeq (oneOverPiShiftedQlog baseShift) s) Relevant m ∨
        Live m
  subwindowCover :
    EndpointExceptionalSubwindowCover
      (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (tailShiftSeq (oneOverPiShiftedQlog baseShift) s) Relevant
  closedBudget :
    ClippedClosedEndpointCountBudget
      (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
      (clippedLayerCakeTrialNu B)
      (clippedLayerCakeQuadraticEffectiveDelta B)
      (EndpointSubwindowUnion
        (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
        (tailShiftSeq (oneOverPiShiftedQlog baseShift) s) Relevant)
  liveDensity : LiveBoundaryDensityTarget Live liveLoss

/-- Preferred chosen subwindow witness target.

This directly proves what `SmallLiveRawBudgetFromEntropyReciprocalTarget`
needs, without the stronger and potentially false universal quantification
over arbitrary closed/live splits. -/
def SmallLiveChosenSubwindowWitnessTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                Nonempty (SmallLiveChosenSubwindowWitness B hB baseShift G s)

/-- The chosen subwindow witness gives the raw small-live budget target
directly. -/
theorem smallLiveRawBudgetFromEntropyReciprocalTarget_of_chosenSubwindowWitnessTarget
    (hChosen : SmallLiveChosenSubwindowWitnessTarget) :
    SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hChosen B hB hBound baseShift hCap G s with ⟨W⟩
  refine ⟨W.liveLoss, W.liveLoss_nonneg, W.liveLoss_lt_slack, ?_⟩
  refine ⟨
    EndpointSubwindowUnion
      (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (tailShiftSeq (oneOverPiShiftedQlog baseShift) s) W.Relevant,
    W.Live,
    ?_,
    W.closedBudget,
    W.liveDensity
  ⟩
  exact nonVisibleBadClosedLiveCover_of_offset_or_live
    (nu := clippedLayerCakeTrialNu B)
    (x := clippedLayerCakeCanonicalX B)
    (X := tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
    (H := tailShiftSeq G.H s) (V := tailShiftSeq G.V s)
    (Relevant := W.Relevant) (Live := W.Live)
    W.offsetOrLive W.subwindowCover

/-- Recommended raw target in the chosen-split formulation. -/
def SmallLiveChosenRecommendedTarget : Prop :=
  EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget ∧
    SmallLiveChosenSubwindowWitnessTarget

/-- Chosen split package gives the two raw field-attack obligations. -/
theorem rawTargets_of_smallLiveChosenRecommendedTarget
    (T : SmallLiveChosenRecommendedTarget) :
    EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget ∧
      SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  exact ⟨T.1,
    smallLiveRawBudgetFromEntropyReciprocalTarget_of_chosenSubwindowWitnessTarget
      T.2⟩

/-! ### Optional internal split of the chosen witness -/

/-- Closed/localization data for the chosen subwindow split, without the
live-density saving. -/
structure SmallLiveChosenClosedLocalizationData
    (B : ℝ) (hB : 4 < B)
    (baseShift : ℕ)
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)
    (s : ℕ) : Type where
  Relevant : ℕ → ℕ → Prop
  Live : ℕ → Prop
  offsetOrLive :
    ∀ m : ℕ,
      NonVisibleBadShell
          (clippedLayerCakeTrialNu B)
          (tailShiftSeq G.H s) (tailShiftSeq G.V s)
          (clippedLayerCakeCanonicalX B) m →
        EndpointExceptionalByOffset
          (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
          (tailShiftSeq (oneOverPiShiftedQlog baseShift) s) Relevant m ∨
        Live m
  subwindowCover :
    EndpointExceptionalSubwindowCover
      (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (tailShiftSeq (oneOverPiShiftedQlog baseShift) s) Relevant
  closedBudget :
    ClippedClosedEndpointCountBudget
      (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
      (clippedLayerCakeTrialNu B)
      (clippedLayerCakeQuadraticEffectiveDelta B)
      (EndpointSubwindowUnion
        (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
        (tailShiftSeq (oneOverPiShiftedQlog baseShift) s) Relevant)

/-- Target for choosing the closed endpoint-subwindow localization. -/
def SmallLiveChosenClosedLocalizationTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                Nonempty (SmallLiveChosenClosedLocalizationData B hB baseShift G s)

/-- Saving target for the live predicate produced by the chosen localization.

Unlike `SmallLiveBoundaryDensitySavingTarget`, this target does not quantify
over arbitrary closed/live predicates. -/
def SmallLiveSavingForChosenLocalizationTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                ∀ D : SmallLiveChosenClosedLocalizationData B hB baseShift G s,
                  ∃ liveLoss : ℝ,
                    0 ≤ liveLoss ∧
                    liveLoss < clippedLayerCakeQuadraticEffectiveSlack B ∧
                    LiveBoundaryDensityTarget D.Live liveLoss

/-- Pure assembly of chosen localization plus saving into the chosen witness. -/
theorem smallLiveChosenSubwindowWitnessTarget_of_localization_and_saving
    (hLoc : SmallLiveChosenClosedLocalizationTarget)
    (hSave : SmallLiveSavingForChosenLocalizationTarget) :
    SmallLiveChosenSubwindowWitnessTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hLoc B hB hBound baseShift hCap G s with ⟨D⟩
  rcases hSave B hB hBound baseShift hCap G s D with
    ⟨liveLoss, hlive_nonneg, hlive_lt, hliveDensity⟩
  exact ⟨{
    Relevant := D.Relevant
    Live := D.Live
    liveLoss := liveLoss
    liveLoss_nonneg := hlive_nonneg
    liveLoss_lt_slack := hlive_lt
    offsetOrLive := D.offsetOrLive
    subwindowCover := D.subwindowCover
    closedBudget := D.closedBudget
    liveDensity := hliveDensity
  }⟩

/-- Chosen localization plus chosen-live saving gives the raw small-live budget
target. -/
theorem smallLiveRawBudgetFromEntropyReciprocalTarget_of_chosen_localization_and_saving
    (hLoc : SmallLiveChosenClosedLocalizationTarget)
    (hSave : SmallLiveSavingForChosenLocalizationTarget) :
    SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  exact smallLiveRawBudgetFromEntropyReciprocalTarget_of_chosenSubwindowWitnessTarget
    (smallLiveChosenSubwindowWitnessTarget_of_localization_and_saving hLoc hSave)

/-!
## Terminal localization for the chosen split

The previous layer introduced a chosen closed/live split. This layer makes the
live predicate concrete: it is exactly the terminal remainder consisting of
non-visible bad shells that are not endpoint-exceptional for the chosen
relevance relation.

For this canonical choice, the live-density saving follows from the pointwise
implication `EndpointLowRelevantForcesVisible`: a terminal shell has a relevant
index below the safe threshold, hence would be visible, contradicting
non-visibility.
-/

namespace TerminalLocalization

noncomputable section

/-! ### Local abbreviations for the chosen shifted endpoint system -/

abbrev terminalNu (B : ℝ) : ℝ :=
  clippedLayerCakeTrialNu B

abbrev terminalXExp (B : ℝ) : ℝ :=
  clippedLayerCakeCanonicalX B

abbrev terminalQlogTail (baseShift s : ℕ) : ℕ → ℝ :=
  tailShiftSeq (oneOverPiShiftedQlog baseShift) s

abbrev terminalHTail
    {B : ℝ} {baseShift : ℕ}
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)
    (s : ℕ) : ℕ → ℝ :=
  tailShiftSeq G.H s

abbrev terminalVTail
    {B : ℝ} {baseShift : ℕ}
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)
    (s : ℕ) : ℕ → ℝ :=
  tailShiftSeq G.V s

abbrev terminalDelta (B : ℝ) : ℝ :=
  clippedLayerCakeQuadraticEffectiveDelta B

/-! ### Terminal live predicate and zero-density proof -/

/-- The terminal live boundary for a chosen relevance relation. -/
def TerminalLiveBoundary
    (nu x : ℝ) (X H V : ℕ → ℝ)
    (Relevant : ℕ → ℕ → Prop) : ℕ → Prop :=
  fun m =>
    NonVisibleBadShell nu H V x m ∧
      ¬ EndpointExceptionalByOffset nu x X Relevant m

/-- If low relevant endpoint data forces visibility, the terminal live boundary
is empty. -/
theorem terminalLiveBoundary_empty_of_lowRelevantForcesVisible
    {nu x : ℝ} {X H V : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    (hLow : EndpointLowRelevantForcesVisible nu x X H V Relevant) :
    ∀ m : ℕ, ¬ TerminalLiveBoundary nu x X H V Relevant m := by
  classical
  intro m hm
  rcases hm with ⟨hNV, hNotEndpoint⟩
  rcases hNV with ⟨hBad, hNotVisible⟩
  have hNotAll :
      ¬ ∀ j : ℕ,
          Relevant m j →
            (1 - x) * ramanujanDenominatorCapLog nu m < X j := by
    intro hAll
    exact hNotEndpoint ⟨hBad, hAll⟩
  push Not at hNotAll
  rcases hNotAll with ⟨j, hRel, hLowCap⟩
  exact hNotVisible (hLow m j hBad hRel hLowCap)

/-- The terminal live boundary has zero upper density whenever low relevant
endpoint data forces visibility. -/
theorem liveBoundaryDensity_terminal_zero_of_lowRelevantForcesVisible
    {nu x : ℝ} {X H V : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    (hLow : EndpointLowRelevantForcesVisible nu x X H V Relevant) :
    LiveBoundaryDensityTarget
      (TerminalLiveBoundary nu x X H V Relevant) 0 := by
  have hdom : Criteria.dominated
      (TerminalLiveBoundary nu x X H V Relevant) (fun _ : ℕ => False) := by
    intro m hm
    exact False.elim
      ((terminalLiveBoundary_empty_of_lowRelevantForcesVisible
        (nu := nu) (x := x) (X := X) (H := H) (V := V)
        (Relevant := Relevant) hLow) m hm)
  exact Criteria.upperDensityAtMost_mono hdom liveBoundaryDensity_false_zero

/-! ### Terminal localization data -/

/-- Concrete terminal-localization data needed to build a chosen small-live
witness. -/
structure SmallLiveTerminalLocalizationData
    (B : ℝ) (hB : 4 < B)
    (baseShift : ℕ)
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)
    (s : ℕ) : Type where
  Relevant : ℕ → ℕ → Prop
  lowRelevantForcesVisible :
    EndpointLowRelevantForcesVisible
      (terminalNu B) (terminalXExp B)
      (terminalQlogTail baseShift s)
      (terminalHTail G s) (terminalVTail G s)
      Relevant
  subwindowCover :
    EndpointExceptionalSubwindowCover
      (terminalNu B) (terminalXExp B)
      (terminalQlogTail baseShift s) Relevant
  closedBudget :
    ClippedClosedEndpointCountBudget
      (terminalQlogTail baseShift s)
      (terminalNu B)
      (terminalDelta B)
      (EndpointSubwindowUnion
        (terminalNu B) (terminalXExp B)
        (terminalQlogTail baseShift s) Relevant)

/-- Terminal-localization data gives the parent chosen closed-localization data. -/
def chosenClosedLocalizationData_of_terminalLocalizationData
    {B : ℝ} {hB : 4 < B}
    {baseShift : ℕ}
    {G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift}
    {s : ℕ}
    (D : SmallLiveTerminalLocalizationData B hB baseShift G s) :
    SmallLiveChosenClosedLocalizationData B hB baseShift G s := {
  Relevant := D.Relevant
  Live := TerminalLiveBoundary
    (terminalNu B) (terminalXExp B)
    (terminalQlogTail baseShift s)
    (terminalHTail G s) (terminalVTail G s)
    D.Relevant
  offsetOrLive := by
    intro m hNV
    by_cases hEnd : EndpointExceptionalByOffset
        (terminalNu B) (terminalXExp B)
        (terminalQlogTail baseShift s) D.Relevant m
    · exact Or.inl hEnd
    · exact Or.inr ⟨hNV, hEnd⟩
  subwindowCover := D.subwindowCover
  closedBudget := D.closedBudget
}

/-- Terminal-localization data gives the full chosen subwindow witness with
zero live loss. -/
def chosenSubwindowWitness_of_terminalLocalizationData
    {B : ℝ} {hB : 4 < B}
    {baseShift : ℕ}
    {G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift}
    {s : ℕ}
    (D : SmallLiveTerminalLocalizationData B hB baseShift G s) :
    SmallLiveChosenSubwindowWitness B hB baseShift G s := {
  Relevant := D.Relevant
  Live := TerminalLiveBoundary
    (terminalNu B) (terminalXExp B)
    (terminalQlogTail baseShift s)
    (terminalHTail G s) (terminalVTail G s)
    D.Relevant
  liveLoss := 0
  liveLoss_nonneg := by norm_num
  liveLoss_lt_slack := clippedLayerCakeQuadraticEffectiveSlack_pos (B := B) hB
  offsetOrLive := by
    intro m hNV
    by_cases hEnd : EndpointExceptionalByOffset
        (terminalNu B) (terminalXExp B)
        (terminalQlogTail baseShift s) D.Relevant m
    · exact Or.inl hEnd
    · exact Or.inr ⟨hNV, hEnd⟩
  subwindowCover := D.subwindowCover
  closedBudget := D.closedBudget
  liveDensity :=
    liveBoundaryDensity_terminal_zero_of_lowRelevantForcesVisible
      (nu := terminalNu B) (x := terminalXExp B)
      (X := terminalQlogTail baseShift s)
      (H := terminalHTail G s) (V := terminalVTail G s)
      (Relevant := D.Relevant)
      D.lowRelevantForcesVisible
}

/-- Preferred replacement target for the two previous chosen-split targets. -/
def SmallLiveTerminalLocalizationTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                Nonempty (SmallLiveTerminalLocalizationData B hB baseShift G s)

/-- Terminal localization proves the parent chosen-subwindow witness target. -/
theorem smallLiveChosenSubwindowWitnessTarget_of_terminalLocalizationTarget
    (hTerm : SmallLiveTerminalLocalizationTarget) :
    SmallLiveChosenSubwindowWitnessTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hTerm B hB hBound baseShift hCap G s with ⟨D⟩
  exact ⟨chosenSubwindowWitness_of_terminalLocalizationData D⟩

/-- Terminal localization proves the raw small-live budget target already used
by the field-attack layer. -/
theorem smallLiveRawBudgetFromEntropyReciprocalTarget_of_terminalLocalizationTarget
    (hTerm : SmallLiveTerminalLocalizationTarget) :
    SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  exact smallLiveRawBudgetFromEntropyReciprocalTarget_of_chosenSubwindowWitnessTarget
    (smallLiveChosenSubwindowWitnessTarget_of_terminalLocalizationTarget hTerm)

/-- Recommended target at this layer. -/
def SmallLiveTerminalRecommendedTarget : Prop :=
  EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget ∧
    SmallLiveTerminalLocalizationTarget

/-- Terminal recommended target gives the parent chosen recommended target. -/
theorem smallLiveChosenRecommendedTarget_of_terminalRecommendedTarget
    (h : SmallLiveTerminalRecommendedTarget) :
    SmallLiveChosenRecommendedTarget := by
  exact ⟨h.1, smallLiveChosenSubwindowWitnessTarget_of_terminalLocalizationTarget h.2⟩

/-- Terminal recommended target gives the raw target pair expected one level up. -/
theorem rawTargets_of_terminalRecommendedTarget
    (h : SmallLiveTerminalRecommendedTarget) :
    EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget ∧
      SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  exact ⟨h.1,
    smallLiveRawBudgetFromEntropyReciprocalTarget_of_terminalLocalizationTarget h.2⟩

/-! ### Active-relevant specialization -/

/-- Active-relevant terminal data. -/
structure SmallLiveActiveRelevantTerminalData
    (B : ℝ) (hB : 4 < B)
    (baseShift : ℕ)
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)
    (s : ℕ) : Type where
  activeWitness :
    EndpointActiveRelevantWitnessExistence
      (terminalNu B) (terminalQlogTail baseShift s)
  lowActiveRelevantForcesVisible :
    EndpointLowRelevantForcesVisible
      (terminalNu B) (terminalXExp B)
      (terminalQlogTail baseShift s)
      (terminalHTail G s) (terminalVTail G s)
      (EndpointActiveRelevant (terminalNu B) (terminalQlogTail baseShift s))
  closedBudget :
    ClippedClosedEndpointCountBudget
      (terminalQlogTail baseShift s)
      (terminalNu B)
      (terminalDelta B)
      (EndpointSubwindowUnion
        (terminalNu B) (terminalXExp B)
        (terminalQlogTail baseShift s)
        (EndpointActiveRelevant (terminalNu B) (terminalQlogTail baseShift s)))

/-- Active-relevant terminal data gives terminal-localization data. -/
def terminalLocalizationData_of_activeRelevantTerminalData
    {B : ℝ} {hB : 4 < B}
    {baseShift : ℕ}
    {G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift}
    {s : ℕ}
    (D : SmallLiveActiveRelevantTerminalData B hB baseShift G s) :
    SmallLiveTerminalLocalizationData B hB baseShift G s := {
  Relevant := EndpointActiveRelevant (terminalNu B) (terminalQlogTail baseShift s)
  lowRelevantForcesVisible := D.lowActiveRelevantForcesVisible
  subwindowCover :=
    endpointExceptionalSubwindowCover_of_belowCapWitness
      (nu := terminalNu B) (x := terminalXExp B)
      (X := terminalQlogTail baseShift s)
      (BaseRelevant :=
        EndpointActiveRelevant (terminalNu B) (terminalQlogTail baseShift s))
      (endpointRelevantBelowCapWitness_of_activeRelevantExistence
        (nu := terminalNu B) (X := terminalQlogTail baseShift s)
        D.activeWitness)
  closedBudget := D.closedBudget
}

/-- Active-relevant terminal target. -/
def SmallLiveActiveRelevantTerminalTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                Nonempty (SmallLiveActiveRelevantTerminalData B hB baseShift G s)

/-- Active-relevant terminal target proves terminal localization. -/
theorem smallLiveTerminalLocalizationTarget_of_activeRelevantTerminalTarget
    (hActive : SmallLiveActiveRelevantTerminalTarget) :
    SmallLiveTerminalLocalizationTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hActive B hB hBound baseShift hCap G s with ⟨D⟩
  exact ⟨terminalLocalizationData_of_activeRelevantTerminalData D⟩

/-- Active-relevant terminal target proves the parent chosen-subwindow witness. -/
theorem smallLiveChosenSubwindowWitnessTarget_of_activeRelevantTerminalTarget
    (hActive : SmallLiveActiveRelevantTerminalTarget) :
    SmallLiveChosenSubwindowWitnessTarget := by
  exact smallLiveChosenSubwindowWitnessTarget_of_terminalLocalizationTarget
    (smallLiveTerminalLocalizationTarget_of_activeRelevantTerminalTarget hActive)

/-- Active-relevant terminal target proves the raw small-live budget target. -/
theorem smallLiveRawBudgetFromEntropyReciprocalTarget_of_activeRelevantTerminalTarget
    (hActive : SmallLiveActiveRelevantTerminalTarget) :
    SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  exact smallLiveRawBudgetFromEntropyReciprocalTarget_of_terminalLocalizationTarget
    (smallLiveTerminalLocalizationTarget_of_activeRelevantTerminalTarget hActive)

/-! ### Final split of the active-relevant terminal target -/

/-- Geometry-only fields for the active-relevant terminal target. -/
structure SmallLiveActiveRelevantGeometryData
    (B : ℝ) (hB : 4 < B)
    (baseShift : ℕ)
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)
    (s : ℕ) : Type where
  activeWitness :
    EndpointActiveRelevantWitnessExistence
      (terminalNu B) (terminalQlogTail baseShift s)
  lowActiveRelevantForcesVisible :
    EndpointLowRelevantForcesVisible
      (terminalNu B) (terminalXExp B)
      (terminalQlogTail baseShift s)
      (terminalHTail G s) (terminalVTail G s)
      (EndpointActiveRelevant (terminalNu B) (terminalQlogTail baseShift s))

/-- Target for active witness existence plus the low-relevant-visible implication. -/
def SmallLiveActiveRelevantGeometryTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                Nonempty (SmallLiveActiveRelevantGeometryData B hB baseShift G s)

/-- Target for the closed endpoint-subwindow budget with active relevance. -/
def SmallLiveActiveRelevantClosedBudgetTarget : Prop :=
  ∀ B : ℝ,
    ∀ _hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ _G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                ClippedClosedEndpointCountBudget
                  (terminalQlogTail baseShift s)
                  (terminalNu B)
                  (terminalDelta B)
                  (EndpointSubwindowUnion
                    (terminalNu B) (terminalXExp B)
                    (terminalQlogTail baseShift s)
                    (EndpointActiveRelevant
                      (terminalNu B) (terminalQlogTail baseShift s)))

/-- The geometry target and closed-budget target assemble the active-relevant
terminal target. -/
theorem smallLiveActiveRelevantTerminalTarget_of_geometry_and_closedBudget
    (hGeom : SmallLiveActiveRelevantGeometryTarget)
    (hBudget : SmallLiveActiveRelevantClosedBudgetTarget) :
    SmallLiveActiveRelevantTerminalTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hGeom B hB hBound baseShift hCap G s with ⟨W⟩
  exact ⟨{
    activeWitness := W.activeWitness
    lowActiveRelevantForcesVisible := W.lowActiveRelevantForcesVisible
    closedBudget := hBudget B hB hBound baseShift hCap G s
  }⟩

/-- The two final active-relevant field targets imply the raw target pair needed
by the integrated field-attack layer. -/
theorem rawTargets_of_activeRelevantGeometry_and_closedBudget
    (hLog : EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget)
    (hGeom : SmallLiveActiveRelevantGeometryTarget)
    (hBudget : SmallLiveActiveRelevantClosedBudgetTarget) :
    EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget ∧
      SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  exact ⟨hLog,
    smallLiveRawBudgetFromEntropyReciprocalTarget_of_activeRelevantTerminalTarget
      (smallLiveActiveRelevantTerminalTarget_of_geometry_and_closedBudget
        hGeom hBudget)⟩

/-- Fully reduced recommendation for the current branch. -/
def SmallLiveTerminalFullyReducedRecommendedTarget : Prop :=
  EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget ∧
    SmallLiveActiveRelevantGeometryTarget ∧
    SmallLiveActiveRelevantClosedBudgetTarget

/-- Fully reduced recommendation gives the terminal recommended target. -/
theorem terminalRecommendedTarget_of_fullyReducedRecommendedTarget
    (h : SmallLiveTerminalFullyReducedRecommendedTarget) :
    SmallLiveTerminalRecommendedTarget := by
  rcases h with ⟨hLog, hGeom, hBudget⟩
  exact ⟨hLog,
    smallLiveTerminalLocalizationTarget_of_activeRelevantTerminalTarget
      (smallLiveActiveRelevantTerminalTarget_of_geometry_and_closedBudget
        hGeom hBudget)⟩

/-- Fully reduced recommendation gives the raw field-attack target pair. -/
theorem rawTargets_of_fullyReducedRecommendedTarget
    (h : SmallLiveTerminalFullyReducedRecommendedTarget) :
    EndpointBelowLeftRawLogBoundFromEntropyReciprocalTarget ∧
      SmallLiveRawBudgetFromEntropyReciprocalTarget := by
  rcases h with ⟨hLog, hGeom, hBudget⟩
  exact rawTargets_of_activeRelevantGeometry_and_closedBudget
    hLog hGeom hBudget

end

