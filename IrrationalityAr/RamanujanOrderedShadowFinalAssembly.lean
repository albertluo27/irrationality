/-!
# Endpoint-active relevance to ratio-active count reduction

This layer removes one more bookkeeping field from the active-relevance route.
The fixed relation `EndpointActiveRelevant nu X m j` already places the
denominator cap inside the endpoint interval for `j`, which forces the jump
condition `(nu - 1) * X j <= X (j + 1)`.  Thus the cutoff active-count target
can be replaced by a simpler count of ratio-active indices.
-/

/-! ## Ratio-active indices -/

/-- A ratio-active endpoint index at exponent `nu`.  This avoids division by
`X j`; it is the multiplicative jump condition in additive log scale. -/
def EndpointRatioActiveIndex
    (nu : ℝ) (X : ℕ → ℝ) (j : ℕ) : Prop :=
  (nu - 1) * X j ≤ X (j + 1)

/-- Ratio-active indices in the finite search range used by the cutoff API. -/
def EndpointRatioActiveIndexFinset
    (nu : ℝ) (X : ℕ → ℝ) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun j =>
    EndpointRatioActiveIndex nu X j

/-- Count of ratio-active indices up to cutoff `M`. -/
def EndpointRatioActiveCount
    (nu : ℝ) (X : ℕ → ℝ) (M : ℕ) : ℕ :=
  (EndpointRatioActiveIndexFinset nu X M).card

/-- Endpoint-active relevance forces ratio-activity. -/
theorem endpointActiveRelevant_implies_endpointRatioActive
    {nu : ℝ} {X : ℕ → ℝ} {m j : ℕ}
    (hnu : 0 < nu)
    (hRel : EndpointActiveRelevant nu X m j) :
    EndpointRatioActiveIndex nu X j := by
  rcases hRel with ⟨hleft, hright⟩
  unfold EndpointRatioActiveIndex endpointRatioScale at *
  have hnu_nonneg : 0 ≤ nu := le_of_lt hnu
  have h1 : nu * X j ≤ nu * ramanujanDenominatorCapLog nu m := by
    exact mul_le_mul_of_nonneg_left hleft hnu_nonneg
  have h2mul :
      nu * ramanujanDenominatorCapLog nu m
        ≤ nu * ((X j + X (j + 1)) / nu) := by
    exact mul_le_mul_of_nonneg_left hright hnu_nonneg
  have h2 :
      nu * ramanujanDenominatorCapLog nu m
        ≤ X j + X (j + 1) := by
    have hnu_ne : nu ≠ 0 := ne_of_gt hnu
    convert h2mul using 1
    field_simp [hnu_ne]
  have hmain : nu * X j ≤ X j + X (j + 1) := le_trans h1 h2
  nlinarith

/-- Cutoff-prefix closed endpoint-active relevance gives a ratio-active index. -/
theorem cutoffPrefixEndpointActiveRelevant_implies_ratioActive
    {nu : ℝ} {X : ℕ → ℝ} {K : ℕ → ℕ}
    {M m j : ℕ}
    (hnu : 0 < nu)
    (hRel : CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X) M m j) :
    EndpointRatioActiveIndex nu X j := by
  exact endpointActiveRelevant_implies_endpointRatioActive hnu hRel.1

/-! ## Cutoff active-count is bounded by ratio-active count -/

/-- Every cutoff-relevant active index for the endpoint-active relation is a
ratio-active index in the same finite range. -/
theorem cutoffRelevantActiveShadowIndexFinset_subset_endpointRatioActive
    {nu : ℝ} {X : ℕ → ℝ} {K : ℕ → ℕ}
    (hnu : 0 < nu) (M : ℕ) :
    CutoffRelevantActiveShadowIndexFinset
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X)) M
      ⊆ EndpointRatioActiveIndexFinset nu X M := by
  classical
  intro j hj
  dsimp [CutoffRelevantActiveShadowIndexFinset] at hj
  rw [Finset.mem_filter] at hj
  rcases hj with ⟨hjRange, hWitness⟩
  rcases hWitness with ⟨m, _hmM, hRel, _hInt⟩
  dsimp [EndpointRatioActiveIndexFinset]
  rw [Finset.mem_filter]
  exact ⟨hjRange,
    cutoffPrefixEndpointActiveRelevant_implies_ratioActive
      (nu := nu) (X := X) (K := K)
      (M := M) (m := m) (j := j) hnu hRel⟩

/-- The cutoff-relevant active-count is bounded by the ratio-active count. -/
theorem cutoffRelevantActiveShadowCount_le_endpointRatioActiveCount
    {nu : ℝ} {X : ℕ → ℝ} {K : ℕ → ℕ}
    (hnu : 0 < nu) (M : ℕ) :
    CutoffRelevantActiveShadowCount
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X)) M
      ≤ EndpointRatioActiveCount nu X M := by
  classical
  unfold CutoffRelevantActiveShadowCount EndpointRatioActiveCount
  exact Finset.card_le_card
    (cutoffRelevantActiveShadowIndexFinset_subset_endpointRatioActive
      (nu := nu) (X := X) (K := K) hnu M)

/-! ## Direct data from ratio-active count data -/

/-- Direct sublinear count data for ratio-active indices. -/
structure EndpointRatioActiveCountDirectData
    (nu : ℝ) (X : ℕ → ℝ) : Type where
  countErr : ℕ → ℝ
  countBound : ∀ᶠ M : ℕ in atTop,
    (EndpointRatioActiveCount nu X M : ℝ) ≤ countErr M
  countErrSublinear : EventuallySublinearCountError countErr

/-- Ratio-active count data gives the direct active-count data required by the
cutoff endpoint route. -/
def cutoffRelevantActiveCountDirectData_of_endpointRatioActiveCountData
    {nu : ℝ} {X : ℕ → ℝ} {K : ℕ → ℕ}
    (hnu : 0 < nu)
    (D : EndpointRatioActiveCountDirectData nu X) :
    CutoffRelevantActiveCountDirectData
      (endpointSubwindowIntervalLeft nu X)
      (endpointSubwindowIntervalRight X)
      (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X)) := {
  countErr := D.countErr
  countBound := by
    filter_upwards [D.countBound] with M hM
    have hleNat := cutoffRelevantActiveShadowCount_le_endpointRatioActiveCount
      (nu := nu) (X := X) (K := K) hnu M
    exact le_trans (by exact_mod_cast hleNat) hM
  countErrSublinear := D.countErrSublinear
}

/-! ## Active-relevance data with ratio-active count field -/

/-- Fixed active-relevance data where the active-count estimate is supplied by a
ratio-active count bound. -/
structure EndpointSubwindowCutoffPrefixActiveRelevantRatioCountData
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Type where
