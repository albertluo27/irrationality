    EndpointSubwindowCutoffPrefixIndexData X H V nu x delta eps :=
  endpointSubwindowCutoffPrefixIndexData_of_witnessDirectActiveData
    (endpointSubwindowCutoffPrefixWitnessDirectActiveData_of_activeRelevantData D)

