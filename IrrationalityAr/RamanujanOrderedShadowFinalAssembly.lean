/-!
# Pure geometric finite count: log-algebra closure

This closes the remaining real-logarithmic algebra target in the pure
geometric active-count route.  The earlier finite power bound gives

`L * rho ^ (card - 1) <= Acoeff * M`.

Here that power inequality is converted into an eventual logarithmic cardinality
bound `card <= C * log (M + 2)`.
-/

/-! ## Elementary eventual log growth -/

/-- The logarithmic cutoff `log (M + 2)` tends to infinity. -/
theorem tendsto_log_nat_add_two_atTop :
    Tendsto (fun M : ℕ => Real.log ((M : ℝ) + 2)) atTop atTop := by
  have harg : Tendsto (fun M : ℕ => (M : ℝ) + 2) atTop atTop := by
    exact Filter.tendsto_atTop_add_const_right atTop (2 : ℝ)
      (tendsto_natCast_atTop_atTop (R := ℝ))
  exact Real.tendsto_log_atTop.comp harg

/-- Any fixed real constant is eventually below `log (M + 2)`. -/
theorem eventually_const_le_log_nat_add_two (A : ℝ) :
    ∀ᶠ M : ℕ in atTop, A ≤ Real.log ((M : ℝ) + 2) := by
  exact tendsto_log_nat_add_two_atTop.eventually_ge_atTop A

/-! ## Pointwise log algebra from a power bound -/

/-- If `T >= 1`, then the affine-log expression produced by taking logarithms
of the power bound is dominated by a fixed multiple of `T`. -/
theorem pureGeometric_log_prefactor_bound
    {gamma B T : ℝ}
    (hgamma : 0 < gamma) (hB : 0 ≤ B) (hT : 1 ≤ T) :
    1 + (B + T) / gamma ≤ (1 + (B + 1) / gamma) * T := by
  have hfracpart : (B + T) / gamma ≤ ((B + 1) / gamma) * T := by
    have hnum : B + T ≤ (B + 1) * T := by
      nlinarith [mul_nonneg hB (sub_nonneg.mpr hT)]
    calc
      (B + T) / gamma ≤ ((B + 1) * T) / gamma :=
        div_le_div_of_nonneg_right hnum (le_of_lt hgamma)
      _ = ((B + 1) / gamma) * T := by ring
  calc
    1 + (B + T) / gamma ≤ T + ((B + 1) / gamma) * T := by
      exact add_le_add hT hfracpart
    _ = (1 + (B + 1) / gamma) * T := by ring

/-- Pointwise logarithmic cardinality bound from the power inequality.

The constant term is absorbed by
`B = |log Acoeff - log L| + 1`, and the variable term `log M` is bounded by
`log (M + 2)`. -/
theorem pureGeometric_card_le_log_nat_add_two_of_power
    {rho L Acoeff : ℝ} {n M : ℕ}
    (hrho : 1 < rho) (hL : 0 < L) (hA : 0 < Acoeff)
    (hM : 1 ≤ M)
    (hpow : L * rho ^ (n - 1) ≤ Acoeff * (M : ℝ)) :
    (n : ℝ) ≤
      1 +
        ((|Real.log Acoeff - Real.log L| + 1) +
            Real.log ((M : ℝ) + 2)) / Real.log rho := by
  classical
  let B : ℝ := |Real.log Acoeff - Real.log L| + 1
  have hlogrho_pos : 0 < Real.log rho := Real.log_pos hrho
  have hrho_pos : 0 < rho := by linarith
  have hMposNat : 0 < M := lt_of_lt_of_le Nat.zero_lt_one hM
  have hMpos : 0 < (M : ℝ) := by exact_mod_cast hMposNat
  have hlogM_le_logp : Real.log (M : ℝ) ≤ Real.log ((M : ℝ) + 2) := by
    exact Real.log_le_log hMpos (by nlinarith)
  have hconst_le_B : Real.log Acoeff - Real.log L ≤ B := by
    dsimp [B]
    have hle_abs :
        Real.log Acoeff - Real.log L ≤
          |Real.log Acoeff - Real.log L| := le_abs_self _
    linarith
  by_cases hn0 : n = 0
  · have hB_nonneg : 0 ≤ B := by
      dsimp [B]
      positivity
    have hlogp_nonneg : 0 ≤ Real.log ((M : ℝ) + 2) :=
      Real.log_nonneg (by nlinarith)
    have hfrac_nonneg :
        0 ≤ (B + Real.log ((M : ℝ) + 2)) / Real.log rho := by
      exact div_nonneg (by nlinarith) (le_of_lt hlogrho_pos)
    have hright_nonneg :
        0 ≤ 1 + (B + Real.log ((M : ℝ) + 2)) / Real.log rho := by
      nlinarith
    simpa [hn0, B, add_comm, add_left_comm, add_assoc] using hright_nonneg
  · have hnpos : 0 < n := Nat.pos_of_ne_zero hn0
    have hpow_pos : 0 < rho ^ (n - 1) := pow_pos hrho_pos _
    have hleft_pos : 0 < L * rho ^ (n - 1) := mul_pos hL hpow_pos
    have hlog_le :
        Real.log (L * rho ^ (n - 1)) ≤ Real.log (Acoeff * (M : ℝ)) :=
      Real.log_le_log hleft_pos hpow
    have hlog_left :
        Real.log (L * rho ^ (n - 1)) =
          Real.log L + ((n - 1 : ℕ) : ℝ) * Real.log rho := by
      rw [Real.log_mul hL.ne' (ne_of_gt hpow_pos)]
      rw [Real.log_pow]
    have hlog_right :
        Real.log (Acoeff * (M : ℝ)) =
          Real.log Acoeff + Real.log (M : ℝ) := by
      rw [Real.log_mul hA.ne' (ne_of_gt hMpos)]
    rw [hlog_left, hlog_right] at hlog_le
    have hmul_le :
        ((n - 1 : ℕ) : ℝ) * Real.log rho ≤
          B + Real.log ((M : ℝ) + 2) := by
      nlinarith [hlog_le, hconst_le_B, hlogM_le_logp]
    have hk_le :
        ((n - 1 : ℕ) : ℝ) ≤
          (B + Real.log ((M : ℝ) + 2)) / Real.log rho := by
      rw [le_div_iff₀ hlogrho_pos]
      exact hmul_le
    have hn_eq_nat : n = (n - 1) + 1 := by omega
    have hn_eq_real : (n : ℝ) = ((n - 1 : ℕ) : ℝ) + 1 := by
      exact_mod_cast hn_eq_nat
    rw [hn_eq_real]
    nlinarith

/-! ## Closure of the remaining pure log-algebra target -/

/-- The real logarithmic algebra target is proved. -/
theorem pureGeometricPowerBoundToLogCountTarget_proved :
    PureGeometricPowerBoundToLogCountTarget := by
  intro rho L Acoeff F X hrho hL hAcoeff hpow
  classical
  by_cases hAzero : Acoeff = 0
  · refine ⟨0, by norm_num, ?_⟩
    filter_upwards with M
    rcases hpow M with hcard0 | hineq
    · simp [hcard0]
    · exfalso
      have hrho_pos : 0 < rho := by linarith
      have hleft_pos : 0 < L * rho ^ ((F M).card - 1) :=
        mul_pos hL (pow_pos hrho_pos _)
      have hright_zero : Acoeff * (M : ℝ) = 0 := by simp [hAzero]
      nlinarith
  · have hApos : 0 < Acoeff := by
      exact lt_of_le_of_ne hAcoeff (by
        intro h
        exact hAzero h.symm)
    let gamma : ℝ := Real.log rho
    let B : ℝ := |Real.log Acoeff - Real.log L| + 1
    let C : ℝ := 1 + (B + 1) / gamma
    have hgamma_pos : 0 < gamma := by
      dsimp [gamma]
      exact Real.log_pos hrho
    have hB_nonneg : 0 ≤ B := by
      dsimp [B]
      positivity
    have hC_nonneg : 0 ≤ C := by
      dsimp [C]
      have hfrac_nonneg : 0 ≤ (B + 1) / gamma :=
        div_nonneg (by nlinarith) (le_of_lt hgamma_pos)
      nlinarith
    refine ⟨C, hC_nonneg, ?_⟩
    have hlog_big :
        ∀ᶠ M : ℕ in atTop, 1 ≤ Real.log ((M : ℝ) + 2) :=
      eventually_const_le_log_nat_add_two 1
    filter_upwards [eventually_ge_atTop 1, hlog_big] with M hM hlog_big_M
    have hlogp_nonneg : 0 ≤ Real.log ((M : ℝ) + 2) := by
      nlinarith
    rcases hpow M with hcard0 | hineq
    · have hprod_nonneg : 0 ≤ C * Real.log ((M : ℝ) + 2) :=
        mul_nonneg hC_nonneg hlogp_nonneg
      simpa [hcard0] using hprod_nonneg
    · have hcard_pre :
          ((F M).card : ℝ) ≤
            1 +
              (B + Real.log ((M : ℝ) + 2)) / gamma := by
        dsimp [B, gamma]
        simpa [B, gamma, add_comm, add_left_comm, add_assoc] using
          pureGeometric_card_le_log_nat_add_two_of_power
            (rho := rho) (L := L) (Acoeff := Acoeff)
            (n := (F M).card) (M := M)
            hrho hL hApos hM hineq
      have hpre_to_target :
          1 + (B + Real.log ((M : ℝ) + 2)) / gamma ≤
            C * Real.log ((M : ℝ) + 2) := by
        dsimp [C]
        exact pureGeometric_log_prefactor_bound
          hgamma_pos hB_nonneg hlog_big_M
      exact hcard_pre.trans hpre_to_target

/-- The pure finite geometric logarithmic count theorem is now proved. -/
theorem pureGeometricFinsetLogCountTarget_proved :
    PureGeometricFinsetLogCountTarget := by
  exact pureGeometricFinsetLogCountTarget_of_powerBound_and_logAlgebra
    pureGeometricPowerBoundTarget_proved
    pureGeometricPowerBoundToLogCountTarget_proved

/-- Finite geometric power bound for endpoint ratio-active indices.

If each selected index has a jump by a factor `a > 1`, and all selected
values are bounded by `T`, then the selected cardinality forces exponential
growth from `X 0`. -/
private theorem pureGeometric_active_finset_pow_bound
    {a T : ℝ} {X : ℕ → ℝ} (s : Finset ℕ)
    (ha : 1 < a)
    (_hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X)
    (hactive : ∀ j : ℕ, j ∈ s → a * X j ≤ X (j + 1))
    (hbound : ∀ j : ℕ, j ∈ s → X j ≤ T)
    (hT : X 0 / a ≤ T) :
    a ^ s.card * X 0 ≤ a * T := by
  classical
  have ha_pos : 0 < a := lt_trans zero_lt_one ha
  let P : ℕ → Prop := fun n =>
    ∀ (s : Finset ℕ) (T : ℝ),
      s.card = n →
      (∀ j : ℕ, j ∈ s → a * X j ≤ X (j + 1)) →
      (∀ j : ℕ, j ∈ s → X j ≤ T) →
      X 0 / a ≤ T →
      a ^ s.card * X 0 ≤ a * T
  have hP : ∀ n : ℕ, P n := by
    intro n
    induction n with
    | zero =>
        intro s T hcard _hactive _hbound hT
        have hs_empty : s = ∅ := Finset.card_eq_zero.mp hcard
        subst s
        simp at *
        have hmul := mul_le_mul_of_nonneg_left hT (le_of_lt ha_pos)
        have hleft : a * (X 0 / a) = X 0 := by
          field_simp [ne_of_gt ha_pos]
        nlinarith
    | succ n ih =>
        intro s T hcard hactive hbound hT
        have hcard_pos : 0 < s.card := by
          rw [hcard]
          exact Nat.succ_pos n
        have hs_nonempty : s.Nonempty := Finset.card_pos.mp hcard_pos
        let m : ℕ := s.max' hs_nonempty
        have hm_mem : m ∈ s := Finset.max'_mem s hs_nonempty
        have hcard_erase : (s.erase m).card = n := by
          rw [Finset.card_erase_of_mem hm_mem, hcard]
          simp
        have hactive_erase :
            ∀ j : ℕ, j ∈ s.erase m → a * X j ≤ X (j + 1) := by
          intro j hj
          exact hactive j (Finset.mem_of_mem_erase hj)
        have hm_bound : X m ≤ T := hbound m hm_mem
        have hbound_erase :
            ∀ j : ℕ, j ∈ s.erase m → X j ≤ T / a := by
          intro j hj
          have hj_s : j ∈ s := Finset.mem_of_mem_erase hj
          have hj_ne_m : j ≠ m := (Finset.mem_erase.mp hj).1
          have hj_le_m : j ≤ m := Finset.le_max' s j hj_s
          have hj_lt_m : j < m := lt_of_le_of_ne hj_le_m hj_ne_m
          have hsucc_le : j + 1 ≤ m := Nat.succ_le_iff.mpr hj_lt_m
          have hmono_le : X (j + 1) ≤ X m := hmono hsucc_le
          have hact : a * X j ≤ X (j + 1) := hactive j hj_s
          have hax_le_T : a * X j ≤ T := le_trans hact (le_trans hmono_le hm_bound)
          exact (le_div_iff₀ ha_pos).2 (by simpa [mul_comm] using hax_le_T)
        have hX0_le_T : X 0 ≤ T := by
          have h0m : 0 ≤ m := Nat.zero_le m
          exact le_trans (hmono h0m) hm_bound
        have hT_erase : X 0 / a ≤ T / a := by
          exact div_le_div_of_nonneg_right hX0_le_T (le_of_lt ha_pos)
        have hIH := ih (s.erase m) (T / a) hcard_erase
          hactive_erase hbound_erase hT_erase
        have hcard_s : s.card = (s.erase m).card + 1 := by
          rw [hcard_erase, hcard]
        calc
          a ^ s.card * X 0
              = a * (a ^ (s.erase m).card * X 0) := by
                rw [hcard_s, pow_succ]
                ring
          _ ≤ a * (a * (T / a)) := by
                exact mul_le_mul_of_nonneg_left hIH (le_of_lt ha_pos)
          _ = a * T := by
                field_simp [ne_of_gt ha_pos]
  exact hP s.card s T rfl hactive hbound hT

/-- Direct endpoint-specific logarithmic count from positivity and monotonicity
of the log-denominator scale. -/
noncomputable def endpointRatioActiveBelowLeftLogCountData_of_geometric
    {nu : ℝ} {X : ℕ → ℝ}
    (hnu : 2 < nu)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X) :
    EndpointRatioActiveBelowLeftLogCountData nu X := by
  classical
  let a : ℝ := nu - 1
  have ha : 1 < a := by dsimp [a]; linarith
  have ha_pos : 0 < a := lt_trans zero_lt_one ha
  have hnu_pos : 0 < nu := by linarith
  have hloga_pos : 0 < Real.log a := Real.log_pos ha
  refine {
    C := 2 / Real.log a
    C_nonneg := ?_
    countBound := ?_
  }
  · exact le_of_lt (div_pos (by norm_num) hloga_pos)
  · have hk_pos : 0 < ramanujanKappa := ramanujanKappa_pos
    have hcoef_pos : 0 < ramanujanKappa / nu := div_pos hk_pos hnu_pos
    have hT_event :
        ∀ᶠ M : ℕ in atTop,
          X 0 / a ≤ (ramanujanKappa / nu) * (M : ℝ) := by
      have htend : Tendsto
          (fun M : ℕ => (ramanujanKappa / nu) * (M : ℝ))
          atTop atTop := by
        exact tendsto_natCast_atTop_atTop.const_mul_atTop hcoef_pos
      exact htend.eventually_ge_atTop (X 0 / a)
    let c0 : ℝ := a * (ramanujanKappa / nu) / X 0
    have hc0_event : ∀ᶠ M : ℕ in atTop, c0 ≤ (M : ℝ) := by
      exact tendsto_natCast_atTop_atTop.eventually_ge_atTop c0
    filter_upwards [hT_event, hc0_event] with M hT hc0M
    let s : Finset ℕ := EndpointRatioActiveBelowLeftIndexFinset nu X M
    let T : ℝ := (ramanujanKappa / nu) * (M : ℝ)
    have hactive : ∀ j : ℕ, j ∈ s → a * X j ≤ X (j + 1) := by
      intro j hj
      dsimp [s, EndpointRatioActiveBelowLeftIndexFinset] at hj
      rw [Finset.mem_filter] at hj
      exact hj.2.1
    have hbound : ∀ j : ℕ, j ∈ s → X j ≤ T := by
      intro j hj
      dsimp [s, EndpointRatioActiveBelowLeftIndexFinset] at hj
      rw [Finset.mem_filter] at hj
      have hleft : endpointSubwindowIntervalLeft nu X j ≤ (M : ℝ) := hj.2.2
      unfold endpointSubwindowIntervalLeft at hleft
      have hcoef_nonneg : 0 ≤ ramanujanKappa / nu := le_of_lt hcoef_pos
      have hmul := mul_le_mul_of_nonneg_right hleft hcoef_nonneg
      have hconvert :
          (nu * X j / ramanujanKappa) * (ramanujanKappa / nu) = X j := by
        field_simp [ne_of_gt hnu_pos, ne_of_gt hk_pos]
      calc
        X j = (nu * X j / ramanujanKappa) * (ramanujanKappa / nu) := by
          rw [hconvert]
        _ ≤ (M : ℝ) * (ramanujanKappa / nu) := hmul
        _ = T := by
          dsimp [T]
          ring
    have hpow := pureGeometric_active_finset_pow_bound
      (a := a) (T := T) (X := X) s ha hXpos hmono hactive hbound hT
    have hX0_pos : 0 < X 0 := hXpos 0
    have hc0_mul : a * (ramanujanKappa / nu) ≤ (M : ℝ) * X 0 := by
      dsimp [c0] at hc0M
      exact (div_le_iff₀ hX0_pos).mp hc0M
    have hM_nonneg : 0 ≤ (M : ℝ) := by positivity
    have hlinear : a * T ≤ ((M : ℝ) * (M : ℝ)) * X 0 := by
      dsimp [T]
      have h := mul_le_mul_of_nonneg_right hc0_mul hM_nonneg
      nlinarith
    have hquad_base : (M : ℝ) * (M : ℝ) ≤ ((M : ℝ) + 2) ^ 2 := by
      nlinarith [sq_nonneg ((M : ℝ) + 2)]
    have hquad : ((M : ℝ) * (M : ℝ)) * X 0 ≤ (((M : ℝ) + 2) ^ 2) * X 0 := by
      exact mul_le_mul_of_nonneg_right hquad_base (le_of_lt hX0_pos)
    have hpow_mul_sq : a ^ s.card * X 0 ≤ (((M : ℝ) + 2) ^ 2) * X 0 :=
      le_trans hpow (le_trans hlinear hquad)
    have hpow_sq : a ^ s.card ≤ ((M : ℝ) + 2) ^ 2 := by
      exact le_of_mul_le_mul_right hpow_mul_sq hX0_pos
    have hpow_pos : 0 < a ^ s.card := pow_pos ha_pos s.card
    have hlog_le : Real.log (a ^ s.card) ≤ Real.log (((M : ℝ) + 2) ^ 2) :=
      Real.log_le_log hpow_pos hpow_sq
    have hlog_left : Real.log (a ^ s.card) = (s.card : ℝ) * Real.log a := by
      rw [Real.log_pow]
    have hlog_right :
        Real.log (((M : ℝ) + 2) ^ 2) =
          (2 : ℝ) * Real.log ((M : ℝ) + 2) := by
      rw [Real.log_pow]
      norm_num
    have hcard_mul :
        (s.card : ℝ) * Real.log a ≤
          2 * Real.log ((M : ℝ) + 2) := by
      simpa [hlog_left, hlog_right] using hlog_le
    have hcard_le :
        (s.card : ℝ) ≤
          (2 / Real.log a) * Real.log ((M : ℝ) + 2) := by
      calc
        (s.card : ℝ)
            = ((s.card : ℝ) * Real.log a) / Real.log a := by
              field_simp [ne_of_gt hloga_pos]
        _ ≤ (2 * Real.log ((M : ℝ) + 2)) / Real.log a := by
              exact div_le_div_of_nonneg_right hcard_mul (le_of_lt hloga_pos)
        _ = (2 / Real.log a) * Real.log ((M : ℝ) + 2) := by
              ring
    simpa [EndpointRatioActiveBelowLeftCount, s, a] using hcard_le

/-- Direct endpoint-geometric count target from positivity and monotonicity. -/
theorem endpointRatioActiveBelowLeftGeometricCountTarget_direct :
    EndpointRatioActiveBelowLeftGeometricCountTarget := by
  intro nu X hnu hXpos hmono
  exact ⟨endpointRatioActiveBelowLeftLogCountData_of_geometric
    (nu := nu) (X := X) hnu hXpos hmono⟩

/-- Therefore the endpoint below-left geometric count target is also proved,
now by the direct endpoint-specific geometric closure. -/
