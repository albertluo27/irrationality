      ClippedEndpointBudgetSplitTarget
        S.X S.H S.V S.nu S.x (oneThresholdBootstrapDelta B S.nu) S.eps) :
    ClippedOneThresholdStrictSlackStepDataWithLiveLoss B := {
  nu := S.nu
  tau := S.tau
  x := S.x
  eps := S.eps
  X := S.X
  H := S.H
  V := S.V
  Hlog := S.Hlog
  u := S.u
  vseq := S.vseq
  closureCert := S.closureCert
  bauer := S.bauer
  nu_gt_two := S.nu_gt_two
  nu_lt_out := S.nu_lt_out
  tau_pos := S.tau_pos
  x_contraction := S.x_contraction
  x_lt_one := S.x_lt_one
  x_le_global := S.x_le_global
  finiteData := S.finiteData
  budgetSplit := budget
  total_nonneg := S.total_nonneg
  total_gain := S.total_gain
}

/-- Source-level live-loss input package. -/
structure LiveLossStrictSlackInputs (B : ℝ) : Type where
