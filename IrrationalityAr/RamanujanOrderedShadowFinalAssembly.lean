/-!
# Prefix-log-index final reduction

This layer replaces the soft prefix-depth hypothesis `K M = o(M)` by the more
structured endpoint expectation that `K M` is eventually logarithmic in the
outer cutoff.
-/

/-! ## Logarithmic prefix bounds imply sublinearity -/

/-- A prefix map is eventually logarithmically bounded if it is eventually at
most a fixed nonnegative multiple of the standard logarithmic count error. -/
def EventualPrefixLogBound (K : ℕ → ℕ) : Prop :=
  ∃ C : ℝ,
    0 ≤ C ∧
      ∀ᶠ M : ℕ in atTop,
        (K M : ℝ) ≤ C * orderedShadowLogError M

/-- A logarithmically bounded prefix map is a sublinear count error. -/
theorem eventuallySublinearCountError_natCast_of_prefixLogBound
    {K : ℕ → ℕ} (hK : EventualPrefixLogBound K) :
    EventuallySublinearCountError (fun M : ℕ => (K M : ℝ)) := by
  rcases hK with ⟨C, hC_nonneg, hK_le⟩
  have hCLog : EventuallySublinearCountError
      (fun M : ℕ => C * orderedShadowLogError M) :=
    EventuallySublinearCountError.const_mul
      (C := C) hC_nonneg eventuallySublinearCountError_orderedShadowLogError
  exact EventuallySublinearCountError.mono hCLog hK_le

