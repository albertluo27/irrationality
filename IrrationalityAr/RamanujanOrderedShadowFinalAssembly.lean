  relaxedSeqConverges : OneThresholdBootstrapRelaxedSeqConvergesToFour B0

/-- Zero-live component final package gives the raw final package. -/
def clippedRawFinalPackage_of_zeroLiveComponentFinalPackage
    {B0 : ℝ}
    (P : ClippedZeroLiveComponentFinalPackage B0) :
    ClippedActiveMassLiveLossStrictSlackRawFinalPackage B0 := {
  startBound := P.startBound
  startAboveFour := P.startAboveFour
  rawStepData := clippedRawDataTarget_of_zeroLiveTargets
