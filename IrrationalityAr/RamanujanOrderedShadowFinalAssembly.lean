      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogEventuallyTailFinalTarget) :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalTailFinalTarget := by
  rcases h with ⟨B0, P⟩
  exact ⟨B0, {
    startBound := P.startBound
    startAboveFour := P.startAboveFour
    actualQlogCofinalTailTarget :=
      actualQlogCofinalTailTarget_of_actualQlogEventuallyTailTarget
        P.actualQlogEventuallyTailTarget
    relaxedMapAboveFour := P.relaxedMapAboveFour
    relaxedSeqConverges := P.relaxedSeqConverges
  }⟩

/-!
# Actual-qlog cofinal-tail reduction along the relaxed bootstrap sequence

The previous actual-qlog cofinal-tail target asks for cofinally many good tails
for every strict cap `B > 4`.  The final iteration only visits the caps
`oneThresholdBootstrapRelaxedSeq B0 n`, so this layer weakens the endpoint input
to that realized sequence.
-/

/-! ## Converting endpoint-only data to cutoff-budget data -/

/-- The Bauer-free controlled-prefix endpoint package still contains enough
information to build the cutoff-budget package used by the one-step measure
improvement theorem. -/
def clippedCanonicalCutoffBudgetData_of_endpointOnlyControlledPrefixData
    {B : ℝ} {hB : 4 < B}
    (D : ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixEndpointOnlyData
      B hB) :
    ClippedCanonicalLiveLossCutoffBudgetData B hB :=
  clippedCanonicalCutoffBudgetData_of_prefixBudgetData
    (clippedCanonicalPrefixBudgetData_of_prefixIndexData
      (clippedCanonicalPrefixIndexData_of_sublinearIndexData
        (clippedCanonicalSublinearIndexData_of_logIndexData
          (clippedCanonicalPrefixLogIndexData_of_activeRelevantLogCountWithPrefixLogData
            (clippedCanonicalActiveLogCountWithPrefixLogData_of_controlledPrefixData
              (clippedCanonicalControlledPrefixData_of_endpointOnlyData D))))))

/-- A fixed actual-qlog shift package, together with positivity and the ratio
cap on that tail, gives the cutoff-budget package needed for one strict step. -/
def clippedCanonicalCutoffBudgetData_of_actualQlogShiftData
    {B : ℝ} {hB : 4 < B} {s : ℕ}
    (D : ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
      B hB s)
    (hpos : ∀ j : ℕ, 0 < tailShiftSeq (oneOverPiShiftedQlog 0) s j)
    (hcap : RatioBoundedBy (tailShiftSeq (oneOverPiShiftedQlog 0) s) (B - 1)) :
    ClippedCanonicalLiveLossCutoffBudgetData B hB :=
  clippedCanonicalCutoffBudgetData_of_endpointOnlyControlledPrefixData
    (clippedCanonicalControlledPrefixEndpointOnlyData_of_actualQlogShiftData
      (B := B) (hB := hB) (s := s) D hpos hcap)

/-- Cofinal actual-qlog endpoint data for a single cap supplies one strict
relaxed-bootstrap step at that cap. -/
theorem oneOverPiMeasureStrictlyBelow_relaxedMap_of_actualQlogCofinalTailAt
    {B : ℝ} {hB : 4 < B}
    (hBound : OneOverPiMeasureStrictlyBelow B)
    (hGeom :
      ∀ N : ℕ,
        ∃ s : ℕ,
          N ≤ s ∧
            Nonempty
              (ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
                B hB s)) :
    OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapRelaxedMap B) := by
  classical
  have Dendpoint :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixEndpointOnlyData
        B hB :=
    activeLogCountControlledPrefixEndpointOnlyData_of_actualQlogCofinalTail
      (B := B) (hB := hB) hBound hGeom
  have Dcutoff : ClippedCanonicalLiveLossCutoffBudgetData B hB :=
    clippedCanonicalCutoffBudgetData_of_endpointOnlyControlledPrefixData Dendpoint
  intro mu hmu
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedCanonicalCutoffBudgetData
    Dcutoff hmu

/-! ## Sequence-only actual-qlog cofinal-tail target -/

/-- Sequence-only cofinal-tail endpoint target. -/
def ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqTarget
    (B0 : ℝ) : Prop :=
  ∀ n : ℕ,
    ∀ hBn : 4 < oneThresholdBootstrapRelaxedSeq B0 n,
      OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapRelaxedSeq B0 n) →
        ∀ N : ℕ,
          ∃ s : ℕ,
            N ≤ s ∧
              Nonempty
                (ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
                  (oneThresholdBootstrapRelaxedSeq B0 n) hBn s)

/-- Sequence-only cofinal endpoint data propagates strict bounds along the
relaxed bootstrap sequence. -/
theorem oneOverPiMeasureStrictlyBelow_relaxedSeq_of_actualQlogCofinalRelaxedSeqTarget
    {B0 : ℝ}
    (hstart : KnownOneOverPiMeasureBound B0)
    (hB0 : 4 < B0)
    (hmap : OneThresholdBootstrapRelaxedMapAboveFour)
    (hSeq :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqTarget
        B0) :
    ∀ n : ℕ,
      OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapRelaxedSeq B0 n) := by
  intro n
  induction n with
  | zero =>
      simpa [oneThresholdBootstrapRelaxedSeq] using hstart
  | succ n ih =>
      have hBn : 4 < oneThresholdBootstrapRelaxedSeq B0 n :=
        oneThresholdBootstrapRelaxedSeq_above_four hmap hB0 n
      have hstep :
          OneOverPiMeasureStrictlyBelow
            (oneThresholdBootstrapRelaxedMap
              (oneThresholdBootstrapRelaxedSeq B0 n)) :=
        oneOverPiMeasureStrictlyBelow_relaxedMap_of_actualQlogCofinalTailAt
          (B := oneThresholdBootstrapRelaxedSeq B0 n)
          (hB := hBn) ih (hSeq n hBn ih)
      simpa [oneThresholdBootstrapRelaxedSeq] using hstep

/-- Final non-strict bound from endpoint data required only along the realized
relaxed bootstrap sequence. -/
theorem oneOverPiMeasureAtMost_four_of_actualQlogCofinalRelaxedSeq
    {B0 : ℝ}
    (hstart : KnownOneOverPiMeasureBound B0)
    (hB0 : 4 < B0)
    (hmap : OneThresholdBootstrapRelaxedMapAboveFour)
    (hconv : OneThresholdBootstrapRelaxedSeqConvergesToFour B0)
    (hSeq :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqTarget
        B0) :
    OneOverPiMeasureAtMost 4 := by
  apply oneOverPiMeasureAtMost_four_of_arbitrarily_close
  intro eps heps
  rcases hconv eps heps with ⟨n, hn⟩
  have hbound :
      OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapRelaxedSeq B0 n) :=
    oneOverPiMeasureStrictlyBelow_relaxedSeq_of_actualQlogCofinalRelaxedSeqTarget
      hstart hB0 hmap hSeq n
  intro mu hmu
  exact lt_trans (hbound mu hmu) hn

/-! ## Final package and compatibility with the previous all-cap target -/

/-- Final package whose endpoint input is only sequence-local cofinal actual-qlog
data. -/
structure ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalPackage
    (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  actualQlogCofinalRelaxedSeqTarget :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqTarget
      B0
  relaxedMapAboveFour : OneThresholdBootstrapRelaxedMapAboveFour
  relaxedSeqConverges : OneThresholdBootstrapRelaxedSeqConvergesToFour B0

/-- Final package in the sequence-only actual-qlog form implies `μ(1/π) ≤ 4` in
`OneOverPiMeasureAtMost` form. -/
theorem oneOverPiMeasureAtMost_four_of_activeLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalPackage
    {B0 : ℝ}
    (P :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalPackage
        B0) :
