/-!
# Clipped active-mass/live-loss component reduction

This opens the packaged strict-slack step target into raw fields: endpoint
closure data, clipped active-mass data, a closed/live split, and scalar
strict-slack inequalities.  It is only a constructor/reduction layer.
-/

/-- Raw data for one clipped active-mass/live-loss strict-slack step. -/
structure ClippedActiveMassLiveLossStrictSlackRawData (B : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  eps : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  activeData : ClippedOneThresholdActiveMassData X B nu
  split : ClippedEndpointControlsNonVisibleBadWithLiveLoss
    X H V nu x (oneThresholdEndpointDelta B nu) eps
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_lt_output : nu < (oneThresholdBootstrapRelaxedMap B)
  tau_pos : 0 < tau
