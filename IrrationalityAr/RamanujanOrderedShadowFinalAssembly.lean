/-!
# Cutoff endpoint prefix-budget closure

This layer turns the cutoff-aware relevant interval budget into the endpoint
prefix estimate that the clipped average naturally supplies.
-/

/-! ## One endpoint interval is controlled by one endpoint excess term -/

/-- The full real length of an endpoint interval is exactly the endpoint excess
term divided by the Ramanujan slope. -/
theorem endpointSubwindow_fullLength_eq_excess_div_kappa
    (X : ℕ → ℝ) (nu : ℝ) (j : ℕ) :
    max 0 (endpointSubwindowIntervalRight X j -
      endpointSubwindowIntervalLeft nu X j)
      = endpointRatioExcessTerm nu X j / ramanujanKappa := by
  have hk : 0 < ramanujanKappa := ramanujanKappa_pos
  unfold endpointSubwindowIntervalRight endpointSubwindowIntervalLeft
    endpointRatioScale endpointRatioExcessTerm
  have hlin :
      (X j + X (j + 1)) / ramanujanKappa - nu * X j / ramanujanKappa
        = (X (j + 1) - (nu - 1) * X j) / ramanujanKappa := by
    field_simp [ne_of_gt hk]
    ring
  rw [hlin]
  by_cases hnonneg : 0 ≤ X (j + 1) - (nu - 1) * X j
  · have hdiv_nonneg :
        0 ≤ (X (j + 1) - (nu - 1) * X j) / ramanujanKappa :=
      div_nonneg hnonneg (le_of_lt hk)
    rw [max_eq_right hdiv_nonneg, max_eq_right hnonneg]
  · have hneg : X (j + 1) - (nu - 1) * X j ≤ 0 := le_of_not_ge hnonneg
    have hdiv_nonpos :
        (X (j + 1) - (nu - 1) * X j) / ramanujanKappa ≤ 0 :=
      div_nonpos_of_nonpos_of_nonneg hneg (le_of_lt hk)
    rw [max_eq_left hdiv_nonpos, max_eq_left hneg]
    simp

/-- The clipped length at any cutoff is bounded by the endpoint excess term. -/
theorem clippedEndpointSubwindowLength_le_excess_div_kappa
    (X : ℕ → ℝ) (nu : ℝ) (M j : ℕ) :
    clippedRealIntervalLength
        (endpointSubwindowIntervalLeft nu X j)
        (endpointSubwindowIntervalRight X j) M
      ≤ endpointRatioExcessTerm nu X j / ramanujanKappa := by
  calc
    clippedRealIntervalLength
        (endpointSubwindowIntervalLeft nu X j)
        (endpointSubwindowIntervalRight X j) M
        ≤ max 0 (endpointSubwindowIntervalRight X j -
            endpointSubwindowIntervalLeft nu X j) :=
          clippedRealIntervalLength_le_fullLength
            (endpointSubwindowIntervalLeft nu X j)
            (endpointSubwindowIntervalRight X j) M
    _ = endpointRatioExcessTerm nu X j / ramanujanKappa :=
          endpointSubwindow_fullLength_eq_excess_div_kappa X nu j

/-! ## Relevant active sums are controlled by endpoint prefixes -/

/-- If every cutoff-relevant active index lies below `K`, then the sum of clipped
endpoint interval lengths over the active index set is bounded by the endpoint
excess prefix up to `K`. -/
theorem cutoffRelevantClippedLengthSum_le_endpointExcessPrefix
    {X : ℕ → ℝ} {nu : ℝ}
    {RelevantAt : ℕ → ℕ → ℕ → Prop} {M K : ℕ}
    (hindex : ∀ i : ℕ,
      i ∈ CutoffRelevantActiveShadowIndexFinset
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        RelevantAt M → i < K) :
    (∑ i ∈ CutoffRelevantActiveShadowIndexFinset
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        RelevantAt M,
      clippedRealIntervalLength
        (endpointSubwindowIntervalLeft nu X i)
        (endpointSubwindowIntervalRight X i) M)
      ≤ endpointRatioExcessSum nu X K / ramanujanKappa := by
  classical
  have hk_nonneg : 0 ≤ ramanujanKappa := le_of_lt ramanujanKappa_pos
  let A := CutoffRelevantActiveShadowIndexFinset
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        RelevantAt M
  have hsubset : A ⊆ Finset.range K := by
    intro i hi
    exact Finset.mem_range.mpr (hindex i hi)
  calc
    (∑ i ∈ A,
      clippedRealIntervalLength
        (endpointSubwindowIntervalLeft nu X i)
        (endpointSubwindowIntervalRight X i) M)
        ≤ ∑ i ∈ A, endpointRatioExcessTerm nu X i / ramanujanKappa := by
          exact Finset.sum_le_sum (fun i _hi =>
            clippedEndpointSubwindowLength_le_excess_div_kappa X nu M i)
    _ ≤ ∑ i ∈ Finset.range K,
          endpointRatioExcessTerm nu X i / ramanujanKappa := by
          refine Finset.sum_le_sum_of_subset_of_nonneg hsubset ?_
          intro i _hiA _hiNot
          exact div_nonneg (by unfold endpointRatioExcessTerm; positivity) hk_nonneg
    _ = endpointRatioExcessSum nu X K / ramanujanKappa := by
          unfold endpointRatioExcessSum
          rw [Finset.sum_div]

/-! ## Prefix-scale data gives the cutoff relevant length budget -/

/-- Data needed to turn the clipped endpoint average into a cutoff-aware
relevant real-length budget. -/
structure CutoffEndpointPrefixScaleBudgetData
    (X : ℕ → ℝ) (nu delta : ℝ)
    (RelevantAt : ℕ → ℕ → ℕ → Prop) : Type where
  K : ℕ → ℕ
  scaleErr : ℕ → ℝ
  delta_nonneg : 0 ≤ delta
  K_tendsto : Tendsto K atTop atTop
  indexCover : ∀ᶠ M : ℕ in atTop,
    ∀ i : ℕ,
      i ∈ CutoffRelevantActiveShadowIndexFinset
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        RelevantAt M → i < K M
  scaleBound : ∀ᶠ M : ℕ in atTop,
    endpointRatioScale X (K M) / ramanujanKappa
      ≤ ((M : ℝ) + 1) + scaleErr M
  scaleErrSublinear : EventuallySublinearCountError scaleErr

/-- The error `delta * scaleErr` is sublinear when `scaleErr` is. -/
theorem cutoffEndpointPrefix_deltaScaleErr_sublinear
    {X : ℕ → ℝ} {nu delta : ℝ}
    {RelevantAt : ℕ → ℕ → ℕ → Prop}
    (D : CutoffEndpointPrefixScaleBudgetData X nu delta RelevantAt) :
    EventuallySublinearCountError (fun M : ℕ => delta * D.scaleErr M) := by
  exact EventuallySublinearCountError.const_mul D.delta_nonneg D.scaleErrSublinear

/-- The clipped endpoint average plus prefix-scale data gives a cutoff-relevant
clipped real-length budget. -/
theorem cutoffRelevantClippedRealShadowLengthBudget_of_endpointPrefixScaleBudgetData
    {X : ℕ → ℝ} {nu delta : ℝ}
    {RelevantAt : ℕ → ℕ → ℕ → Prop}
    (D : CutoffEndpointPrefixScaleBudgetData X nu delta RelevantAt)
    (havg : ClippedEndpointWeightedAverageBound X nu delta) :
    CutoffRelevantClippedRealShadowLengthBudget
      (endpointSubwindowIntervalLeft nu X)
      (endpointSubwindowIntervalRight X)
      RelevantAt delta (fun M : ℕ => delta * D.scaleErr M) := by
  have hAvgAlong :
      ∀ᶠ M : ℕ in atTop,
        clippedEndpointExcessSum X nu (D.K M)
          ≤ delta * clippedEndpointScale X (D.K M) :=
    D.K_tendsto.eventually havg
  filter_upwards [D.indexCover, D.scaleBound, hAvgAlong] with M hIndex hScale hAvg
  have hsum := cutoffRelevantClippedLengthSum_le_endpointExcessPrefix
    (X := X) (nu := nu) (RelevantAt := RelevantAt)
    (M := M) (K := D.K M) hIndex
  have hAvgK :
      endpointRatioExcessSum nu X (D.K M)
        ≤ delta * endpointRatioScale X (D.K M) := by
    simpa [clippedEndpointExcessSum, clippedEndpointScale] using hAvg
  have hk_pos : 0 < ramanujanKappa := ramanujanKappa_pos
  have hdivAvg :
      endpointRatioExcessSum nu X (D.K M) / ramanujanKappa
        ≤ delta * (endpointRatioScale X (D.K M) / ramanujanKappa) := by
    have h := div_le_div_of_nonneg_right hAvgK (le_of_lt hk_pos)
    simpa [mul_div_assoc] using h
  have hScaleMul :
      delta * (endpointRatioScale X (D.K M) / ramanujanKappa)
        ≤ delta * (((M : ℝ) + 1) + D.scaleErr M) :=
    mul_le_mul_of_nonneg_left hScale D.delta_nonneg
  calc
    (∑ i ∈ CutoffRelevantActiveShadowIndexFinset
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        RelevantAt M,
      clippedRealIntervalLength
        (endpointSubwindowIntervalLeft nu X i)
        (endpointSubwindowIntervalRight X i) M)
        ≤ endpointRatioExcessSum nu X (D.K M) / ramanujanKappa := hsum
    _ ≤ delta * (endpointRatioScale X (D.K M) / ramanujanKappa) := hdivAvg
    _ ≤ delta * (((M : ℝ) + 1) + D.scaleErr M) := hScaleMul
    _ = delta * ((M : ℝ) + 1) + delta * D.scaleErr M := by ring

/-! ## Endpoint cutoff-budget data from prefix-scale data -/

/-- A more primitive endpoint budget package: it replaces the abstract closed
length-budget field by prefix-scale data plus the clipped endpoint average. -/
structure EndpointSubwindowCutoffPrefixBudgetData
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Type where
  RelevantAt : ℕ → ℕ → ℕ → Prop
  LiveAt : ℕ → ℕ → Prop
  LiveErr : ℕ → ℝ
  cover : CutoffClosedLiveInitialSegmentCover
    (NonVisibleBadShell nu H V x)
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    RelevantAt LiveAt
  activeCover : CutoffRelevantActiveShadowIndicesCoverUnion
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    RelevantAt
  activeSublinear : CutoffRelevantActiveShadowCountSublinear
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    RelevantAt
  prefixScale : CutoffEndpointPrefixScaleBudgetData X nu delta RelevantAt
  liveErrSublinear : EventuallySublinearCountError LiveErr
  liveBudget : CutoffLiveBoundaryCountBudget LiveAt eps LiveErr

/-- The primitive prefix-budget package constructs the cutoff-aware endpoint
budget data used by the final route. -/
def endpointSubwindowCutoffBudgetData_of_prefixBudgetData
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (D : EndpointSubwindowCutoffPrefixBudgetData X H V nu x delta eps) :
    EndpointSubwindowCutoffRelevantClosedLiveBudgetData
      X H V nu x delta eps := {
  RelevantAt := D.RelevantAt
  LiveAt := D.LiveAt
  ClosedErr := fun M : ℕ => delta * D.prefixScale.scaleErr M
  LiveErr := D.LiveErr
  cover := D.cover
  activeCover := D.activeCover
  activeSublinear := D.activeSublinear
  closedErrSublinear :=
    cutoffEndpointPrefix_deltaScaleErr_sublinear D.prefixScale
  liveErrSublinear := D.liveErrSublinear
  closedLengthBudget := by
    intro havg
    exact cutoffRelevantClippedRealShadowLengthBudget_of_endpointPrefixScaleBudgetData
      D.prefixScale havg
  liveBudget := D.liveBudget
}

/-! ## Canonical final route with prefix-budget endpoint data -/

/-- Canonical live-loss data with endpoint geometry supplied by primitive
