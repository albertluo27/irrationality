/-!
## Direct dynamic cutoff route

The static `TelescopingCutoffBudgetFinalTarget` asks for a zero-live
`ClippedEndpointBudgetSplitWithLiveLoss`.  The cutoff machinery more naturally
produces `EndpointSubwindowCutoffRelevantClosedLiveBudgetData`, which already
implies the density-control field needed by `TelescopingClippedStepDataClean`.
-/

/-- Concrete one-step data where the non-visible-bad control is supplied by the
dynamic cutoff-aware closed/live budget theorem rather than by the static
`ClippedEndpointBudgetSplitWithLiveLoss` interface. -/
structure TelescopingDynamicCutoffStepData (B M : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closure : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_le_B : nu ≤ B
  nu_lt_M : nu < M
  tau_pos : 0 < tau
  x_gt_contraction : shellSpikeContractionExponent tau nu M < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  X_pos : ∀ j : ℕ, 0 < X j
  X_mono : Monotone X
  ratio_cap : RatioBoundedBy X (B - 1)
  cutoffBudget :
    EndpointSubwindowCutoffRelevantClosedLiveBudgetData
      X H V nu x (telescopingClippedEndpointDelta B nu) 0
  gain_strict :
    nu / M + telescopingClippedEndpointDelta B nu < shellSpikeGoodDensityGain tau x

/-- Dynamic cutoff data supplies the `controls` field of the clean telescoping
step data. -/
def TelescopingClippedStepDataClean.ofDynamicCutoff
    {B M : ℝ} (D : TelescopingDynamicCutoffStepData B M) :
    TelescopingClippedStepDataClean B M where
  nu := D.nu
  tau := D.tau
  x := D.x
  X := D.X
  H := D.H
  V := D.V
  Hlog := D.Hlog
  u := D.u
  vseq := D.vseq
  closure := D.closure
  bauer := D.bauer
  nu_gt_two := D.nu_gt_two
  nu_le_B := D.nu_le_B
  nu_lt_M := D.nu_lt_M
  tau_pos := D.tau_pos
  x_gt_contraction := D.x_gt_contraction
  x_lt_one := D.x_lt_one
  x_le_global := D.x_le_global
  gain_le_one := D.gain_le_one
  X_pos := D.X_pos
  X_mono := D.X_mono
  ratio_cap := D.ratio_cap
  controls := by
    intro havg
    have h := nonVisibleBadDensity_of_endpointCutoffRelevantClosedLiveBudgetData
      (X := D.X) (H := D.H) (V := D.V)
      (nu := D.nu) (x := D.x)
      (delta := telescopingClippedEndpointDelta B D.nu) (eps := 0)
