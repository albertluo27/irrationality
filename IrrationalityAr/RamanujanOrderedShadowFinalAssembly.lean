/-! ## Zero-live specialization -/

/-- Scalar parameters for the zero-live branch. -/
structure ClippedStrictSlackZeroLiveScalarData (B : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  nu_gt_two : 2 < nu
  nu_le_B : nu ≤ B
  nu_lt_output : nu < oneThresholdBootstrapRelaxedMap B
  tau_pos : 0 < tau
  x_contraction :
    shellSpikeContractionExponent tau nu (oneThresholdBootstrapRelaxedMap B) < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_surplus_zero :
    nu / oneThresholdBootstrapRelaxedMap B + oneThresholdEndpointDelta B nu
      < shellSpikeGoodDensityGain tau x

/-- Zero-live scalar data is ordinary scalar data with `eps = 0`. -/
def clippedStrictSlackScalarData_of_zeroLive
    {B : ℝ}
    (Z : ClippedStrictSlackZeroLiveScalarData B) :
    ClippedStrictSlackScalarData B := {
  nu := Z.nu
  tau := Z.tau
  x := Z.x
  eps := 0
  nu_gt_two := Z.nu_gt_two
  nu_lt_output := Z.nu_lt_output
  tau_pos := Z.tau_pos
  x_contraction := Z.x_contraction
  x_lt_one := Z.x_lt_one
  x_le_global := Z.x_le_global
  deltaeps_nonneg := by
    have hdelta : 0 ≤ oneThresholdEndpointDelta B Z.nu :=
      oneThresholdEndpointDelta_nonneg Z.nu_gt_two Z.nu_le_B
    simpa using hdelta
  gain_surplus := by
    simpa using Z.gain_surplus_zero
}

/-- Geometric data for the zero-live branch. -/
structure ClippedActiveMassZeroLiveGeometryData
    (B nu tau x : ℝ) : Type where
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  activeData : ClippedOneThresholdActiveMassData X B nu
  split : ClippedEndpointControlsNonVisibleBadWithLiveLoss
    X H V nu x (oneThresholdEndpointDelta B nu) 0
  bauer : BauerRamanujanIdentity

/-- Convert zero-live geometry data into live-loss geometry data. -/
def clippedGeometryData_of_zeroLiveGeometry
    {B nu tau x : ℝ}
    (G : ClippedActiveMassZeroLiveGeometryData B nu tau x) :
    ClippedActiveMassLiveLossGeometryData B nu tau x 0 := {
  X := G.X
  H := G.H
  V := G.V
  Hlog := G.Hlog
  u := G.u
  vseq := G.vseq
  closureCert := G.closureCert
  activeData := G.activeData
  split := G.split
  bauer := G.bauer
}

/-- Zero-live scalar target. -/
def ClippedStrictSlackZeroLiveScalarDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedStrictSlackZeroLiveScalarData B)

/-- Zero-live geometric target. -/
def ClippedActiveMassZeroLiveGeometryDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        ∀ Z : ClippedStrictSlackZeroLiveScalarData B,
          Nonempty (ClippedActiveMassZeroLiveGeometryData B Z.nu Z.tau Z.x)

/-- Direct zero-live raw-data target from matching zero-live scalar and geometry
targets. -/
theorem clippedRawDataTarget_of_zeroLiveTargets
    (hscalar : ClippedStrictSlackZeroLiveScalarDataTarget)
    (hgeom : ClippedActiveMassZeroLiveGeometryDataTarget) :
    ClippedActiveMassLiveLossStrictSlackRawDataTarget := by
  intro B hB hBound
  rcases hscalar B hB hBound with ⟨Z⟩
  rcases hgeom B hB hBound Z with ⟨G0⟩
  let S : ClippedStrictSlackScalarData B :=
    clippedStrictSlackScalarData_of_zeroLive Z
  let G : ClippedActiveMassLiveLossGeometryData B S.nu S.tau S.x S.eps := by
    change ClippedActiveMassLiveLossGeometryData B Z.nu Z.tau Z.x 0
    exact clippedGeometryData_of_zeroLiveGeometry G0
  exact ⟨clippedRawData_of_scalar_geometry S G⟩

/-- Final package for the zero-live branch. -/
