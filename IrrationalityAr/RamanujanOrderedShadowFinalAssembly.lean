  rcases hShifted B hB hBound with ⟨D⟩
  exact ⟨clippedLayerCakeQuadraticGeometricCoreData_of_oneOverPiShiftedData D⟩

/-- Final wrapper from the concrete shifted one-over-pi target. -/
theorem oneOverPi_irratMeasure_le_four_of_oneOverPiShiftedQuadraticGeometricCoreDataTarget
    (hShifted : OneOverPiShiftedQuadraticGeometricCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
