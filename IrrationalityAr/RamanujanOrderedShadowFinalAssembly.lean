/-!
# Pure geometric finite count: power/log split

This layer refines `PureGeometricFinsetLogCountTarget` into two smaller target
predicates: a finite combinatorial power bound for multiplicatively separated
finsets, and a real-variable logarithmic algebra step converting that power
bound into an `O(log M)` count.
-/

/-! ## Atomic pure targets -/

/-- Finite combinatorial power bound for multiplicatively separated finsets.

If every selected value lies in `[L, Acoeff * M]` and selected values are
multiplicatively separated by `rho > 1` in increasing index order, then either
there are no selected indices or
`L * rho ^ (card - 1) <= Acoeff * M`. -/
def PureGeometricPowerBoundTarget : Prop :=
  ∀ (rho L Acoeff : ℝ) (A : Finset ℕ) (X : ℕ → ℝ) (M : ℕ),
    1 < rho →
      0 < L →
        0 ≤ Acoeff →
          (∀ j : ℕ, j ∈ A → L ≤ X j) →
            (∀ j : ℕ, j ∈ A → X j ≤ Acoeff * (M : ℝ)) →
              FinsetMultiplicativelySeparated A X rho →
                A.card = 0 ∨
                  L * rho ^ (A.card - 1) ≤ Acoeff * (M : ℝ)

/-- Logarithmic algebra target.

This is the real-variable step: if the power bound holds for every cutoff `M`,
then the cardinals are eventually bounded by `C * log (M + 2)` for some
nonnegative `C`. -/
def PureGeometricPowerBoundToLogCountTarget : Prop :=
  ∀ (rho L Acoeff : ℝ) (F : ℕ → Finset ℕ) (_X : ℕ → ℝ),
    1 < rho →
      0 < L →
        0 ≤ Acoeff →
          (∀ M : ℕ,
            (F M).card = 0 ∨
              L * rho ^ ((F M).card - 1) ≤ Acoeff * (M : ℝ)) →
            ∃ C : ℝ,
              0 ≤ C ∧
                ∀ᶠ M : ℕ in atTop,
                  ((F M).card : ℝ) ≤ C * Real.log ((M : ℝ) + 2)

/-- Bundled form of the two pure power/log targets. -/
def PureGeometricPowerLogTargets : Prop :=
  PureGeometricPowerBoundTarget ∧
    PureGeometricPowerBoundToLogCountTarget

/-! ## The split targets imply the existing pure geometric count target -/

/-- The finite power bound and the logarithmic algebra step imply the existing
`PureGeometricFinsetLogCountTarget`. -/
theorem pureGeometricFinsetLogCountTarget_of_powerBound_and_logAlgebra
    (hpow : PureGeometricPowerBoundTarget)
    (hlog : PureGeometricPowerBoundToLogCountTarget) :
    PureGeometricFinsetLogCountTarget := by
  intro rho L Acoeff F X hrho hL hAcoeff hLower hUpper hSep
  exact hlog rho L Acoeff F X hrho hL hAcoeff (by
    intro M
    exact hpow rho L Acoeff (F M) X M hrho hL hAcoeff
      (fun j hj => hLower M j hj)
      (fun j hj => hUpper M j hj)
      (hSep M))

/-- Bundled power/log targets imply the existing pure geometric count target. -/
theorem pureGeometricFinsetLogCountTarget_of_powerLogTargets
    (h : PureGeometricPowerLogTargets) :
    PureGeometricFinsetLogCountTarget := by
  exact pureGeometricFinsetLogCountTarget_of_powerBound_and_logAlgebra
    h.1 h.2

