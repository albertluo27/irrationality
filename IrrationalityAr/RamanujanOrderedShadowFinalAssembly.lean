  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  activeData : ClippedOneThresholdActiveMassData X B nu
  split : ClippedEndpointControlsNonVisibleBadWithLiveLoss
    X H V nu x (oneThresholdEndpointDelta B nu) eps
  bauer : BauerRamanujanIdentity

/-- Combine scalar data and geometric data into the raw strict-slack data. -/
def clippedRawData_of_scalar_geometry
    {B : ℝ}
    (S : ClippedStrictSlackScalarData B)
    (G : ClippedActiveMassLiveLossGeometryData B S.nu S.tau S.x S.eps) :
    ClippedActiveMassLiveLossStrictSlackRawData B := {
  nu := S.nu
  tau := S.tau
  x := S.x
  eps := S.eps
  X := G.X
  H := G.H
  V := G.V
  Hlog := G.Hlog
  u := G.u
  vseq := G.vseq
  closureCert := G.closureCert
  activeData := G.activeData
  split := G.split
  bauer := G.bauer
  nu_gt_two := S.nu_gt_two
  nu_lt_output := S.nu_lt_output
  tau_pos := S.tau_pos
  x_contraction := S.x_contraction
  x_lt_one := S.x_lt_one
  x_le_global := S.x_le_global
  deltaeps_nonneg := S.deltaeps_nonneg
  gain_surplus := S.gain_surplus
}

/-- Target for scalar strict-slack parameters.  The input bound is included so
future proofs may choose parameters depending on the current measure bound. -/
def ClippedStrictSlackScalarDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedStrictSlackScalarData B)

/-- Target for the geometric data once scalar parameters have been chosen. -/
def ClippedActiveMassLiveLossGeometryDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        ∀ S : ClippedStrictSlackScalarData B,
          Nonempty (ClippedActiveMassLiveLossGeometryData B S.nu S.tau S.x S.eps)

/-- Scalar target plus geometric target gives the raw-data target. -/
theorem clippedRawDataTarget_of_scalar_geometryTargets
    (hscalar : ClippedStrictSlackScalarDataTarget)
    (hgeom : ClippedActiveMassLiveLossGeometryDataTarget) :
    ClippedActiveMassLiveLossStrictSlackRawDataTarget := by
  intro B hB hBound
  rcases hscalar B hB hBound with ⟨S⟩
  rcases hgeom B hB hBound S with ⟨G⟩
  exact ⟨clippedRawData_of_scalar_geometry S G⟩

/-- Final package split into scalar and geometric targets. -/
structure ClippedComponentFinalPackage (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  scalarData : ClippedStrictSlackScalarDataTarget
  geometryData : ClippedActiveMassLiveLossGeometryDataTarget
  relaxedMapAboveFour : OneThresholdBootstrapRelaxedMapAboveFour
  relaxedSeqConverges : OneThresholdBootstrapRelaxedSeqConvergesToFour B0

/-- Component final package gives the raw final package. -/
def clippedRawFinalPackage_of_componentFinalPackage
    {B0 : ℝ}
    (P : ClippedComponentFinalPackage B0) :
    ClippedActiveMassLiveLossStrictSlackRawFinalPackage B0 := {
  startBound := P.startBound
  startAboveFour := P.startAboveFour
