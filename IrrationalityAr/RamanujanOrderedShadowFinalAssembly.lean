/-!
# Pure geometric finite count: power-bound closure

This closes the finite combinatorial half of the pure geometric count split.
The only remaining pure-count ingredient is the real logarithmic algebra target
`PureGeometricPowerBoundToLogCountTarget`.
-/

/-! ## Finite max-element power bound -/

/-- A multiplicatively separated nonempty finset has geometric growth up to its
maximum selected index. -/
theorem pureGeometric_powerBound_to_max
    {rho L : ℝ} {A : Finset ℕ} {X : ℕ → ℝ}
    (hrho : 1 < rho)
    (_hL : 0 < L)
    (hLower : ∀ j : ℕ, j ∈ A → L ≤ X j)
    (hSep : FinsetMultiplicativelySeparated A X rho)
    (hAne : A.Nonempty) :
    L * rho ^ (A.card - 1) ≤ X (A.max' hAne) := by
  classical
  have hstrong :
      ∀ n : ℕ,
        ∀ A : Finset ℕ,
          A.card = n →
            (∀ j : ℕ, j ∈ A → L ≤ X j) →
              FinsetMultiplicativelySeparated A X rho →
                ∀ hAne : A.Nonempty,
                  L * rho ^ (A.card - 1) ≤ X (A.max' hAne) := by
    intro n
    induction n using Nat.strong_induction_on with
    | h n ih =>
        intro A hcard hLower hSep hAne
        by_cases hcard_one : A.card = 1
        · have hpow : rho ^ (A.card - 1) = 1 := by
            rw [hcard_one]
            norm_num
          simpa [hpow] using hLower (A.max' hAne) (Finset.max'_mem A hAne)
        · let m : ℕ := A.max' hAne
          have hmA : m ∈ A := by
            simpa [m] using Finset.max'_mem A hAne
          let B : Finset ℕ := A.erase m
          have hBcard : B.card = A.card - 1 := by
            dsimp [B]
            exact Finset.card_erase_of_mem hmA
          have hAcard_pos : 0 < A.card := Finset.card_pos.mpr hAne
          have hAcard_ge_two : 2 ≤ A.card := by
            omega
          have hBpos : 0 < B.card := by
            rw [hBcard]
            omega
          have hBne : B.Nonempty := Finset.card_pos.mp hBpos
          let b : ℕ := B.max' hBne
          have hbB : b ∈ B := by
            simpa [b] using Finset.max'_mem B hBne
          have hb_erase := Finset.mem_erase.mp hbB
          have hb_ne_m : b ≠ m := hb_erase.1
          have hbA : b ∈ A := hb_erase.2
          have hb_le_m : b ≤ m := by
            simpa [m] using Finset.le_max' A b hbA
          have hb_lt_m : b < m := lt_of_le_of_ne hb_le_m hb_ne_m
          have hLowerB : ∀ j : ℕ, j ∈ B → L ≤ X j := by
            intro j hj
            exact hLower j (Finset.mem_erase.mp hj).2
          have hSepB : FinsetMultiplicativelySeparated B X rho := by
            intro i j hi hj hij
            exact hSep i j
              (Finset.mem_erase.mp hi).2
              (Finset.mem_erase.mp hj).2 hij
          have hBlt : B.card < n := by
            rw [← hcard]
            rw [hBcard]
            omega
          have hInd : L * rho ^ (B.card - 1) ≤ X b := by
            simpa [b] using ih B.card hBlt B rfl hLowerB hSepB hBne
          have hrho_pos : 0 < rho := by linarith
          have hrho_nonneg : 0 ≤ rho := le_of_lt hrho_pos
          have hmul_ind :
              rho * (L * rho ^ (B.card - 1)) ≤ rho * X b :=
            mul_le_mul_of_nonneg_left hInd hrho_nonneg
          have hsep_bm : rho * X b ≤ X m :=
            hSep b m hbA hmA hb_lt_m
          have hchain :
              rho * (L * rho ^ (B.card - 1)) ≤ X m :=
            le_trans hmul_ind hsep_bm
          have hcard_minus : A.card - 1 = B.card := by
            rw [hBcard]
          have hpoweq :
              rho * (L * rho ^ (B.card - 1)) =
                L * rho ^ (A.card - 1) := by
            rw [hcard_minus]
            calc
              rho * (L * rho ^ (B.card - 1))
                  = L * (rho ^ (B.card - 1) * rho) := by ring
              _ = L * rho ^ ((B.card - 1) + 1) := by rw [pow_succ]
              _ = L * rho ^ B.card := by
                    have hsub : B.card - 1 + 1 = B.card := by omega
                    rw [hsub]
          simpa [m, hpoweq] using hchain
  exact hstrong A.card A rfl hLower hSep hAne

/-- The finite combinatorial power-bound target is now proved. -/
theorem pureGeometricPowerBoundTarget_proved :
    PureGeometricPowerBoundTarget := by
  intro rho L Acoeff A X M hrho hL _hAcoeff hLower hUpper hSep
  classical
  by_cases hA0 : A.card = 0
  · exact Or.inl hA0
  · right
    have hApos : 0 < A.card := Nat.pos_of_ne_zero hA0
    have hAne : A.Nonempty := Finset.card_pos.mp hApos
    let m : ℕ := A.max' hAne
    have hmA : m ∈ A := by
      simpa [m] using Finset.max'_mem A hAne
    have hmax : L * rho ^ (A.card - 1) ≤ X m := by
      simpa [m] using
        pureGeometric_powerBound_to_max
          (rho := rho) (L := L) (A := A) (X := X)
          hrho hL hLower hSep hAne
    exact le_trans hmax (hUpper m hmA)

/-! ## Power/log package with only the real log-algebra target left -/

/-- The proved power bound plus the remaining log-algebra target gives the
bundled power/log targets. -/
theorem pureGeometricPowerLogTargets_of_logAlgebra
    (hlog : PureGeometricPowerBoundToLogCountTarget) :
    PureGeometricPowerLogTargets := by
  exact ⟨pureGeometricPowerBoundTarget_proved, hlog⟩

/-- Final package after closing the finite power-bound target.  The only pure
geometric-count input left is the real logarithmic algebra statement. -/
structure ClippedCanonicalLiveLossPrefixActiveRelevantLogAlgebraFinalPackage
    (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  logAlgebra : PureGeometricPowerBoundToLogCountTarget
  geometricTarget : ClippedCanonicalLiveLossPrefixActiveRelevantGeometricCountTarget
