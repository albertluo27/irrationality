/-! ## Fixed-tail actual-qlog endpoint data -/

/-- Endpoint data for one fixed tail of the actual one-over-pi qlog sequence.

At tail `s`, the denominator-log scale is fixed to
`tailShiftSeq (oneOverPiShiftedQlog 0) s`.  The auxiliary endpoint-shadow
sequences are allowed to be tail-specific. -/
structure ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
    (B : ℝ) (hB : 4 < B) (s : ℕ) : Type where
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate
      Hlog u vseq H V
      (clippedCanonicalStrictSlackScalarData B hB).tau
      (clippedCanonicalStrictSlackScalarData B hB).x
  logCountData :
    EndpointSubwindowCutoffPrefixActiveRelevantLogCountData
      (tailShiftSeq (oneOverPiShiftedQlog 0) s)
      H V
      (clippedCanonicalStrictSlackScalarData B hB).nu
      (clippedCanonicalStrictSlackScalarData B hB).x
      (oneThresholdEndpointDelta B
        (clippedCanonicalStrictSlackScalarData B hB).nu)
      (clippedCanonicalStrictSlackScalarData B hB).eps
  prefixControl : EndpointPrefixControlledByBelowLeftActiveCountData
    (clippedCanonicalStrictSlackScalarData B hB).nu
    (tailShiftSeq (oneOverPiShiftedQlog 0) s)
    logCountData.K

/-- A fixed-tail actual-qlog payload plus global tail positivity and ratio cap
constructs the Bauer-free endpoint-only controlled-prefix data. -/
def clippedCanonicalControlledPrefixEndpointOnlyData_of_actualQlogShiftData
    {B : ℝ} {hB : 4 < B} {s : ℕ}
    (D :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
        B hB s)
    (hpos : ∀ j : ℕ, 0 < tailShiftSeq (oneOverPiShiftedQlog 0) s j)
    (hcap : RatioBoundedBy (tailShiftSeq (oneOverPiShiftedQlog 0) s) (B - 1)) :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixEndpointOnlyData
      B hB := {
  base := {
    X := tailShiftSeq (oneOverPiShiftedQlog 0) s
    H := D.H
    V := D.V
    Hlog := D.Hlog
    u := D.u
    vseq := D.vseq
    closureCert := D.closureCert
    nu_le_B := clippedCanonicalStrictSlackScalarData_nu_le_B (B := B) hB
    X_pos := hpos
    X_mono := monotone_tailShiftSeq
      (X := oneOverPiShiftedQlog 0) (N := s)
      (oneOverPiShiftedQlog_monotone 0)
    ratio_cap := hcap
    logCountData := D.logCountData
  }
  prefixControl := D.prefixControl
}

/-! ## Eventual-tail target -/

/-- Eventual-tail actual-qlog endpoint target.

For each strict cap `B`, the endpoint geometry/counting payload is required
only for all sufficiently large shifts of the actual qlog sequence. -/
def ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogEventuallyTailTarget :
    Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelow B →
        ∀ᶠ s : ℕ in atTop,
          Nonempty
            (ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
              B hB s)

/-- From eventual tail positivity, eventual ratio cap, and eventual endpoint
geometry, choose a single tail satisfying all three requirements. -/
def activeLogCountControlledPrefixEndpointOnlyData_of_actualQlogEventuallyTail
    {B : ℝ} {hB : 4 < B}
    (hBound : OneOverPiMeasureStrictlyBelow B)
    (hGeom :
      ∀ᶠ s : ℕ in atTop,
        Nonempty
          (ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
            B hB s)) :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixEndpointOnlyData
      B hB := by
  classical
  have hPosEv : ∀ᶠ j : ℕ in atTop, 0 < oneOverPiShiftedQlog 0 j :=
    oneOverPiShiftedQlog_eventuallyPositiveLogScale 0
  have hCapEv : EventuallyRatioBoundedBy (oneOverPiShiftedQlog 0) (B - 1) :=
    eventuallyRatioBoundedBy_actual_oneOverPiQlog_of_strictCap
      (B := B) hBound
  have hExists :
      ∃ s : ℕ,
        (∀ j : ℕ, 0 < tailShiftSeq (oneOverPiShiftedQlog 0) s j) ∧
          RatioBoundedBy (tailShiftSeq (oneOverPiShiftedQlog 0) s) (B - 1) ∧
            Nonempty
              (ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
                B hB s) := by
    rcases (Filter.eventually_atTop.1 hPosEv) with ⟨Npos, hNpos⟩
    rcases (Filter.eventually_atTop.1 hCapEv) with ⟨Ncap, hNcap⟩
    rcases (Filter.eventually_atTop.1 hGeom) with ⟨Ngeom, hNgeom⟩
    let s : ℕ := max Ngeom (max Npos Ncap)
    have hgeom_s : Ngeom ≤ s := by
      dsimp [s]
      exact Nat.le_max_left _ _
    have hpos_s : Npos ≤ s := by
      dsimp [s]
      exact le_trans (Nat.le_max_left Npos Ncap)
        (Nat.le_max_right Ngeom (max Npos Ncap))
    have hcap_s : Ncap ≤ s := by
      dsimp [s]
      exact le_trans (Nat.le_max_right Npos Ncap)
        (Nat.le_max_right Ngeom (max Npos Ncap))
    have hspos : ∀ j : ℕ, 0 < tailShiftSeq (oneOverPiShiftedQlog 0) s j := by
      intro j
      unfold tailShiftSeq
      exact hNpos (s + j)
        (le_trans hpos_s (Nat.le_add_right s j))
    have hscap : RatioBoundedBy (tailShiftSeq (oneOverPiShiftedQlog 0) s) (B - 1) := by
      intro j
      rw [logJumpRatio_tailShiftSeq]
      exact hNcap (s + j)
        (le_trans hcap_s (Nat.le_add_right s j))
    exact ⟨s, hspos, hscap, hNgeom s hgeom_s⟩
  let s : ℕ := Classical.choose hExists
  have hspos : ∀ j : ℕ, 0 < tailShiftSeq (oneOverPiShiftedQlog 0) s j :=
    (Classical.choose_spec hExists).1
  have hscap : RatioBoundedBy (tailShiftSeq (oneOverPiShiftedQlog 0) s) (B - 1) :=
    (Classical.choose_spec hExists).2.1
  let D :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogShiftData
        B hB s :=
    Classical.choice (Classical.choose_spec hExists).2.2
  exact
    clippedCanonicalControlledPrefixEndpointOnlyData_of_actualQlogShiftData
      (B := B) (hB := hB) (s := s) D hspos hscap

/-- The eventual-tail actual-qlog target implies the previous endpoint-only
controlled-prefix target. -/
theorem activeLogCountControlledPrefixEndpointOnlyTarget_of_actualQlogEventuallyTailTarget
    (h :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogEventuallyTailTarget) :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixEndpointOnlyTarget := by
  intro B hB hBound
  exact ⟨activeLogCountControlledPrefixEndpointOnlyData_of_actualQlogEventuallyTail
    (B := B) (hB := hB) hBound (h B hB hBound)⟩

