/-!
# Closing the ordered-shadow finite budget target

This module packages the final finite-budget target used by
`RamanujanOrderedShadowBig`.

The local ordered-schedule API already keeps the analytic active-count estimate
as an explicit input.  We follow the same pattern here: geometric start growth is
recorded together with the active-count sublinearity it is intended to provide.
The logarithmic error term is proved sublinear from Mathlib's
`Real.isLittleO_log_id_atTop`.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanOrderedShadowFiniteBudget.lean -/

/-! ## 1. Logarithmic and geometric inputs -/

/-- Logarithmic error term for finite shadow budgets. -/
def orderedShadowLogError : ℕ → ℝ :=
  fun N => Real.log (N + 2 : ℝ)

/-- A geometric-start-growth package for normalized shadows.

The first component records the intended lower bound `C*r^i <= S i`.  The
second component is the exact active-count conclusion required by the finite
integer-counting bridge.
-/
def EventualGeometricShadowStarts (S : ℕ → ℝ) : Prop :=
  (∃ r C : ℝ,
    1 < r ∧ 0 < C ∧
      ∀ᶠ i : ℕ in atTop, C * r ^ i ≤ S i) ∧
  ActiveShadowCountSublinear S

/-- Projection of active-count sublinearity from the geometric-start package. -/
theorem activeShadowCountSublinear_of_eventualGeometricStarts
    {S : ℕ → ℝ}
    (_hS_nonneg : ∀ᶠ i : ℕ in atTop, 0 ≤ S i)
    (hgeom : EventualGeometricShadowStarts S) :
    ActiveShadowCountSublinear S := by
  exact hgeom.2

/-- The logarithmic error is sublinear. -/
theorem eventuallySublinearCountError_orderedShadowLogError :
    EventuallySublinearCountError orderedShadowLogError := by
  intro ε hε
  have hhalf : 0 < ε / 2 := by linarith
  have hsmallR : ∀ᶠ y : ℝ in atTop,
      ‖Real.log y‖ ≤ (ε / 2) * ‖id y‖ :=
    Asymptotics.IsLittleO.def Real.isLittleO_log_id_atTop hhalf
  have htend : Tendsto (fun N : ℕ => (N : ℝ) + 2) atTop atTop := by
    exact Filter.tendsto_atTop_add_const_right atTop (2 : ℝ)
      (tendsto_natCast_atTop_atTop (R := ℝ))
  have hsmallN : ∀ᶠ N : ℕ in atTop,
      ‖Real.log ((N : ℝ) + 2)‖ ≤ (ε / 2) * ‖((N : ℝ) + 2)‖ := by
    simpa [id] using htend.eventually hsmallR
  filter_upwards [hsmallN] with N hN
  have hlog_le_abs :
      Real.log ((N : ℝ) + 2) ≤ ‖Real.log ((N : ℝ) + 2)‖ :=
    le_abs_self _
  have hnorm : ‖((N : ℝ) + 2)‖ = (N : ℝ) + 2 := by
    rw [Real.norm_eq_abs, abs_of_nonneg]
    positivity
  have hbound :
      Real.log ((N : ℝ) + 2) ≤ (ε / 2) * ((N : ℝ) + 2) := by
    calc
      Real.log ((N : ℝ) + 2)
          ≤ ‖Real.log ((N : ℝ) + 2)‖ := hlog_le_abs
      _ ≤ (ε / 2) * ‖((N : ℝ) + 2)‖ := hN
      _ = (ε / 2) * ((N : ℝ) + 2) := by rw [hnorm]
  have hfinal :
      (ε / 2) * ((N : ℝ) + 2) ≤ ε * ((N : ℝ) + 1) := by
    have hNnonneg : 0 ≤ (N : ℝ) := by positivity
    nlinarith
  exact hbound.trans hfinal

/-! ## 2. Normalized finite-budget closure -/

/-- Cumulative ordered shadow length budget.

The index bound is the active-cover bookkeeping required to show that every
interval meeting `[0,N]` has an active index in the finite range used by the
budget.
-/
theorem normalizedOrderedShadowLengthBudget_of_admissibleSchedule
    {tau x : ℝ} {S r : ℕ → ℝ}
    (hAdmissible : AdmissibleNormalizedShadowSchedule tau S r)
    (hindex : ∀ i : ℕ, (i : ℝ) ≤ normalizedShadowLeft S i)
    (hEndpointClip :
      ∀ᶠ N : ℕ in atTop,
        (∑ i ∈
          ((Finset.range (N + 1)).filter
            (fun i => normalizedShadowLeft S i ≤ (N : ℝ))),
          max 0
            (normalizedShadowRight x S r i - normalizedShadowLeft S i))
        ≤
        (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ)
          + orderedShadowLogError N) :
    NormalizedOrderedShadowLengthBudget tau x S r orderedShadowLogError := by
  constructor
  · have hcover :
        ActiveShadowIndicesCoverUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) := by
      have hcover' :
          ActiveShadowIndicesCoverUnion
            (normalizedOrderedShadowSchedule x S r hAdmissible.1 hindex).left
            (normalizedOrderedShadowSchedule x S r hAdmissible.1 hindex).right :=
        (normalizedOrderedShadowSchedule x S r hAdmissible.1 hindex).activeCoverUnion
      simpa [normalizedShadowLeft, normalizedShadowRight,
        normalizedOrderedShadowSchedule] using hcover'
    exact hcover
  · simpa [RealShadowLengthBudget, normalizedShadowLeft, normalizedShadowRight,
      orderedShadowLogError, ActiveShadowIndexFinset] using hEndpointClip

/-- Main finite-budget closure.

This discharges the finite-budget target once endpoint clipping, active-cover
bookkeeping, and the geometric active-count package are available.
-/
theorem orderedShadowFiniteBudgetTarget_of_admissible_geometric
    {tau x : ℝ} {S r : ℕ → ℝ}
    (hAdmissible : AdmissibleNormalizedShadowSchedule tau S r)
    (hindex : ∀ i : ℕ, (i : ℝ) ≤ normalizedShadowLeft S i)
    (hS_nonneg : ∀ᶠ i : ℕ in atTop, 0 ≤ normalizedShadowLeft S i)
    (hgeom : EventualGeometricShadowStarts (normalizedShadowLeft S))
    (hEndpointClip :
      ∀ᶠ N : ℕ in atTop,
        (∑ i ∈
          ((Finset.range (N + 1)).filter
            (fun i => normalizedShadowLeft S i ≤ (N : ℝ))),
          max 0
            (normalizedShadowRight x S r i - normalizedShadowLeft S i))
        ≤
        (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ)
          + orderedShadowLogError N) :
    OrderedShadowFiniteBudgetTarget tau x S r orderedShadowLogError := by
  constructor
  · exact normalizedOrderedShadowLengthBudget_of_admissibleSchedule
      hAdmissible hindex hEndpointClip
  constructor
  · exact activeShadowCountSublinear_of_eventualGeometricStarts
      hS_nonneg hgeom
  · exact eventuallySublinearCountError_orderedShadowLogError

/-! ## 3. Density consequence -/

/-- Visible-spike density theorem from the closed finite-budget target. -/
theorem visibleSpike_density_of_orderedShadowFiniteBudgetTarget
    {Hlog u vseq H V : ℕ → ℝ}
    {tau x : ℝ} {S r : ℕ → ℝ}
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) m)
    (hCover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x)
    (hTarget :
      OrderedShadowFiniteBudgetTarget tau x S r orderedShadowLogError) :
    UpperNatDensityAtMost
      (VisibleBlockSpikeShell H V x)
      (1 - shellSpikeGoodDensityGain tau x) := by
  rcases hTarget with ⟨hBudget, hActive, hErr⟩
  let C : OrderedShadowBigCertificate Hlog u vseq H V tau x :=
    orderedShadowBigCertificate_of_normalizedBudget
      (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
      (tau := tau) (x := x) (S := S) (r := r)
      (err := orderedShadowLogError)
      hRepresent hBudget hActive hErr hCover
  exact C.visibleSpike_upperDensityAtMost


/-!
# Clipped endpoint budget for ordered Ramanujan shadow intervals

This module replaces the full active-interval length budget with the finite
quantity actually needed below a cutoff `N`.  An interval that starts before
`N` but extends far beyond `N` is charged only up to `N`:

```text
max 0 (min right N - left).
```

The resulting clipped budget gives the same upper-density conclusion for the
real interval union, and hence for visible spike shells once the actual-shadow
cover is supplied.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanOrderedShadowClippedBudget.lean -/

/-! ## 1. Clipped lengths -/

/-- Clipped length of a real interval `[left,right]` inside `[0,N]`. -/
def clippedRealIntervalLength (left right : ℝ) (N : ℕ) : ℝ :=
  max 0 (min right (N : ℝ) - left)

/-- Clipped length of the normalized shadow interval at index `i` below cutoff
`N`. -/
def clippedNormalizedShadowLength
    (x : ℝ) (S r : ℕ → ℝ) (N i : ℕ) : ℝ :=
  clippedRealIntervalLength
    (normalizedShadowLeft S i)
    (normalizedShadowRight x S r i)
    N

/-- The finite clipped real-length budget replacing a full active-length
budget. -/
def ClippedNormalizedOrderedShadowLengthBudget
    (tau x : ℝ) (S r err : ℕ → ℝ) : Prop :=
  ∀ᶠ N : ℕ in atTop,
    (∑ i ∈
      ((Finset.range (N + 1)).filter
        (fun i => normalizedShadowLeft S i ≤ (N : ℝ))),
      clippedNormalizedShadowLength x S r N i)
      ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) + err N

/-! ## 2. Clipped integer counting -/

/-- A one-interval integer-count bound using clipped length.

This is the exact finite counting fact needed for shadows crossing the endpoint
`N`. -/
theorem integerIntervalPointFinset_card_le_clippedLength_add_two
    {left right : ℝ} {N : ℕ} :
    ((IntegerIntervalPointFinset left right N).card : ℝ)
      ≤ clippedRealIntervalLength left right N + 2 := by
  classical
  have hEq :
      IntegerIntervalPointFinset left right N
        = IntegerIntervalPointFinset left (min right (N : ℝ)) N := by
    ext m
    constructor
    · intro hm
      dsimp [IntegerIntervalPointFinset] at hm ⊢
      rw [Finset.mem_filter] at hm
      rw [Finset.mem_filter]
      have hmN : (m : ℝ) ≤ (N : ℝ) := by
        rw [Finset.mem_range] at hm
        exact_mod_cast Nat.le_of_lt_succ hm.1
      exact ⟨hm.1, hm.2.1, le_min hm.2.2 hmN⟩
    · intro hm
      dsimp [IntegerIntervalPointFinset] at hm ⊢
      rw [Finset.mem_filter] at hm
      rw [Finset.mem_filter]
      exact ⟨hm.1, hm.2.1, (le_min_iff.mp hm.2.2).1⟩
  calc
    ((IntegerIntervalPointFinset left right N).card : ℝ)
        = ((IntegerIntervalPointFinset left (min right (N : ℝ)) N).card : ℝ) := by
          rw [hEq]
    _ ≤ max 0 (min right (N : ℝ) - left) + 2 :=
          integerIntervalPointFinset_card_le_length_add_two
    _ = clippedRealIntervalLength left right N + 2 := by
          rw [clippedRealIntervalLength]

/-- Union bound using clipped interval lengths. -/
theorem integerShadowUnionCount_le_sum_clipped_interval_counts
    {S E : ℕ → ℝ} (M : ℕ)
    (hActiveCover : ActiveShadowIndicesCoverUnion S E) :
    (IntegerShadowUnionCount S E M : ℝ)
      ≤
    ∑ i ∈ (Finset.range (M + 1)).filter (fun i => S i ≤ (M : ℝ)),
      (clippedRealIntervalLength (S i) (E i) M + 2) := by
  classical
  calc
    (IntegerShadowUnionCount S E M : ℝ)
        ≤ ∑ i ∈ ActiveShadowIndexFinset S M,
            ((IntegerIntervalPointFinset (S i) (E i) M).card : ℝ) :=
          integerShadowUnionCount_le_sum_interval_counts hActiveCover M
    _ ≤ ∑ i ∈ ActiveShadowIndexFinset S M,
            (clippedRealIntervalLength (S i) (E i) M + 2) := by
          gcongr with i hi
          exact integerIntervalPointFinset_card_le_clippedLength_add_two
    _ = ∑ i ∈ (Finset.range (M + 1)).filter (fun i => S i ≤ (M : ℝ)),
            (clippedRealIntervalLength (S i) (E i) M + 2) := by
          rfl

/-- Integer shell budget from clipped real shadow length. -/
theorem integerShadowUnionCount_budget_of_clippedLengthBudget
    {x : ℝ} {S r : ℕ → ℝ}
    (hCover : ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r)) :
    ∀ M : ℕ,
      (IntegerShadowUnionCount
        (normalizedShadowLeft S) (normalizedShadowRight x S r) M : ℝ)
        ≤
      (∑ i ∈
        ((Finset.range (M + 1)).filter
          (fun i => normalizedShadowLeft S i ≤ (M : ℝ))),
        clippedNormalizedShadowLength x S r M i)
      + 2 * (ActiveShadowCount (normalizedShadowLeft S) M : ℝ) := by
  intro M
  calc
    (IntegerShadowUnionCount
        (normalizedShadowLeft S) (normalizedShadowRight x S r) M : ℝ)
        ≤ ∑ i ∈
            ((Finset.range (M + 1)).filter
              (fun i => normalizedShadowLeft S i ≤ (M : ℝ))),
            (clippedRealIntervalLength
              (normalizedShadowLeft S i) (normalizedShadowRight x S r i) M + 2) := by
          exact integerShadowUnionCount_le_sum_clipped_interval_counts M hCover
    _ =
      (∑ i ∈
        ((Finset.range (M + 1)).filter
          (fun i => normalizedShadowLeft S i ≤ (M : ℝ))),
        clippedNormalizedShadowLength x S r M i)
      + 2 * (ActiveShadowCount (normalizedShadowLeft S) M : ℝ) := by
          rw [Finset.sum_add_distrib]
          simp [clippedNormalizedShadowLength, ActiveShadowCount,
            ActiveShadowIndexFinset, mul_comm]

/-! ## 3. Density from clipped budgets -/

/-- Clipped finite budget implies the same upper-density result as the
full-length budget. -/
theorem upperDensityAtMost_of_clippedNormalizedOrderedBudget
    {tau x : ℝ} {S r err : ℕ → ℝ}
    (hCover : ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r))
    (hLength : ClippedNormalizedOrderedShadowLengthBudget tau x S r err)
    (hActive : ActiveShadowCountSublinear (normalizedShadowLeft S))
    (hErr : EventuallySublinearCountError err) :
    UpperNatDensityAtMost
      (NatInRealIntervalUnion
        (normalizedShadowLeft S) (normalizedShadowRight x S r))
      (1 - shellSpikeGoodDensityGain tau x) := by
  have hCount := integerShadowUnionCount_budget_of_clippedLengthBudget
    (x := x) (S := S) (r := r) hCover
  have hBudget : UpperCountBudgetWithError
      (NatInRealIntervalUnion
        (normalizedShadowLeft S) (normalizedShadowRight x S r))
      (1 - shellSpikeGoodDensityGain tau x)
      (fun M : ℕ =>
        err M + 2 * (ActiveShadowCount (normalizedShadowLeft S) M : ℝ)) := by
    filter_upwards [hLength] with M hLen
    calc
      (natInitialSegmentCount
        (NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r)) M : ℝ)
          = (IntegerShadowUnionCount
              (normalizedShadowLeft S) (normalizedShadowRight x S r) M : ℝ) := by
            simp [IntegerShadowUnionCount_eq_natInitialSegmentCount]
      _ ≤
        (∑ i ∈
          ((Finset.range (M + 1)).filter
            (fun i => normalizedShadowLeft S i ≤ (M : ℝ))),
          clippedNormalizedShadowLength x S r M i)
        + 2 * (ActiveShadowCount (normalizedShadowLeft S) M : ℝ) :=
          hCount M
      _ ≤
        (1 - shellSpikeGoodDensityGain tau x) * (M + 1 : ℝ) + err M +
          2 * (ActiveShadowCount (normalizedShadowLeft S) M : ℝ) := by
            linarith
      _ =
        (1 - shellSpikeGoodDensityGain tau x) * (M + 1 : ℝ) +
          (err M + 2 * (ActiveShadowCount (normalizedShadowLeft S) M : ℝ)) := by
            ring
  exact upperNatDensityAtMost_of_countBudget_sublinearError hBudget
    (intervalCounting_totalError_sublinear hErr hActive)

/-- Predicted shadow density from a clipped normalized ordered budget. -/
theorem predictedSpikeShadowDensity_of_clippedNormalizedOrderedBudget
    {Hlog u vseq : ℕ → ℝ} {tau x : ℝ} {S r err : ℕ → ℝ}
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) m)
    (hCover : ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r))
    (hLength : ClippedNormalizedOrderedShadowLengthBudget tau x S r err)
    (hActive : ActiveShadowCountSublinear (normalizedShadowLeft S))
    (hErr : EventuallySublinearCountError err) :
    PredictedSpikeShadowDensity Hlog u vseq tau x := by
  unfold PredictedSpikeShadowDensity
  exact Criteria.upperDensityAtMost_mono hRepresent
    (upperDensityAtMost_of_clippedNormalizedOrderedBudget
      hCover hLength hActive hErr)

/-- Visible-spike density theorem from a clipped normalized ordered budget. -/
theorem visibleSpike_density_of_clippedNormalizedOrderedBudget
    {Hlog u vseq H V : ℕ → ℝ}
    {tau x : ℝ} {S r err : ℕ → ℝ}
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) m)
    (hCover : ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r))
    (hLength : ClippedNormalizedOrderedShadowLengthBudget tau x S r err)
    (hActive : ActiveShadowCountSublinear (normalizedShadowLeft S))
    (hErr : EventuallySublinearCountError err)
    (hActualCover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x) :
    UpperNatDensityAtMost
      (VisibleBlockSpikeShell H V x)
      (1 - shellSpikeGoodDensityGain tau x) := by
  exact upperDensity_badShells_atMost_of_shadowCover hActualCover
    (predictedSpikeShadowDensity_of_clippedNormalizedOrderedBudget
      hRepresent hCover hLength hActive hErr)

/-! ## 4. Local clipping algebra -/

/-- If the endpoint budget is valid at the right endpoint of a shadow, then it
is valid at every point inside that shadow.

The right endpoint is `shellSpikeNormalizedEnd r x * S`, and the already
integrated endpoint theorem proves the endpoint case from the carry budget. -/
  theorem clipped_inside_shadow_budget
    {tau x S r Cprev T : ℝ}
    (htau : 0 < tau)
    (hx0 : 0 < x) (hxsep : shellSpikeSeparationThreshold tau < x) (hx1 : x < 1)
    (_hr_nonneg : 0 ≤ r) (hr_le : r ≤ tau)
    (hS_nonneg : 0 ≤ S)
    (_hT_left : S ≤ T)
    (hT_right : T ≤ shellSpikeNormalizedEnd r x * S)
    (hCarry : Cprev ≤ shellSpikeCarry tau x * S)
    (hGain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau x) :
    Cprev + (T - S)
      ≤ (1 - shellSpikeGoodDensityGain tau x) * T := by
  have hendpoint :
      Cprev + shellSpikeNormalizedLength r x * S ≤
        shellSpikeBadDensity tau x * (shellSpikeNormalizedEnd r x * S) :=
    shellSpike_budget_at_endpoint
      htau hx0 hxsep hx1 hS_nonneg hr_le hCarry
  have hElen :
      shellSpikeNormalizedEnd r x * S - S =
        shellSpikeNormalizedLength r x * S := by
    rw [shellSpikeNormalizedLength]
    ring
  have hendpoint' :
      Cprev + (shellSpikeNormalizedEnd r x * S - S) ≤
        (1 - shellSpikeGoodDensityGain tau x) *
          (shellSpikeNormalizedEnd r x * S) := by
    simpa [hElen, shellSpikeBadDensity] using hendpoint
  have hmono :
      Cprev + (T - S) - (1 - shellSpikeGoodDensityGain tau x) * T ≤
        Cprev + (shellSpikeNormalizedEnd r x * S - S) -
          (1 - shellSpikeGoodDensityGain tau x) *
            (shellSpikeNormalizedEnd r x * S) := by
    have hmul := mul_le_mul_of_nonneg_left hT_right hGain_nonneg
    nlinarith
  nlinarith


/-!
# Endpoint clipping for ordered shadow schedules

This module is the bridge after `RamanujanOrderedShadowClippedBudget`.
It records the order data and finite endpoint-splitting lemmas used to produce
clipped real-length budgets from ordered normalized shadow schedules.

The integer-counting layer is already closed by the clipped-budget module.  The
remaining endpoint argument is exposed as an explicit case-analysis budget, so
the interface stays axiom-free while the real schedule-specific proof remains
visible.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanOrderedShadowEndpointClip.lean -/

/-! ## 1. Ordered endpoint schedules -/

/-- Ordered endpoints for a normalized shadow schedule.  This records only the
order data needed to turn endpoint budgets into clipped budgets. -/
structure OrderedNormalizedShadowEndpoints
    (x : ℝ) (S r : ℕ → ℝ) : Prop where
  left_mono : Monotone (normalizedShadowLeft S)
  right_mono : Monotone (normalizedShadowRight x S r)
  nonoverlap : ∀ i : ℕ,
    normalizedShadowRight x S r i ≤ normalizedShadowLeft S (i + 1)
  left_nonneg : ∀ i : ℕ, 0 ≤ normalizedShadowLeft S i

/-- The finite set of normalized shadow indices active at cutoff `N`. -/
def normalizedActiveIndices (S : ℕ → ℝ) (N : ℕ) : Finset ℕ :=
  (Finset.range (N + 1)).filter
    (fun i => normalizedShadowLeft S i ≤ (N : ℝ))

/-- Clipped normalized shadow length summed over active indices. -/
def clippedNormalizedActiveLengthSum
    (x : ℝ) (S r : ℕ → ℝ) (N : ℕ) : ℝ :=
  ∑ i ∈ normalizedActiveIndices S N,
    clippedNormalizedShadowLength x S r N i

/-- Completed normalized shadow length summed over the prefix `range k`. -/
def normalizedPrefixLengthSum
    (x : ℝ) (S r : ℕ → ℝ) (k : ℕ) : ℝ :=
  ∑ i ∈ Finset.range k,
    max 0 (normalizedShadowRight x S r i - normalizedShadowLeft S i)

/-- Endpoint budget for completed prefixes. -/
def NormalizedPrefixEndpointBudget
    (tau x : ℝ) (S r err : ℕ → ℝ) : Prop :=
  ∀ᶠ k : ℕ in atTop,
    normalizedPrefixLengthSum x S r (k + 1)
      ≤ (1 - shellSpikeGoodDensityGain tau x)
          * normalizedShadowRight x S r k
        + err k

/-- Carry budget for completed prefixes before a current shadow.  The inside
case needs this form, because `clipped_inside_shadow_budget` starts from the
carry coefficient at the left endpoint of the current interval. -/
def NormalizedPrefixCarryBudget
    (tau x : ℝ) (S r err : ℕ → ℝ) : Prop :=
  ∀ᶠ k : ℕ in atTop,
    normalizedPrefixLengthSum x S r k
      ≤ shellSpikeCarry tau x * normalizedShadowLeft S k + err k

/-- Error transport from index `k` to cutoff `N`.  In applications `k ≤ N`, so
`err k` is bounded by a sublinear function of `N` such as `log(N+2)`. -/
def EndpointClipErrorTransport (err clipErr : ℕ → ℝ) : Prop :=
  ∀ᶠ N : ℕ in atTop,
    ∀ k ≤ N, err k ≤ clipErr N

/-! ## 2. Finite clipping identities -/

/-- If the active set is empty, the clipped sum is zero. -/
theorem clippedNormalizedActiveLengthSum_eq_zero_of_no_active
    {x : ℝ} {S r : ℕ → ℝ} {N : ℕ}
    (h : normalizedActiveIndices S N = ∅) :
    clippedNormalizedActiveLengthSum x S r N = 0 := by
  simp [clippedNormalizedActiveLengthSum, h]

/-- If an interval ends before the cutoff, its clipped length is its full
positive part. -/
theorem clippedNormalizedShadowLength_eq_full_of_right_le_cutoff
    {x : ℝ} {S r : ℕ → ℝ} {N i : ℕ}
    (hRight : normalizedShadowRight x S r i ≤ (N : ℝ)) :
    clippedNormalizedShadowLength x S r N i =
      max 0 (normalizedShadowRight x S r i - normalizedShadowLeft S i) := by
  rw [clippedNormalizedShadowLength, clippedRealIntervalLength]
  rw [min_eq_left hRight]

/-- If the cutoff lies inside an interval, the clipped length is cutoff minus
the left endpoint. -/
theorem clippedNormalizedShadowLength_eq_cutoff_sub_of_inside
    {x : ℝ} {S r : ℕ → ℝ} {N i : ℕ}
    (hLeft : normalizedShadowLeft S i ≤ (N : ℝ))
    (hRight : (N : ℝ) ≤ normalizedShadowRight x S r i) :
    clippedNormalizedShadowLength x S r N i =
      (N : ℝ) - normalizedShadowLeft S i := by
  rw [clippedNormalizedShadowLength, clippedRealIntervalLength]
  rw [min_eq_right hRight]
  exact max_eq_right (sub_nonneg.mpr hLeft)

/-- If the active indices are exactly `range (k+1)`, then the clipped active
length sum is the completed prefix before `k` plus the clipped contribution of
block `k`.  Earlier blocks are complete by nonoverlap. -/
theorem clippedActiveSum_eq_prefix_plus_current
    {x : ℝ} {S r : ℕ → ℝ} {N k : ℕ}
    (hord : OrderedNormalizedShadowEndpoints x S r)
    (hactive : normalizedActiveIndices S N = Finset.range (k + 1)) :
    clippedNormalizedActiveLengthSum x S r N
      = normalizedPrefixLengthSum x S r k
        + clippedNormalizedShadowLength x S r N k := by
  classical
  have hk_mem : k ∈ normalizedActiveIndices S N := by
    rw [hactive]
    simp
  have hleftk : normalizedShadowLeft S k ≤ (N : ℝ) := by
    dsimp [normalizedActiveIndices] at hk_mem
    rw [Finset.mem_filter] at hk_mem
    exact hk_mem.2
  rw [clippedNormalizedActiveLengthSum, hactive, Finset.sum_range_succ,
    normalizedPrefixLengthSum]
  congr 1
  refine Finset.sum_congr rfl ?_
  intro i hi
  rw [Finset.mem_range] at hi
  have hrightN : normalizedShadowRight x S r i ≤ (N : ℝ) := by
    calc
      normalizedShadowRight x S r i
          ≤ normalizedShadowLeft S (i + 1) := hord.nonoverlap i
      _ ≤ normalizedShadowLeft S k := hord.left_mono (Nat.succ_le_of_lt hi)
      _ ≤ (N : ℝ) := hleftk
  exact clippedNormalizedShadowLength_eq_full_of_right_le_cutoff hrightN

/-! ## 3. Local gap and inside estimates -/

/-- Gap case: if the last active shadow is already completed before `N`, then
the clipped active length is bounded by the endpoint budget at that shadow. -/
theorem clippedActiveLengthSum_le_of_cutoff_in_gap_local
    {tau x : ℝ} {S r err clipErr : ℕ → ℝ} {N k : ℕ}
    (hdelta_nonneg : 0 ≤ 1 - shellSpikeGoodDensityGain tau x)
    (hord : OrderedNormalizedShadowEndpoints x S r)
    (hEndpointAt :
      normalizedPrefixLengthSum x S r (k + 1)
        ≤ (1 - shellSpikeGoodDensityGain tau x) *
            normalizedShadowRight x S r k + err k)
    (hTransportAt : err k ≤ clipErr N)
    (hactive : normalizedActiveIndices S N = Finset.range (k + 1))
    (hcompleted : normalizedShadowRight x S r k ≤ (N : ℝ)) :
    clippedNormalizedActiveLengthSum x S r N
      ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ)
        + clipErr N := by
  have hsplit := clippedActiveSum_eq_prefix_plus_current
    (x := x) (S := S) (r := r) (N := N) (k := k) hord hactive
  have hcurrent :
      clippedNormalizedShadowLength x S r N k =
        max 0 (normalizedShadowRight x S r k - normalizedShadowLeft S k) :=
    clippedNormalizedShadowLength_eq_full_of_right_le_cutoff hcompleted
  have hsum :
      clippedNormalizedActiveLengthSum x S r N =
        normalizedPrefixLengthSum x S r (k + 1) := by
    rw [hsplit, hcurrent]
    simp [normalizedPrefixLengthSum, Finset.sum_range_succ]
  have hright_le : normalizedShadowRight x S r k ≤ (N + 1 : ℝ) := by
    have hN : (N : ℝ) ≤ (N + 1 : ℝ) := by norm_num
    exact le_trans hcompleted hN
  have hmul :
      (1 - shellSpikeGoodDensityGain tau x) *
          normalizedShadowRight x S r k
        ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) :=
    mul_le_mul_of_nonneg_left hright_le hdelta_nonneg
  calc
    clippedNormalizedActiveLengthSum x S r N
        = normalizedPrefixLengthSum x S r (k + 1) := hsum
    _ ≤ (1 - shellSpikeGoodDensityGain tau x) *
          normalizedShadowRight x S r k + err k := hEndpointAt
    _ ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) + clipErr N := by
          linarith

/-- Inside-shadow case from a local carry budget at the left endpoint of the
current interval. -/
theorem clippedActiveLengthSum_le_of_cutoff_inside_current_local
    {tau x : ℝ} {S r err clipErr : ℕ → ℝ} {N k : ℕ}
    (htau : 0 < tau)
    (hx0 : 0 < x) (hxsep : shellSpikeSeparationThreshold tau < x) (hx1 : x < 1)
    (hdelta_nonneg : 0 ≤ 1 - shellSpikeGoodDensityGain tau x)
    (hgain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau x)
    (hord : OrderedNormalizedShadowEndpoints x S r)
    (hCarryAt :
      normalizedPrefixLengthSum x S r k
        ≤ shellSpikeCarry tau x * normalizedShadowLeft S k + err k)
    (hTransportAt : err k ≤ clipErr N)
    (hactive : normalizedActiveIndices S N = Finset.range (k + 1))
    (hinside_left : normalizedShadowLeft S k ≤ (N : ℝ))
    (hinside_right : (N : ℝ) ≤ normalizedShadowRight x S r k)
    (hr_nonneg : 0 ≤ r k) (hr_le : r k ≤ tau) :
    clippedNormalizedActiveLengthSum x S r N
      ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ)
        + clipErr N := by
  have hsplit := clippedActiveSum_eq_prefix_plus_current
    (x := x) (S := S) (r := r) (N := N) (k := k) hord hactive
  have hcurrent :
      clippedNormalizedShadowLength x S r N k =
        (N : ℝ) - normalizedShadowLeft S k :=
    clippedNormalizedShadowLength_eq_cutoff_sub_of_inside hinside_left hinside_right
  have hcarry_no_err :
      normalizedPrefixLengthSum x S r k - err k
        ≤ shellSpikeCarry tau x * normalizedShadowLeft S k := by
    linarith
  have hclip := clipped_inside_shadow_budget
    (tau := tau) (x := x)
    (S := normalizedShadowLeft S k) (r := r k)
    (Cprev := normalizedPrefixLengthSum x S r k - err k)
    (T := (N : ℝ))
    htau hx0 hxsep hx1 hr_nonneg hr_le (hord.left_nonneg k)
    hinside_left
    (by simpa [normalizedShadowLeft, normalizedShadowRight,
        normalizedShadowEndAt] using hinside_right)
    hcarry_no_err hgain_nonneg
  have hwith_err :
      normalizedPrefixLengthSum x S r k +
          ((N : ℝ) - normalizedShadowLeft S k)
        ≤ (1 - shellSpikeGoodDensityGain tau x) * (N : ℝ) + err k := by
    linarith
  have hNle : (N : ℝ) ≤ (N + 1 : ℝ) := by norm_num
  have hmul :
      (1 - shellSpikeGoodDensityGain tau x) * (N : ℝ)
        ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) :=
    mul_le_mul_of_nonneg_left hNle hdelta_nonneg
  calc
    clippedNormalizedActiveLengthSum x S r N
        = normalizedPrefixLengthSum x S r k +
            ((N : ℝ) - normalizedShadowLeft S k) := by
          rw [hsplit, hcurrent]
    _ ≤ (1 - shellSpikeGoodDensityGain tau x) * (N : ℝ) + err k := hwith_err
    _ ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) + clipErr N := by
          linarith

/-! ## 4. Case-analysis interface -/

/-- The endpoint clipping case analysis needed at each cutoff.  This is the
finite output of choosing the last active interval and applying either the gap
or inside estimate. -/
def EndpointClipCaseAnalysis
    (tau x : ℝ) (S r clipErr : ℕ → ℝ) : Prop :=
  ∀ᶠ N : ℕ in atTop,
    clippedNormalizedActiveLengthSum x S r N
      ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ)
        + clipErr N

/-- The case-analysis budget is exactly the clipped normalized ordered shadow
length budget required by the integer-counting layer. -/
theorem clippedNormalizedOrderedShadowLengthBudget_of_endpointClipCaseAnalysis
    {tau x : ℝ} {S r clipErr : ℕ → ℝ}
    (hClip : EndpointClipCaseAnalysis tau x S r clipErr) :
    ClippedNormalizedOrderedShadowLengthBudget tau x S r clipErr := by
  simpa [EndpointClipCaseAnalysis, ClippedNormalizedOrderedShadowLengthBudget,
    clippedNormalizedActiveLengthSum, normalizedActiveIndices]
    using hClip

/-- Endpoint clipping from prefix data, with the finite case analysis left as
an explicit hypothesis.  The local gap and inside lemmas above are the intended
tools for proving `hClipCases` for a concrete ordered schedule. -/
theorem clippedNormalizedOrderedShadowLengthBudget_of_prefixEndpointBudget
    {tau x : ℝ} {S r err carryErr clipErr : ℕ → ℝ}
    (_htau : 0 < tau)
    (_hx0 : 0 < x) (_hxsep : shellSpikeSeparationThreshold tau < x)
    (_hx1 : x < 1)
    (_hdelta_nonneg : 0 ≤ 1 - shellSpikeGoodDensityGain tau x)
    (_hgain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau x)
    (_hord : OrderedNormalizedShadowEndpoints x S r)
    (_hr_nonneg : ∀ i, 0 ≤ r i)
    (_hr_le : ∀ i, r i ≤ tau)
    (_hEndpoint : NormalizedPrefixEndpointBudget tau x S r err)
    (_hCarry : NormalizedPrefixCarryBudget tau x S r carryErr)
    (_hEndpointTransport : EndpointClipErrorTransport err clipErr)
    (_hCarryTransport : EndpointClipErrorTransport carryErr clipErr)
    (hClipCases : EndpointClipCaseAnalysis tau x S r clipErr) :
    ClippedNormalizedOrderedShadowLengthBudget tau x S r clipErr :=
  clippedNormalizedOrderedShadowLengthBudget_of_endpointClipCaseAnalysis hClipCases


/-!
# Endpoint-clip case analysis for ordered normalized shadows

This module closes the finite active-set part of the endpoint-clipping argument.
For a fixed integer cutoff `N`, the active set

```text
{ i <= N : normalizedShadowLeft S i <= N }
```

is an initial segment whenever the normalized left endpoints are monotone.  Thus
it is empty, or it is `range (k+1)` for a maximal active index `k`.  The cutoff
is then either inside the last active interval or in the gap after it by linear
order on `ℝ`.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanOrderedShadowCaseAnalysis.lean -/

/-- Local active set used by the case-analysis bridge.  This mirrors
`normalizedActiveIndices`; keeping the local abbreviation makes the endpoint
case statements easier to read. -/
abbrev endpointActiveIndices (S : ℕ → ℝ) (N : ℕ) : Finset ℕ :=
  normalizedActiveIndices S N

/-- A local formulation of the active-prefix alternative. -/
def ActivePrefixAlternative (S : ℕ → ℝ) : Prop :=
  ∀ N : ℕ,
    endpointActiveIndices S N = ∅ ∨
      ∃ k : ℕ, endpointActiveIndices S N = Finset.range (k + 1)

/-- A local formulation of the endpoint clipping case split. -/
def EndpointClipCaseAnalysisLocal
    (x : ℝ) (S r : ℕ → ℝ) : Prop :=
  ∀ N : ℕ,
    endpointActiveIndices S N = ∅ ∨
      ∃ k : ℕ,
        endpointActiveIndices S N = Finset.range (k + 1) ∧
          ((N : ℝ) ≤ normalizedShadowRight x S r k ∨
            normalizedShadowRight x S r k ≤ (N : ℝ))

/-- If an index is active, its left endpoint is at most the cutoff. -/
theorem left_le_of_mem_endpointActiveIndices
    {S : ℕ → ℝ} {N i : ℕ}
    (hi : i ∈ endpointActiveIndices S N) :
    normalizedShadowLeft S i ≤ (N : ℝ) := by
  simpa [endpointActiveIndices, normalizedActiveIndices] using
    (Finset.mem_filter.mp hi).2

/-- Active indices are bounded by `N`, because the active set is filtered from
`range (N+1)`. -/
theorem index_le_of_mem_endpointActiveIndices
    {S : ℕ → ℝ} {N i : ℕ}
    (hi : i ∈ endpointActiveIndices S N) :
    i ≤ N := by
  have hmem : i ∈ Finset.range (N + 1) :=
    (Finset.mem_filter.mp hi).1
  exact Nat.lt_succ_iff.mp (Finset.mem_range.mp hmem)

/-- Monotonicity of left endpoints makes activity downward closed. -/
theorem endpointActiveIndices_downward_closed
    {S : ℕ → ℝ} {N i j : ℕ}
    (hmono : Monotone (normalizedShadowLeft S))
    (hi : i ∈ endpointActiveIndices S N)
    (hjle : j ≤ i) :
    j ∈ endpointActiveIndices S N := by
  have hjN : j < N + 1 := Nat.lt_succ_of_le
    (le_trans hjle (index_le_of_mem_endpointActiveIndices hi))
  have hleft_i : normalizedShadowLeft S i ≤ (N : ℝ) :=
    left_le_of_mem_endpointActiveIndices hi
  have hleft_j_i : normalizedShadowLeft S j ≤ normalizedShadowLeft S i :=
    hmono hjle
  exact Finset.mem_filter.mpr
    ⟨Finset.mem_range.mpr hjN, le_trans hleft_j_i hleft_i⟩

/-- If `k` is an active maximal index, then the active set is exactly
`range (k+1)`. -/
theorem endpointActiveIndices_eq_range_succ_of_max
    {S : ℕ → ℝ} {N k : ℕ}
    (hmono : Monotone (normalizedShadowLeft S))
    (hk : k ∈ endpointActiveIndices S N)
    (hmax : ∀ i : ℕ, i ∈ endpointActiveIndices S N → i ≤ k) :
    endpointActiveIndices S N = Finset.range (k + 1) := by
  apply Finset.ext
  intro i
  constructor
  · intro hi
    exact Finset.mem_range.mpr (Nat.lt_succ_of_le (hmax i hi))
  · intro hi
    exact endpointActiveIndices_downward_closed hmono hk
      (Nat.lt_succ_iff.mp (Finset.mem_range.mp hi))

/-- Finite active sets have an initial-segment description under monotone left
endpoints. -/
theorem activePrefixAlternative_of_monotone_left
    {S : ℕ → ℝ}
    (hmono : Monotone (normalizedShadowLeft S)) :
    ActivePrefixAlternative S := by
  intro N
  classical
  by_cases hne : endpointActiveIndices S N = ∅
  · exact Or.inl hne
  · have hnonempty : (endpointActiveIndices S N).Nonempty := by
      simpa [Finset.nonempty_iff_ne_empty] using hne
    let k := (endpointActiveIndices S N).max' hnonempty
    have hk : k ∈ endpointActiveIndices S N :=
      Finset.max'_mem _ _
    have hmax : ∀ i : ℕ, i ∈ endpointActiveIndices S N → i ≤ k := by
      intro i hi
      exact Finset.le_max' _ _ hi
    exact Or.inr ⟨k, endpointActiveIndices_eq_range_succ_of_max
      hmono hk hmax⟩

/-- The last active interval either contains the cutoff or lies before it. -/
theorem endpoint_last_interval_inside_or_gap
    {x : ℝ} {S r : ℕ → ℝ} {N k : ℕ} :
    (N : ℝ) ≤ normalizedShadowRight x S r k ∨
      normalizedShadowRight x S r k ≤ (N : ℝ) := by
  exact le_total (N : ℝ) (normalizedShadowRight x S r k)

/-- Endpoint case analysis from monotone left endpoints. -/
theorem endpointClipCaseAnalysisLocal_of_monotone_left
    {x : ℝ} {S r : ℕ → ℝ}
    (hmono : Monotone (normalizedShadowLeft S)) :
    EndpointClipCaseAnalysisLocal x S r := by
  intro N
  rcases activePrefixAlternative_of_monotone_left (S := S) hmono N with hempty | ⟨k, hk⟩
  · exact Or.inl hempty
  · exact Or.inr ⟨k, hk, endpoint_last_interval_inside_or_gap⟩

/-- Ordered endpoint schedules provide the local active-prefix case split. -/
theorem endpointClipCaseAnalysisLocal_of_orderedNormalizedShadowEndpoints
    {x : ℝ} {S r : ℕ → ℝ}
    (hord : OrderedNormalizedShadowEndpoints x S r) :
    EndpointClipCaseAnalysisLocal x S r :=
  endpointClipCaseAnalysisLocal_of_monotone_left hord.left_mono


/-!
# Ordered shadow endpoint-budget closure

This module connects the finite active-set case split with the local gap/inside
endpoint estimates.  The result is the clipped real-length budget consumed by
`RamanujanOrderedShadowClippedBudget`.

The mathematically correct output is the clipped budget.  We do not coerce it
into the older full-length `OrderedShadowFiniteBudgetTarget`, since full active
length is stronger and can fail for intervals crossing the cutoff.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanOrderedShadowEndpointBudgetClosure.lean -/

/-! ## 1. Closure input -/

/-- Hypotheses needed to derive the clipped endpoint budget from ordered
shadows. -/
structure OrderedEndpointBudgetClosureInput
    (tau x : ℝ) (S r err clipErr : ℕ → ℝ) : Prop where
  htau : 0 < tau
  hx0 : 0 < x
  hxsep : shellSpikeSeparationThreshold tau < x
  hx1 : x < 1
  hdelta_nonneg : 0 ≤ 1 - shellSpikeGoodDensityGain tau x
  hgain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau x
  hord : OrderedNormalizedShadowEndpoints x S r
  hr_nonneg : ∀ i, 0 ≤ r i
  hr_le : ∀ i, r i ≤ tau
  hEndpoint : NormalizedPrefixEndpointBudget tau x S r err
  hCarry : NormalizedPrefixCarryBudget tau x S r err
  hTransport : EndpointClipErrorTransport err clipErr

/-- Eventual nonnegativity of the right side.  In applications this is harmless
for logarithmic or otherwise eventually nonnegative errors. -/
def EventuallyNonnegativeClipRHS
    (tau x : ℝ) (clipErr : ℕ → ℝ) : Prop :=
  ∀ᶠ N : ℕ in atTop,
    0 ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) + clipErr N

/-! ## 2. Pointwise case closure -/

/-- Extract the left-side fact `left k ≤ N` from an active-prefix equality. -/
theorem endpointClip_localData_of_caseSplit
    {S : ℕ → ℝ} {N k : ℕ}
    (hactive : normalizedActiveIndices S N = Finset.range (k + 1)) :
    normalizedShadowLeft S k ≤ (N : ℝ) := by
  have hk_mem_range : k ∈ Finset.range (k + 1) :=
    Finset.mem_range.mpr (Nat.lt_succ_self k)
  have hk_active : k ∈ normalizedActiveIndices S N := by
    simp [hactive, hk_mem_range]
  simpa [normalizedActiveIndices] using (Finset.mem_filter.mp hk_active).2

/-- Empty active set case gives the clipped budget immediately. -/
theorem clippedBudget_emptyActive_case
    {tau x : ℝ} {S r clipErr : ℕ → ℝ} {N : ℕ}
    (hactive_empty : normalizedActiveIndices S N = ∅)
    (hrhs_nonneg :
      0 ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) + clipErr N) :
    clippedNormalizedActiveLengthSum x S r N
      ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) + clipErr N := by
  rw [clippedNormalizedActiveLengthSum_eq_zero_of_no_active hactive_empty]
  exact hrhs_nonneg

/-- Pointwise endpoint-budget closure at a fixed cutoff.

The endpoint/carry hypotheses are supplied only for the maximal active index
chosen by the case split.  The eventual theorem below proves those hypotheses
hold for all sufficiently large cutoffs. -/
theorem clippedBudget_pointwise_of_caseAnalysis
    {tau x : ℝ} {S r err clipErr : ℕ → ℝ} {N : ℕ}
    (H : OrderedEndpointBudgetClosureInput tau x S r err clipErr)
    (hEndpointAt : ∀ k : ℕ,
      normalizedActiveIndices S N = Finset.range (k + 1) →
        normalizedPrefixLengthSum x S r (k + 1)
          ≤ (1 - shellSpikeGoodDensityGain tau x) *
              normalizedShadowRight x S r k + err k)
    (hCarryAt : ∀ k : ℕ,
      normalizedActiveIndices S N = Finset.range (k + 1) →
        normalizedPrefixLengthSum x S r k
          ≤ shellSpikeCarry tau x * normalizedShadowLeft S k + err k)
    (hTransportAt : ∀ k ≤ N, err k ≤ clipErr N)
    (hcase :
      normalizedActiveIndices S N = ∅ ∨
        ∃ k : ℕ,
          normalizedActiveIndices S N = Finset.range (k + 1) ∧
            ((N : ℝ) ≤ normalizedShadowRight x S r k ∨
              normalizedShadowRight x S r k ≤ (N : ℝ)))
    (hrhs_nonneg :
      0 ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) + clipErr N) :
    clippedNormalizedActiveLengthSum x S r N
      ≤ (1 - shellSpikeGoodDensityGain tau x) * (N + 1 : ℝ) + clipErr N := by
  classical
  rcases hcase with hempty | ⟨k, hactive, hsplit⟩
  · exact clippedBudget_emptyActive_case (tau := tau) (x := x) (S := S) (r := r)
      (clipErr := clipErr) hempty hrhs_nonneg
  · have hleft : normalizedShadowLeft S k ≤ (N : ℝ) :=
      endpointClip_localData_of_caseSplit (S := S) hactive
    have hk_active : k ∈ normalizedActiveIndices S N := by
      rw [hactive]
      simp
    have hkN : k ≤ N := by
      exact index_le_of_mem_endpointActiveIndices
        (S := S) (N := N) (i := k) (by simpa [endpointActiveIndices] using hk_active)
    rcases hsplit with hinside | hgap
    · exact clippedActiveLengthSum_le_of_cutoff_inside_current_local
        H.htau H.hx0 H.hxsep H.hx1 H.hdelta_nonneg H.hgain_nonneg H.hord
        (hCarryAt k hactive) (hTransportAt k hkN)
        hactive hleft hinside (H.hr_nonneg k) (H.hr_le k)
    · exact clippedActiveLengthSum_le_of_cutoff_in_gap_local
        H.hdelta_nonneg H.hord (hEndpointAt k hactive)
        (hTransportAt k hkN) hactive hgap

/-! ## 3. Eventual clipped budget -/

/-- Main endpoint-budget closure theorem. -/
theorem clippedNormalizedOrderedShadowLengthBudget_of_orderedEndpointClosure
    {tau x : ℝ} {S r err clipErr : ℕ → ℝ}
    (H : OrderedEndpointBudgetClosureInput tau x S r err clipErr)
    (hRHS : EventuallyNonnegativeClipRHS tau x clipErr) :
    ClippedNormalizedOrderedShadowLengthBudget tau x S r clipErr := by
  rcases Filter.eventually_atTop.1 H.hEndpoint with ⟨Ke, hKe⟩
  rcases Filter.eventually_atTop.1 H.hCarry with ⟨Kc, hKc⟩
  let K : ℕ := max Ke Kc
  obtain ⟨Bleft, hBleft⟩ := exists_nat_gt (normalizedShadowLeft S K)
  have hKeK : Ke ≤ K := by simp [K]
  have hKcK : Kc ≤ K := by simp [K]
  filter_upwards [Filter.eventually_ge_atTop (max K Bleft), H.hTransport, hRHS]
    with N hNlarge hTransportN hRHSN
  have hKN : K ≤ N := le_trans (Nat.le_max_left K Bleft) hNlarge
  have hBleftN : Bleft ≤ N := le_trans (Nat.le_max_right K Bleft) hNlarge
  have hleftK : normalizedShadowLeft S K ≤ (N : ℝ) := by
    have hBreal : (Bleft : ℝ) ≤ (N : ℝ) := by exact_mod_cast hBleftN
    linarith
  have hKactive : K ∈ normalizedActiveIndices S N := by
    dsimp [normalizedActiveIndices]
    rw [Finset.mem_filter]
    exact ⟨Finset.mem_range.mpr (Nat.lt_succ_of_le hKN), hleftK⟩
  have hEndpointAt : ∀ k : ℕ,
      normalizedActiveIndices S N = Finset.range (k + 1) →
        normalizedPrefixLengthSum x S r (k + 1)
          ≤ (1 - shellSpikeGoodDensityGain tau x) *
              normalizedShadowRight x S r k + err k := by
    intro k hactive
    have hKrange : K ∈ Finset.range (k + 1) := by
      simpa [hactive] using hKactive
    have hKleK : K ≤ k := Nat.lt_succ_iff.mp (Finset.mem_range.mp hKrange)
    exact hKe k (le_trans hKeK hKleK)
  have hCarryAt : ∀ k : ℕ,
      normalizedActiveIndices S N = Finset.range (k + 1) →
        normalizedPrefixLengthSum x S r k
          ≤ shellSpikeCarry tau x * normalizedShadowLeft S k + err k := by
    intro k hactive
    have hKrange : K ∈ Finset.range (k + 1) := by
      simpa [hactive] using hKactive
    have hKleK : K ≤ k := Nat.lt_succ_iff.mp (Finset.mem_range.mp hKrange)
    exact hKc k (le_trans hKcK hKleK)
  have hcase :=
    endpointClipCaseAnalysisLocal_of_orderedNormalizedShadowEndpoints
      (x := x) (S := S) (r := r) H.hord N
  exact clippedBudget_pointwise_of_caseAnalysis
    (H := H) hEndpointAt hCarryAt hTransportN hcase hRHSN

/-! ## 4. Density wrappers -/

/-- Predicted shadow density from ordered endpoint closure and active-cover
bookkeeping. -/
theorem predictedSpikeShadowDensity_of_orderedEndpointClosure
    {Hlog u vseq : ℕ → ℝ} {tau x : ℝ} {S r err clipErr : ℕ → ℝ}
    (H : OrderedEndpointBudgetClosureInput tau x S r err clipErr)
    (hRHS : EventuallyNonnegativeClipRHS tau x clipErr)
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) m)
    (hActiveCover : ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r))
    (hActive : ActiveShadowCountSublinear (normalizedShadowLeft S))
    (hErr : EventuallySublinearCountError clipErr) :
    PredictedSpikeShadowDensity Hlog u vseq tau x := by
  exact predictedSpikeShadowDensity_of_clippedNormalizedOrderedBudget
    hRepresent hActiveCover
    (clippedNormalizedOrderedShadowLengthBudget_of_orderedEndpointClosure H hRHS)
    hActive hErr

/-- Visible-spike density from ordered endpoint closure. -/
theorem visibleSpike_density_of_orderedEndpointClosure
    {Hlog u vseq Hheight V : ℕ → ℝ}
    {tau x : ℝ} {S r err clipErr : ℕ → ℝ}
    (H : OrderedEndpointBudgetClosureInput tau x S r err clipErr)
    (hRHS : EventuallyNonnegativeClipRHS tau x clipErr)
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) m)
    (hActiveCover : ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r))
    (hActive : ActiveShadowCountSublinear (normalizedShadowLeft S))
    (hErr : EventuallySublinearCountError clipErr)
    (hActualCover : ActualSpikeShellsHaveShadowCover Hlog u vseq V Hheight x) :
    UpperNatDensityAtMost
      (VisibleBlockSpikeShell Hheight V x)
      (1 - shellSpikeGoodDensityGain tau x) := by
  exact visibleSpike_density_of_clippedNormalizedOrderedBudget
    hRepresent hActiveCover
    (clippedNormalizedOrderedShadowLengthBudget_of_orderedEndpointClosure H hRHS)
    hActive hErr hActualCover


open scoped BigOperators

/-!
# Final assembly after ordered-shadow endpoint closure

The ordered-shadow density side now runs through the clipped endpoint-budget
route.  The remaining arithmetic input is the domination

```text
BadRamanujanTruncation nu m -> VisibleBlockSpikeShell H V x m.
```

Once that domination is supplied at an exponent `x` above the contraction
threshold, the existing Bauer/Ramanujan contraction wrapper gives `mu < M`.
-/


/-! ## Merged from IrrationalityAr/RamanujanOrderedShadowFinalAssembly.lean -/

/-! ## 1. Compact final data -/

/-- The remaining arithmetic target after the ordered-shadow density side is
closed.  This is deliberately a predicate, not an axiom. -/
def BadTruncationsForceVisibleShellSpikes
    (nu : ℝ) (H V : ℕ → ℝ) (x : ℝ) : Prop :=
  ∀ m : ℕ,
    BadRamanujanTruncation nu m → VisibleBlockSpikeShell H V x m

/-- A compact package for the completed ordered-shadow endpoint-closure data. -/
structure OrderedEndpointClosureCertificate
    (Hlog u vseq H V : ℕ → ℝ) (tau x : ℝ) where
  /-- Actual visible shell spikes are covered by logarithmic spike shadows. -/
  actualCover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x
  /-- The endpoint-clipped ordered-shadow machinery proves predicted shadow density. -/
  predictedDensity : PredictedSpikeShadowDensity Hlog u vseq tau x

/-- Build the compact certificate directly from the endpoint-closure route. -/
theorem orderedEndpointClosureCertificate_of_orderedEndpointClosure
    {Hlog u vseq Hheight V : ℕ → ℝ}
    {tau x : ℝ} {S r err clipErr : ℕ → ℝ}
    (Hclose : OrderedEndpointBudgetClosureInput tau x S r err clipErr)
    (hRHS : EventuallyNonnegativeClipRHS tau x clipErr)
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) m)
    (hActiveCover : ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r))
    (hActive : ActiveShadowCountSublinear (normalizedShadowLeft S))
    (hErr : EventuallySublinearCountError clipErr)
    (hActualCover : ActualSpikeShellsHaveShadowCover Hlog u vseq V Hheight x) :
    OrderedEndpointClosureCertificate Hlog u vseq Hheight V tau x where
  actualCover := hActualCover
  predictedDensity := predictedSpikeShadowDensity_of_orderedEndpointClosure
    Hclose hRHS hRepresent hActiveCover hActive hErr

/-! ## 2. Density consequences -/

/-- The ordered endpoint-closure certificate gives visible-shell spike density. -/
theorem OrderedEndpointClosureCertificate.visibleSpike_density_atMost
    {Hlog u vseq H V : ℕ → ℝ} {tau x : ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x) :
    UpperNatDensityAtMost
      (VisibleBlockSpikeShell H V x)
      (1 - shellSpikeGoodDensityGain tau x) := by
  exact upperDensity_badShells_atMost_of_shadowCover
    C.actualCover C.predictedDensity

/-- Strict visible-spike density below the contraction target, from the ordered
endpoint-closure certificate. -/
theorem OrderedEndpointClosureCertificate.visibleSpike_density_less_contraction
    {Hlog u vseq H V : ℕ → ℝ} {tau nu M x : ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (htau : 0 < tau) (hnu : 0 < nu) (hM : 0 < M)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau) :
    UpperNatDensityLessThan
      (VisibleBlockSpikeShell H V x)
      (1 - nu / M) := by
  exact visibleSpikeShell_densityLessThan_contractionTarget
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    (tau := tau) (nu := nu) (M := M) (x := x)
    htau hnu hM hx hx1 hxθ C.actualCover C.predictedDensity

/-! ## 3. Final measure-improvement assembly -/

/-- Final ordered-shadow endpoint-closure route to strict measure improvement.

The density proof is supplied by the endpoint-closure certificate; the only
remaining arithmetic input is `hdom`. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_orderedEndpointClosureCertificate
    {mu nu M tau x : ℝ}
    {Hlog u vseq H V : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hdom : BadTruncationsForceVisibleShellSpikes nu H V x) :
    mu < M := by
  exact oneOverPi_irratMeasure_lt_of_Bauer_visibleShellGain_contractionExponent
    (mu := mu) (nu := nu) (M := M) (tau := tau) (x := x)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    hBauer hmu hnu2 hnuM htau hx hx1 hxθ hdom
    C.actualCover C.predictedDensity

/-- Fully expanded final wrapper from endpoint-closure inputs. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_orderedEndpointClosure
    {mu nu M tau x : ℝ}
    {Hlog u vseq Hheight V : ℕ → ℝ}
    {S r err clipErr : ℕ → ℝ}
    (Hclose : OrderedEndpointBudgetClosureInput tau x S r err clipErr)
    (hRHS : EventuallyNonnegativeClipRHS tau x clipErr)
    (hRepresent : ∀ m : ℕ,
      spikeShadowShellUnion Hlog u vseq x m →
        NatInRealIntervalUnion
          (normalizedShadowLeft S) (normalizedShadowRight x S r) m)
    (hActiveCover : ActiveShadowIndicesCoverUnion
      (normalizedShadowLeft S) (normalizedShadowRight x S r))
    (hActive : ActiveShadowCountSublinear (normalizedShadowLeft S))
    (hErr : EventuallySublinearCountError clipErr)
    (hActualCover : ActualSpikeShellsHaveShadowCover Hlog u vseq V Hheight x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hdom : BadTruncationsForceVisibleShellSpikes nu Hheight V x) :
    mu < M := by
  let C : OrderedEndpointClosureCertificate Hlog u vseq Hheight V tau x :=
    orderedEndpointClosureCertificate_of_orderedEndpointClosure
      Hclose hRHS hRepresent hActiveCover hActive hErr hActualCover
  exact oneOverPi_irratMeasure_lt_of_Bauer_orderedEndpointClosureCertificate
    (mu := mu) (nu := nu) (M := M) (tau := tau) (x := x)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := Hheight) (V := V)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hdom

/-! ## 4. Remaining arithmetic target -/

/-- The final remaining hard theorem, now isolated as a named target. -/
def EndpointResidueBreaksLossBarrier
    (nu : ℝ) (H V : ℕ → ℝ) (x : ℝ) : Prop :=
  BadTruncationsForceVisibleShellSpikes nu H V x



/-!
# Endpoint-residue route past the loss barrier

The final ordered-shadow assembly has reduced the measure-improvement
problem to:

```text
BadRamanujanTruncation nu m -> VisibleBlockSpikeShell H V x m
```

for some exponent `x` above the contraction exponent.

The generic bad-to-visible route has effective loss `L = 2` and is sharp.
This module records the next arithmetic target: a Ramanujan-specific
endpoint/residue exclusion that gives effective loss `L < 2`.
-/

/-- Ramanujan-specific endpoint avoidance.

Informally, a bad truncation should not occur at the dangerous endpoint where
`X_j` is approximately `kappa * m / nu`.  This predicate records a uniform
avoidance factor in the normalization used by the Ramanujan shell window. -/
def EndpointAvoidanceForBadTruncations
    (nu sigma : ℝ) (X : ℕ → ℝ) : Prop :=
  ∀ᶠ m in Filter.atTop,
    BadRamanujanTruncation nu m →
      ∃ j : ℕ,
        X j ≤ sigma * (6 * Real.log 2) * (m : ℝ) / nu

/-- Ramanujan-specific effective-loss gain.

The generic argument gives

```text
v_j >= beta * m - 2 * X_j - O(1).
```

This target asks for the improved form

```text
v_j >= beta * m - (2 - Delta) * X_j - O(1).
```

Any fixed `Delta > 0` is meaningful. -/
def EndpointResidueEffectiveLossGain
    (nu beta Delta : ℝ) (X v : ℕ → ℝ) : Prop :=
  ∀ᶠ m in Filter.atTop,
    BadRamanujanTruncation nu m →
      ∃ j : ℕ,
        v j ≥ beta * (m : ℝ) - (2 - Delta) * X j

/-- Direct target used by final assembly. -/
def EndpointResidueBreaksLossBarrierTarget
    (nu : ℝ) (H V : ℕ → ℝ) (x : ℝ) : Prop :=
  BadTruncationsForceVisibleShellSpikes nu H V x

/-- If endpoint-residue information gives an exponent above the contraction
threshold, the final ordered-shadow assembly produces a strict measure
improvement. -/
theorem measureImprovement_of_endpointResidueVisibleSpike
    {mu nu M tau x : ℝ}
    {Hlog u vseq H V : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hEndpointResidue :
      EndpointResidueBreaksLossBarrierTarget nu H V x) :
    mu < M := by
  exact oneOverPi_irratMeasure_lt_of_Bauer_orderedEndpointClosureCertificate
    (mu := mu) (nu := nu) (M := M) (tau := tau) (x := x)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hEndpointResidue

/-- Practical next theorem target.

Prove this by showing that a bad Ramanujan truncation cannot be realized near
the endpoint of its upper spike window.  Any positive gain over the generic
loss `2` can be enough if `nu` is chosen close to `M`. -/
def NextArithmeticTarget
    (nu beta kappa tau M : ℝ) : Prop :=
  ∃ Delta : ℝ,
    0 < Delta ∧
    2 - Delta < criticalEffectiveLoss kappa nu beta tau M

/-! ## Missing ingredient diagnosis -/

/-- Logarithmic denominator cap at Ramanujan shell `m` for trial exponent `nu`.
Mathematically this is `(kappa / nu) * m`, where `kappa = 6 * log 2`. -/
def ramanujanDenominatorCapLog (nu : ℝ) (m : ℕ) : ℝ :=
  (6 * Real.log 2 / nu) * (m : ℝ)

/-- Endpoint offset of a candidate denominator log `Xj` inside the denominator
cap.  Positive offset means the candidate denominator is below the cap by a
visible margin. -/
def endpointOffset (nu : ℝ) (m : ℕ) (Xj : ℝ) : ℝ :=
  ramanujanDenominatorCapLog nu m - Xj

/-- The visible intermediate-length proxy attached to the offset.
If `q_j = exp Xj` and `H_m = exp cap`, then `exp(endpointOffset)` is roughly
`H_m / q_j`, the number of intermediate denominators from this block visible
below the Ramanujan exactness height. -/
def visibleLengthProxy (nu : ℝ) (m : ℕ) (Xj : ℝ) : ℝ :=
  Real.exp (endpointOffset nu m Xj)

/-- Same-shell endpoint avoidance strong enough to force a visible block spike
of exponent `x`.

This is the clean pointwise missing target:

```text
Bad(m) -> exists j, X_j <= (1 - x) * cap(m).
```

Equivalently, `endpointOffset >= x * cap(m)`, so the visible intermediate
length is at least `H_m^x`. -/
def SameShellEndpointAvoidance
    (Bad : ℕ → Prop) (X : ℕ → ℝ) (nu x : ℝ) : Prop :=
  ∀ᶠ m in Filter.atTop,
    Bad m → ∃ j : ℕ,
      X j ≤ (1 - x) * ramanujanDenominatorCapLog nu m

/-- Density-level endpoint avoidance.  This is weaker and often more realistic:
all but a density-small subset of bad shells have enough offset to create a
visible spike. -/
def DensityEndpointAvoidance
    (Bad : ℕ → Prop) (X : ℕ → ℝ) (nu x delta : ℝ) : Prop :=
  UpperNatDensityAtMost
    (fun m : ℕ => Bad m ∧
      ∀ j : ℕ, ¬ X j ≤ (1 - x) * ramanujanDenominatorCapLog nu m)
    delta

/-- Window-localization target.
A bad shell is not merely in the upper spike window; it lies after a fixed
fraction of the way from the left endpoint toward the visible-spike region. -/
def BadWindowLocalization
    (Bad : ℕ → Prop) (X : ℕ → ℝ) (nu theta : ℝ) : Prop :=
  ∀ᶠ m in Filter.atTop,
    Bad m → ∃ j : ℕ,
      theta * ramanujanDenominatorCapLog nu m ≤ endpointOffset nu m (X j)

/-- Intermediate-index realization target.
For a bad rational represented as an intermediate convergent in block `j` with
parameter `t`, prove `t` is large enough to force a visible block spike.  This
bypasses the generic loss-`2` principal-endpoint obstruction. -/
def IntermediateIndexRealization
    (Bad : ℕ → Prop) (_blockIndex param : ℕ → ℕ) (H : ℕ → ℝ) (x : ℝ) : Prop :=
  ∀ᶠ m in Filter.atTop,
    Bad m → (param m : ℝ) ≥ Real.rpow (H m) x

/-- Lagged visible-spike domination.
This is an alternative to same-shell domination: an early bad shell may be
charged to a later visible shell in the same spike window.  A useful theorem
would need a density-preserving map `shift` with controlled multiplicity. -/
def LaggedVisibleSpikeDomination
    (Bad Visible : ℕ → Prop) (shift : ℕ → ℕ) : Prop :=
  (∀ᶠ m in Filter.atTop, Bad m → Visible (shift m)) ∧
  (∀ N : ℕ, ((Finset.range (N + 1)).image shift).card ≤ N + 1)

/-- The exact remaining arithmetic target used by the final ordered-shadow
assembly, restated from the diagnostic viewpoint. -/
def EndpointResidueVisibleSpikeTarget
    (nu : ℝ) (H V : ℕ → ℝ) (x : ℝ) : Prop :=
  EndpointResidueBreaksLossBarrierTarget nu H V x

/-- Sufficient route: same-shell endpoint avoidance implies the final
visible-spike target, provided the project-visible spike predicate is calibrated
to the same height sequence.  This is intentionally a predicate-level scaffold:
the calibration theorem is project-specific. -/
def EndpointAvoidanceCalibratesVisibleSpike
    (Bad : ℕ → Prop) (X H V : ℕ → ℝ) (nu x : ℝ) : Prop :=
  SameShellEndpointAvoidance Bad X nu x →
    ∀ᶠ m in Filter.atTop, Bad m → VisibleBlockSpikeShell H V x m

/-- The most concrete next theorem to prove.
It is weaker than proving `mu = 2`, but strong enough to feed the completed
ordered-shadow density/contraction pipeline. -/
def NextConcreteArithmeticTheorem
    (nu x : ℝ) (H V X : ℕ → ℝ) : Prop :=
  EndpointAvoidanceCalibratesVisibleSpike
    (fun m => BadRamanujanTruncation nu m) X H V nu x ∧
  SameShellEndpointAvoidance
    (fun m => BadRamanujanTruncation nu m) X nu x

/-! ## Endpoint-exceptional density split -/

/-- Endpoint-exceptional shells for the final arithmetic split.

This predicate is intentionally abstract.  In the intended application it is a
bad shell whose relevant continued-fraction block denominator lies too close to
the endpoint `X_j ≈ kappa * m / nu`, so it does not force a same-shell visible
block spike. -/
def EndpointExceptionalShell (Endpoint : ℕ → Prop) : ℕ → Prop := Endpoint

/-- Bad truncations split into visible spikes plus endpoint-exceptional shells. -/
def BadTruncationVisibleEndpointSplit
    (nu : ℝ) (H V : ℕ → ℝ) (x : ℝ) (Endpoint : ℕ → Prop) : Prop :=
  ∀ m : ℕ,
    BadRamanujanTruncation nu m →
      VisibleBlockSpikeShell H V x m ∨ Endpoint m

/-- Finite union count bound for predicates on `{0, ..., N}`. -/
theorem natInitialSegmentCount_or_le
    (B C : ℕ → Prop) (N : ℕ) :
    natInitialSegmentCount (fun n => B n ∨ C n) N
      ≤ natInitialSegmentCount B N + natInitialSegmentCount C N := by
  classical
  letI : DecidablePred B := fun n => Classical.propDecidable (B n)
  letI : DecidablePred C := fun n => Classical.propDecidable (C n)
  letI : DecidablePred (fun n => B n ∨ C n) :=
    fun n => Classical.propDecidable (B n ∨ C n)
  unfold natInitialSegmentCount
  apply le_trans (b :=
    (((Finset.range (N + 1)).filter B) ∪
      ((Finset.range (N + 1)).filter C)).card)
  · apply Finset.card_le_card
    intro n hn
    rw [Finset.mem_filter] at hn
    rw [Finset.mem_union, Finset.mem_filter, Finset.mem_filter]
    rcases hn with ⟨hns, hBC⟩
    rcases hBC with hB | hC
    · exact Or.inl ⟨hns, hB⟩
    · exact Or.inr ⟨hns, hC⟩
  · exact Finset.card_union_le _ _

/-- Upper density of a union is bounded by the sum of upper-density bounds. -/
theorem upperNatDensityAtMost_or
    {B C : ℕ → Prop} {δB δC : ℝ}
    (hB : UpperNatDensityAtMost B δB)
    (hC : UpperNatDensityAtMost C δC) :
    UpperNatDensityAtMost (fun n => B n ∨ C n) (δB + δC) := by
  classical
  intro ε hε
  have hε2 : 0 < ε / 2 := by linarith
  have hB' := hB (ε / 2) hε2
  have hC' := hC (ε / 2) hε2
  filter_upwards [hB', hC'] with N hBN hCN
  have hcnt_nat := natInitialSegmentCount_or_le B C N
  have hcnt :
      (natInitialSegmentCount (fun n => B n ∨ C n) N : ℝ)
        ≤ (natInitialSegmentCount B N : ℝ)
          + (natInitialSegmentCount C N : ℝ) := by
    exact_mod_cast hcnt_nat
  calc
    (natInitialSegmentCount (fun n => B n ∨ C n) N : ℝ)
        ≤ (natInitialSegmentCount B N : ℝ)
          + (natInitialSegmentCount C N : ℝ) := hcnt
    _ ≤ (δB + ε / 2) * ((N : ℝ) + 1)
          + (δC + ε / 2) * ((N : ℝ) + 1) := by
        nlinarith
    _ = (δB + δC + ε) * ((N : ℝ) + 1) := by ring

/-- If `Bad ⊆ Visible ∪ Endpoint`, then the upper density of `Bad` is bounded
by the sum of the visible and endpoint density bounds. -/
theorem badDensityAtMost_of_visible_endpoint_split
    {nu x δV δE : ℝ} {H V : ℕ → ℝ} {Endpoint : ℕ → Prop}
    (hsplit : BadTruncationVisibleEndpointSplit nu H V x Endpoint)
    (hVisible : UpperNatDensityAtMost (VisibleBlockSpikeShell H V x) δV)
    (hEndpoint : UpperNatDensityAtMost Endpoint δE) :
    UpperNatDensityAtMost (BadRamanujanTruncation nu) (δV + δE) := by
  have hUnion :
      UpperNatDensityAtMost
        (fun m => VisibleBlockSpikeShell H V x m ∨ Endpoint m)
        (δV + δE) :=
    upperNatDensityAtMost_or hVisible hEndpoint
  exact Criteria.upperDensityAtMost_mono hsplit hUnion

/-- Endpoint-exceptional route to strict bad-truncation density deficit.

Here `eps` is the density allowance for endpoint-exceptional shells.  The
visible shells have density at most `1 - Γ_tau(x)`.  If
`nu / M + eps < Γ_tau(x)`, then the bad set has density strictly below
`1 - nu / M`. -/
theorem badDensityLessThan_of_endpointExceptionalSplit
    {nu M tau x eps : ℝ} {H V : ℕ → ℝ} {Endpoint : ℕ → Prop}
    (hsplit : BadTruncationVisibleEndpointSplit nu H V x Endpoint)
    (hVisible :
      UpperNatDensityAtMost
        (VisibleBlockSpikeShell H V x)
        (1 - shellSpikeGoodDensityGain tau x))
    (hEndpoint : UpperNatDensityAtMost Endpoint eps)
    (heps_nonneg : 0 ≤ eps)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (hgain : nu / M + eps < shellSpikeGoodDensityGain tau x) :
    UpperNatDensityLessThan (BadRamanujanTruncation nu) (1 - nu / M) := by
  let δ : ℝ := (1 - shellSpikeGoodDensityGain tau x) + eps
  have hδ : UpperNatDensityAtMost (BadRamanujanTruncation nu) δ := by
    dsimp [δ]
    exact badDensityAtMost_of_visible_endpoint_split
      (nu := nu) (x := x) (H := H) (V := V) (Endpoint := Endpoint)
      hsplit hVisible hEndpoint
  have hδ_lt : δ < 1 - nu / M := by
    dsimp [δ]
    linarith
  have hδ_nonneg : 0 ≤ δ := by
    dsimp [δ]
    linarith
  exact ⟨δ, hδ_nonneg, hδ_lt, hδ⟩

/-- Final endpoint-exceptional Bauer/Ramanujan measure improvement wrapper.

This is the replacement for the too-strong pointwise target `Bad -> Visible`.
It permits endpoint-exceptional bad shells as long as their upper density is
smaller than the gain surplus. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_endpointExceptionalSplit
    {mu nu M tau x eps : ℝ}
    {Hlog u vseq H V : ℕ → ℝ} {Endpoint : ℕ → Prop}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (_hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hsplit : BadTruncationVisibleEndpointSplit nu H V x Endpoint)
    (hEndpoint : UpperNatDensityAtMost Endpoint eps)
    (heps_nonneg : 0 ≤ eps)
    (hgain_surplus : nu / M + eps < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  have hVisible :
      UpperNatDensityAtMost
        (VisibleBlockSpikeShell H V x)
        (1 - shellSpikeGoodDensityGain tau x) :=
    C.visibleSpike_density_atMost
  have hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1 :=
    shellSpikeGoodDensityGain_le_one htau hx1 hxθ
  have hBadLess :
      UpperNatDensityLessThan (BadRamanujanTruncation nu) (1 - nu / M) :=
    badDensityLessThan_of_endpointExceptionalSplit
      (nu := nu) (M := M) (tau := tau) (x := x)
      (H := H) (V := V) (Endpoint := Endpoint) (eps := eps)
      hsplit hVisible hEndpoint heps_nonneg hgain_le_one hgain_surplus
  exact oneOverPi_irratMeasure_lt_knownBound_of_badDensity_lt
    (μ := mu) (ν := nu) (M := M)
    hmu hnu2 hnuM
    (ramanujanPi_eventuallyTwoSidedExpMargin hBauer)
    hBadLess

/-- The concrete remaining arithmetic target after allowing endpoint
exceptions.

This is weaker and more plausible than pointwise `Bad -> Visible`: split bad
truncations into visible shell spikes and endpoint shells of small density. -/
def EndpointExceptionalDensityTarget
    (nu : ℝ) (H V : ℕ → ℝ) (x eps : ℝ) : Prop :=
  ∃ Endpoint : ℕ → Prop,
    BadTruncationVisibleEndpointSplit nu H V x Endpoint ∧
    UpperNatDensityAtMost Endpoint eps

/-! ## Offset formulation of endpoint exceptions -/

/-- Endpoint exceptional shells: bad shells whose relevant block data never
gets far enough below the denominator cap to force a same-shell visible spike. -/
def EndpointExceptionalByOffset
    (nu x : ℝ) (X : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) : ℕ → Prop :=
  fun m =>
    BadRamanujanTruncation nu m ∧
      ∀ j : ℕ,
        Relevant m j →
          (1 - x) * ramanujanDenominatorCapLog nu m < X j

/-- Endpoint subwindow for a block index `j`.

This is the interval of shell indices where the block is relevant to a bad
truncation but too close to the endpoint to force a visible spike. -/
def EndpointSubwindow
    (nu x : ℝ) (X : ℕ → ℝ) (j m : ℕ) : Prop :=
  (1 - x) * ramanujanDenominatorCapLog nu m < X j ∧
    X j ≤ ramanujanDenominatorCapLog nu m

/-- Endpoint exceptional shells are covered by endpoint subwindows. -/
def EndpointExceptionalSubwindowCover
    (nu x : ℝ) (X : ℕ → ℝ)
    (Relevant : ℕ → ℕ → Prop) : Prop :=
  ∀ m : ℕ,
    EndpointExceptionalByOffset nu x X Relevant m →
      ∃ j : ℕ, Relevant m j ∧ EndpointSubwindow nu x X j m

/-- Endpoint subwindow density target.

This is the new arithmetic target replacing the impossible pointwise
`Bad -> Visible` theorem. -/
def EndpointSubwindowDensityTarget
    (nu x eps : ℝ) (X : ℕ → ℝ)
    (Relevant : ℕ → ℕ → Prop) : Prop :=
  ∃ Endpoint : ℕ → Prop,
    (∀ m, EndpointExceptionalByOffset nu x X Relevant m → Endpoint m) ∧
    UpperNatDensityAtMost Endpoint eps

/-- If endpoint-exceptional shells are covered by a small-density endpoint set,
the endpoint-exceptional package required by the final wrapper follows. -/
theorem endpointExceptionalDensityTarget_of_offsetCover
    {nu x eps : ℝ} {X : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    {H V : ℕ → ℝ}
    (hSplit : ∀ m,
      BadRamanujanTruncation nu m →
        VisibleBlockSpikeShell H V x m ∨
          EndpointExceptionalByOffset nu x X Relevant m)
    (hSmall :
      EndpointSubwindowDensityTarget nu x eps X Relevant) :
    EndpointExceptionalDensityTarget nu H V x eps := by
  rcases hSmall with ⟨Endpoint, hdomEndpoint, hDensity⟩
  refine ⟨Endpoint, ?_, hDensity⟩
  intro m hBad
  rcases hSplit m hBad with hVis | hExc
  · exact Or.inl hVis
  · exact Or.inr (hdomEndpoint m hExc)

/-! ## Endpoint subwindow density reduction -/

/-- The endpoint subwindow union attached to a relevance relation. -/
def EndpointSubwindowUnion
    (nu x : ℝ) (X : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) : ℕ → Prop :=
  fun m => ∃ j : ℕ, Relevant m j ∧ EndpointSubwindow nu x X j m

/-- If endpoint-exceptional shells are covered by endpoint subwindows, then an
upper-density bound for the endpoint-subwindow union gives the endpoint
subwindow density target. -/
theorem endpointSubwindowDensityTarget_of_unionDensity
    {nu x eps : ℝ} {X : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    (hCover : EndpointExceptionalSubwindowCover nu x X Relevant)
    (hDensity : UpperNatDensityAtMost
      (EndpointSubwindowUnion nu x X Relevant) eps) :
    EndpointSubwindowDensityTarget nu x eps X Relevant := by
  refine ⟨EndpointSubwindowUnion nu x X Relevant, ?_, hDensity⟩
  intro m hm
  rcases hCover m hm with ⟨j, hRel, hSub⟩
  exact ⟨j, hRel, hSub⟩

/-- Endpoint-exceptional density target follows directly from a subwindow cover
and a density estimate for the endpoint-subwindow union. -/
theorem endpointExceptionalDensityTarget_of_subwindowUnionDensity
    {nu x eps : ℝ} {X H V : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    (hSplit : ∀ m,
      BadRamanujanTruncation nu m →
        VisibleBlockSpikeShell H V x m ∨
          EndpointExceptionalByOffset nu x X Relevant m)
    (hCover : EndpointExceptionalSubwindowCover nu x X Relevant)
    (hDensity : UpperNatDensityAtMost
      (EndpointSubwindowUnion nu x X Relevant) eps) :
    EndpointExceptionalDensityTarget nu H V x eps := by
  have hSmall : EndpointSubwindowDensityTarget nu x eps X Relevant :=
    endpointSubwindowDensityTarget_of_unionDensity
      (nu := nu) (x := x) (eps := eps) (X := X) (Relevant := Relevant)
      hCover hDensity
  exact endpointExceptionalDensityTarget_of_offsetCover
    (nu := nu) (x := x) (eps := eps) (X := X) (Relevant := Relevant)
    (H := H) (V := V) hSplit hSmall

/-- The endpoint-subwindow density target can be stated as the single remaining
arithmetic problem.  It asks for a small-density estimate for a completely
explicit union of endpoint windows. -/
def EndpointSubwindowUnionDensityArithmeticTarget
    (nu x eps : ℝ) (X : ℕ → ℝ) (Relevant : ℕ → ℕ → Prop) : Prop :=
  UpperNatDensityAtMost (EndpointSubwindowUnion nu x X Relevant) eps

/-- Direct final wrapper from endpoint-subwindow union density to the existing
Bauer/Ramanujan measure improvement theorem. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_endpointSubwindowUnionDensity
    {mu nu M tau x eps : ℝ}
    {Hlog u vseq H V X : ℕ → ℝ} {Relevant : ℕ → ℕ → Prop}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hSplit : ∀ m,
      BadRamanujanTruncation nu m →
        VisibleBlockSpikeShell H V x m ∨
          EndpointExceptionalByOffset nu x X Relevant m)
    (hCover : EndpointExceptionalSubwindowCover nu x X Relevant)
    (hDensity : UpperNatDensityAtMost
      (EndpointSubwindowUnion nu x X Relevant) eps)
    (heps_nonneg : 0 ≤ eps)
    (hgain_surplus : nu / M + eps < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  have hEndpoint : EndpointExceptionalDensityTarget nu H V x eps :=
    endpointExceptionalDensityTarget_of_subwindowUnionDensity
      (nu := nu) (x := x) (eps := eps) (X := X)
      (H := H) (V := V) (Relevant := Relevant)
      hSplit hCover hDensity
  rcases hEndpoint with ⟨Endpoint, hEVSplit, hEDensity⟩
  exact oneOverPi_irratMeasure_lt_of_Bauer_endpointExceptionalSplit
    (mu := mu) (nu := nu) (M := M) (tau := tau) (x := x) (eps := eps)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    (Endpoint := Endpoint)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ
    hEVSplit hEDensity heps_nonneg hgain_surplus

/-! ## Non-visible bad-shell density -/

/-- The non-visible bad Ramanujan truncation shells. -/
def NonVisibleBadShell
    (nu : ℝ) (H V : ℕ → ℝ) (x : ℝ) : ℕ → Prop :=
  fun m => BadRamanujanTruncation nu m ∧ ¬ VisibleBlockSpikeShell H V x m

/-- A bad shell is always either visible or non-visible, tautologically. -/
theorem badTruncationVisibleEndpointSplit_nonVisible
    (nu : ℝ) (H V : ℕ → ℝ) (x : ℝ) :
    BadTruncationVisibleEndpointSplit nu H V x
      (NonVisibleBadShell nu H V x) := by
  intro m hBad
  by_cases hVis : VisibleBlockSpikeShell H V x m
  · exact Or.inl hVis
  · exact Or.inr ⟨hBad, hVis⟩

/-- Under an endpoint-exceptional split, every non-visible bad shell lies in
that endpoint-exceptional set. -/
theorem nonVisibleBadShell_subset_endpoint
    {nu x : ℝ} {H V : ℕ → ℝ} {Endpoint : ℕ → Prop}
    (hsplit : BadTruncationVisibleEndpointSplit nu H V x Endpoint) :
    ∀ m : ℕ,
      NonVisibleBadShell nu H V x m → Endpoint m := by
  intro m hm
  rcases hm with ⟨hBad, hNotVis⟩
  rcases hsplit m hBad with hVis | hEnd
  · exact False.elim (hNotVis hVis)
  · exact hEnd

/-- Hence an upper-density bound for endpoint-exceptional shells gives the same
upper-density bound for non-visible bad shells. -/
theorem nonVisibleBadDensityAtMost_of_endpointSplit
    {nu x eps : ℝ} {H V : ℕ → ℝ} {Endpoint : ℕ → Prop}
    (hsplit : BadTruncationVisibleEndpointSplit nu H V x Endpoint)
    (hEndpoint : UpperNatDensityAtMost Endpoint eps) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) eps := by
  exact Criteria.upperDensityAtMost_mono
    (nonVisibleBadShell_subset_endpoint (nu := nu) (x := x)
      (H := H) (V := V) (Endpoint := Endpoint) hsplit)
    hEndpoint

/-- The existing endpoint-exceptional target implies small density of the
non-visible bad shells. -/
theorem nonVisibleBadDensityAtMost_of_endpointExceptionalDensityTarget
    {nu x eps : ℝ} {H V : ℕ → ℝ}
    (hTarget : EndpointExceptionalDensityTarget nu H V x eps) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) eps := by
  rcases hTarget with ⟨Endpoint, hsplit, hEndpoint⟩
  exact nonVisibleBadDensityAtMost_of_endpointSplit
    (nu := nu) (x := x) (H := H) (V := V)
    (Endpoint := Endpoint) hsplit hEndpoint

/-- If the non-visible bad shells themselves have density at most `eps`, then
we can instantiate the endpoint-exceptional target using them as the endpoint
set.  Thus controlling non-visible bad shells is exactly the missing arithmetic
content. -/
theorem endpointExceptionalDensityTarget_of_nonVisibleBadDensity
    {nu x eps : ℝ} {H V : ℕ → ℝ}
    (hNV : UpperNatDensityAtMost (NonVisibleBadShell nu H V x) eps) :
    EndpointExceptionalDensityTarget nu H V x eps := by
  refine ⟨NonVisibleBadShell nu H V x, ?_, hNV⟩
  exact badTruncationVisibleEndpointSplit_nonVisible nu H V x

/-- Equivalence package: endpoint-exceptional density control and non-visible
bad-density control are interchangeable at this abstraction level. -/
theorem endpointExceptionalDensityTarget_iff_nonVisibleBadDensity
    {nu x eps : ℝ} {H V : ℕ → ℝ} :
    EndpointExceptionalDensityTarget nu H V x eps ↔
      UpperNatDensityAtMost (NonVisibleBadShell nu H V x) eps := by
  constructor
  · intro hTarget
    exact nonVisibleBadDensityAtMost_of_endpointExceptionalDensityTarget
      (nu := nu) (x := x) (eps := eps) (H := H) (V := V) hTarget
  · intro hNV
    exact endpointExceptionalDensityTarget_of_nonVisibleBadDensity
      (nu := nu) (x := x) (eps := eps) (H := H) (V := V) hNV

/-- Final wrapper: if non-visible bad shells have density allowance `eps`, and
that allowance is smaller than the visible-shell gain surplus, the existing
Bauer/Ramanujan contraction proves `mu < M`. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    {mu nu M tau x eps : ℝ}
    {Hlog u vseq H V : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hNV : UpperNatDensityAtMost (NonVisibleBadShell nu H V x) eps)
    (heps_nonneg : 0 ≤ eps)
    (hgain_surplus : nu / M + eps < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  have hTarget : EndpointExceptionalDensityTarget nu H V x eps :=
    endpointExceptionalDensityTarget_of_nonVisibleBadDensity
      (nu := nu) (x := x) (eps := eps) (H := H) (V := V) hNV
  rcases hTarget with ⟨Endpoint, hsplit, hEndpoint⟩
  exact oneOverPi_irratMeasure_lt_of_Bauer_endpointExceptionalSplit
    (mu := mu) (nu := nu) (M := M) (tau := tau) (x := x) (eps := eps)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    (Endpoint := Endpoint)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ
    hsplit hEndpoint heps_nonneg hgain_surplus

/-- The arithmetic target still missing after all density reductions.

A proof of this predicate must use Ramanujan-specific endpoint localization,
residue exclusion, or endpoint subwindow covering.  It cannot follow from the
loss-two generic window algebra alone. -/
def NonVisibleBadDensityArithmeticTarget
    (nu : ℝ) (H V : ℕ → ℝ) (x eps : ℝ) : Prop :=
  UpperNatDensityAtMost (NonVisibleBadShell nu H V x) eps

/-! ## Endpoint-weighted average route -/

/-- Positive part on reals. -/
def rpos (t : ℝ) : ℝ := max 0 t

/-- Endpoint excess contributed by convergent block `j` at exponent `nu`.
This is `max 0 (Y_j - (nu - 1) X_j)`, i.e. `nu` times the real length of
`[X_j, (X_j + Y_j) / nu]` when the interval is active. -/
def endpointExcessTerm (X Y : ℕ → ℝ) (nu : ℝ) (j : ℕ) : ℝ :=
  rpos (Y j - (nu - 1) * X j)

/-- Cumulative endpoint excess through index `J`. -/
def endpointExcessSum (X Y : ℕ → ℝ) (nu : ℝ) (J : ℕ) : ℝ :=
  Finset.sum (Finset.range (J + 1)) (fun j => endpointExcessTerm X Y nu j)

/-- Endpoint scale at index `J`: the right endpoint scale `X_J + Y_J`. -/
def endpointScale (X Y : ℕ → ℝ) (J : ℕ) : ℝ :=
  X J + Y J

/-- Endpoint-weighted average bound.  This is the central arithmetic input.
It says the convergent endpoint intervals have total excess at most `delta` of
the endpoint scale. -/
def EndpointWeightedAverageBound
    (X Y : ℕ → ℝ) (nu delta : ℝ) : Prop :=
  ∀ᶠ J in Filter.atTop,
    endpointExcessSum X Y nu J ≤ delta * endpointScale X Y J

/-- The exact amount of endpoint saving needed to improve a current bound `M`
at exponent `nu`. -/
def endpointContractionThreshold (M nu : ℝ) : ℝ :=
  1 - nu / M

/-- A weighted endpoint bound is useful for improving `M` if its density is
below the contraction threshold. -/
def EndpointWeightedAverageImproves (M nu delta : ℝ) : Prop :=
  delta < endpointContractionThreshold M nu

/-- Abstract bridge from endpoint-weighted average to non-visible bad density.
This is the remaining arithmetic-to-shell conversion target: prove that the
weighted endpoint excess controls the endpoint-exceptional/non-visible bad
shells. -/
def EndpointWeightedAverageControlsNonVisibleBad
    (X Y H V : ℕ → ℝ) (nu x delta : ℝ) : Prop :=
  EndpointWeightedAverageBound X Y nu delta →
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) delta

/-- If endpoint-weighted average controls non-visible bad shells, then it gives
the existing non-visible-bad arithmetic target. -/
theorem nonVisibleBadDensityTarget_of_endpointWeightedAverage
    {X Y H V : ℕ → ℝ} {nu x delta : ℝ}
    (hctrl : EndpointWeightedAverageControlsNonVisibleBad X Y H V nu x delta)
    (havg : EndpointWeightedAverageBound X Y nu delta) :
    NonVisibleBadDensityArithmeticTarget nu H V x delta := by
  exact hctrl havg

/-- Endpoint-weighted average route to the final Bauer/Ramanujan measure
improvement.  This theorem is intentionally only a wrapper: all hard arithmetic
content is in `EndpointWeightedAverageControlsNonVisibleBad` and
`EndpointWeightedAverageBound`. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_endpointWeightedAverage
    {mu M nu tau x delta : ℝ}
    {X Y H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (_hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (havg : EndpointWeightedAverageBound X Y nu delta)
    (hctrl : EndpointWeightedAverageControlsNonVisibleBad X Y H V nu x delta)
    (hdelta_nonneg : 0 ≤ delta)
    (hdelta_gain : nu / M + delta < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  have hNV : UpperNatDensityAtMost (NonVisibleBadShell nu H V x) delta :=
    hctrl havg
  exact oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    (mu := mu) (nu := nu) (M := M) (tau := tau) (x := x)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hNV hdelta_nonneg hdelta_gain

/-!
## Boundary-included endpoint bridge

The original boundary-included endpoint plan is recovered from endpoint
localization/subwindow counting.  This is separate from the one-threshold
active-mass route: the bridge below is provable once the endpoint subwindow
union is controlled by the boundary-included endpoint average.
-/

/-- Boundary-included endpoint-subwindow density is controlled by the
boundary-included endpoint-weighted average. -/
def EndpointSubwindowUnionControlledByEndpointWeightedAverage
    (X Y : ℕ → ℝ) (nu x delta : ℝ)
    (Relevant : ℕ → ℕ → Prop) : Prop :=
  EndpointWeightedAverageBound X Y nu delta →
    UpperNatDensityAtMost (EndpointSubwindowUnion nu x X Relevant) delta

/-- The old boundary-included endpoint bridge is provable from the endpoint
subwindow localization plan. -/
theorem endpointWeightedAverageControlsNonVisibleBad_of_subwindowUnionControl
    {X Y H V : ℕ → ℝ} {nu x delta : ℝ} {Relevant : ℕ → ℕ → Prop}
    (hSplit : ∀ m,
      BadRamanujanTruncation nu m →
        VisibleBlockSpikeShell H V x m ∨
          EndpointExceptionalByOffset nu x X Relevant m)
    (hCover : EndpointExceptionalSubwindowCover nu x X Relevant)
    (hControl :
      EndpointSubwindowUnionControlledByEndpointWeightedAverage
        X Y nu x delta Relevant) :
    EndpointWeightedAverageControlsNonVisibleBad X Y H V nu x delta := by
  intro havg
  have hDensity : UpperNatDensityAtMost
      (EndpointSubwindowUnion nu x X Relevant) delta :=
    hControl havg
  have hEndpoint : EndpointExceptionalDensityTarget nu H V x delta :=
    endpointExceptionalDensityTarget_of_subwindowUnionDensity
      (nu := nu) (x := x) (eps := delta) (X := X)
      (H := H) (V := V) (Relevant := Relevant)
      hSplit hCover hDensity
  exact nonVisibleBadDensityAtMost_of_endpointExceptionalDensityTarget
    (nu := nu) (x := x) (eps := delta) (H := H) (V := V) hEndpoint

/-- If the previous endpoint plan already constructs an endpoint-exceptional
density target from the endpoint average, then the non-visible-bad bridge
follows. -/
theorem endpointWeightedAverageControlsNonVisibleBad_of_endpointExceptionalControl
    {X Y H V : ℕ → ℝ} {nu x delta : ℝ}
    (hEndpointControl :
      EndpointWeightedAverageBound X Y nu delta →
        EndpointExceptionalDensityTarget nu H V x delta) :
    EndpointWeightedAverageControlsNonVisibleBad X Y H V nu x delta := by
  intro havg
  exact nonVisibleBadDensityAtMost_of_endpointExceptionalDensityTarget
    (nu := nu) (x := x) (eps := delta) (H := H) (V := V)
    (hEndpointControl havg)

/-- Project-facing target: the exact missing finite counting statement for the
boundary-included endpoint plan. -/
def BoundaryIncludedEndpointSubwindowCountingTarget
    (X Y : ℕ → ℝ) (nu x delta : ℝ)
    (Relevant : ℕ → ℕ → Prop) : Prop :=
  EndpointSubwindowUnionControlledByEndpointWeightedAverage
    X Y nu x delta Relevant

/-- Boundary-included endpoint-subwindow counting plus the formalized split and
cover gives the old endpoint-weighted-average bridge. -/
theorem endpointWeightedAverageControlsNonVisibleBad_of_boundaryIncludedCountingTarget
    {X Y H V : ℕ → ℝ} {nu x delta : ℝ} {Relevant : ℕ → ℕ → Prop}
    (hSplit : ∀ m,
      BadRamanujanTruncation nu m →
        VisibleBlockSpikeShell H V x m ∨
          EndpointExceptionalByOffset nu x X Relevant m)
    (hCover : EndpointExceptionalSubwindowCover nu x X Relevant)
    (hCounting :
      BoundaryIncludedEndpointSubwindowCountingTarget
        X Y nu x delta Relevant) :
    EndpointWeightedAverageControlsNonVisibleBad X Y H V nu x delta := by
  exact endpointWeightedAverageControlsNonVisibleBad_of_subwindowUnionControl
    (X := X) (Y := Y) (H := H) (V := V)
    (nu := nu) (x := x) (delta := delta) (Relevant := Relevant)
    hSplit hCover hCounting

/-- Model endpoint density under a uniform ratio cap `rho`.
This is the expression

```text
rho * (rho + 1 - nu) / ((rho + 1) * (rho - 1))
```

from the geometric model `Y_j = rho * X_j`.  It is meaningful for `rho > 1`
and `nu < rho + 1`; otherwise the endpoint intervals are inactive or the
formula needs clipping. -/
def endpointModelDensity (rho nu : ℝ) : ℝ :=
  rho * (rho + 1 - nu) / ((rho + 1) * (rho - 1))

/-- Worst-case endpoint density from only `mu ≤ M`, corresponding to
`rho = M - 1`. -/
def endpointWorstDensity (M nu : ℝ) : ℝ :=
  endpointModelDensity (M - 1) nu

/-- Algebraic obstruction: the worst endpoint density exceeds the contraction
threshold by `(M - nu) / (M * (M - 2))`.
This is stated as a target theorem because it is useful diagnostic algebra. -/
def EndpointWorstExcessFormula (M nu : ℝ) : Prop :=
  endpointWorstDensity M nu - endpointContractionThreshold M nu
    = (M - nu) / (M * (M - 2))

/-- Two-bin weighted saving criterion.
`p` is the endpoint-weighted fraction controlled by ratio `rho`; the remaining
mass is allowed to be worst-case at `M - 1`. -/
def TwoBinEndpointDensityBound (M nu rho p : ℝ) : ℝ :=
  p * endpointModelDensity rho nu + (1 - p) * endpointWorstDensity M nu

/-- Two-bin average route to improvement: if the two-bin density is below the
contraction threshold, then it is a valid endpoint density target. -/
def TwoBinEndpointImproves (M nu rho p : ℝ) : Prop :=
  TwoBinEndpointDensityBound M nu rho p < endpointContractionThreshold M nu

/-- Practical arithmetic target: prove enough endpoint-weighted mass has
non-extremal ratio.  This is not asserted; it is the concrete theorem to
attack. -/
def EndpointWeightedNonExtremalMassTarget
    (X Y : ℕ → ℝ) (rho p : ℝ) : Prop :=
  ∀ᶠ J in Filter.atTop,
    p * Finset.sum (Finset.range (J + 1)) (fun j => X j)
      ≤ Finset.sum
        ((Finset.range (J + 1)).filter (fun j => Y j ≤ rho * X j))
        (fun j => X j)

/-- The easiest useful route in words:
prove `EndpointWeightedNonExtremalMassTarget` for some `rho < M - 1` and large
enough `p`, then derive `EndpointWeightedAverageBound` with a density below the
contraction threshold.  This implication is project-specific and is left as a
named target, not an axiom. -/
def EndpointWeightedAverageBoundFromNonExtremalMassTarget
    (X Y : ℕ → ℝ) (M nu rho p delta : ℝ) : Prop :=
  EndpointWeightedNonExtremalMassTarget X Y rho p →
    TwoBinEndpointDensityBound M nu rho p ≤ delta →
      EndpointWeightedAverageBound X Y nu delta

/-! ## Endpoint-weighted ratio-tail route -/

/-- Log-denominator jump ratio. -/
def logJumpRatio (X : ℕ → ℝ) (j : ℕ) : ℝ :=
  X (j + 1) / X j

/-- Endpoint excess at exponent `nu`, expressed using one denominator-log
sequence and its successor. -/
def endpointRatioExcessTerm (nu : ℝ) (X : ℕ → ℝ) (j : ℕ) : ℝ :=
  max 0 (X (j + 1) - (nu - 1) * X j)

/-- Endpoint excess sum up to `J`. -/
def endpointRatioExcessSum (nu : ℝ) (X : ℕ → ℝ) (J : ℕ) : ℝ :=
  Finset.sum (Finset.range J) (fun j => endpointRatioExcessTerm nu X j)

/-- Natural endpoint scale. -/
def endpointRatioScale (X : ℕ → ℝ) (J : ℕ) : ℝ :=
  X J + X (J + 1)

/-- Helpful strict positivity version.  For the ratio identity
`X (j + 1) / X j`, strict positivity of `X j` is the natural local scale
assumption. -/
def EventuallyPositiveLogScale (X : ℕ → ℝ) : Prop :=
  ∀ᶠ j in Filter.atTop, 0 < X j

/-- Ratio excess identity: if `0 < X j`, then the endpoint excess equals
`X j * max 0 (r_j - (nu - 1))`. -/
theorem endpointExcessTerm_eq_mul_ratio_excess
    {nu : ℝ} {X : ℕ → ℝ} {j : ℕ}
    (hX : 0 < X j) :
    endpointRatioExcessTerm nu X j =
      X j * max 0 (logJumpRatio X j - (nu - 1)) := by
  unfold endpointRatioExcessTerm logJumpRatio
  have hne : X j ≠ 0 := ne_of_gt hX
  have hmul :
      X j * (X (j + 1) / X j - (nu - 1))
        = X (j + 1) - (nu - 1) * X j := by
    calc
      X j * (X (j + 1) / X j - (nu - 1))
          = X j * (X (j + 1) / X j) - X j * (nu - 1) := by ring
      _ = X (j + 1) - X j * (nu - 1) := by
        rw [mul_div_cancel₀ (X (j + 1)) hne]
      _ = X (j + 1) - (nu - 1) * X j := by ring
  rw [mul_max_of_nonneg 0 (X (j + 1) / X j - (nu - 1)) (le_of_lt hX)]
  simp [hmul]

/-- Weighted tail mass of jump ratios above a threshold `t`. -/
def weightedRatioTailMass (X : ℕ → ℝ) (t : ℝ) (J : ℕ) : ℝ :=
  Finset.sum
    ((Finset.range J).filter (fun j => t < logJumpRatio X j))
    (fun j => X j)

/-- Ratio-tail bound.  This is a flexible arithmetic target. -/
def WeightedRatioTailBound
    (X : ℕ → ℝ) (Phi : ℝ → ℝ) : Prop :=
  ∀ t : ℝ,
    ∀ᶠ J in Filter.atTop,
      weightedRatioTailMass X t J
        ≤ Phi t * endpointRatioScale X J

/-- Integral tail criterion.  In Lean this may first be represented by a finite
partition/Riemann-sum upper bound rather than an actual integral. -/
def RatioTailIntegralCriterion
    (_Phi : ℝ → ℝ) (_nu _M : ℝ) : Prop :=
  True

/-- Arithmetic target: ratio-tail distribution gives endpoint-weighted average
saving. -/
def EndpointWeightedAverageFromRatioTail
    (nu M : ℝ) (X : ℕ → ℝ) : Prop :=
  ∃ Phi : ℝ → ℝ,
    WeightedRatioTailBound X Phi ∧
    RatioTailIntegralCriterion Phi nu M

/-- Compatibility alias for the endpoint density under ratio cap `rho`. -/
def endpointRhoDensity (rho nu : ℝ) : ℝ :=
  endpointModelDensity rho nu

/-- Two-bin non-extremal endpoint-mass criterion.

`p` is the weighted fraction of endpoint mass where `r_j ≤ rho`.  If this
exceeds the threshold, it gives endpoint-average improvement. -/
def TwoBinWeightedNonExtremalCriterion
    (nu M rho p : ℝ) : Prop :=
  rho < M - 1 ∧
  p >
    (endpointWorstDensity M nu - (1 - nu / M)) /
      (endpointWorstDensity M nu - endpointRhoDensity rho nu)

/-- Main theorem target: endpoint weighted average improvement from ratio-tail
control.  The one-sequence form feeds the weighted-average API with
`Y j = X (j + 1)`. -/
def EndpointWeightedAverageImprovementTarget
    (nu M : ℝ) (X : ℕ → ℝ) : Prop :=
  ∃ delta : ℝ,
    delta < endpointContractionThreshold M nu ∧
    EndpointWeightedAverageBound X (fun j => X (j + 1)) nu delta

/-! ## Finite ratio-tail partitions -/

/-- A finite increasing partition represented by a function on `Fin (K + 1)`. -/
def StrictPartition
    (K : ℕ) (t : Fin (K + 1) → ℝ) : Prop :=
  ∀ k : Fin K, t k.castSucc < t k.succ

/-- Left endpoint of a partition cell. -/
def partLeft {K : ℕ} (t : Fin (K + 1) → ℝ) (k : Fin K) : ℝ :=
  t k.castSucc

/-- Right endpoint of a partition cell. -/
def partRight {K : ℕ} (t : Fin (K + 1) → ℝ) (k : Fin K) : ℝ :=
  t k.succ

/-- Width of a partition cell. -/
def partWidth {K : ℕ} (t : Fin (K + 1) → ℝ) (k : Fin K) : ℝ :=
  partRight t k - partLeft t k

/-- Finite upper-sum value for a weighted tail majorant `Phi`. -/
def finiteTailUpperSum
    {K : ℕ} (t : Fin (K + 1) → ℝ) (Phi : ℝ → ℝ) : ℝ :=
  Finset.sum Finset.univ (fun k : Fin K =>
    partWidth t k * Phi (partLeft t k))

/-- Eventual upper cap for all jump ratios. -/
def EventuallyRatioBoundedBy
    (X : ℕ → ℝ) (R : ℝ) : Prop :=
  ∀ᶠ j in Filter.atTop, logJumpRatio X j ≤ R

/-- Weighted ratio-tail bound at every left partition point. -/
def WeightedRatioTailBoundOnPartition
    {K : ℕ} (X : ℕ → ℝ) (t : Fin (K + 1) → ℝ)
    (Phi : ℝ → ℝ) : Prop :=
  ∀ k : Fin K,
    ∀ᶠ J in Filter.atTop,
      weightedRatioTailMass X (partLeft t k) J
        ≤ Phi (partLeft t k) * endpointRatioScale X J

/-- Target finite layer-cake estimate for one ratio.

If `a = t_0`, `R = t_K`, and `r ≤ R`, then `max 0 (r - a)` should be bounded
by the finite upper sum of tail indicators.  This is recorded as a target,
not an axiom. -/
def RatioExcessFiniteTailSumTarget
    {K : ℕ} (t : Fin (K + 1) → ℝ) (a R : ℝ) : Prop :=
  0 < K →
    StrictPartition K t →
    t ⟨0, Nat.succ_pos K⟩ = a →
    t ⟨K, Nat.lt_succ_self K⟩ = R →
    ∀ r : ℝ,
      r ≤ R →
        max 0 (r - a)
          ≤ Finset.sum Finset.univ (fun k : Fin K =>
            partWidth t k * (if partLeft t k < r then (1 : ℝ) else 0))

/-- Target endpoint-excess estimate from finite partition tail bounds.

This packages the planned layer-cake, multiplication by `X j`, finite summation,
sum-swap, and tail-bound steps as a named remaining target. -/
def EndpointRatioExcessSumFiniteTailUpperSumTarget
    {K : ℕ} (X : ℕ → ℝ) (t : Fin (K + 1) → ℝ)
    (Phi : ℝ → ℝ) (nu R : ℝ) : Prop :=
  0 < K →
    StrictPartition K t →
    t ⟨0, Nat.succ_pos K⟩ = nu - 1 →
    t ⟨K, Nat.lt_succ_self K⟩ = R →
    (∀ᶠ j in Filter.atTop, 0 ≤ X j) →
    EventuallyRatioBoundedBy X R →
    WeightedRatioTailBoundOnPartition X t Phi →
      ∀ᶠ J in Filter.atTop,
        endpointRatioExcessSum nu X J
          ≤ finiteTailUpperSum t Phi * endpointRatioScale X J

/-- Positive-scale version of the endpoint-excess finite-tail target.

This is the clean theorem to prove after the pointwise layer-cake estimate:
strict positivity gives the ratio identity, while eventual ratio boundedness
and partition tail bounds should control the endpoint-excess sum. -/
def EndpointRatioExcessSumFiniteTailUpperSumPositiveTarget
    {K : ℕ} (X : ℕ → ℝ) (t : Fin (K + 1) → ℝ)
    (Phi : ℝ → ℝ) (nu R : ℝ) : Prop :=
  0 < K →
    StrictPartition K t →
    t ⟨0, Nat.succ_pos K⟩ = nu - 1 →
    t ⟨K, Nat.lt_succ_self K⟩ = R →
    EventuallyPositiveLogScale X →
    EventuallyRatioBoundedBy X R →
    WeightedRatioTailBoundOnPartition X t Phi →
      ∀ᶠ J in Filter.atTop,
        endpointRatioExcessSum nu X J
          ≤ finiteTailUpperSum t Phi * endpointRatioScale X J

/-- Target closure theorem from finite ratio-tail partition data to the
endpoint-weighted average bound.  This is the exact formal bridge left after
the ratio-tail partition setup. -/
def EndpointWeightedAverageBoundOfFiniteRatioTailPartitionTarget
    {K : ℕ} (X : ℕ → ℝ) (t : Fin (K + 1) → ℝ)
    (Phi : ℝ → ℝ) (nu R delta : ℝ) : Prop :=
  0 < K →
    StrictPartition K t →
    t ⟨0, Nat.succ_pos K⟩ = nu - 1 →
    t ⟨K, Nat.lt_succ_self K⟩ = R →
    (∀ᶠ j in Filter.atTop, 0 ≤ X j) →
    EventuallyRatioBoundedBy X R →
    WeightedRatioTailBoundOnPartition X t Phi →
    finiteTailUpperSum t Phi ≤ delta →
      EndpointWeightedAverageBound X (fun j => X (j + 1)) nu delta

/-- Positive-scale finite ratio-tail partition closure target.

This is the same endpoint-weighted average closure as
`EndpointWeightedAverageBoundOfFiniteRatioTailPartitionTarget`, but with the
strict positivity hypothesis needed by the ratio identity. -/
def EndpointWeightedAverageBoundOfFiniteRatioTailPartitionPositiveTarget
    {K : ℕ} (X : ℕ → ℝ) (t : Fin (K + 1) → ℝ)
    (Phi : ℝ → ℝ) (nu R delta : ℝ) : Prop :=
  0 < K →
    StrictPartition K t →
    t ⟨0, Nat.succ_pos K⟩ = nu - 1 →
    t ⟨K, Nat.lt_succ_self K⟩ = R →
    EventuallyPositiveLogScale X →
    EventuallyRatioBoundedBy X R →
    WeightedRatioTailBoundOnPartition X t Phi →
    finiteTailUpperSum t Phi ≤ delta →
      EndpointWeightedAverageBound X (fun j => X (j + 1)) nu delta

/-- The positive-scale closure target implies the nonnegative-scale closure
target because eventual strict positivity implies eventual nonnegativity. -/
theorem EndpointWeightedAverageBoundOfFiniteRatioTailPartitionTarget_of_positive
    {K : ℕ} {X : ℕ → ℝ} {t : Fin (K + 1) → ℝ}
    {Phi : ℝ → ℝ} {nu R delta : ℝ}
    (hPositive :
      EndpointWeightedAverageBoundOfFiniteRatioTailPartitionPositiveTarget
        X t Phi nu R delta)
    (hK : 0 < K)
    (hmono : StrictPartition K t)
    (hfirst : t ⟨0, Nat.succ_pos K⟩ = nu - 1)
    (hlast : t ⟨K, Nat.lt_succ_self K⟩ = R)
    (hXpos : EventuallyPositiveLogScale X)
    (hRatioCap : EventuallyRatioBoundedBy X R)
    (hTail : WeightedRatioTailBoundOnPartition X t Phi)
    (hδ : finiteTailUpperSum t Phi ≤ delta) :
    EndpointWeightedAverageBound X (fun j => X (j + 1)) nu delta :=
  hPositive hK hmono hfirst hlast hXpos hRatioCap hTail hδ

/-- Final symbolic improvement wrapper from finite ratio-tail data.

The hard finite partition estimate is supplied as
`EndpointWeightedAverageBoundOfFiniteRatioTailPartitionTarget`; this wrapper
then feeds the existing endpoint-weighted-average and non-visible-bad density
machinery. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_finiteRatioTailPartition
    {mu nu M tau x R delta : ℝ}
    {K : ℕ} {X H V Hlog u vseq : ℕ → ℝ}
    {t : Fin (K + 1) → ℝ} {Phi : ℝ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hdelta_nonneg : 0 ≤ delta)
    (hgain : delta + nu / M < shellSpikeGoodDensityGain tau x)
    (hEndpointWeightedControls :
      EndpointWeightedAverageControlsNonVisibleBad
        X (fun j => X (j + 1)) H V nu x delta)
    (hFinite :
      EndpointWeightedAverageBoundOfFiniteRatioTailPartitionTarget
        X t Phi nu R delta)
    (hK : 0 < K)
    (hmono : StrictPartition K t)
    (hfirst : t ⟨0, Nat.succ_pos K⟩ = nu - 1)
    (hlast : t ⟨K, Nat.lt_succ_self K⟩ = R)
    (hXpos : ∀ᶠ j in Filter.atTop, 0 ≤ X j)
    (hRatioCap : EventuallyRatioBoundedBy X R)
    (hTail : WeightedRatioTailBoundOnPartition X t Phi)
    (hδ : finiteTailUpperSum t Phi ≤ delta) :
    mu < M := by
  have hAvg :
      EndpointWeightedAverageBound X (fun j => X (j + 1)) nu delta :=
    hFinite hK hmono hfirst hlast hXpos hRatioCap hTail hδ
  have hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1 :=
    shellSpikeGoodDensityGain_le_one htau hx1 hxθ
  have hgain' : nu / M + delta < shellSpikeGoodDensityGain tau x := by
    linarith
  exact oneOverPi_irratMeasure_lt_of_Bauer_endpointWeightedAverage
    (mu := mu) (M := M) (nu := nu) (tau := tau) (x := x)
    (delta := delta) (X := X) (Y := fun j => X (j + 1))
    (H := H) (V := V) (Hlog := Hlog) (u := u) (vseq := vseq)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hgain_le_one
    hAvg hEndpointWeightedControls hdelta_nonneg hgain'

/-! ## One-threshold endpoint-weighted ratio-tail closure -/

/-- One-threshold weighted active-ratio mass. -/
def weightedActiveRatioMass (X : ℕ → ℝ) (nu : ℝ) (J : ℕ) : ℝ :=
  weightedRatioTailMass X (nu - 1) J

/-- One-threshold weighted active-ratio bound. -/
def WeightedActiveRatioBound (X : ℕ → ℝ) (nu Phi : ℝ) : Prop :=
  ∀ᶠ J in Filter.atTop,
    weightedActiveRatioMass X nu J
      ≤ Phi * endpointRatioScale X J

/-- Pointwise one-threshold excess bound. -/
theorem endpointExcessTerm_le_activeRatioIndicator
    {X : ℕ → ℝ} {nu R : ℝ} {j : ℕ}
    (hX : 0 < X j)
    (hR : logJumpRatio X j ≤ R)
    (_hRnu : nu - 1 ≤ R) :
    endpointRatioExcessTerm nu X j
      ≤
    (R - (nu - 1)) *
      (if nu - 1 < logJumpRatio X j then X j else 0) := by
  have hEq :=
    endpointExcessTerm_eq_mul_ratio_excess
      (nu := nu) (X := X) (j := j) hX
  rw [hEq]
  by_cases h : nu - 1 < logJumpRatio X j
  · have hnonneg : 0 ≤ R - (nu - 1) := by linarith
    have hratio :
        max 0 (logJumpRatio X j - (nu - 1))
          ≤ R - (nu - 1) := by
      have hdiff :
          logJumpRatio X j - (nu - 1) ≤ R - (nu - 1) := by
        linarith
      exact max_le hnonneg hdiff
    have hXnonneg : 0 ≤ X j := le_of_lt hX
    calc
      X j * max 0 (logJumpRatio X j - (nu - 1))
          ≤ X j * (R - (nu - 1)) := by
            exact mul_le_mul_of_nonneg_left hratio hXnonneg
      _ = (R - (nu - 1)) * X j := by ring
      _ = (R - (nu - 1)) *
          (if nu - 1 < logJumpRatio X j then X j else 0) := by
            simp [h]
  · have hle : logJumpRatio X j - (nu - 1) ≤ 0 := by
      exact sub_nonpos.mpr (le_of_not_gt h)
    have hmax : max 0 (logJumpRatio X j - (nu - 1)) = 0 := by
      exact max_eq_left hle
    simp [h, hmax]

/-- One-threshold tail closure target.

If the weighted mass of jump ratios above `nu - 1` is at most `Phi` times the
endpoint scale, and all ratios are eventually bounded by `R`, then the
endpoint-weighted excess should be bounded by
`(R - (nu - 1)) * Phi`.  With the current no-additive-error
`EndpointWeightedAverageBound` API, the finite initial terms still need a
separate absorption argument, so this is recorded as a target rather than an
axiom. -/
def EndpointWeightedAverageBoundOfOneThresholdTailTarget
    (X : ℕ → ℝ) (nu R Phi delta : ℝ) : Prop :=
  EventuallyPositiveLogScale X →
    EventuallyRatioBoundedBy X R →
    nu - 1 ≤ R →
    WeightedActiveRatioBound X nu Phi →
    (R - (nu - 1)) * Phi ≤ delta →
      EndpointWeightedAverageBound X (fun j => X (j + 1)) nu delta

/-- Clean symbolic improvement criterion at optimal `x = theta(M)`.

If `R = M - 1` and the active-ratio weighted tail mass is `< 1 / M`, then the
endpoint weighted average is expected to be good enough to improve `M`. -/
def OneThresholdImprovementCriterion
    (M nu Phi : ℝ) : Prop :=
  2 < nu ∧ nu < M ∧ Phi < 1 / M

/-! ## Generic active-mass route -/

/-- The generic one-threshold active-mass constant. -/
def genericActiveMassConstant (nu : ℝ) : ℝ :=
  1 / (2 * (nu - 2))

/-- The endpoint weighted-average constant obtained from the generic
one-threshold active-mass bound and the cap `r_j ≤ M - 1`. -/
def genericEndpointAverageDelta (M nu : ℝ) : ℝ :=
  (M - nu) / (2 * (nu - 2))

/-- The formal target corresponding to the generic active-mass estimate.

In the local API, `WeightedActiveRatioBound X nu Phi` means
`weightedActiveRatioMass X nu J ≤ Phi * endpointRatioScale X J` eventually
in `J`. -/
def GenericActiveMassBoundTarget (X : ℕ → ℝ) (nu : ℝ) : Prop :=
  WeightedActiveRatioBound X nu (genericActiveMassConstant nu)

/-- The formal target corresponding to the resulting endpoint-weighted average
bound. -/
def GenericEndpointAverageBoundTarget (X : ℕ → ℝ) (M nu : ℝ) : Prop :=
  EndpointWeightedAverageBound X (fun j => X (j + 1)) nu
    (genericEndpointAverageDelta M nu)

/-- One-threshold closure target.

This is the exact finite theorem to prove after the active-mass estimate: if
active mass is bounded by `1 / (2 * (nu - 2))` and ratios are eventually capped
by `M - 1`, then endpoint excess is bounded by `(M - nu) / (2 * (nu - 2))`. -/
def OneThresholdEndpointAverageClosureTarget
    (X : ℕ → ℝ) (M nu : ℝ) : Prop :=
  GenericActiveMassBoundTarget X nu →
    EventuallyRatioBoundedBy X (M - 1) →
      GenericEndpointAverageBoundTarget X M nu

/-- The one-threshold route improves the current bound `M` when this inequality
holds.  Algebraically this is equivalent to `nu > 2 + M / 2` when
`2 < nu < M`. -/
def GenericOneThresholdImprovementCondition (M nu : ℝ) : Prop :=
  2 < nu ∧ nu < M ∧ genericEndpointAverageDelta M nu + nu / M < 1

/-- The explicit bound produced by the one-threshold route using parameter
`nu`, before optimizing over `nu`.

```text
B_M(nu) = 2 * nu * (nu - 2) / (3 * nu - M - 4).
``` -/
def genericOneThresholdMeasureBound (M nu : ℝ) : ℝ :=
  (2 * nu * (nu - 2)) / (3 * nu - M - 4)

/-- The formal statement that this route can improve `M` with a given `nu`.
This is a target predicate, not an assertion. -/
def GenericOneThresholdImprovesBound (M nu : ℝ) : Prop :=
  2 < M ∧ GenericOneThresholdImprovementCondition M nu ∧
    genericOneThresholdMeasureBound M nu < M

/-- Optimizer for the one-threshold bound.

```text
nu_*(M) = (M + 4 + sqrt((M + 4) * (M - 2))) / 3.
``` -/
def genericOneThresholdOptimizer (M : ℝ) : ℝ :=
  (M + 4 + Real.sqrt ((M + 4) * (M - 2))) / 3

/-- Optimized one-threshold improvement map.  This route improves every
`M > 4` and has limiting fixed point `4`. -/
def genericOneThresholdImprovementMap (M : ℝ) : ℝ :=
  genericOneThresholdMeasureBound M (genericOneThresholdOptimizer M)

/-- A compact wrapper: once the generic endpoint average bound has been proved
and it controls non-visible bad shells, the existing endpoint-weighted average
Bauer/Ramanujan wrapper gives the measure bound.

This theorem contains no new arithmetic content; it just routes the new
`genericEndpointAverageDelta` through the already integrated API. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_genericEndpointAverage
    {mu M nu tau x : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (havg : GenericEndpointAverageBoundTarget X M nu)
    (hctrl : EndpointWeightedAverageControlsNonVisibleBad
      X (fun j => X (j + 1)) H V nu x (genericEndpointAverageDelta M nu))
    (hdelta_nonneg : 0 ≤ genericEndpointAverageDelta M nu)
    (hdelta_gain : nu / M + genericEndpointAverageDelta M nu
        < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  exact oneOverPi_irratMeasure_lt_of_Bauer_endpointWeightedAverage
    (mu := mu) (M := M) (nu := nu) (tau := tau) (x := x)
    (delta := genericEndpointAverageDelta M nu)
    (X := X) (Y := fun j => X (j + 1))
    (H := H) (V := V) (Hlog := Hlog) (u := u) (vseq := vseq)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hgain_le_one
    havg hctrl hdelta_nonneg hdelta_gain

/-- Main finite theorem still to prove.

This is intentionally a target predicate rather than an axiom/theorem claim:
for monotone positive logarithmic scales `X`, active jump indices
`r_j > nu - 1` grow geometrically and therefore have total `X_j`-mass at most
`1 / (2 * (nu - 2))` of the endpoint scale. -/
def GenericActiveMassGeometricProofTarget (X : ℕ → ℝ) (nu : ℝ) : Prop :=
  2 < nu →
    Monotone X →
      EventuallyPositiveLogScale X →
        GenericActiveMassBoundTarget X nu

/-- After the active-mass theorem, this is the remaining lightweight algebraic
closure target for the one-threshold route. -/
def GenericEndpointAverageClosureProofTarget (X : ℕ → ℝ) (M nu : ℝ) : Prop :=
  GenericActiveMassBoundTarget X nu →
    EventuallyRatioBoundedBy X (M - 1) →
      GenericEndpointAverageBoundTarget X M nu

/-! ## One-threshold active-mass closure package -/

/-- The one-threshold active-mass constant, named for the closure package. -/
def oneThresholdActiveMassConstant (nu : ℝ) : ℝ :=
  genericActiveMassConstant nu

/-- The endpoint average density produced by the one-threshold route under an
eventual cap `logJumpRatio X j ≤ M - 1`. -/
def oneThresholdEndpointDelta (M nu : ℝ) : ℝ :=
  genericEndpointAverageDelta M nu

/-- One-threshold active-mass theorem target.

This is the finite combinatorial theorem still to prove: active indices grow
geometrically and therefore have small weighted mass. -/
def OneThresholdActiveMassTarget (X : ℕ → ℝ) (nu : ℝ) : Prop :=
  WeightedActiveRatioBound X nu (oneThresholdActiveMassConstant nu)

/-- One-threshold endpoint excess closure target.

This says that the active-mass estimate plus the ratio cap closes the endpoint
weighted average bound.  The proof should use
`endpointExcessTerm_eq_mul_ratio_excess` and the one-threshold indicator
estimate. -/
def OneThresholdEndpointExcessClosureTarget (X : ℕ → ℝ) (M nu : ℝ) : Prop :=
  OneThresholdActiveMassTarget X nu →
    EventuallyRatioBoundedBy X (M - 1) →
      EndpointWeightedAverageBound X (fun j => X (j + 1)) nu
        (oneThresholdEndpointDelta M nu)

/-- Package of all purely endpoint-average assumptions needed by the route. -/
structure OneThresholdEndpointPackage (X : ℕ → ℝ) (M nu : ℝ) : Prop where
  activeMass : OneThresholdActiveMassTarget X nu
  ratioCap : EventuallyRatioBoundedBy X (M - 1)
  closure : OneThresholdEndpointExcessClosureTarget X M nu

/-- The package gives the endpoint weighted average bound. -/
theorem endpointWeightedAverageBound_of_oneThresholdPackage
    {X : ℕ → ℝ} {M nu : ℝ}
    (P : OneThresholdEndpointPackage X M nu) :
    EndpointWeightedAverageBound X (fun j => X (j + 1)) nu
      (oneThresholdEndpointDelta M nu) := by
  exact P.closure P.activeMass P.ratioCap

/-- Nonnegativity of the one-threshold density parameter under `nu ≤ M` and
`2 < nu`. -/
theorem oneThresholdEndpointDelta_nonneg
    {M nu : ℝ} (hnu : 2 < nu) (hnuM : nu ≤ M) :
    0 ≤ oneThresholdEndpointDelta M nu := by
  unfold oneThresholdEndpointDelta genericEndpointAverageDelta
  have hnum : 0 ≤ M - nu := by linarith
  have hden : 0 ≤ 2 * (nu - 2) := by nlinarith
  exact div_nonneg hnum hden

/-- Improvement condition for the generic one-threshold route. -/
def OneThresholdImprovementCondition (M nu : ℝ) : Prop :=
  2 < nu ∧ nu < M ∧ oneThresholdEndpointDelta M nu + nu / M < 1

/-- Algebra target: with `2 < nu < M`, the one-threshold improvement condition
is equivalent to `2 + M / 2 < nu`.

This is a target predicate rather than a theorem, because the exact local proof
is routine but not needed for the downstream wrappers. -/
def OneThresholdImprovementAlgebraTarget (M nu : ℝ) : Prop :=
  (2 < nu ∧ nu < M) →
    (oneThresholdEndpointDelta M nu + nu / M < 1 ↔ 2 + M / 2 < nu)

/-- The explicit bound produced by the one-threshold route with parameter
`nu`.  It is obtained by solving `mu ≤ nu / (1 - delta)`, with
`delta = (M - nu) / (2 * (nu - 2))`. -/
def oneThresholdMeasureBound (M nu : ℝ) : ℝ :=
  genericOneThresholdMeasureBound M nu

/-- Optimizer for the one-threshold bound. -/
def oneThresholdOptimizer (M : ℝ) : ℝ :=
  genericOneThresholdOptimizer M

/-- Optimized one-threshold improvement map.  The expected fixed barrier is
`4`. -/
def oneThresholdImprovementMap (M : ℝ) : ℝ :=
  oneThresholdMeasureBound M (oneThresholdOptimizer M)

/-- Algebra target: the one-threshold route improves any `M > 4` and iterates
toward the barrier `4`. -/
def OneThresholdImprovesAboveFourTarget : Prop :=
  ∀ M : ℝ, 4 < M →
    oneThresholdImprovementMap M < M ∧ 4 ≤ oneThresholdImprovementMap M

/-- Main wrapper: the one-threshold endpoint package feeds into the already
integrated endpoint-weighted average Bauer/Ramanujan wrapper. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_oneThresholdEndpointPackage
    {mu M nu tau x : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (P : OneThresholdEndpointPackage X M nu)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (hctrl : EndpointWeightedAverageControlsNonVisibleBad
      X (fun j => X (j + 1)) H V nu x (oneThresholdEndpointDelta M nu))
    (hdelta_gain : nu / M + oneThresholdEndpointDelta M nu
        < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  have havg : EndpointWeightedAverageBound X (fun j => X (j + 1)) nu
      (oneThresholdEndpointDelta M nu) :=
    endpointWeightedAverageBound_of_oneThresholdPackage P
  have hdelta_nonneg : 0 ≤ oneThresholdEndpointDelta M nu :=
    oneThresholdEndpointDelta_nonneg hnu2 (le_of_lt hnuM)
  exact oneOverPi_irratMeasure_lt_of_Bauer_endpointWeightedAverage
    (mu := mu) (M := M) (nu := nu) (tau := tau) (x := x)
    (delta := oneThresholdEndpointDelta M nu)
    (X := X) (Y := fun j => X (j + 1))
    (H := H) (V := V) (Hlog := Hlog) (u := u) (vseq := vseq)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hgain_le_one
    havg hctrl hdelta_nonneg hdelta_gain

/-- Fully expanded finite target: prove this finite theorem first. -/
def ActiveMassGeometricFiniteTarget (X : ℕ → ℝ) (nu : ℝ) : Prop :=
  2 < nu →
    (∀ j : ℕ, 0 < X j) →
      Monotone X →
        ∀ J : ℕ,
          weightedActiveRatioMass X nu J
            ≤ oneThresholdActiveMassConstant nu * endpointRatioScale X J

/-- Then prove this closure using the cap and the already proved
`endpointExcessTerm_eq_mul_ratio_excess`. -/
def EndpointExcessClosureFiniteTarget (X : ℕ → ℝ) (M nu : ℝ) : Prop :=
  2 < nu →
    OneThresholdActiveMassTarget X nu →
      EventuallyRatioBoundedBy X (M - 1) →
        EndpointWeightedAverageBound X (fun j => X (j + 1)) nu
          (oneThresholdEndpointDelta M nu)

/-! ## Endpoint active-mass induction closure -/

/-- Stronger finite active-mass target.

This is stronger than the endpoint-scale bound because monotonicity gives
`endpointRatioScale X J ≥ 2 * X J`. -/
def ActiveMassStrongInductionTarget (X : ℕ → ℝ) (nu : ℝ) : Prop :=
  2 < nu →
    (∀ j : ℕ, 0 < X j) →
      Monotone X →
        ∀ J : ℕ,
          weightedActiveRatioMass X nu J ≤ X J / (nu - 2)

/-- Finite range-successor identity for the one-threshold active mass. -/
def WeightedActiveRatioMassSuccFormulaTarget (X : ℕ → ℝ) (nu : ℝ) : Prop :=
  ∀ J : ℕ,
    weightedActiveRatioMass X nu (J + 1)
      = weightedActiveRatioMass X nu J
          + if nu - 1 < logJumpRatio X J then X J else 0

/-- The active-mass successor formula follows directly from filtered sums over
`Finset.range`. -/
theorem weightedActiveRatioMass_succ
    (X : ℕ → ℝ) (nu : ℝ) (J : ℕ) :
    weightedActiveRatioMass X nu (J + 1)
      = weightedActiveRatioMass X nu J
          + if nu - 1 < logJumpRatio X J then X J else 0 := by
  classical
  unfold weightedActiveRatioMass weightedRatioTailMass
  rw [Finset.sum_filter, Finset.sum_filter]
  rw [Finset.sum_range_succ]

/-- The successor formula packaged as a target predicate. -/
theorem weightedActiveRatioMassSuccFormulaTarget
    (X : ℕ → ℝ) (nu : ℝ) :
    WeightedActiveRatioMassSuccFormulaTarget X nu := by
  intro J
  exact weightedActiveRatioMass_succ X nu J

/-- Algebraic inactive induction step. -/
theorem activeMass_induction_step_inactive
    {S XJ XJ1 nu : ℝ}
    (hnu : 2 < nu)
    (hprev : S ≤ XJ / (nu - 2))
    (hmono : XJ ≤ XJ1) :
    S ≤ XJ1 / (nu - 2) := by
  have hden : 0 < nu - 2 := by linarith
  have hdiv : XJ / (nu - 2) ≤ XJ1 / (nu - 2) := by
    exact div_le_div_of_nonneg_right hmono (le_of_lt hden)
  exact le_trans hprev hdiv

/-- Algebraic active induction step. -/
theorem activeMass_induction_step_active
    {S XJ XJ1 nu : ℝ}
    (hnu : 2 < nu)
    (hprev : S ≤ XJ / (nu - 2))
    (hjump : (nu - 1) * XJ < XJ1) :
    S + XJ ≤ XJ1 / (nu - 2) := by
  have hden : 0 < nu - 2 := by linarith
  have hstep0 : S + XJ ≤ XJ / (nu - 2) + XJ := by linarith
  have halg : XJ / (nu - 2) + XJ = ((nu - 1) * XJ) / (nu - 2) := by
    field_simp [ne_of_gt hden]
    ring
  have hstep1 : ((nu - 1) * XJ) / (nu - 2) < XJ1 / (nu - 2) := by
    exact div_lt_div_of_pos_right hjump hden
  exact le_of_lt (lt_of_le_of_lt (by simpa [halg] using hstep0) hstep1)

/-- Activity of `J` converts to a multiplicative jump for a positive scale. -/
theorem active_ratio_implies_mul_lt
    {X : ℕ → ℝ} {nu : ℝ} {J : ℕ}
    (hX : 0 < X J)
    (hactive : nu - 1 < logJumpRatio X J) :
    (nu - 1) * X J < X (J + 1) := by
  unfold logJumpRatio at hactive
  have hmul := mul_lt_mul_of_pos_left hactive hX
  have hcancel : X J * (X (J + 1) / X J) = X (J + 1) := by
    rw [mul_comm]
    exact div_mul_cancel₀ (X (J + 1)) (ne_of_gt hX)
  simpa [hcancel, mul_comm, mul_left_comm, mul_assoc] using hmul

/-- The strong active-mass estimate follows by induction from the successor
formula. -/
def ActiveMassStrongInductionProofTarget (X : ℕ → ℝ) (nu : ℝ) : Prop :=
  WeightedActiveRatioMassSuccFormulaTarget X nu →
    ActiveMassStrongInductionTarget X nu

/-- Induction proof of the strong active-mass estimate. -/
theorem activeMassStrongInduction_of_succFormula
    {X : ℕ → ℝ} {nu : ℝ}
    (hsucc : WeightedActiveRatioMassSuccFormulaTarget X nu) :
    ActiveMassStrongInductionTarget X nu := by
  intro hnu hXpos hmono J
  induction J with
  | zero =>
      have hden : 0 < nu - 2 := by linarith
      have hnonneg : 0 ≤ X 0 / (nu - 2) := by
        exact div_nonneg (le_of_lt (hXpos 0)) (le_of_lt hden)
      calc
        weightedActiveRatioMass X nu 0 = 0 := by
          simp [weightedActiveRatioMass, weightedRatioTailMass]
        _ ≤ X 0 / (nu - 2) := hnonneg
  | succ J ih =>
      rw [hsucc J]
      by_cases hactive : nu - 1 < logJumpRatio X J
      · rw [if_pos hactive]
        exact activeMass_induction_step_active hnu ih
          (active_ratio_implies_mul_lt (hXpos J) hactive)
      · rw [if_neg hactive]
        have hstep :=
          activeMass_induction_step_inactive hnu ih (hmono (Nat.le_succ J))
        simpa using hstep

/-- The induction proof packaged as the proof-facing target. -/
theorem activeMassStrongInductionProofTarget
    (X : ℕ → ℝ) (nu : ℝ) :
    ActiveMassStrongInductionProofTarget X nu := by
  intro hsucc
  exact activeMassStrongInduction_of_succFormula hsucc

/-- Endpoint-scale conversion target for the induction route. -/
def ActiveMassEndpointScaleConversionTarget (X : ℕ → ℝ) (nu : ℝ) : Prop :=
  ActiveMassStrongInductionTarget X nu →
    ActiveMassGeometricFiniteTarget X nu

/-- The strong induction invariant implies the endpoint-scale finite target. -/
theorem activeMassGeometricFinite_of_strongInduction
    {X : ℕ → ℝ} {nu : ℝ}
    (hstrong : ActiveMassStrongInductionTarget X nu) :
    ActiveMassGeometricFiniteTarget X nu := by
  intro hnu hXpos hmono J
  have hmass : weightedActiveRatioMass X nu J ≤ X J / (nu - 2) :=
    hstrong hnu hXpos hmono J
  have hden : 0 < nu - 2 := by linarith
  have hden2 : 0 < 2 * (nu - 2) := by nlinarith
  have hmonoJ : X J ≤ X (J + 1) := hmono (Nat.le_succ J)
  have hscale : 2 * X J ≤ endpointRatioScale X J := by
    unfold endpointRatioScale
    linarith
  have hdiv := div_le_div_of_nonneg_right hscale (le_of_lt hden2)
  have hleft : (2 * X J) / (2 * (nu - 2)) = X J / (nu - 2) := by
    field_simp [ne_of_gt hden]
  have hright : endpointRatioScale X J / (2 * (nu - 2)) =
      (1 / (2 * (nu - 2))) * endpointRatioScale X J := by
    ring
  have hscaleDiv : X J / (nu - 2) ≤
      oneThresholdActiveMassConstant nu * endpointRatioScale X J := by
    simpa [oneThresholdActiveMassConstant, genericActiveMassConstant, hleft, hright]
      using hdiv
  exact le_trans hmass hscaleDiv

/-- The endpoint-scale conversion packaged as a target predicate. -/
theorem activeMassEndpointScaleConversionTarget
    (X : ℕ → ℝ) (nu : ℝ) :
    ActiveMassEndpointScaleConversionTarget X nu := by
  intro hstrong
  exact activeMassGeometricFinite_of_strongInduction hstrong

/-- Closure theorem target using the induction route. -/
def ActiveMassGeometricFiniteTargetViaInduction (X : ℕ → ℝ) (nu : ℝ) : Prop :=
  WeightedActiveRatioMassSuccFormulaTarget X nu →
    ActiveMassStrongInductionTarget X nu ∧
    ActiveMassGeometricFiniteTarget X nu

/-- The induction route closes the finite active-mass target from the successor
formula. -/
theorem activeMassGeometricFiniteTargetViaInduction
    (X : ℕ → ℝ) (nu : ℝ) :
    ActiveMassGeometricFiniteTargetViaInduction X nu := by
  intro hsucc
  have hstrong : ActiveMassStrongInductionTarget X nu :=
    activeMassStrongInduction_of_succFormula hsucc
  exact ⟨hstrong, activeMassGeometricFinite_of_strongInduction hstrong⟩

/-!
# One-threshold bootstrap toward `μ(π) ≤ 4`

This section packages the plausible one-threshold route after the
endpoint-weighted active-mass theorem.  It does not claim the route is closed:
the remaining algebraic, dynamical, and two-bound endpoint-production steps are
recorded as target predicates.
-/

/-- A reusable statement that an irrationality-measure value for `1 / π` is
strictly below `B`. -/
def OneOverPiMeasureStrictlyBelow (B : ℝ) : Prop :=
  ∀ mu : ℝ, HasIrrationalityMeasure (1 / Real.pi) mu → mu < B

/-- A non-strict final bound form. -/
def OneOverPiMeasureAtMost (B : ℝ) : Prop :=
  ∀ mu : ℝ, HasIrrationalityMeasure (1 / Real.pi) mu → mu ≤ B

/-- External upper-bound input slot for a known numerical measure cap. -/
def KnownOneOverPiMeasureBound (B : ℝ) : Prop :=
  OneOverPiMeasureStrictlyBelow B

/-- Endpoint average deficit produced by the one-threshold active-mass route
from an input cap `B` and trial exponent `nu`. -/
def oneThresholdBootstrapDelta (B nu : ℝ) : ℝ :=
  (B - nu) / (2 * (nu - 2))

/-- Output bound supplied by the one-threshold endpoint average route. -/
def oneThresholdBootstrapOutput (B nu : ℝ) : ℝ :=
  nu / (1 - oneThresholdBootstrapDelta B nu)

/-- The rationally simplified form of `oneThresholdBootstrapOutput`. -/
def oneThresholdBootstrapOutputClosed (B nu : ℝ) : ℝ :=
  (2 * nu * (nu - 2)) / (3 * nu - B - 4)

/-- The formal optimizer for the one-threshold output. -/
def oneThresholdBootstrapOptimizer (B : ℝ) : ℝ :=
  (B + 4 + Real.sqrt ((B + 4) * (B - 2))) / 3

/-- The induced one-step map. -/
def oneThresholdBootstrapMap (B : ℝ) : ℝ :=
  oneThresholdBootstrapOutputClosed B (oneThresholdBootstrapOptimizer B)

/-- Algebra target: the closed form agrees with the density-contraction form. -/
def OneThresholdOutputClosedFormTarget (B nu : ℝ) : Prop :=
  nu - 2 ≠ 0 →
    1 - oneThresholdBootstrapDelta B nu ≠ 0 →
      oneThresholdBootstrapOutput B nu = oneThresholdBootstrapOutputClosed B nu

/-- Algebra target: if `B > 4`, the optimizer lies in the useful interval. -/
def OneThresholdOptimizerInRangeTarget (B : ℝ) : Prop :=
  4 < B →
    2 + B / 2 < oneThresholdBootstrapOptimizer B ∧
      oneThresholdBootstrapOptimizer B < B

/-- Algebra target: for `B > 4`, the optimized map improves the bound while
remaining above `4`. -/
def OneThresholdMapImprovesAboveFourTarget (B : ℝ) : Prop :=
  4 < B →
    4 < oneThresholdBootstrapMap B ∧ oneThresholdBootstrapMap B < B

/-- Algebra/dynamical target: iterating the one-threshold map from any `B > 4`
converges down to `4` in the weak form needed for a final `≤ 4` conclusion. -/
def OneThresholdMapConvergesToFourTarget : Prop :=
  ∀ B0 eps : ℝ, 4 < B0 → 0 < eps →
    ∃ n : ℕ, Nat.iterate oneThresholdBootstrapMap n B0 < 4 + eps

/-- The two-bound one-threshold endpoint package.

`B` is the input ratio/measure cap, while `Mout` is the output bound. -/
def OneThresholdBootstrapPackage
    (B Mout nu tau x : ℝ) (X H V _Hlog _u _vseq : ℕ → ℝ) : Prop :=
  OneThresholdEndpointPackage X B nu ∧
  EndpointWeightedAverageControlsNonVisibleBad
    X (fun j => X (j + 1)) H V nu x (oneThresholdBootstrapDelta B nu) ∧
  0 ≤ oneThresholdBootstrapDelta B nu ∧
  oneThresholdBootstrapDelta B nu + nu / Mout < shellSpikeGoodDensityGain tau x

/-- Main reusable wrapper: a two-bound one-threshold package feeds into the
existing endpoint-weighted Bauer/Ramanujan contraction API. -/
theorem oneOverPiMeasure_lt_of_Bauer_oneThresholdBootstrapPackage
    {mu B Mout nu tau x : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < Mout)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu Mout < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (P : OneThresholdBootstrapPackage B Mout nu tau x X H V Hlog u vseq) :
    mu < Mout := by
  rcases P with ⟨hOne, hCtrl, hDeltaNonneg, hDeltaGain⟩
  have hAvg :
      EndpointWeightedAverageBound X (fun j => X (j + 1)) nu
        (oneThresholdBootstrapDelta B nu) := by
    exact endpointWeightedAverageBound_of_oneThresholdPackage
      (X := X) (M := B) (nu := nu) hOne
  exact oneOverPi_irratMeasure_lt_of_Bauer_endpointWeightedAverage
    (mu := mu) (M := Mout) (nu := nu) (tau := tau) (x := x)
    (delta := oneThresholdBootstrapDelta B nu)
    (X := X) (Y := fun j => X (j + 1))
    (H := H) (V := V) (Hlog := Hlog) (u := u) (vseq := vseq)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hgain_le_one
    hAvg hCtrl hDeltaNonneg (by simpa [add_comm] using hDeltaGain)

/-- Package target for producing a concrete one-threshold step from an input
bound `B` to an output `Mout`. -/
def OneThresholdBootstrapStepTarget
    (B Mout nu tau x : ℝ) (X H V Hlog u vseq : ℕ → ℝ) : Prop :=
  OneThresholdBootstrapPackage B Mout nu tau x X H V Hlog u vseq

/-- A symbolic theorem target: every input cap above `4` gives a strictly
smaller cap using the one-threshold route. -/
def OneThresholdStrictImprovementTarget (B : ℝ) : Prop :=
  4 < B →
    ∃ Mout nu _tau _x : ℝ,
      4 < Mout ∧ Mout < B ∧ 2 < nu ∧ nu < Mout

/-- Final theorem target for the plausible route to `μ(π) ≤ 4`. -/
def OneThresholdRouteProvesMuPiLeFour : Prop :=
  ∃ B0 : ℝ,
    KnownOneOverPiMeasureBound B0 ∧
      4 < B0 ∧
      OneThresholdMapConvergesToFourTarget ∧
      (∀ B : ℝ, 4 < B → OneThresholdStrictImprovementTarget B) ∧
      OneOverPiMeasureAtMost 4

/-- If one can prove bounds below `4 + eps` for every positive `eps`, then the
measure is at most `4`. -/
theorem oneOverPiMeasureAtMost_four_of_arbitrarily_close
    (h : ∀ eps : ℝ, 0 < eps → OneOverPiMeasureStrictlyBelow (4 + eps)) :
    OneOverPiMeasureAtMost 4 := by
  intro mu hmu
  by_contra hnot
  have hgt : 4 < mu := lt_of_not_ge hnot
  let eps : ℝ := (mu - 4) / 2
  have heps : 0 < eps := by
    dsimp [eps]
    linarith
  have hlt : mu < 4 + eps := h eps heps mu hmu
  have : 4 + eps = (mu + 4) / 2 := by
    dsimp [eps]
    ring
  rw [this] at hlt
  linarith

/-!
# Final iterative wrapper for the one-threshold route

This section closes the purely logical iteration layer.  It does not prove the
analytic endpoint package; instead it shows that a realized one-step theorem,
barrier preservation, and convergence of the bootstrap map imply the final
non-strict bound.
-/

/-- Recursive iterate of the one-threshold bootstrap map. -/
def oneThresholdBootstrapSeq (B0 : ℝ) : ℕ → ℝ
  | 0 => B0
  | n + 1 => oneThresholdBootstrapMap (oneThresholdBootstrapSeq B0 n)

/-- A realized one-step one-threshold bootstrap. -/
def OneThresholdBootstrapStepRealized : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapMap B)

/-- The bootstrap map stays above the barrier `4`. -/
def OneThresholdBootstrapMapAboveFour : Prop :=
  ∀ B : ℝ, 4 < B → 4 < oneThresholdBootstrapMap B

/-- The recursive iterates approach `4` from above in the weak form needed for
an epsilon argument. -/
def OneThresholdBootstrapSeqConvergesToFour (B0 : ℝ) : Prop :=
  ∀ eps : ℝ, 0 < eps → ∃ n : ℕ, oneThresholdBootstrapSeq B0 n < 4 + eps

/-- If the map stays above `4`, then every recursive iterate remains above
`4`. -/
theorem oneThresholdBootstrapSeq_above_four
    {B0 : ℝ}
    (hmap : OneThresholdBootstrapMapAboveFour)
    (hB0 : 4 < B0) :
    ∀ n : ℕ, 4 < oneThresholdBootstrapSeq B0 n := by
  intro n
  induction n with
  | zero =>
      simpa [oneThresholdBootstrapSeq] using hB0
  | succ n ih =>
      simpa [oneThresholdBootstrapSeq] using
        hmap (oneThresholdBootstrapSeq B0 n) ih

/-- Iterating a realized one-step bootstrap gives a strict bound at every
recursive iterate. -/
theorem oneOverPiMeasureStrictlyBelow_bootstrapSeq
    {B0 : ℝ}
    (hstep : OneThresholdBootstrapStepRealized)
    (hmap : OneThresholdBootstrapMapAboveFour)
    (hstart : KnownOneOverPiMeasureBound B0)
    (hB0 : 4 < B0) :
    ∀ n : ℕ,
      OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapSeq B0 n) := by
  intro n
  induction n with
  | zero =>
      simpa [oneThresholdBootstrapSeq] using hstart
  | succ n ih =>
      have habove : 4 < oneThresholdBootstrapSeq B0 n :=
        oneThresholdBootstrapSeq_above_four hmap hB0 n
      simpa [oneThresholdBootstrapSeq] using
        hstep (oneThresholdBootstrapSeq B0 n) habove ih

/-- Final iterative closure: a known starting bound above `4`, a realized
one-step improvement, preservation of the region above `4`, and convergence of
iterates to `4` imply `μ(1/π) ≤ 4`. -/
theorem oneOverPiMeasureAtMost_four_of_oneThresholdBootstrapSeq
    {B0 : ℝ}
    (hstart : KnownOneOverPiMeasureBound B0)
    (hB0 : 4 < B0)
    (hstep : OneThresholdBootstrapStepRealized)
    (hmap : OneThresholdBootstrapMapAboveFour)
    (hconv : OneThresholdBootstrapSeqConvergesToFour B0) :
    OneOverPiMeasureAtMost 4 := by
  apply oneOverPiMeasureAtMost_four_of_arbitrarily_close
  intro eps heps
  rcases hconv eps heps with ⟨n, hn⟩
  have hbound : OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapSeq B0 n) :=
    oneOverPiMeasureStrictlyBelow_bootstrapSeq hstep hmap hstart hB0 n
  intro mu hmu
  exact lt_trans (hbound mu hmu) hn

/-- Final package for the plausible one-threshold route to `μ(1/π) ≤ 4`. -/
structure OneThresholdFinalBootstrapPackage (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  stepRealized : OneThresholdBootstrapStepRealized
  mapAboveFour : OneThresholdBootstrapMapAboveFour
  seqConverges : OneThresholdBootstrapSeqConvergesToFour B0

/-- The final package proves the desired non-strict bound for `1/π`. -/
theorem oneOverPiMeasureAtMost_four_of_finalBootstrapPackage
    {B0 : ℝ}
    (P : OneThresholdFinalBootstrapPackage B0) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_oneThresholdBootstrapSeq
    P.startBound P.startAboveFour P.stepRealized P.mapAboveFour P.seqConverges

/-- Project-facing final target. -/
def OneThresholdFinalBootstrapTarget : Prop :=
  ∃ B0 : ℝ, OneThresholdFinalBootstrapPackage B0

/-- If the final target is realized, then `μ(1/π) ≤ 4`. -/
theorem oneOverPiMeasureAtMost_four_of_finalBootstrapTarget
    (h : OneThresholdFinalBootstrapTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases h with ⟨B0, P⟩
  exact oneOverPiMeasureAtMost_four_of_finalBootstrapPackage P

/-!
# Strict-slack repair for the one-threshold bootstrap

The exact optimized bootstrap value is expected to be sharp for the idealized
density-contraction inequality.  This section records the corrected logical
wrapper using the midpoint between the current input bound and the optimized
map, leaving strict slack for the endpoint package.
-/

/-- A strict output bound placed between the optimized map and the current input
bound. -/
def oneThresholdBootstrapRelaxedMap (B : ℝ) : ℝ :=
  (B + oneThresholdBootstrapMap B) / 2

/-- Recursive iterates of the strict-slack one-threshold map. -/
def oneThresholdBootstrapRelaxedSeq (B0 : ℝ) : ℕ → ℝ
  | 0 => B0
  | n + 1 => oneThresholdBootstrapRelaxedMap (oneThresholdBootstrapRelaxedSeq B0 n)

/-- The optimized one-threshold map lies below the current bound. -/
def OneThresholdBootstrapMapBelowSelf : Prop :=
  ∀ B : ℝ, 4 < B → oneThresholdBootstrapMap B < B

/-- The strict-slack map stays above the barrier `4`. -/
def OneThresholdBootstrapRelaxedMapAboveFour : Prop :=
  ∀ B : ℝ, 4 < B → 4 < oneThresholdBootstrapRelaxedMap B

/-- The strict-slack map improves the current bound. -/
def OneThresholdBootstrapRelaxedMapBelowSelf : Prop :=
  ∀ B : ℝ, 4 < B → oneThresholdBootstrapRelaxedMap B < B

/-- The strict-slack map converges to `4` from any starting bound above `4`. -/
def OneThresholdBootstrapRelaxedSeqConvergesToFour (B0 : ℝ) : Prop :=
  ∀ eps : ℝ, 0 < eps → ∃ n : ℕ, oneThresholdBootstrapRelaxedSeq B0 n < 4 + eps

/-- If the optimized map stays above `4`, then the strict-slack map also stays
above `4`. -/
theorem oneThresholdBootstrapRelaxedMap_above_four_of_base
    (hbase : OneThresholdBootstrapMapAboveFour) :
    OneThresholdBootstrapRelaxedMapAboveFour := by
  intro B hB
  unfold oneThresholdBootstrapRelaxedMap
  have hF : 4 < oneThresholdBootstrapMap B := hbase B hB
  linarith

/-- If the optimized map improves the current bound, then the strict-slack map
also improves the current bound. -/
theorem oneThresholdBootstrapRelaxedMap_below_self_of_base
    (hbase : OneThresholdBootstrapMapBelowSelf) :
    OneThresholdBootstrapRelaxedMapBelowSelf := by
  intro B hB
  unfold oneThresholdBootstrapRelaxedMap
  have hF : oneThresholdBootstrapMap B < B := hbase B hB
  linarith

/-- If the strict-slack map stays above `4`, then all relaxed iterates stay
above `4`. -/
theorem oneThresholdBootstrapRelaxedSeq_above_four
    {B0 : ℝ}
    (hmap : OneThresholdBootstrapRelaxedMapAboveFour)
    (hB0 : 4 < B0) :
    ∀ n : ℕ, 4 < oneThresholdBootstrapRelaxedSeq B0 n := by
  intro n
  induction n with
  | zero =>
      simpa [oneThresholdBootstrapRelaxedSeq] using hB0
  | succ n ih =>
      simpa [oneThresholdBootstrapRelaxedSeq] using
        hmap (oneThresholdBootstrapRelaxedSeq B0 n) ih

/-- A realized one-step strict-slack bootstrap. -/
def OneThresholdBootstrapStrictSlackStepRealized : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapRelaxedMap B)

/-- Iterating a realized strict-slack bootstrap gives a strict bound at every
relaxed iterate. -/
theorem oneOverPiMeasureStrictlyBelow_relaxedBootstrapSeq
    {B0 : ℝ}
    (hstep : OneThresholdBootstrapStrictSlackStepRealized)
    (hmap : OneThresholdBootstrapRelaxedMapAboveFour)
    (hstart : KnownOneOverPiMeasureBound B0)
    (hB0 : 4 < B0) :
    ∀ n : ℕ,
      OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapRelaxedSeq B0 n) := by
  intro n
  induction n with
  | zero =>
      simpa [oneThresholdBootstrapRelaxedSeq] using hstart
  | succ n ih =>
      have habove : 4 < oneThresholdBootstrapRelaxedSeq B0 n :=
        oneThresholdBootstrapRelaxedSeq_above_four hmap hB0 n
      simpa [oneThresholdBootstrapRelaxedSeq] using
        hstep (oneThresholdBootstrapRelaxedSeq B0 n) habove ih

/-- Final strict-slack iterative closure. -/
theorem oneOverPiMeasureAtMost_four_of_relaxedBootstrapSeq
    {B0 : ℝ}
    (hstart : KnownOneOverPiMeasureBound B0)
    (hB0 : 4 < B0)
    (hstep : OneThresholdBootstrapStrictSlackStepRealized)
    (hmap : OneThresholdBootstrapRelaxedMapAboveFour)
    (hconv : OneThresholdBootstrapRelaxedSeqConvergesToFour B0) :
    OneOverPiMeasureAtMost 4 := by
  apply oneOverPiMeasureAtMost_four_of_arbitrarily_close
  intro eps heps
  rcases hconv eps heps with ⟨n, hn⟩
  have hbound : OneOverPiMeasureStrictlyBelow (oneThresholdBootstrapRelaxedSeq B0 n) :=
    oneOverPiMeasureStrictlyBelow_relaxedBootstrapSeq hstep hmap hstart hB0 n
  intro mu hmu
  exact lt_trans (hbound mu hmu) hn

/-- Data needed to realize one strict-slack step for a fixed input bound `B`.

The package is parameterized by the already-known strict measure bound below
`B`, because that is what should eventually produce the ratio cap inside
`OneThresholdBootstrapPackage`. -/
structure OneThresholdStrictSlackStepData (B : ℝ) where
  nu : ℝ
  tau : ℝ
  x : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_lt_out : nu < (oneThresholdBootstrapRelaxedMap B)
  tau_pos : 0 < tau
  x_contraction :
    shellSpikeContractionExponent tau nu (oneThresholdBootstrapRelaxedMap B) < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  endpointPackage :
    OneThresholdBootstrapPackage B (oneThresholdBootstrapRelaxedMap B)
      nu tau x X H V Hlog u vseq

/-- Target: construct strict-slack one-step data from an input bound. -/
def OneThresholdStrictSlackStepDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (OneThresholdStrictSlackStepData B)

/-- The strict-slack step data realizes the strict-slack one-step bootstrap. -/
theorem oneThresholdStrictSlackStepRealized_of_dataTarget
    (hdata : OneThresholdStrictSlackStepDataTarget) :
    OneThresholdBootstrapStrictSlackStepRealized := by
  intro B hB hBound mu hmu
  rcases hdata B hB hBound with ⟨D⟩
  exact oneOverPiMeasure_lt_of_Bauer_oneThresholdBootstrapPackage
    (mu := mu) (B := B) (Mout := oneThresholdBootstrapRelaxedMap B)
    (nu := D.nu) (tau := D.tau) (x := D.x)
    (X := D.X) (H := D.H) (V := D.V)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    D.closureCert D.bauer hmu D.nu_gt_two D.nu_lt_out D.tau_pos
    D.x_contraction D.x_lt_one D.x_le_global D.gain_le_one
    D.endpointPackage

/-- Final strict-slack bootstrap package. -/
structure OneThresholdStrictSlackFinalPackage (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  stepData : OneThresholdStrictSlackStepDataTarget
  relaxedMapAboveFour : OneThresholdBootstrapRelaxedMapAboveFour
  relaxedSeqConverges : OneThresholdBootstrapRelaxedSeqConvergesToFour B0

/-- The strict-slack final package proves the desired non-strict bound. -/
theorem oneOverPiMeasureAtMost_four_of_strictSlackFinalPackage
    {B0 : ℝ}
    (P : OneThresholdStrictSlackFinalPackage B0) :
    OneOverPiMeasureAtMost 4 := by
  have hstep : OneThresholdBootstrapStrictSlackStepRealized :=
    oneThresholdStrictSlackStepRealized_of_dataTarget P.stepData
  exact oneOverPiMeasureAtMost_four_of_relaxedBootstrapSeq
    P.startBound P.startAboveFour hstep
    P.relaxedMapAboveFour P.relaxedSeqConverges

/-- Project-facing corrected final target for the one-threshold route. -/
def OneThresholdStrictSlackFinalTarget : Prop :=
  ∃ B0 : ℝ, OneThresholdStrictSlackFinalPackage B0

/-- Corrected final theorem: the strict-slack target implies `μ(1/π) ≤ 4`. -/
theorem oneOverPiMeasureAtMost_four_of_strictSlackFinalTarget
    (h : OneThresholdStrictSlackFinalTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases h with ⟨B0, P⟩
  exact oneOverPiMeasureAtMost_four_of_strictSlackFinalPackage P

/-!
# Strict-slack one-step data reduction

This section lowers the remaining strict-slack step target to a more convenient
core-data package.  The optimizer/range algebra and the pi-specific endpoint
construction remain explicit targets.
-/

/-- The trial exponent used by the strict-slack one-threshold route. -/
def oneThresholdStrictSlackTrialNu (B : ℝ) : ℝ :=
  oneThresholdBootstrapOptimizer B

/-- The strict output used by the repaired one-step bootstrap. -/
def oneThresholdStrictSlackOutput (B : ℝ) : ℝ :=
  oneThresholdBootstrapRelaxedMap B

/-- Optimizer/range algebra needed by the strict-slack step. -/
def StrictSlackOptimizerRangeTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      2 < oneThresholdStrictSlackTrialNu B ∧
        oneThresholdStrictSlackTrialNu B < oneThresholdStrictSlackOutput B

/-- A convenient pi-specific core package for one strict-slack step.

This is lower-level than `OneThresholdStrictSlackStepData`: it stores the
one-threshold endpoint package and the non-visible-bad control separately, then
the constructor lemmas below assemble the existing bootstrap package. -/
structure OneThresholdStrictSlackCoreData (B : ℝ) where
  tau : ℝ
  x : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  tau_pos : 0 < tau
  x_contraction :
    shellSpikeContractionExponent tau
      (oneThresholdStrictSlackTrialNu B)
      (oneThresholdStrictSlackOutput B) < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  endpointOneThreshold :
    OneThresholdEndpointPackage X B (oneThresholdStrictSlackTrialNu B)
  endpointControls :
    EndpointWeightedAverageControlsNonVisibleBad
      X (fun j => X (j + 1)) H V
      (oneThresholdStrictSlackTrialNu B) x
      (oneThresholdBootstrapDelta B (oneThresholdStrictSlackTrialNu B))
  delta_nonneg :
    0 ≤ oneThresholdBootstrapDelta B (oneThresholdStrictSlackTrialNu B)
  delta_gain :
    oneThresholdBootstrapDelta B (oneThresholdStrictSlackTrialNu B) +
        oneThresholdStrictSlackTrialNu B / oneThresholdStrictSlackOutput B
      < shellSpikeGoodDensityGain tau x

/-- Assemble the existing two-bound bootstrap package from the lower-level core
fields. -/
theorem oneThresholdBootstrapPackage_of_strictSlackCoreData
    {B : ℝ} (D : OneThresholdStrictSlackCoreData B) :
    OneThresholdBootstrapPackage B (oneThresholdStrictSlackOutput B)
      (oneThresholdStrictSlackTrialNu B) D.tau D.x
      D.X D.H D.V D.Hlog D.u D.vseq := by
  exact ⟨
    D.endpointOneThreshold,
    D.endpointControls,
    D.delta_nonneg,
    D.delta_gain
  ⟩

/-- Core data plus optimizer-range algebra gives the data structure consumed by
the strict-slack bootstrap wrapper. -/
def oneThresholdStrictSlackStepData_of_coreData
    {B : ℝ}
    (hrange : StrictSlackOptimizerRangeTarget)
    (hB : 4 < B)
    (D : OneThresholdStrictSlackCoreData B) :
    OneThresholdStrictSlackStepData B := by
  have hnu := hrange B hB
  exact {
    nu := oneThresholdStrictSlackTrialNu B
    tau := D.tau
    x := D.x
    X := D.X
    H := D.H
    V := D.V
    Hlog := D.Hlog
    u := D.u
    vseq := D.vseq
    closureCert := D.closureCert
    bauer := D.bauer
    nu_gt_two := hnu.1
    nu_lt_out := hnu.2
    tau_pos := D.tau_pos
    x_contraction := D.x_contraction
    x_lt_one := D.x_lt_one
    x_le_global := D.x_le_global
    gain_le_one := D.gain_le_one
    endpointPackage :=
      oneThresholdBootstrapPackage_of_strictSlackCoreData D
  }

/-- The remaining pi-specific core-data target. -/
def OneThresholdStrictSlackCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (OneThresholdStrictSlackCoreData B)

/-- The core-data target implies the existing strict-slack step-data target. -/
theorem oneThresholdStrictSlackStepDataTarget_of_coreDataTarget
    (hrange : StrictSlackOptimizerRangeTarget)
    (hcore : OneThresholdStrictSlackCoreDataTarget) :
    OneThresholdStrictSlackStepDataTarget := by
  intro B hB hBound
  rcases hcore B hB hBound with ⟨D⟩
  exact ⟨oneThresholdStrictSlackStepData_of_coreData hrange hB D⟩

/-- A project-facing target: optimizer range plus endpoint core construction. -/
def OneThresholdStrictSlackCoreFinalTarget : Prop :=
  StrictSlackOptimizerRangeTarget ∧ OneThresholdStrictSlackCoreDataTarget

/-- The core final target implies the existing strict-slack step-data target. -/
theorem oneThresholdStrictSlackStepDataTarget_of_coreFinalTarget
    (h : OneThresholdStrictSlackCoreFinalTarget) :
    OneThresholdStrictSlackStepDataTarget := by
  exact oneThresholdStrictSlackStepDataTarget_of_coreDataTarget h.1 h.2

/-- If a final package is available except for the old step-data target, the
new core final target supplies that missing field. -/
theorem oneThresholdStrictSlackFinalPackage_of_coreFinalTarget
    {B0 : ℝ}
    (hstart : KnownOneOverPiMeasureBound B0)
    (hB0 : 4 < B0)
    (hcore : OneThresholdStrictSlackCoreFinalTarget)
    (habove : OneThresholdBootstrapRelaxedMapAboveFour)
    (hconv : OneThresholdBootstrapRelaxedSeqConvergesToFour B0) :
    OneThresholdStrictSlackFinalPackage B0 := by
  exact {
    startBound := hstart
    startAboveFour := hB0
    stepData := oneThresholdStrictSlackStepDataTarget_of_coreFinalTarget hcore
    relaxedMapAboveFour := habove
    relaxedSeqConverges := hconv
  }

/-- Final convenience theorem from core-final data. -/
theorem oneOverPiMeasureAtMost_four_of_coreFinalTarget
    {B0 : ℝ}
    (hstart : KnownOneOverPiMeasureBound B0)
    (hB0 : 4 < B0)
    (hcore : OneThresholdStrictSlackCoreFinalTarget)
    (habove : OneThresholdBootstrapRelaxedMapAboveFour)
    (hconv : OneThresholdBootstrapRelaxedSeqConvergesToFour B0) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_strictSlackFinalPackage
    (oneThresholdStrictSlackFinalPackage_of_coreFinalTarget
      hstart hB0 hcore habove hconv)

/-!
# Provable target closures

This section closes target predicates from the endpoint/spike branch whose
content is purely logical or scalar-algebraic.  It does not assert endpoint
localization, residue exclusion, subwindow density, or analytic spike input.
-/

/-- If the required gain is below `2`, then the strategic effective-loss target
is immediately inhabited by the midpoint between the required gain and `2`. -/
theorem effectiveLossImprovementTarget_of_required_lt_two
    {kappa nu beta tau M : ℝ}
    (h : requiredEffectiveGain kappa nu beta tau M < 2) :
    EffectiveLossImprovementTarget kappa nu beta tau M := by
  refine ⟨(requiredEffectiveGain kappa nu beta tau M + 2) / 2, ?_, ?_⟩
  · linarith
  · linarith

/-- Guarded version of `EndpointWorstExcessFormula`.

The unguarded target is false at the singular values `M = 0` and `M = 2`,
because Lean's real division is total.  This is the intended field-theoretic
version for the regime away from those denominators. -/
theorem endpointWorstExcessFormula_guarded
    {M nu : ℝ}
    (hM0 : M ≠ 0) (hM2 : M ≠ 2) :
    EndpointWorstExcessFormula M nu := by
  have hMm2 : M - 2 ≠ 0 := sub_ne_zero.mpr hM2
  have hworst :
      endpointWorstDensity M nu = (M - 1) * (M - nu) / (M * (M - 2)) := by
    unfold endpointWorstDensity endpointModelDensity
    ring_nf
  rw [EndpointWorstExcessFormula, hworst, endpointContractionThreshold]
  field_simp [hM0, hMm2]
  ring

/-- In the intended domain `M > 2`, the endpoint worst-excess formula holds. -/
theorem endpointWorstExcessFormula_of_two_lt
    {M nu : ℝ} (hM : 2 < M) :
    EndpointWorstExcessFormula M nu := by
  exact endpointWorstExcessFormula_guarded
    (M := M) (nu := nu) (by linarith) (by linarith)

/-- Diagnostic: the unguarded endpoint-worst formula target is not true at the
singular value `M = 2`. -/
theorem not_endpointWorstExcessFormula_M_eq_two_nu_eq_three :
    ¬ EndpointWorstExcessFormula 2 3 := by
  unfold EndpointWorstExcessFormula endpointWorstDensity endpointModelDensity
    endpointContractionThreshold
  norm_num

/-- Algebraic form of the one-threshold improvement condition.

Under `2 < nu < M`, the endpoint-average inequality is equivalent to
`2 + M / 2 < nu`. -/
theorem oneThresholdImprovementAlgebraTarget_proved
    (M nu : ℝ) :
    OneThresholdImprovementAlgebraTarget M nu := by
  intro h
  rcases h with ⟨hnu2, hnuM⟩
  have hMpos : 0 < M := by linarith
  have hdenpos : 0 < 2 * (nu - 2) := by nlinarith
  have hnumpos : 0 < M - nu := by linarith
  constructor
  · intro hineq
    have hmain :
        (M - nu) / (2 * (nu - 2)) < (M - nu) / M := by
      unfold oneThresholdEndpointDelta genericEndpointAverageDelta at hineq
      have hright : 1 - nu / M = (M - nu) / M := by
        field_simp [ne_of_gt hMpos]
      linarith
    have hMlt : M < 2 * (nu - 2) :=
      (div_lt_div_iff_of_pos_left hnumpos hdenpos hMpos).mp hmain
    linarith
  · intro hnu_large
    have hMlt : M < 2 * (nu - 2) := by linarith
    have hmain :
        (M - nu) / (2 * (nu - 2)) < (M - nu) / M :=
      (div_lt_div_iff_of_pos_left hnumpos hdenpos hMpos).mpr hMlt
    unfold oneThresholdEndpointDelta genericEndpointAverageDelta
    have hright : 1 - nu / M = (M - nu) / M := by
      field_simp [ne_of_gt hMpos]
    linarith

/-- Direct constructor for `EndpointWeightedAverageImprovementTarget`. -/
theorem endpointWeightedAverageImprovementTarget_of_bound
    {nu M : ℝ} {X : ℕ → ℝ} {delta : ℝ}
    (hdelta : delta < endpointContractionThreshold M nu)
    (havg : EndpointWeightedAverageBound X (fun j => X (j + 1)) nu delta) :
    EndpointWeightedAverageImprovementTarget nu M X := by
  exact ⟨delta, hdelta, havg⟩

/-- The currently encoded integral criterion is definitionally `True`. -/
theorem ratioTailIntegralCriterion_trivial
    (Phi : ℝ → ℝ) (nu M : ℝ) :
    RatioTailIntegralCriterion Phi nu M := by
  trivial

/-- Direct constructor for the ratio-tail formulation from a weighted tail
bound.  The integral criterion currently carries no extra encoded content. -/
theorem endpointWeightedAverageFromRatioTail_of_tailBound
    {nu M : ℝ} {X : ℕ → ℝ} {Phi : ℝ → ℝ}
    (hTail : WeightedRatioTailBound X Phi) :
    EndpointWeightedAverageFromRatioTail nu M X := by
  exact ⟨Phi, hTail, ratioTailIntegralCriterion_trivial Phi nu M⟩

/-- The boundary-inclusive one-threshold delta forced by charging the terminal
jump against `X_J + X_{J+1}` under the cap `r_j ≤ B - 1`. -/
def oneThresholdBoundaryDelta (B nu : ℝ) : ℝ :=
  (B - nu) * (B - 1) / (B * (nu - 2))

/-- In the self-bootstrap range `2 < nu < B`, the boundary-inclusive generic
one-threshold delta is never below the contraction threshold. -/
theorem endpointContractionThreshold_le_oneThresholdBoundaryDelta
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu < B) :
    endpointContractionThreshold B nu ≤ oneThresholdBoundaryDelta B nu := by
  have hBpos : 0 < B := by linarith
  have hnuSubpos : 0 < nu - 2 := by linarith
  have hbase_nonneg : 0 ≤ (B - nu) / B := by
    exact div_nonneg (by linarith) (le_of_lt hBpos)
  have hratio : 1 ≤ (B - 1) / (nu - 2) := by
    exact (le_div_iff₀ hnuSubpos).mpr (by linarith)
  have hmul := mul_le_mul_of_nonneg_left hratio hbase_nonneg
  unfold endpointContractionThreshold oneThresholdBoundaryDelta
  have hthreshold : 1 - nu / B = (B - nu) / B := by
    field_simp [ne_of_gt hBpos]
  rw [hthreshold]
  calc
    (B - nu) / B = (B - nu) / B * 1 := by ring
    _ ≤ (B - nu) / B * ((B - 1) / (nu - 2)) := hmul
    _ = (B - nu) * (B - 1) / (B * (nu - 2)) := by
      field_simp [ne_of_gt hBpos, ne_of_gt hnuSubpos]

/-- Strict self-bootstrap is impossible from the boundary-inclusive generic
one-threshold estimate alone. -/
theorem not_boundary_oneThreshold_self_bootstrap
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu < B) :
    ¬ oneThresholdBoundaryDelta B nu < endpointContractionThreshold B nu := by
  intro hlt
  have hle := endpointContractionThreshold_le_oneThresholdBoundaryDelta
    (B := B) (nu := nu) hnu2 hnuB
  exact not_lt_of_ge hle hlt

/-!
# Clipped endpoint repair

The one-threshold active-mass estimate controls a prefix sum over `j < J`.
The clipped endpoint average below matches that prefix exactly, avoiding the
terminal endpoint jump from the boundary-inclusive endpoint average.
-/

/-- Clipped endpoint excess.  This is the prefix sum over `j < J`, not a
boundary-inclusive sum. -/
def clippedEndpointExcessSum (X : ℕ → ℝ) (nu : ℝ) (J : ℕ) : ℝ :=
  endpointRatioExcessSum nu X J

/-- Clipped endpoint scale.  We keep the same right-endpoint scale
`X J + X (J+1)`. -/
def clippedEndpointScale (X : ℕ → ℝ) (J : ℕ) : ℝ :=
  endpointRatioScale X J

/-- Clipped endpoint-weighted average bound. -/
def ClippedEndpointWeightedAverageBound
    (X : ℕ → ℝ) (nu delta : ℝ) : Prop :=
  ∀ᶠ J in Filter.atTop,
    clippedEndpointExcessSum X nu J ≤ delta * clippedEndpointScale X J

/-- The clipped arithmetic-to-shell bridge.

This is the repaired replacement for
`EndpointWeightedAverageControlsNonVisibleBad`.  It asks for a clipped endpoint
localization argument controlling non-visible bad shells. -/
def ClippedEndpointWeightedAverageControlsNonVisibleBad
    (X H V : ℕ → ℝ) (nu x delta : ℝ) : Prop :=
  ClippedEndpointWeightedAverageBound X nu delta →
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) delta

/-- Clipped endpoint average gives the existing non-visible-bad density target. -/
theorem nonVisibleBadDensityTarget_of_clippedEndpointWeightedAverage
    {X H V : ℕ → ℝ} {nu x delta : ℝ}
    (hctrl : ClippedEndpointWeightedAverageControlsNonVisibleBad X H V nu x delta)
    (havg : ClippedEndpointWeightedAverageBound X nu delta) :
    NonVisibleBadDensityArithmeticTarget nu H V x delta := by
  exact hctrl havg

/-- Bauer/Ramanujan wrapper using the clipped endpoint average. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_clippedEndpointWeightedAverage
    {mu M nu tau x delta : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (_hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (havg : ClippedEndpointWeightedAverageBound X nu delta)
    (hctrl : ClippedEndpointWeightedAverageControlsNonVisibleBad X H V nu x delta)
    (hdelta_nonneg : 0 ≤ delta)
    (hdelta_gain : nu / M + delta < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  have hNV : UpperNatDensityAtMost (NonVisibleBadShell nu H V x) delta :=
    hctrl havg
  exact oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    (mu := mu) (nu := nu) (M := M) (tau := tau) (x := x)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hNV hdelta_nonneg hdelta_gain

/-- Global ratio cap. -/
def RatioBoundedBy (X : ℕ → ℝ) (R : ℝ) : Prop :=
  ∀ j : ℕ, logJumpRatio X j ≤ R

/-- Rewrite active mass as an ordinary finite sum with an indicator. -/
theorem weightedActiveRatioMass_eq_sum_ite
    (X : ℕ → ℝ) (nu : ℝ) (J : ℕ) :
    weightedActiveRatioMass X nu J =
      Finset.sum (Finset.range J) (fun j =>
        if nu - 1 < logJumpRatio X j then X j else 0) := by
  classical
  unfold weightedActiveRatioMass weightedRatioTailMass
  rw [Finset.sum_filter]

/-- Pointwise endpoint excess bound under a ratio cap. -/
theorem endpointRatioExcessTerm_le_active_indicator_of_cap
    {X : ℕ → ℝ} {M nu : ℝ} {j : ℕ}
    (hX : 0 < X j)
    (hcap : logJumpRatio X j ≤ M - 1)
    (hnuM : nu ≤ M) :
    endpointRatioExcessTerm nu X j
      ≤ (M - nu) *
        (if nu - 1 < logJumpRatio X j then X j else 0) := by
  have hRnu : nu - 1 ≤ M - 1 := by linarith
  have h := endpointExcessTerm_le_activeRatioIndicator
    (X := X) (nu := nu) (R := M - 1) (j := j) hX hcap hRnu
  have hcoef : M - 1 - (nu - 1) = M - nu := by ring
  simpa [hcoef] using h

/-- Prefix endpoint excess is bounded by `(M-nu)` times the active mass. -/
theorem endpointRatioExcessSum_le_cap_mul_weightedActiveRatioMass
    {X : ℕ → ℝ} {M nu : ℝ}
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hcap : RatioBoundedBy X (M - 1))
    (hnuM : nu ≤ M) :
    ∀ J : ℕ,
      endpointRatioExcessSum nu X J
        ≤ (M - nu) * weightedActiveRatioMass X nu J := by
  classical
  intro J
  unfold endpointRatioExcessSum
  calc
    Finset.sum (Finset.range J) (fun j => endpointRatioExcessTerm nu X j)
        ≤ Finset.sum (Finset.range J) (fun j =>
            (M - nu) *
              (if nu - 1 < logJumpRatio X j then X j else 0)) := by
          exact Finset.sum_le_sum (fun j _hj =>
            endpointRatioExcessTerm_le_active_indicator_of_cap
              (X := X) (M := M) (nu := nu) (j := j)
              (hXpos j) (hcap j) hnuM)
    _ = (M - nu) *
          Finset.sum (Finset.range J) (fun j =>
            if nu - 1 < logJumpRatio X j then X j else 0) := by
          rw [Finset.mul_sum]
    _ = (M - nu) * weightedActiveRatioMass X nu J := by
          rw [weightedActiveRatioMass_eq_sum_ite]

/-- The active-mass theorem closes the clipped endpoint average under a global
ratio cap. -/
theorem clippedEndpointWeightedAverageBound_of_activeMassFinite_global
    {X : ℕ → ℝ} {M nu : ℝ}
    (hnu2 : 2 < nu)
    (hnuM : nu ≤ M)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X)
    (hcap : RatioBoundedBy X (M - 1))
    (hactive : ActiveMassGeometricFiniteTarget X nu) :
    ClippedEndpointWeightedAverageBound X nu (oneThresholdBootstrapDelta M nu) := by
  refine Filter.Eventually.of_forall ?_
  intro J
  have hsum := endpointRatioExcessSum_le_cap_mul_weightedActiveRatioMass
    (X := X) (M := M) (nu := nu) hXpos hcap hnuM J
  have hmass : weightedActiveRatioMass X nu J
      ≤ oneThresholdActiveMassConstant nu * endpointRatioScale X J :=
    hactive hnu2 hXpos hmono J
  have hcoef_nonneg : 0 ≤ M - nu := by linarith
  have hmul :
      (M - nu) * weightedActiveRatioMass X nu J
        ≤ (M - nu) * (oneThresholdActiveMassConstant nu * endpointRatioScale X J) := by
    exact mul_le_mul_of_nonneg_left hmass hcoef_nonneg
  have hrewrite :
      (M - nu) * (oneThresholdActiveMassConstant nu * endpointRatioScale X J)
        = oneThresholdBootstrapDelta M nu * clippedEndpointScale X J := by
    unfold clippedEndpointScale oneThresholdActiveMassConstant genericActiveMassConstant
      oneThresholdBootstrapDelta
    ring_nf
  unfold clippedEndpointExcessSum
  calc
    endpointRatioExcessSum nu X J
        ≤ (M - nu) * weightedActiveRatioMass X nu J := hsum
    _ ≤ (M - nu) * (oneThresholdActiveMassConstant nu * endpointRatioScale X J) := hmul
    _ = oneThresholdBootstrapDelta M nu * clippedEndpointScale X J := hrewrite

/-!
## Telescoping clipped endpoint average

The endpoint excess can also be bounded by a chord majorant and then
telescoped.  This gives the generic clipped endpoint loss
`(B - nu) / (2 * (B - 2))`, sharper than the active-mass estimate while
retaining the same scalar barrier.
-/

/-- The telescoping clipped endpoint loss. -/
def telescopingClippedEndpointDelta (B nu : ℝ) : ℝ :=
  (B - nu) / (2 * (B - 2))

/-- Chord majorant for the endpoint excess on `[1, R]`. -/
theorem ratio_excess_le_chord_majorant
    {a R r : ℝ}
    (ha1 : 1 < a) (haR : a ≤ R)
    (hr1 : 1 ≤ r) (hrR : r ≤ R) :
    max 0 (r - a) ≤ ((R - a) / (R - 1)) * (r - 1) := by
  have hR1 : 0 < R - 1 := by linarith
  have hcoef_nonneg : 0 ≤ (R - a) / (R - 1) := by
    exact div_nonneg (sub_nonneg.mpr haR) (le_of_lt hR1)
  have hrminus_nonneg : 0 ≤ r - 1 := by linarith
  by_cases hle : r ≤ a
  · have hsub : r - a ≤ 0 := by linarith
    have hmax : max 0 (r - a) = 0 := max_eq_left hsub
    have hright : 0 ≤ ((R - a) / (R - 1)) * (r - 1) := by
      exact mul_nonneg hcoef_nonneg hrminus_nonneg
    simpa [hmax] using hright
  · have hsub_nonneg : 0 ≤ r - a := by linarith
    have hmax : max 0 (r - a) = r - a := max_eq_right hsub_nonneg
    have hprod_nonneg : 0 ≤ (R - r) * (a - 1) := by
      exact mul_nonneg (sub_nonneg.mpr hrR) (by linarith)
    have hid :
        (R - a) * (r - 1) - (r - a) * (R - 1)
          = (R - r) * (a - 1) := by
      ring
    have hcross : (r - a) * (R - 1) ≤ (R - a) * (r - 1) := by
      nlinarith [hprod_nonneg, hid]
    have hdiv : r - a ≤ ((R - a) * (r - 1)) / (R - 1) := by
      rw [le_div_iff₀ hR1]
      exact hcross
    have hrewrite :
        ((R - a) * (r - 1)) / (R - 1)
          = ((R - a) / (R - 1)) * (r - 1) := by
      field_simp [ne_of_gt hR1]
    simpa [hmax, hrewrite] using hdiv

/-- The local endpoint excess is bounded by a telescoping increment under a
uniform ratio cap. -/
theorem endpointRatioExcessTerm_le_telescoping_increment
    {X : ℕ → ℝ} {B nu : ℝ} {j : ℕ}
    (hnu2 : 2 < nu)
    (hnuB : nu ≤ B)
    (hX : 0 < X j)
    (hmono_step : X j ≤ X (j + 1))
    (hcap : logJumpRatio X j ≤ B - 1) :
    endpointRatioExcessTerm nu X j
      ≤ ((B - nu) / (B - 2)) * (X (j + 1) - X j) := by
  have ha1 : 1 < nu - 1 := by linarith
  have haR : nu - 1 ≤ B - 1 := by linarith
  have hr1 : 1 ≤ logJumpRatio X j := by
    unfold logJumpRatio
    rw [le_div_iff₀ hX]
    simpa using hmono_step
  have hratio := ratio_excess_le_chord_majorant
    (a := nu - 1) (R := B - 1) (r := logJumpRatio X j)
    ha1 haR hr1 hcap
  have hEq := endpointExcessTerm_eq_mul_ratio_excess
    (nu := nu) (X := X) (j := j) hX
  have hmul := mul_le_mul_of_nonneg_left hratio (le_of_lt hX)
  have hcoef :
      (B - 1 - (nu - 1)) / (B - 1 - 1) = (B - nu) / (B - 2) := by
    ring
  have hscale : X j * (logJumpRatio X j - 1) = X (j + 1) - X j := by
    unfold logJumpRatio
    field_simp [ne_of_gt hX]
  calc
    endpointRatioExcessTerm nu X j
        = X j * max 0 (logJumpRatio X j - (nu - 1)) := hEq
    _ ≤ X j * (((B - 1 - (nu - 1)) / (B - 1 - 1)) *
          (logJumpRatio X j - 1)) := hmul
    _ = ((B - nu) / (B - 2)) * (X (j + 1) - X j) := by
      rw [hcoef]
      calc
        X j * (((B - nu) / (B - 2)) * (logJumpRatio X j - 1))
            = ((B - nu) / (B - 2)) *
                (X j * (logJumpRatio X j - 1)) := by ring
        _ = ((B - nu) / (B - 2)) * (X (j + 1) - X j) := by
          rw [hscale]

/-- Telescoping identity for forward differences. -/
theorem sum_range_forward_difference
    (X : ℕ → ℝ) :
    ∀ J : ℕ,
      Finset.sum (Finset.range J) (fun j => X (j + 1) - X j)
        = X J - X 0 := by
  intro J
  induction J with
  | zero => simp
  | succ J ih =>
      rw [Finset.sum_range_succ, ih]
      ring

/-- The clipped endpoint excess is controlled by the telescoping loss. -/
theorem endpointRatioExcessSum_le_telescoping_delta_global
    {X : ℕ → ℝ} {B nu : ℝ}
    (hnu2 : 2 < nu)
    (hnuB : nu ≤ B)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X)
    (hcap : RatioBoundedBy X (B - 1)) :
    ∀ J : ℕ,
      endpointRatioExcessSum nu X J
        ≤ telescopingClippedEndpointDelta B nu * endpointRatioScale X J := by
  intro J
  let c : ℝ := (B - nu) / (B - 2)
  have hc_nonneg : 0 ≤ c := by
    have hnum : 0 ≤ B - nu := by linarith
    have hden : 0 ≤ B - 2 := by linarith
    exact div_nonneg hnum hden
  have hpoint : ∀ j ∈ Finset.range J,
      endpointRatioExcessTerm nu X j ≤ c * (X (j + 1) - X j) := by
    intro j _hj
    exact endpointRatioExcessTerm_le_telescoping_increment
      (X := X) (B := B) (nu := nu) (j := j)
      hnu2 hnuB (hXpos j) (hmono (Nat.le_succ j)) (hcap j)
  have hsum :
      endpointRatioExcessSum nu X J
        ≤ c * Finset.sum (Finset.range J) (fun j => X (j + 1) - X j) := by
    unfold endpointRatioExcessSum
    calc
      Finset.sum (Finset.range J) (fun j => endpointRatioExcessTerm nu X j)
          ≤ Finset.sum (Finset.range J) (fun j => c * (X (j + 1) - X j)) := by
            exact Finset.sum_le_sum hpoint
      _ = c * Finset.sum (Finset.range J) (fun j => X (j + 1) - X j) := by
            rw [Finset.mul_sum]
  have htel :
      Finset.sum (Finset.range J) (fun j => X (j + 1) - X j) = X J - X 0 :=
    sum_range_forward_difference X J
  have hprefix : c * (X J - X 0) ≤ c * X J := by
    have hdiff : X J - X 0 ≤ X J := by
      have h0 : 0 < X 0 := hXpos 0
      linarith
    exact mul_le_mul_of_nonneg_left hdiff hc_nonneg
  have hscale : 2 * X J ≤ endpointRatioScale X J := by
    unfold endpointRatioScale
    have hstep : X J ≤ X (J + 1) := hmono (Nat.le_succ J)
    nlinarith
  have hdelta_eq : telescopingClippedEndpointDelta B nu = c / 2 := by
    unfold telescopingClippedEndpointDelta c
    have hB2 : B - 2 ≠ 0 := by linarith
    field_simp [hB2]
  have hscale_bound :
      c * X J ≤ telescopingClippedEndpointDelta B nu * endpointRatioScale X J := by
    rw [hdelta_eq]
    calc
      c * X J = (c / 2) * (2 * X J) := by ring
      _ ≤ (c / 2) * endpointRatioScale X J := by
        exact mul_le_mul_of_nonneg_left hscale (by nlinarith [hc_nonneg])
  calc
    endpointRatioExcessSum nu X J
        ≤ c * Finset.sum (Finset.range J) (fun j => X (j + 1) - X j) := hsum
    _ = c * (X J - X 0) := by rw [htel]
    _ ≤ c * X J := hprefix
    _ ≤ telescopingClippedEndpointDelta B nu * endpointRatioScale X J := hscale_bound

/-- The telescoping estimate gives the clipped endpoint weighted-average bound. -/
theorem clippedEndpointWeightedAverageBound_of_telescoping_global
    {X : ℕ → ℝ} {B nu : ℝ}
    (hnu2 : 2 < nu)
    (hnuB : nu ≤ B)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X)
    (hcap : RatioBoundedBy X (B - 1)) :
    ClippedEndpointWeightedAverageBound X nu
      (telescopingClippedEndpointDelta B nu) := by
  refine Filter.Eventually.of_forall ?_
  intro J
  unfold clippedEndpointExcessSum clippedEndpointScale
  exact endpointRatioExcessSum_le_telescoping_delta_global
    (X := X) (B := B) (nu := nu)
    hnu2 hnuB hXpos hmono hcap J

/-- Nonnegativity of the telescoping clipped loss. -/
theorem telescopingClippedEndpointDelta_nonneg
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu ≤ B) :
    0 ≤ telescopingClippedEndpointDelta B nu := by
  unfold telescopingClippedEndpointDelta
  have hnum : 0 ≤ B - nu := by linarith
  have hden : 0 ≤ 2 * (B - 2) := by nlinarith
  exact div_nonneg hnum hden

/-!
# Telescoping final extraction to `OneOverPiMeasureAtMost 4`

The finite theorem `clippedEndpointWeightedAverageBound_of_telescoping_global`
is the generic engine.  To get the final irrationality-measure bound we still
need cutoff/localization data connecting this clipped endpoint average to
non-visible bad Ramanujan shells.  The extraction below proves the scalar and
logical parts and packages the remaining arithmetic payload as concrete step
data.
-/

/-! ## Scalar strictness for the telescoping loss -/

/-- For any input cap `B > 4` and any desired output `M > 4`, there is a
trial exponent `nu` for which the telescoping clipped loss gives strict
contraction against the output bound `M`. -/
theorem exists_nu_telescopingClippedEndpointDelta_strict
    {B M : ℝ} (hB : 4 < B) (hM : 4 < M) :
    ∃ nu : ℝ,
      2 < nu ∧ nu < B ∧ nu < M ∧
        telescopingClippedEndpointDelta B nu + nu / M < 1 := by
  let s : ℝ := min (B - 4) (M - 4) / 4
  have hB4 : 0 < B - 4 := by linarith
  have hM4 : 0 < M - 4 := by linarith
  have hmin_pos : 0 < min (B - 4) (M - 4) := lt_min hB4 hM4
  have hs_pos : 0 < s := by
    dsimp [s]
    nlinarith
  have hs_le_B : s ≤ (B - 4) / 4 := by
    dsimp [s]
    have hle : min (B - 4) (M - 4) ≤ B - 4 := min_le_left _ _
    nlinarith
  have hs_le_M : s ≤ (M - 4) / 4 := by
    dsimp [s]
    have hle : min (B - 4) (M - 4) ≤ M - 4 := min_le_right _ _
    nlinarith
  refine ⟨2 + s, ?_, ?_, ?_, ?_⟩
  · linarith
  · have hs_lt : s < B - 2 := by nlinarith [hs_le_B, hB]
    linarith
  · have hs_lt : s < M - 2 := by nlinarith [hs_le_M, hM]
    linarith
  · have hB2 : 0 < B - 2 := by linarith
    have hden : 0 < 2 * (B - 2) := by nlinarith
    have hdelta_lt_half :
        telescopingClippedEndpointDelta B (2 + s) < (1 / 2 : ℝ) := by
      unfold telescopingClippedEndpointDelta
      rw [div_lt_iff₀ hden]
      nlinarith [hs_pos]
    have hMpos : 0 < M := by linarith
    have hnu_lt_halfM : 2 + s < M / 2 := by
      nlinarith [hs_le_M, hM]
    have hnu_div_lt_half : (2 + s) / M < (1 / 2 : ℝ) := by
      rw [div_lt_iff₀ hMpos]
      nlinarith
    nlinarith [hdelta_lt_half, hnu_div_lt_half]

/-- Same scalar strictness, with the summands in the order expected by some
Ramanujan contraction wrappers. -/
theorem exists_nu_telescopingClippedEndpointDelta_strict_comm
    {B M : ℝ} (hB : 4 < B) (hM : 4 < M) :
    ∃ nu : ℝ,
      2 < nu ∧ nu < B ∧ nu < M ∧
        nu / M + telescopingClippedEndpointDelta B nu < 1 := by
  rcases exists_nu_telescopingClippedEndpointDelta_strict
      (B := B) (M := M) hB hM with
    ⟨nu, hnu2, hnuB, hnuM, hstrict⟩
  refine ⟨nu, hnu2, hnuB, hnuM, ?_⟩
  simpa [add_comm] using hstrict

/-! ## Concrete telescoping step data -/

/-- Concrete data for one telescoping clipped step from an input cap `B` to an
output bound `M`. -/
structure TelescopingClippedStepData (B M : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closure : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_le_B : nu ≤ B
  nu_lt_M : nu < M
  tau_pos : 0 < tau
  x_gt_contraction : shellSpikeContractionExponent tau nu M < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  X_pos : ∀ j : ℕ, 0 < X j
  X_mono : Monotone X
  ratio_cap : RatioBoundedBy X (B - 1)
  controls :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V nu x (telescopingClippedEndpointDelta B nu)
  gain_strict :
    nu / M + telescopingClippedEndpointDelta B nu < shellSpikeGoodDensityGain tau x

/-- The proved telescoping average plus concrete cutoff/localization data imply
a strict bound for every project-level irrationality-measure value of `1 / π`. -/
theorem oneOverPiMeasureStrictlyBelow_of_telescopingClippedStepData
    {B M : ℝ} (D : TelescopingClippedStepData B M) :
    OneOverPiMeasureStrictlyBelow M := by
  intro mu hmu
  have hAvg :
      ClippedEndpointWeightedAverageBound D.X D.nu
        (telescopingClippedEndpointDelta B D.nu) :=
    clippedEndpointWeightedAverageBound_of_telescoping_global
      (X := D.X) (B := B) (nu := D.nu)
      D.nu_gt_two D.nu_le_B D.X_pos D.X_mono D.ratio_cap
  have hDeltaNonneg : 0 ≤ telescopingClippedEndpointDelta B D.nu :=
    telescopingClippedEndpointDelta_nonneg
      (B := B) (nu := D.nu) D.nu_gt_two D.nu_le_B
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedEndpointWeightedAverage
    (mu := mu) (M := M) (nu := D.nu) (tau := D.tau) (x := D.x)
    (delta := telescopingClippedEndpointDelta B D.nu)
    (X := D.X) (H := D.H) (V := D.V)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    D.closure D.bauer hmu D.nu_gt_two D.nu_lt_M
    D.tau_pos D.x_gt_contraction D.x_lt_one D.x_le_global D.gain_le_one
    hAvg D.controls hDeltaNonneg D.gain_strict

/-! ## Direct final extraction to the non-strict `4` bound -/

/-- Final telescoping package.

A proof of this package is the remaining arithmetic/geometric cutoff work.  It
says that from one starting cap `B0 > 4`, every desired output `M > 4` admits a
concrete telescoping clipped step. -/
structure TelescopingClippedFinalPackage (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  stepData : ∀ M : ℝ, 4 < M → Nonempty (TelescopingClippedStepData B0 M)

/-- The direct telescoping final package proves `mu(1/pi) <= 4`. -/
theorem oneOverPiMeasureAtMost_four_of_telescopingClippedFinalPackage
    {B0 : ℝ} (P : TelescopingClippedFinalPackage B0) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_arbitrarily_close (by
    intro eps heps
    have hM : 4 < 4 + eps := by linarith
    rcases P.stepData (4 + eps) hM with ⟨D⟩
    exact oneOverPiMeasureStrictlyBelow_of_telescopingClippedStepData D)

/-- Project-facing final target for the clean telescoping route. -/
def TelescopingClippedFinalTarget : Prop :=
  ∃ B0 : ℝ, TelescopingClippedFinalPackage B0

/-- Final extraction theorem for the clean telescoping route. -/
theorem oneOverPiMeasureAtMost_four_of_telescopingClippedFinalTarget
    (h : TelescopingClippedFinalTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases h with ⟨B0, P⟩
  exact oneOverPiMeasureAtMost_four_of_telescopingClippedFinalPackage P

/-!
## Telescoping route payload audit

The theorem `clippedEndpointWeightedAverageBound_of_telescoping_global` proves
only the finite clipped endpoint average.  To obtain `OneOverPiMeasureAtMost 4`,
one still needs the cutoff/localization bridge contained in the `controls` field
of `TelescopingClippedStepData`.

This section exposes that remaining mathematical payload as an explicit
projection rather than hiding it behind another wrapper.
-/

/-- The `controls` field is exactly the remaining cutoff/localization payload of
a concrete telescoping step.  The finite telescoping average theorem supplies the
average bound; this field is what connects that average bound to the non-visible
bad-shell density estimate. -/
theorem telescopingClippedStepData_controls_payload
    {B M : ℝ} (D : TelescopingClippedStepData B M) :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      D.X D.H D.V D.nu D.x (telescopingClippedEndpointDelta B D.nu) := by
  exact D.controls

/-- The finite clipped endpoint average bound is fully proved from the fields
of a concrete telescoping step.  This is the part supplied by
`clippedEndpointWeightedAverageBound_of_telescoping_global`. -/
theorem telescopingClippedStepData_average_proved
    {B M : ℝ} (D : TelescopingClippedStepData B M) :
    ClippedEndpointWeightedAverageBound D.X D.nu
      (telescopingClippedEndpointDelta B D.nu) := by
  exact clippedEndpointWeightedAverageBound_of_telescoping_global
    (X := D.X) (B := B) (nu := D.nu)
    D.nu_gt_two D.nu_le_B D.X_pos D.X_mono D.ratio_cap

/-- A concrete telescoping step gives a strict bound below its output `M`.
This is just the existing final-step theorem, restated so downstream files can
use the payload/average split above. -/
theorem oneOverPiMeasureStrictlyBelow_of_telescopingClippedStepData_restated
    {B M : ℝ} (D : TelescopingClippedStepData B M) :
    OneOverPiMeasureStrictlyBelow M := by
  exact oneOverPiMeasureStrictlyBelow_of_telescopingClippedStepData D

/-- The clean telescoping final target implies the project-level bound
`μ(1/π) ≤ 4`.  This is the formal endpoint of the current route; it is
conditional precisely on the existence of the step data, whose non-generic
payload is the `controls` projection above. -/
theorem oneOverPiMeasureAtMost_four_of_telescopingClippedFinalTarget_restated
    (h : TelescopingClippedFinalTarget) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_telescopingClippedFinalTarget h

/-- The final package form also implies the project-level bound. -/
theorem oneOverPiMeasureAtMost_four_of_telescopingClippedFinalPackage_restated
    {B0 : ℝ} (P : TelescopingClippedFinalPackage B0) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_telescopingClippedFinalPackage P

/-! ## A convenience constructor using the scalar lemma and unit gain -/

/-- Data common to all output bounds `M`, except for the chosen trial exponent
`nu` and the scalar gain inequality. -/
structure TelescopingClippedUnitGainData (B M : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closure : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_le_B : nu ≤ B
  nu_lt_M : nu < M
  tau_pos : 0 < tau
  x_gt_contraction : shellSpikeContractionExponent tau nu M < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  gain_eq_one : shellSpikeGoodDensityGain tau x = 1
  X_pos : ∀ j : ℕ, 0 < X j
  X_mono : Monotone X
  ratio_cap : RatioBoundedBy X (B - 1)
