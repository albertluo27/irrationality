/-!
# Sublinear-error budget reduction for the final small-live endpoint target

The small-live endpoint target above uses a zero-error closed count budget.
Endpoint localization arguments often naturally produce a sublinear finite-count
error.  This section proves that such a sublinear closed-count error is
harmless for the final `mu(1/pi) <= 4` route.
-/

/-! ## Budget split with sublinear closed-count error -/

/-- Budget-level clipped closed/live split where the closed part is controlled
with a sublinear count error rather than with a zero-error count budget. -/
def ClippedEndpointCountBudgetWithErrorSplitWithLiveLoss
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Prop :=
  ∃ Closed Live : ℕ → Prop,
  ∃ E : ℕ → ℝ,
    NonVisibleBadClosedLiveCover nu x H V Closed Live ∧
    ClippedClosedEndpointCountBudgetWithError X nu delta Closed E ∧
    EventuallySublinearCountError E ∧
    LiveBoundaryDensityTarget Live eps

/-- The sublinear-error budget split implies the integrated closed/live split
interface. -/
theorem clippedEndpointControlsNonVisibleBadWithLiveLoss_of_countBudgetWithErrorSplit
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (hsplit : ClippedEndpointCountBudgetWithErrorSplitWithLiveLoss
      X H V nu x delta eps) :
    ClippedEndpointControlsNonVisibleBadWithLiveLoss X H V nu x delta eps := by
  rcases hsplit with ⟨Closed, Live, E, hcover, hbudget, hE, hlive⟩
  exact ⟨Closed, Live, hcover,
    clippedClosedEndpointControls_of_countBudgetWithError hbudget hE,
    hlive⟩

/-- With positive live loss, a sublinear-error budget split gives the same
non-visible-bad density bound with total density constant `delta + eps`. -/
theorem nonVisibleBadDensity_of_countBudgetWithErrorSplit_liveLoss
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (hsplit : ClippedEndpointCountBudgetWithErrorSplitWithLiveLoss
      X H V nu x delta eps)
    (havg : ClippedEndpointWeightedAverageBound X nu delta) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) (delta + eps) := by
  exact nonVisibleBadDensity_of_split_liveLoss
    (clippedEndpointControlsNonVisibleBadWithLiveLoss_of_countBudgetWithErrorSplit
      hsplit)
    havg

/-- The zero-error budget split is a special case of the sublinear-error budget
split. -/
theorem countBudgetWithErrorSplit_of_countBudgetSplit
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (hsplit : ClippedEndpointCountBudgetSplitWithLiveLoss
      X H V nu x delta eps) :
    ClippedEndpointCountBudgetWithErrorSplitWithLiveLoss X H V nu x delta eps := by
  rcases hsplit with ⟨Closed, Live, hcover, hbudget, hlive⟩
  refine ⟨Closed, Live, fun _ => 0, hcover, ?_,
    eventuallySublinearCountError_zero, hlive⟩
  exact clippedClosedEndpointCountBudgetWithError_zero hbudget

/-! ## Generic one-step theorem with sublinear-error budget split -/

/-- A clipped endpoint average at density `delta`, plus a sublinear-error
closed/live budget split with live loss `eps`, gives one strict measure
improvement whenever the scalar gain inequality has room for `delta + eps`. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_of_countBudgetWithErrorLiveLossStep
    {Mout nu tau x delta eps : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hnu2 : 2 < nu) (hnuM : nu < Mout)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu Mout < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (havg : ClippedEndpointWeightedAverageBound X nu delta)
    (hsplit : ClippedEndpointCountBudgetWithErrorSplitWithLiveLoss
      X H V nu x delta eps)
    (hdens_nonneg : 0 ≤ delta + eps)
    (hgain : delta + eps + nu / Mout < shellSpikeGoodDensityGain tau x) :
    OneOverPiMeasureStrictlyBelowEffectiveRaw Mout := by
  intro mu hmu
  have hNV : UpperNatDensityAtMost (NonVisibleBadShell nu H V x) (delta + eps) :=
    nonVisibleBadDensity_of_countBudgetWithErrorSplit_liveLoss
      (X := X) (H := H) (V := V) (nu := nu) (x := x)
      (delta := delta) (eps := eps) hsplit havg
  have hgain' : nu / Mout + (delta + eps) < shellSpikeGoodDensityGain tau x := by
    linarith
  exact oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    (mu := mu) (nu := nu) (M := Mout) (tau := tau) (x := x)
    (eps := delta + eps)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hNV hdens_nonneg hgain'

/-! ## Quadratic small-live core data with sublinear closed-count error -/

/-- Quadratic small-live core data where the endpoint closed part is allowed a
sublinear count error. -/
structure ClippedLayerCakeQuadraticSmallLiveErrorCoreData (B : ℝ) : Type where
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate Hlog u vseq H V
      (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)
  bauer : BauerRamanujanIdentity
  finiteData :
    ClippedOneThresholdFiniteData X B (clippedLayerCakeTrialNu B)
  eps : ℝ
  eps_nonneg : 0 ≤ eps
  eps_lt_slack : eps < clippedLayerCakeQuadraticEffectiveSlack B
  budgetSplit :
    ClippedEndpointCountBudgetWithErrorSplitWithLiveLoss
      X H V (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (clippedLayerCakeQuadraticEffectiveDelta B) eps

/-- The sublinear-error small-live core supplies the same clipped endpoint
average as the zero-error core. -/
theorem clippedEndpointAverageBound_of_quadraticSmallLiveErrorCoreData
    {B : ℝ} (D : ClippedLayerCakeQuadraticSmallLiveErrorCoreData B) :
    ClippedEndpointWeightedAverageBound D.X (clippedLayerCakeTrialNu B)
      (clippedLayerCakeQuadraticEffectiveDelta B) := by
  have hAvg :
      ClippedEndpointWeightedAverageBound D.X (clippedLayerCakeTrialNu B)
        (oneThresholdBootstrapDelta B (clippedLayerCakeTrialNu B)) :=
    clippedEndpointAverage_of_finiteData D.finiteData
  simpa [oneThresholdBootstrapDelta_trial_eq_clippedLayerCakeQuadraticEffectiveDelta]
    using hAvg

/-- One sublinear-error small-live core data package gives one strict quadratic
output bound. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_of_quadraticSmallLiveErrorCoreData
    {B : ℝ} (hB : 4 < B)
    (D : ClippedLayerCakeQuadraticSmallLiveErrorCoreData B) :
    OneOverPiMeasureStrictlyBelowEffectiveRaw
      (clippedLayerCakeQuadraticOutput B) := by
  have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
  have hnu2 : 2 < clippedLayerCakeTrialNu B := hcap.2.2.2.1
  have hnuM : clippedLayerCakeTrialNu B < clippedLayerCakeQuadraticOutput B :=
    hcap.2.2.2.2.1
  have htau : 0 < clippedLayerCakeCanonicalTau B :=
    clippedLayerCakeCanonicalTau_pos (B := B) hB
  have hx : shellSpikeContractionExponent
        (clippedLayerCakeCanonicalTau B) (clippedLayerCakeTrialNu B)
        (clippedLayerCakeQuadraticOutput B) < clippedLayerCakeCanonicalX B :=
    shellSpikeContractionExponent_lt_clippedLayerCakeCanonicalX_quadratic
      (B := B) hB
  have hx1 : clippedLayerCakeCanonicalX B < 1 :=
    clippedLayerCakeCanonicalX_lt_one (B := B) hB
  have hxθ : clippedLayerCakeCanonicalX B ≤
      shellSpikeGlobalExponent (clippedLayerCakeCanonicalTau B) := by
    rfl
  have havg := clippedEndpointAverageBound_of_quadraticSmallLiveErrorCoreData D
  have hdens_nonneg :
      0 ≤ clippedLayerCakeQuadraticEffectiveDelta B + D.eps := by
    have hδ := clippedLayerCakeQuadraticEffectiveDelta_nonneg (B := B) hB
    linarith [D.eps_nonneg]
  have hgainOne :
      clippedLayerCakeQuadraticEffectiveDelta B + D.eps +
        clippedLayerCakeTrialNu B / clippedLayerCakeQuadraticOutput B <
          shellSpikeGoodDensityGain
            (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B) := by
    have hstrict := clippedLayerCakeQuadraticEffectiveDelta_liveGain
      (B := B) (eps := D.eps) hB D.eps_lt_slack
    have hgain := shellSpikeGoodDensityGain_clippedLayerCakeCanonicalX_eq_one
      (B := B) hB
    simpa [hgain] using hstrict
  exact oneOverPiMeasureStrictlyBelowEffectiveRaw_of_countBudgetWithErrorLiveLossStep
    (Mout := clippedLayerCakeQuadraticOutput B)
    (nu := clippedLayerCakeTrialNu B)
    (tau := clippedLayerCakeCanonicalTau B)
    (x := clippedLayerCakeCanonicalX B)
    (delta := clippedLayerCakeQuadraticEffectiveDelta B)
    (eps := D.eps)
    (X := D.X) (H := D.H) (V := D.V)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    D.closureCert D.bauer hnu2 hnuM htau hx hx1 hxθ
    havg D.budgetSplit hdens_nonneg hgainOne

/-- Sublinear-error small-live active-mass target for every strict cap above
`4`. -/
def ClippedLayerCakeQuadraticSmallLiveErrorCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        Nonempty (ClippedLayerCakeQuadraticSmallLiveErrorCoreData B)

/-- Sublinear-error small-live data propagates strict bounds along the quadratic
iterates. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_quadraticIterate_of_smallLiveErrorCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticSmallLiveErrorCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ n : ℕ,
      OneOverPiMeasureStrictlyBelowEffectiveRaw
        (clippedLayerCakeQuadraticIterate B0 n) := by
  intro n
  induction n with
  | zero =>
      simpa [clippedLayerCakeQuadraticIterate] using hStart
  | succ n ih =>
      have hBn : 4 < clippedLayerCakeQuadraticIterate B0 n :=
        four_lt_clippedLayerCakeQuadraticIterate hB0 n
      rcases hCore (clippedLayerCakeQuadraticIterate B0 n) hBn ih with ⟨D⟩
      have hStep :=
        oneOverPiMeasureStrictlyBelowEffectiveRaw_of_quadraticSmallLiveErrorCoreData
          (B := clippedLayerCakeQuadraticIterate B0 n) hBn D
      simpa [clippedLayerCakeQuadraticIterate] using hStep

/-- Final wrapper: sublinear-error small-live quadratic core data implies the
non-strict bound `mu(1/pi) <= 4`. -/
theorem oneOverPi_irratMeasure_le_four_of_quadraticSmallLiveErrorCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticSmallLiveErrorCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ mu : ℝ,
      HasIrrationalityMeasure (1 / Real.pi) mu → mu ≤ 4 := by
  intro mu hmu
  by_contra hnot
  have hgt : 4 < mu := lt_of_not_ge hnot
  let eps0 : ℝ := (mu - 4) / 2
  have heps0 : 0 < eps0 := by
    unfold eps0
    linarith
  have hIter :=
    oneOverPiMeasureStrictlyBelowEffectiveRaw_quadraticIterate_of_smallLiveErrorCoreDataTarget
      hCore hB0 hStart
  have htend := tendsto_clippedLayerCakeQuadraticIterate (B0 := B0) hB0
  have hEventually :
      ∀ᶠ n : ℕ in atTop,
        clippedLayerCakeQuadraticIterate B0 n < 4 + eps0 := by
    have hlt : (4 : ℝ) < 4 + eps0 := by linarith
    exact (tendsto_order.1 htend).2 (4 + eps0) hlt
  rcases (eventually_atTop.1 hEventually) with ⟨N, hN⟩
  have hmu_lt_iter : mu < clippedLayerCakeQuadraticIterate B0 N :=
    hIter N mu hmu
  have hiter_lt : clippedLayerCakeQuadraticIterate B0 N < 4 + eps0 :=
    hN N le_rfl
  have hmu_lt : mu < 4 + eps0 := lt_trans hmu_lt_iter hiter_lt
  unfold eps0 at hmu_lt
  linarith

/-! ## One-over-pi final endpoint target with sublinear-error closed budget -/

/-- Final endpoint-geometry budget target allowing both a small live-boundary
loss and a sublinear closed-count error. -/
def OneOverPiTailStableSmallLiveBudgetWithErrorSplitForClosureTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ D : OneOverPiTailStableOrderedEndpointClosureData B baseShift,
              ∀ s : ℕ,
                ∃ liveLoss : ℝ,
                  0 ≤ liveLoss ∧
                  liveLoss < clippedLayerCakeQuadraticEffectiveSlack B ∧
                  ClippedEndpointCountBudgetWithErrorSplitWithLiveLoss
                    (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
                    (tailShiftSeq D.H s) (tailShiftSeq D.V s)
                    (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
                    (clippedLayerCakeQuadraticEffectiveDelta B) liveLoss

/-- The zero-error small-live budget target is a special case of the
sublinear-error target. -/
theorem oneOverPiTailStableSmallLiveBudgetWithErrorSplitForClosureTarget_of_smallLive
    (hSmall : OneOverPiTailStableSmallLiveBudgetSplitForClosureTarget) :
    OneOverPiTailStableSmallLiveBudgetWithErrorSplitForClosureTarget := by
  intro B hB hBound baseShift hCap D s
  rcases hSmall B hB hBound baseShift hCap D s with
    ⟨liveLoss, hnonneg, hlt, hsplit⟩
  exact ⟨liveLoss, hnonneg, hlt,
    countBudgetWithErrorSplit_of_countBudgetSplit hsplit⟩

/-- Final endpoint geometry target with sublinear closed-count error. -/
def OneOverPiFinalEndpointGeometrySmallLiveBudgetWithErrorTarget : Prop :=
  OneOverPiTailStableOrderedEndpointClosureForShiftTarget ∧
  OneOverPiTailStableSmallLiveBudgetWithErrorSplitForClosureTarget

/-- Construct one sublinear-error small-live core package from the final
endpoint target. -/
theorem clippedLayerCakeQuadraticSmallLiveErrorCoreData_of_finalEndpointGeometrySmallLiveBudgetWithErrorTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveBudgetWithErrorTarget)
    {B : ℝ} (hB : 4 < B)
    (hBound : OneOverPiMeasureStrictlyBelowEffectiveRaw B) :
    Nonempty (ClippedLayerCakeQuadraticSmallLiveErrorCoreData B) := by
  rcases hFinal with ⟨hClosure, hSmallLive⟩
  have hRatioTarget : OneOverPiShiftedQlogRatioCapFromMeasureTarget :=
    oneOverPiShiftedQlogRatioCapFromMeasureTarget_of_denLogRatioBounded
      oneOverPiContinuantDenLogRatioBoundedTarget_of_finiteMeasure
  rcases hRatioTarget B hB hBound with ⟨baseShift, hCap⟩
  rcases hClosure B hB hBound baseShift hCap with ⟨D⟩
  rcases exists_tailShiftSeq_pos_and_ratioBoundedBy
      (X := oneOverPiShiftedQlog baseShift) (R := B - 1)
      (oneOverPiShiftedQlog_eventuallyPositiveLogScale baseShift) hCap with
    ⟨s, hXpos, hRatio⟩
  rcases hSmallLive B hB hBound baseShift hCap D s with
    ⟨liveLoss, hlive_nonneg, hlive_lt, hBudget⟩
  refine ⟨{
    X := tailShiftSeq (oneOverPiShiftedQlog baseShift) s
    H := tailShiftSeq D.H s
    V := tailShiftSeq D.V s
    Hlog := tailShiftSeq D.Hlog s
    u := tailShiftSeq D.u s
    vseq := tailShiftSeq D.vseq s
    closureCert := D.closureCert_tail s
    bauer := D.bauer
    finiteData := ?_
    eps := liveLoss
    eps_nonneg := hlive_nonneg
    eps_lt_slack := hlive_lt
    budgetSplit := hBudget
  }⟩
  have hrange := clippedLayerCakeTrialNu_range (M := B) hB
  exact clippedOneThresholdFiniteData_of_ratioBounded
    (X := tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
    (B := B) (nu := clippedLayerCakeTrialNu B)
    hrange.1 (le_of_lt hrange.2)
    hXpos
    (monotone_tailShiftSeq
      (X := oneOverPiShiftedQlog baseShift) (N := s)
      (oneOverPiShiftedQlog_monotone baseShift))
    hRatio

/-- The final sublinear-error endpoint geometry target supplies the generic
sublinear-error small-live core-data target. -/
theorem clippedLayerCakeQuadraticSmallLiveErrorCoreDataTarget_of_finalEndpointGeometrySmallLiveBudgetWithErrorTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveBudgetWithErrorTarget) :
