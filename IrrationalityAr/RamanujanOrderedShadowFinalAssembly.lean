/-! ## 1. The certified-prefix union -/

/-- The increasing union of all certified odd-block sets obtained from a chosen
certified-prefix function `Jcert`.

Mathematically this is

`⋃ m, C_{Jcert m}(a)`.
-/
noncomputable def certifiedOddBlocksUnion
    (a : ℕ → ℕ) (Jcert : ℕ → ℕ) : Set ℕ :=
  certifiedOddBlocksStageUnion a Jcert

/-- The older certified-block union API is definitionally the stage-union API. -/
theorem certifiedOddBlocksUnion_eq_stageUnion
    (a : ℕ → ℕ) (Jcert : ℕ → ℕ) :
    certifiedOddBlocksUnion a Jcert = certifiedOddBlocksStageUnion a Jcert := rfl

@[simp] theorem mem_certifiedOddBlocksUnion_iff
    {a Jcert : ℕ → ℕ} {n : ℕ} :
    n ∈ certifiedOddBlocksUnion a Jcert ↔
      ∃ m : ℕ, n ∈ certifiedOddBlocks a (Jcert m) := by
  simp [certifiedOddBlocksUnion]

/-- The certified union is always contained in `A α`, once `a` is the simple CF
coefficient sequence of `α`. -/
theorem certifiedOddBlocksUnion_subset_A_of_IsSimpleCFExpansion
    {α : ℝ} {a Jcert : ℕ → ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a) :
    certifiedOddBlocksUnion a Jcert ⊆ A α := by
  exact certifiedOddBlocksStageUnion_subset_A_of_IsSimpleCFExpansion
    hαpos hαirr hcf

/-- Cofinality of the certified-prefix function.  This is the exact abstract
property needed to turn finite prefix certification into complete coverage. -/
def CertifiedPrefixCofinal (Jcert : ℕ → ℕ) : Prop :=
  CertifiedPrefixCofinalComplete Jcert

/-- The older certified-prefix cofinality predicate is definitionally the
complete cofinality predicate. -/
theorem CertifiedPrefixCofinal_iff_complete (Jcert : ℕ → ℕ) :
    CertifiedPrefixCofinal Jcert ↔ CertifiedPrefixCofinalComplete Jcert := by
  rfl

/-- Co-final certified prefixes cover the whole coefficient-side odd-block set.

This is the core formal version of the statement:

If every finite CF block depth is eventually certified, then the union of the
certified finite sets contains every selected odd block. -/
theorem oddBlockASet_subset_certifiedOddBlocksUnion_of_cofinal
    {a Jcert : ℕ → ℕ}
    (hcofinal : CertifiedPrefixCofinal Jcert) :
    oddBlockASet a ⊆ certifiedOddBlocksUnion a Jcert := by
  exact oddBlockASet_subset_certifiedOddBlocksStageUnion_of_cofinal hcofinal

/-- Completed coverage theorem, general parameter version.

If the certified-prefix lengths are cofinal, then the certified union is exactly
`A α`. -/
theorem certifiedOddBlocksUnion_eq_A_of_cofinal_IsSimpleCFExpansion
    {α : ℝ} {a Jcert : ℕ → ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a)
    (hcofinal : CertifiedPrefixCofinal Jcert) :
    certifiedOddBlocksUnion a Jcert = A α := by
  exact certifiedOddBlocksStageUnion_eq_A_of_cofinal_IsSimpleCFExpansion
    hαpos hαirr hcf hcofinal

/-! ## 2. Specialization to `1 / π` -/

/-- The union of all certified `1 / π` prefix sets attached to `Jcert`. -/
noncomputable def certifiedAOneOverPiUnionAt
    (Jcert : ℕ → ℕ) : Set ℕ :=
  certifiedAOneOverPiStageUnion Jcert

/-- The older `1 / π` certified-union API is definitionally the stage-union
API. -/
theorem certifiedAOneOverPiUnionAt_eq_stageUnion (Jcert : ℕ → ℕ) :
    certifiedAOneOverPiUnionAt Jcert = certifiedAOneOverPiStageUnion Jcert := rfl

@[simp] theorem mem_certifiedAOneOverPiUnionAt_iff
    {Jcert : ℕ → ℕ} {n : ℕ} :
    n ∈ certifiedAOneOverPiUnionAt Jcert ↔
      ∃ m : ℕ, n ∈ certifiedAOneOverPiSubsetAt Jcert m := by
  simp [certifiedAOneOverPiUnionAt]

/-- If `Jcert` certifies arbitrarily long CF prefixes of `1 / π`, then the
Ramanujan-certified union is the whole floor-sum set `A_{1 / π}`. -/
theorem certifiedAOneOverPiUnionAt_eq_A_of_cofinal
    {Jcert : ℕ → ℕ}
    (hcofinal : CertifiedPrefixCofinal Jcert) :
    certifiedAOneOverPiUnionAt Jcert = A oneOverPi := by
  exact certifiedAOneOverPiStageUnion_eq_A_of_cofinal hcofinal

/-- Named predicate for the informal statement: the Ramanujan-certified union
covers the whole `A_{1 / π}` sequence. -/
def RamanujanCertifiedCoversAll (Jcert : ℕ → ℕ) : Prop :=
  certifiedAOneOverPiUnionAt Jcert = A oneOverPi

/-- The coverage conjecture is reduced to the concrete cofinal-prefix theorem. -/
theorem RamanujanCertifiedCoversAll_of_cofinal
    {Jcert : ℕ → ℕ}
    (hcofinal : CertifiedPrefixCofinal Jcert) :
    RamanujanCertifiedCoversAll Jcert := by
  exact certifiedAOneOverPiUnionAt_eq_A_of_cofinal hcofinal

/-! ## 3. Rate and loss predicates -/

/-- Stage `m` covers every actual `A_{1 / π}` element below the exponential
height `exp(Λ m)`.  This is stronger than merely producing many certified
terms; it is the formal version of bounded certification loss. -/
def CoversAOneOverPiBelowExpAt
    (Jcert : ℕ → ℕ) (Λ : ℝ) (m : ℕ) : Prop :=
  ∀ n : ℕ,
    n ∈ A oneOverPi →
      (n : ℝ) ≤ Real.exp (Λ * (m : ℝ)) →
        n ∈ certifiedAOneOverPiSubsetAt Jcert m

/-- Eventual bounded certification loss below exponential height.  Informally,
this is the useful form of `m(N) ≲ log N`. -/
def EventuallyCoversAOneOverPiBelowExp
    (Jcert : ℕ → ℕ) (Λ : ℝ) : Prop :=
  ∀ᶠ m : ℕ in atTop, CoversAOneOverPiBelowExpAt Jcert Λ m

/-- Efficient production of certified terms below exponential height.
This matches the theorem family already developed in `Ramanujan.lean`. -/
def EfficientRamanujanProductionAt
    (Jcert : ℕ → ℕ) (ρ Λ : ℝ) : Prop :=
  0 < ρ ∧ 0 < Λ ∧
    ∀ᶠ m : ℕ in atTop,
      ρ * (m : ℝ) ≤
        ((certifiedAOneOverPiSubsetBelowExpAt Jcert m Λ).card : ℝ)

/-- Completed wrapper: linear card lower bound plus endpoint-height control
implies efficient certified production. -/
theorem efficientRamanujanProductionAt_of_card_lower_and_endpoint_bound
    {Jcert : ℕ → ℕ} {ρ Λ : ℝ}
    (hρ : 0 < ρ)
    (hΛ : 0 < Λ)
    (hcard : EventuallyLinearLowerBound (certifiedAOneOverPiCardAt Jcert) ρ)
    (hden :
      ∀ᶠ m : ℕ in atTop,
        (continuantDen oneOverPiCF (Jcert m) : ℝ) ≤
          Real.exp (Λ * (m : ℝ))) :
    EfficientRamanujanProductionAt Jcert ρ Λ := by
  refine ⟨hρ, hΛ, ?_⟩
  exact eventuallyManyCertifiedAOneOverPiBelowExpAt_of_card_lower_and_endpoint_bound
    hcard hden

/-! ## 4. Conjectural targets left as predicates, not axioms -/

/-- A future theorem should prove this for the actual Ramanujan interval prefix
selector: the intervals certify arbitrarily long CF prefixes. -/
def RamanujanPrefixCofinalityConjecture
    (Jcert : ℕ → ℕ) : Prop :=
  CertifiedPrefixCofinal Jcert

/-- A future theorem should prove that the certification loss is logarithmic:
stage `m` covers every true `A_{1 / π}` term below `exp(Λ m)` for some `Λ`. -/
def LogarithmicCertificationLossConjecture
    (Jcert : ℕ → ℕ) : Prop :=
  ∃ Λ : ℝ, 0 < Λ ∧ EventuallyCoversAOneOverPiBelowExp Jcert Λ

/-- A future theorem should prove efficient production with positive constants. -/
def EfficientProductionConjecture
    (Jcert : ℕ → ℕ) : Prop :=
  ∃ ρ Λ : ℝ, EfficientRamanujanProductionAt Jcert ρ Λ

/-!
The next object is intentionally schematic.  It is meant to express the much
stronger idea that large canonical blocks are not only certified by intervals,
but are explained by determinant-one Ramanujan/Farey paths.
-/

/-- A determinant-one rational path `t ↦ (P0 + dP t)/(Q0 + dQ t)`.
The determinant condition says consecutive path fractions are Farey neighbors. -/
def DeterminantOneLinearPath
    (P0 dP Q0 dQ : ℕ) : Prop :=
  |((dP : ℤ) * (Q0 : ℤ) - (P0 : ℤ) * (dQ : ℤ))| = 1

/-- A schematic predicate saying that canonical block `j` is explained by some
linear determinant-one path.  The exact interval-side hypotheses should be
filled in when the next Ramanujan/Farey-path file is written. -/
def CanonicalBlockExplainedByLinearFareyPath
    (_a : ℕ → ℕ) (_j : ℕ) : Prop :=
  ∃ P0 dP Q0 dQ : ℕ,
    DeterminantOneLinearPath P0 dP Q0 dQ ∧
      0 < dQ ∧
        -- Placeholder for: the selected shifted denominators in block `j`
        -- are obtained from odd numerator indices along this path.
        True

/-- Structural conjecture: every sufficiently large visible canonical block of
`1 / π` is explained by a determinant-one Ramanujan/Farey path.  This is much
stronger than coverage and is the genuinely interesting structural direction. -/
def LargeBlocksExplainedByRamanujanPathsConjecture : Prop :=
  ∀ᶠ j : ℕ in atTop,
    1 < canonicalBlockLength oneOverPiCF j →
      CanonicalBlockExplainedByLinearFareyPath oneOverPiCF j


