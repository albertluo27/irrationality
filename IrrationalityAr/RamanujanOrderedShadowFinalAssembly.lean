/-!
# Direct active-count budget reduction

The prefix-sublinear route is a useful sufficient route, but for the actual
continued-fraction endpoint indices it is safer to keep the active-index count
as its own quantitative estimate.  This layer removes the need to prove a
sublinear raw prefix map `K(M)`.

Instead, it asks directly for a sublinear bound on the cutoff-relevant active
index count.  This is the right interface for a later proof using
multiplicative active jumps, since active indices satisfy an endpoint-excess
condition rather than merely an index bound.
-/

/-! ## Direct active-count budget -/

/-- Direct sublinear active-count data for a cutoff-relevant family of real
intervals. -/
structure CutoffRelevantActiveCountDirectData
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop) : Type where
  countErr : ℕ → ℝ
  countBound : ∀ᶠ M : ℕ in atTop,
    (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ) ≤ countErr M
  countErrSublinear : EventuallySublinearCountError countErr

/-- Direct active-count data gives the active-count sublinearity field required
by the existing cutoff-budget API. -/
theorem cutoffRelevantActiveShadowCountSublinear_of_directData
    {S E : ℕ → ℝ} {RelevantAt : ℕ → ℕ → ℕ → Prop}
    (D : CutoffRelevantActiveCountDirectData S E RelevantAt) :
    CutoffRelevantActiveShadowCountSublinear S E RelevantAt := by
  intro eps heps
  filter_upwards [D.countBound, D.countErrSublinear eps heps] with M hcnt herr
  exact le_trans hcnt herr

