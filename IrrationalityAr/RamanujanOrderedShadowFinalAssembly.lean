  H := D.H
  V := D.V
  Hlog := D.Hlog
  u := D.u
  vseq := D.vseq
  closureCert := D.closureCert
  bauer := D.bauer
  X_pos := D.X_pos
  X_mono := D.X_mono
  ratio_cap := D.ratio_cap
  clippedControls := D.clippedControls

/-- Concrete shifted one-over-pi target.  This is the main remaining
arithmetic/geometric target for this route. -/
def OneOverPiShiftedQuadraticGeometricCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        Nonempty (OneOverPiShiftedQuadraticGeometricCoreData B)

/-- The concrete shifted one-over-pi target implies the geometric-core target. -/
theorem clippedLayerCakeQuadraticGeometricCoreDataTarget_of_oneOverPiShiftedTarget
    (hShifted : OneOverPiShiftedQuadraticGeometricCoreDataTarget) :
    ClippedLayerCakeQuadraticGeometricCoreDataTarget := by
