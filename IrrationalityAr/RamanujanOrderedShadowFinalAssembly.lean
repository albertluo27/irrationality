/-!
# Pure finite geometric-count bridge for below-left ratio-active indices

The endpoint-specific geometric count target reduces to one finite
combinatorial target: multiplicatively separated selected indices below a
linear scale cutoff have logarithmic cardinality.
-/

/-! ## Pure finite geometric separation target -/

/-- A finite set of indices is multiplicatively separated with respect to `X`
by factor `rho` if each later selected index has `X`-value at least `rho` times
the earlier selected index. -/
def FinsetMultiplicativelySeparated
    (A : Finset ℕ) (X : ℕ → ℝ) (rho : ℝ) : Prop :=
  ∀ i j : ℕ,
    i ∈ A →
      j ∈ A →
        i < j →
          rho * X i ≤ X j

/-- Pure finite geometric logarithmic counting target.

This is the active-count combinatorics left after the endpoint reductions:
every finite family whose `X`-values are bounded below by a positive number,
bounded above by a linear cutoff, and multiplicatively separated by a fixed
factor `rho > 1`, has cardinality `O(log M)`. -/
def PureGeometricFinsetLogCountTarget : Prop :=
  ∀ (rho L Acoeff : ℝ) (F : ℕ → Finset ℕ) (X : ℕ → ℝ),
    1 < rho →
      0 < L →
        0 ≤ Acoeff →
          (∀ M j : ℕ, j ∈ F M → L ≤ X j) →
            (∀ M j : ℕ, j ∈ F M → X j ≤ Acoeff * (M : ℝ)) →
              (∀ M : ℕ, FinsetMultiplicativelySeparated (F M) X rho) →
                ∃ C : ℝ,
                  0 ≤ C ∧
                    ∀ᶠ M : ℕ in atTop,
                      ((F M).card : ℝ) ≤ C * Real.log ((M : ℝ) + 2)

/-! ## Endpoint below-left families satisfy the pure hypotheses -/

/-- Endpoint below-left active finite sets are multiplicatively separated in
`X`, with factor `endpointRatioActiveGrowthFactor nu`. -/
theorem endpointRatioActiveBelowLeftIndexFinset_multiplicativelySeparated
    {nu : ℝ} {X : ℕ → ℝ} (M : ℕ)
    (hnu : 2 < nu)
    (hX_pos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X) :
    FinsetMultiplicativelySeparated
      (EndpointRatioActiveBelowLeftIndexFinset nu X M)
      X (endpointRatioActiveGrowthFactor nu) := by
  classical
  intro i j hi hj hij
  have hiIdx : EndpointRatioActiveBelowLeftIndex nu X M i := by
    dsimp [EndpointRatioActiveBelowLeftIndexFinset] at hi
    exact (Finset.mem_filter.mp hi).2
  have hjIdx : EndpointRatioActiveBelowLeftIndex nu X M j := by
    dsimp [EndpointRatioActiveBelowLeftIndexFinset] at hj
    exact (Finset.mem_filter.mp hj).2
  exact endpointRatioActiveBelowLeftIndex_growthFactor_mul_le_later
    (nu := nu) (X := X) (M := M) (i := i) (j := j)
    hnu hX_pos hmono hiIdx hjIdx hij

/-- Endpoint below-left active indices have `X`-value bounded below by `X 0`,
by monotonicity. -/
theorem endpointRatioActiveBelowLeftIndexFinset_X0_le
    {nu : ℝ} {X : ℕ → ℝ}
    (hmono : Monotone X)
    (M j : ℕ)
    (_hj : j ∈ EndpointRatioActiveBelowLeftIndexFinset nu X M) :
    X 0 ≤ X j := by
  exact hmono (Nat.zero_le j)

/-- Endpoint below-left active indices have `X`-value bounded above linearly in
`M`. -/
theorem endpointRatioActiveBelowLeftIndexFinset_X_le_linearCutoff
    {nu : ℝ} {X : ℕ → ℝ}
    (hnu : 0 < nu)
    (M j : ℕ)
    (hj : j ∈ EndpointRatioActiveBelowLeftIndexFinset nu X M) :
    X j ≤ (ramanujanKappa / nu) * (M : ℝ) := by
  classical
  have hIdx : EndpointRatioActiveBelowLeftIndex nu X M j := by
    dsimp [EndpointRatioActiveBelowLeftIndexFinset] at hj
    exact (Finset.mem_filter.mp hj).2
  have h := endpointRatioActiveBelowLeftIndex_X_le_cutoff
    (nu := nu) (X := X) (M := M) (j := j) hnu hIdx
  have hrewrite : ramanujanKappa * (M : ℝ) / nu =
      (ramanujanKappa / nu) * (M : ℝ) := by
    ring
  simpa [hrewrite] using h

/-! ## Pure geometric count implies the endpoint geometric count target -/

/-- The pure finite geometric logarithmic counting target gives the endpoint
below-left logarithmic count data, in the `Nonempty` form required by the
existing geometric-count target. -/
theorem endpointRatioActiveBelowLeftLogCountData_nonempty_of_pureGeometricFinsetLogCountTarget
    (hpure : PureGeometricFinsetLogCountTarget)
    {nu : ℝ} {X : ℕ → ℝ}
    (hnu : 2 < nu)
    (hX_pos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X) :
    Nonempty (EndpointRatioActiveBelowLeftLogCountData nu X) := by
  classical
  let F : ℕ → Finset ℕ := fun M =>
    EndpointRatioActiveBelowLeftIndexFinset nu X M
  let rho : ℝ := endpointRatioActiveGrowthFactor nu
  let L : ℝ := X 0
  let Acoeff : ℝ := ramanujanKappa / nu
  have hrho : 1 < rho := by
    simpa [rho] using
      (one_lt_endpointRatioActiveGrowthFactor_of_two_lt (nu := nu) hnu)
  have hL : 0 < L := by
    simpa [L] using hX_pos 0
  have hnu_pos : 0 < nu := by linarith
  have hAcoeff : 0 ≤ Acoeff := by
    exact div_nonneg (le_of_lt ramanujanKappa_pos) (le_of_lt hnu_pos)
  have hLower : ∀ M j : ℕ, j ∈ F M → L ≤ X j := by
    intro M j hj
    simpa [F, L] using
      endpointRatioActiveBelowLeftIndexFinset_X0_le
        (nu := nu) (X := X) hmono M j hj
  have hUpper : ∀ M j : ℕ, j ∈ F M → X j ≤ Acoeff * (M : ℝ) := by
    intro M j hj
    simpa [F, Acoeff] using
      endpointRatioActiveBelowLeftIndexFinset_X_le_linearCutoff
        (nu := nu) (X := X) hnu_pos M j hj
  have hSep : ∀ M : ℕ, FinsetMultiplicativelySeparated (F M) X rho := by
    intro M
    simpa [F, rho] using
      endpointRatioActiveBelowLeftIndexFinset_multiplicativelySeparated
        (nu := nu) (X := X) M hnu hX_pos hmono
  rcases hpure rho L Acoeff F X hrho hL hAcoeff hLower hUpper hSep
    with ⟨C, hC_nonneg, hC_bound⟩
  exact ⟨{
    C := C
    C_nonneg := hC_nonneg
    countBound := by
      filter_upwards [hC_bound] with M hM
      simpa [F, EndpointRatioActiveBelowLeftCount] using hM
  }⟩

/-- The pure finite geometric logarithmic counting theorem implies the existing
endpoint geometric-count target. -/
theorem endpointRatioActiveBelowLeftGeometricCountTarget_of_pureGeometric
    (hpure : PureGeometricFinsetLogCountTarget) :
    EndpointRatioActiveBelowLeftGeometricCountTarget := by
  intro nu X hnu hX_pos hmono
  exact
    endpointRatioActiveBelowLeftLogCountData_nonempty_of_pureGeometricFinsetLogCountTarget
      hpure hnu hX_pos hmono

