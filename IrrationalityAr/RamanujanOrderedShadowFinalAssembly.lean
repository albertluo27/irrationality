/-!
# Active-relevant endpoint geometry: actual qlog average reduction

The previous direct-average route removed the legacy pointwise `ratio_cap`
field from the active-relevant endpoint package by asking directly for the
clipped endpoint average bound consumed by the density theorem.

This layer removes that average bound from the remaining endpoint payload in
the actual `1 / pi` qlog route.  For the actual denominator-log sequence, a
strict current measure cap gives an eventual qlog ratio cap; after discarding a
finite prefix, the telescoping clipped endpoint theorem supplies the needed
direct average bound.
-/

/-! ## Telescoping average implies the one-threshold clipped average -/

/-- The telescoping clipped endpoint loss is bounded by the one-threshold
endpoint loss whenever `2 < nu <= B`. -/
theorem telescopingClippedEndpointDelta_le_oneThresholdEndpointDelta
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu <= B) :
    telescopingClippedEndpointDelta B nu <= oneThresholdEndpointDelta B nu := by
  unfold telescopingClippedEndpointDelta oneThresholdEndpointDelta
    genericEndpointAverageDelta
  have hB2 : 0 < B - 2 := by linarith
  have hnu2' : 0 < nu - 2 := by linarith
  have hdenB : 0 < 2 * (B - 2) := by nlinarith
  have hdenNu : 0 < 2 * (nu - 2) := by nlinarith
  have hnum : 0 <= B - nu := by linarith
  have hden_le : 2 * (nu - 2) <= 2 * (B - 2) := by nlinarith
  rw [div_le_div_iff₀ hdenB hdenNu]
  exact mul_le_mul_of_nonneg_left hden_le hnum

/-- A global tail ratio cap proves the one-threshold clipped endpoint average
on that tail, using the sharper telescoping theorem and then enlarging the
allowed loss. -/
theorem clippedEndpointWeightedAverageBound_of_tailShift_globalRatioCap
    {X : ℕ → ℝ} {B nu : ℝ} {s : ℕ}
    (hnu2 : 2 < nu) (hnuB : nu <= B)
    (hXposTail : ∀ j : ℕ, 0 < tailShiftSeq X s j)
    (hmono : Monotone X)
    (hcapTail : RatioBoundedBy (tailShiftSeq X s) (B - 1)) :
    ClippedEndpointWeightedAverageBound (tailShiftSeq X s) nu
      (oneThresholdEndpointDelta B nu) := by
  have htel : ClippedEndpointWeightedAverageBound (tailShiftSeq X s) nu
      (telescopingClippedEndpointDelta B nu) :=
    clippedEndpointWeightedAverageBound_of_telescoping_global
      (X := tailShiftSeq X s) (B := B) (nu := nu)
      hnu2 hnuB hXposTail (monotone_tailShiftSeq hmono) hcapTail
  have hdelta : telescopingClippedEndpointDelta B nu
      <= oneThresholdEndpointDelta B nu :=
    telescopingClippedEndpointDelta_le_oneThresholdEndpointDelta
      (B := B) (nu := nu) hnu2 hnuB
  refine htel.mono ?_
  intro J hJ
  have hscale_nonneg : 0 <= clippedEndpointScale (tailShiftSeq X s) J := by
    unfold clippedEndpointScale endpointRatioScale
    have h0 : 0 <= tailShiftSeq X s J := le_of_lt (hXposTail J)
    have h1 : 0 <= tailShiftSeq X s (J + 1) :=
      le_of_lt (hXposTail (J + 1))
    linarith
  have hmul :
      telescopingClippedEndpointDelta B nu *
          clippedEndpointScale (tailShiftSeq X s) J
        <=
      oneThresholdEndpointDelta B nu *
          clippedEndpointScale (tailShiftSeq X s) J := by
    exact mul_le_mul_of_nonneg_right hdelta hscale_nonneg
  exact le_trans hJ hmul

