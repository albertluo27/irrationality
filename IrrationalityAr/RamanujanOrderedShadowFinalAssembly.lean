/-! ## Live-loss strict-slack route: concrete source-level input package -/

/-- All fields of `ClippedOneThresholdStrictSlackStepDataWithLiveLoss` except
the endpoint budget split. -/
structure LiveLossStepSkeleton (B : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  eps : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_lt_out : nu < oneThresholdBootstrapRelaxedMap B
  tau_pos : 0 < tau
  x_contraction :
    shellSpikeContractionExponent tau nu (oneThresholdBootstrapRelaxedMap B) < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  finiteData : ClippedOneThresholdFiniteData X B nu
  total_nonneg : 0 ≤ clippedLiveLossTotalDelta B nu eps
  total_gain :
    nu / oneThresholdBootstrapRelaxedMap B +
        clippedLiveLossTotalDelta B nu eps < shellSpikeGoodDensityGain tau x

/-- Insert the budget split into the live-loss strict-slack skeleton. -/
def liveLossStepData_of_skeleton
    {B : ℝ}
    (S : LiveLossStepSkeleton B)
