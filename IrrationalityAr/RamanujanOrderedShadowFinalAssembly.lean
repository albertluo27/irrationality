/-!
# One-threshold relaxed scalar convergence

This closes the scalar part of the active-log-count route.  In the gap variable
`y = B - 4`, the relaxed one-threshold map has the exact form

`y ↦ y - y^2 / (10*y + 32 + 8*sqrt ((B + 4)*(B - 2)))`.

The reciprocal gap therefore gains a fixed positive amount along the iteration,
so the relaxed iterates converge down to `4`.
-/

/-- Square-root term used by the optimized one-threshold map. -/
def oneThresholdRelaxedSqrt (B : ℝ) : ℝ :=
  Real.sqrt ((B + 4) * (B - 2))

/-- The one-threshold relaxed square-root term is positive above `4`. -/
theorem oneThresholdRelaxedSqrt_pos {B : ℝ} (hB : 4 < B) :
    0 < oneThresholdRelaxedSqrt B := by
  unfold oneThresholdRelaxedSqrt
  exact Real.sqrt_pos.2 (by nlinarith)

/-- The one-threshold relaxed square-root term is nonnegative. -/
theorem oneThresholdRelaxedSqrt_nonneg (B : ℝ) :
    0 ≤ oneThresholdRelaxedSqrt B := by
  unfold oneThresholdRelaxedSqrt
  exact Real.sqrt_nonneg _

/-- Square of the one-threshold relaxed square-root term. -/
theorem oneThresholdRelaxedSqrt_sq {B : ℝ} (hB : 4 < B) :
    oneThresholdRelaxedSqrt B ^ 2 = (B + 4) * (B - 2) := by
  unfold oneThresholdRelaxedSqrt
  rw [Real.sq_sqrt]
  nlinarith

/-- Closed square-root form of the optimized one-threshold map. -/
theorem oneThresholdBootstrapMap_eq_closed_sqrt_scalar
    {B : ℝ} (hB : 4 < B) :
    oneThresholdBootstrapMap B =
      (4 * (B + 1 + oneThresholdRelaxedSqrt B)) / 9 := by
  unfold oneThresholdBootstrapMap oneThresholdBootstrapOutputClosed
    oneThresholdBootstrapOptimizer oneThresholdRelaxedSqrt
  let s : ℝ := Real.sqrt ((B + 4) * (B - 2))
  have hs_pos : 0 < s := by
    dsimp [s]
    exact Real.sqrt_pos.2 (by nlinarith)
  have hs_ne : s ≠ 0 := ne_of_gt hs_pos
  have hs_sq : s ^ 2 = (B + 4) * (B - 2) := by
    dsimp [s]
    rw [Real.sq_sqrt]
    nlinarith
  change
    (2 * ((B + 4 + s) / 3) * (((B + 4 + s) / 3) - 2)) /
        (3 * ((B + 4 + s) / 3) - B - 4) =
      4 * (B + 1 + s) / 9
  have hden : 3 * ((B + 4 + s) / 3) - B - 4 = s := by ring
  rw [hden]
  field_simp [hs_ne]
  nlinarith [hs_sq]

/-- Exact gap formula for the relaxed one-threshold map. -/
theorem oneThresholdBootstrapRelaxedMap_gap_formula_scalar
    {B : ℝ} (hB : 4 < B) :
    oneThresholdBootstrapRelaxedMap B - 4 =
      (B - 4) - (B - 4) ^ 2 /
        (10 * (B - 4) + 32 + 8 * oneThresholdRelaxedSqrt B) := by
  unfold oneThresholdBootstrapRelaxedMap
  rw [oneThresholdBootstrapMap_eq_closed_sqrt_scalar (B := B) hB]
  let D : ℝ := 10 * (B - 4) + 32 + 8 * oneThresholdRelaxedSqrt B
  have hs_nonneg : 0 ≤ oneThresholdRelaxedSqrt B :=
    oneThresholdRelaxedSqrt_nonneg B
  have hD : D ≠ 0 := by
    dsimp [D]
    nlinarith
  have hs_sq := oneThresholdRelaxedSqrt_sq (B := B) hB
  have hmul :
      ((((B + (4 * (B + 1 + oneThresholdRelaxedSqrt B)) / 9) / 2) - 4) *
          D =
        (B - 4) * D - (B - 4) ^ 2) := by
    dsimp [D]
    ring_nf at hs_sq ⊢
    nlinarith
  have hrhs : (B - 4) - (B - 4) ^ 2 / D =
      ((B - 4) * D - (B - 4) ^ 2) / D := by
    field_simp [hD]
  rw [hrhs]
  rw [eq_div_iff hD]
  exact hmul

/-- Algebraic reciprocal identity for the relaxed gap step. -/
theorem oneThresholdRelaxed_reciprocal_gap_aux
    {y s : ℝ} (hy : 0 < y) (hs : 0 ≤ s) :
    1 / (y - y ^ 2 / (10 * y + 32 + 8 * s)) =
      1 / y + 1 / (9 * y + 32 + 8 * s) := by
  let D : ℝ := 10 * y + 32 + 8 * s
  let E : ℝ := 9 * y + 32 + 8 * s
  have hy0 : y ≠ 0 := ne_of_gt hy
  have hD0 : D ≠ 0 := by
    dsimp [D]
    nlinarith
  have hE0 : E ≠ 0 := by
    dsimp [E]
    nlinarith
  have hgap : y - y ^ 2 / D = y * E / D := by
    field_simp [hD0]
    dsimp [D, E]
    ring
  rw [show 10 * y + 32 + 8 * s = D by rfl]
  rw [show 9 * y + 32 + 8 * s = E by rfl]
  rw [hgap]
  field_simp [hy0, hD0, hE0]
  ring

/-- Exact reciprocal increment for one relaxed one-threshold step. -/
theorem oneThresholdBootstrapRelaxedMap_reciprocal_gap_formula
    {B : ℝ} (hB : 4 < B) :
    1 / (oneThresholdBootstrapRelaxedMap B - 4) =
      1 / (B - 4) +
        1 / (9 * (B - 4) + 32 + 8 * oneThresholdRelaxedSqrt B) := by
  rw [oneThresholdBootstrapRelaxedMap_gap_formula_scalar (B := B) hB]
  have hy : 0 < B - 4 := by linarith
  have hs_nonneg : 0 ≤ oneThresholdRelaxedSqrt B :=
    oneThresholdRelaxedSqrt_nonneg B
  exact oneThresholdRelaxed_reciprocal_gap_aux
    (y := B - 4) (s := oneThresholdRelaxedSqrt B) hy hs_nonneg

/-- The relaxed one-threshold map is strictly below the input bound above `4`. -/
theorem oneThresholdBootstrapRelaxedMapBelowSelf_proved :
    OneThresholdBootstrapRelaxedMapBelowSelf := by
  intro B hB
  unfold oneThresholdBootstrapRelaxedMap
  have hmap : oneThresholdBootstrapMap B < B :=
    oneThresholdBootstrapMap_lt_base_of_four_lt (B := B) hB
  linarith

/-- Relaxed one-threshold iterates stay above `4`. -/
theorem oneThresholdBootstrapRelaxedSeq_four_lt_scalar
    {B0 : ℝ} (hB0 : 4 < B0) :
    ∀ n : ℕ, 4 < oneThresholdBootstrapRelaxedSeq B0 n := by
  exact oneThresholdBootstrapRelaxedSeq_above_four
    oneThresholdBootstrapRelaxedMapAboveFour_proved hB0

/-- Relaxed one-threshold iterates are bounded by the initial bound. -/
theorem oneThresholdBootstrapRelaxedSeq_le_initial_scalar
    {B0 : ℝ} (hB0 : 4 < B0) :
    ∀ n : ℕ, oneThresholdBootstrapRelaxedSeq B0 n ≤ B0 := by
  intro n
  induction n with
  | zero =>
      simp [oneThresholdBootstrapRelaxedSeq]
  | succ n ih =>
      have hgt : 4 < oneThresholdBootstrapRelaxedSeq B0 n :=
        oneThresholdBootstrapRelaxedSeq_four_lt_scalar hB0 n
      have hlt : oneThresholdBootstrapRelaxedMap
          (oneThresholdBootstrapRelaxedSeq B0 n) <
            oneThresholdBootstrapRelaxedSeq B0 n :=
        oneThresholdBootstrapRelaxedMapBelowSelf_proved
          (oneThresholdBootstrapRelaxedSeq B0 n) hgt
      simp [oneThresholdBootstrapRelaxedSeq]
      exact le_trans (le_of_lt hlt) ih

/-- Gap positivity for relaxed one-threshold iterates. -/
theorem oneThresholdBootstrapRelaxedSeq_gap_pos_scalar
    {B0 : ℝ} (hB0 : 4 < B0) (n : ℕ) :
    0 < oneThresholdBootstrapRelaxedSeq B0 n - 4 := by
  have h := oneThresholdBootstrapRelaxedSeq_four_lt_scalar hB0 n
  linarith

/-- Gap upper bound by the initial gap for relaxed one-threshold iterates. -/
theorem oneThresholdBootstrapRelaxedSeq_gap_le_initial_scalar
    {B0 : ℝ} (hB0 : 4 < B0) (n : ℕ) :
    oneThresholdBootstrapRelaxedSeq B0 n - 4 ≤ B0 - 4 := by
  have hle := oneThresholdBootstrapRelaxedSeq_le_initial_scalar hB0 n
  linarith

/-- Monotonicity of the square-root term on the range needed by the iterates. -/
theorem oneThresholdRelaxedSqrt_le_of_le_above_four
    {B C : ℝ} (hB : 4 < B) (hBC : B ≤ C) :
    oneThresholdRelaxedSqrt B ≤ oneThresholdRelaxedSqrt C := by
  unfold oneThresholdRelaxedSqrt
  have hrad : (B + 4) * (B - 2) ≤ (C + 4) * (C - 2) := by
    nlinarith
  exact Real.sqrt_le_sqrt hrad

/-- A fixed lower bound for the reciprocal gap increment. -/
theorem oneThresholdBootstrapRelaxedSeq_reciprocal_step_lower_scalar
    {B0 : ℝ} (hB0 : 4 < B0) (n : ℕ) :
    1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0)
      ≤
    1 / (oneThresholdBootstrapRelaxedSeq B0 (n + 1) - 4) -
      1 / (oneThresholdBootstrapRelaxedSeq B0 n - 4) := by
  let Bn := oneThresholdBootstrapRelaxedSeq B0 n
  have hBn_gt : 4 < Bn := oneThresholdBootstrapRelaxedSeq_four_lt_scalar hB0 n
  have hBn_le : Bn ≤ B0 := oneThresholdBootstrapRelaxedSeq_le_initial_scalar hB0 n
  have hs_le : oneThresholdRelaxedSqrt Bn ≤ oneThresholdRelaxedSqrt B0 :=
    oneThresholdRelaxedSqrt_le_of_le_above_four hBn_gt hBn_le
  have hdenBn_pos :
      0 < 9 * (Bn - 4) + 32 + 8 * oneThresholdRelaxedSqrt Bn := by
    have hs_nonneg : 0 ≤ oneThresholdRelaxedSqrt Bn :=
      oneThresholdRelaxedSqrt_nonneg Bn
    nlinarith
  have hden_le :
      9 * (Bn - 4) + 32 + 8 * oneThresholdRelaxedSqrt Bn ≤
        9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0 := by
    nlinarith
  have hrecip :
      1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0) ≤
        1 / (9 * (Bn - 4) + 32 + 8 * oneThresholdRelaxedSqrt Bn) := by
    exact one_div_le_one_div_of_le hdenBn_pos hden_le
  have hformula := oneThresholdBootstrapRelaxedMap_reciprocal_gap_formula
    (B := Bn) hBn_gt
  have hstep_eq :
      1 / (oneThresholdBootstrapRelaxedSeq B0 (n + 1) - 4) -
          1 / (oneThresholdBootstrapRelaxedSeq B0 n - 4)
        = 1 / (9 * (Bn - 4) + 32 + 8 * oneThresholdRelaxedSqrt Bn) := by
    calc
      1 / (oneThresholdBootstrapRelaxedSeq B0 (n + 1) - 4) -
          1 / (oneThresholdBootstrapRelaxedSeq B0 n - 4)
          = 1 / (oneThresholdBootstrapRelaxedMap Bn - 4) -
              1 / (Bn - 4) := by
                simp [oneThresholdBootstrapRelaxedSeq, Bn]
      _ = 1 / (9 * (Bn - 4) + 32 + 8 * oneThresholdRelaxedSqrt Bn) := by
                linarith [hformula]
  rw [hstep_eq]
  exact hrecip

/-- Reciprocal gaps grow at least linearly. -/
theorem oneThresholdBootstrapRelaxedSeq_reciprocal_lower_scalar
    {B0 : ℝ} (hB0 : 4 < B0) :
    ∀ n : ℕ,
      1 / (B0 - 4) + (n : ℝ) *
          (1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0))
        ≤ 1 / (oneThresholdBootstrapRelaxedSeq B0 n - 4) := by
  intro n
  let c : ℝ :=
    1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0)
  induction n with
  | zero =>
      simp [oneThresholdBootstrapRelaxedSeq]
  | succ n ih =>
      have hstep := oneThresholdBootstrapRelaxedSeq_reciprocal_step_lower_scalar
        (B0 := B0) hB0 n
      have hleft :
          1 / (B0 - 4) + ((n + 1 : ℕ) : ℝ) * c =
            (1 / (B0 - 4) + (n : ℝ) * c) + c := by
        norm_num [Nat.cast_add, Nat.cast_one]
        ring_nf
      calc
        1 / (B0 - 4) + ((n + 1 : ℕ) : ℝ) *
            (1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0))
            = (1 / (B0 - 4) + (n : ℝ) * c) + c := by
                simpa [c] using hleft
        _ ≤ 1 / (oneThresholdBootstrapRelaxedSeq B0 n - 4) + c := by
                linarith
        _ ≤ 1 / (oneThresholdBootstrapRelaxedSeq B0 (n + 1) - 4) := by
                dsimp [c]
                linarith

/-- The reciprocal-linear majorant tends to zero. -/
theorem tendsto_oneThresholdRelaxed_reciprocal_linear_majorant
    {B0 : ℝ} (hB0 : 4 < B0) :
    Tendsto
      (fun n : ℕ =>
        1 / (1 / (B0 - 4) + (n : ℝ) *
          (1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0))))
      atTop (nhds 0) := by
  let c : ℝ :=
    1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0)
  have hcpos : 0 < c := by
    dsimp [c]
    have hs_nonneg : 0 ≤ oneThresholdRelaxedSqrt B0 :=
      oneThresholdRelaxedSqrt_nonneg B0
    positivity
  have hn : Tendsto (fun n : ℕ => (n : ℝ)) atTop atTop :=
    tendsto_natCast_atTop_atTop
  have hmul : Tendsto (fun n : ℕ => c * (n : ℝ)) atTop atTop :=
    Filter.Tendsto.const_mul_atTop hcpos hn
  have hden : Tendsto
      (fun n : ℕ => c * (n : ℝ) + 1 / (B0 - 4))
      atTop atTop :=
    Filter.Tendsto.atTop_add hmul tendsto_const_nhds
  have hquot : Tendsto
      (fun n : ℕ =>
        (1 : ℝ) / (c * (n : ℝ) + 1 / (B0 - 4)))
      atTop (nhds 0) :=
    tendsto_const_nhds.div_atTop hden
  simpa [c, mul_comm, add_comm, add_left_comm, add_assoc] using hquot

/-- Relaxed one-threshold gaps are bounded by the reciprocal-linear majorant. -/
theorem oneThresholdBootstrapRelaxedSeq_gap_le_reciprocal_linear_majorant_scalar
    {B0 : ℝ} (hB0 : 4 < B0) :
    ∀ n : ℕ,
      oneThresholdBootstrapRelaxedSeq B0 n - 4
        ≤ 1 / (1 / (B0 - 4) + (n : ℝ) *
          (1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0))) := by
  intro n
  let gap := oneThresholdBootstrapRelaxedSeq B0 n - 4
  let A := 1 / (B0 - 4) + (n : ℝ) *
    (1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0))
  have hgap_pos : 0 < gap := by
    simpa [gap] using oneThresholdBootstrapRelaxedSeq_gap_pos_scalar hB0 n
  have hA_pos : 0 < A := by
    have h0 : 0 < 1 / (B0 - 4) := by positivity
    have hc : 0 ≤ (n : ℝ) *
        (1 / (9 * (B0 - 4) + 32 + 8 * oneThresholdRelaxedSqrt B0)) := by
      have hs_nonneg : 0 ≤ oneThresholdRelaxedSqrt B0 :=
        oneThresholdRelaxedSqrt_nonneg B0
      positivity
    dsimp [A]
    exact add_pos_of_pos_of_nonneg h0 hc
  have hrecip : A ≤ 1 / gap := by
    simpa [A, gap] using
      oneThresholdBootstrapRelaxedSeq_reciprocal_lower_scalar
        (B0 := B0) hB0 n
  have hmul : A * gap ≤ 1 := by
    have h := mul_le_mul_of_nonneg_right hrecip (le_of_lt hgap_pos)
    have hone : (1 / gap) * gap = 1 := by
      field_simp [ne_of_gt hgap_pos]
    exact le_trans h hone.le
  rw [le_div_iff₀ hA_pos]
  simpa [gap, A, mul_comm, mul_left_comm, mul_assoc] using hmul

/-- The gaps of the relaxed one-threshold iterates tend to zero. -/
theorem tendsto_oneThresholdBootstrapRelaxedSeq_gap_zero_scalar
    {B0 : ℝ} (hB0 : 4 < B0) :
    Tendsto
      (fun n : ℕ => oneThresholdBootstrapRelaxedSeq B0 n - 4)
      atTop (nhds 0) := by
  exact squeeze_zero
    (fun n => le_of_lt (oneThresholdBootstrapRelaxedSeq_gap_pos_scalar hB0 n))
    (oneThresholdBootstrapRelaxedSeq_gap_le_reciprocal_linear_majorant_scalar hB0)
    (tendsto_oneThresholdRelaxed_reciprocal_linear_majorant hB0)

/-- The relaxed one-threshold iterates tend to `4`. -/
theorem tendsto_oneThresholdBootstrapRelaxedSeq_scalar
    {B0 : ℝ} (hB0 : 4 < B0) :
    Tendsto (fun n : ℕ => oneThresholdBootstrapRelaxedSeq B0 n)
      atTop (nhds 4) := by
  have hgap := tendsto_oneThresholdBootstrapRelaxedSeq_gap_zero_scalar hB0
  have hadd : Tendsto
      (fun n : ℕ => (oneThresholdBootstrapRelaxedSeq B0 n - 4) + 4)
      atTop (nhds (0 + 4)) :=
    hgap.add tendsto_const_nhds
  convert hadd using 1
  · ext n
    ring
  · norm_num

/-- Closure of the weak scalar convergence predicate used by the final route. -/
theorem oneThresholdBootstrapRelaxedSeqConvergesToFour_proved
    {B0 : ℝ} (hB0 : 4 < B0) :
    OneThresholdBootstrapRelaxedSeqConvergesToFour B0 := by
  intro eps heps
  have htend := tendsto_oneThresholdBootstrapRelaxedSeq_scalar (B0 := B0) hB0
  have hnhds : Set.Iio (4 + eps) ∈ nhds (4 : ℝ) := by
    exact Iio_mem_nhds (by linarith)
  have hev : ∀ᶠ n in atTop,
      oneThresholdBootstrapRelaxedSeq B0 n ∈ Set.Iio (4 + eps) :=
    htend.eventually hnhds
  rcases eventually_atTop.1 hev with ⟨N, hN⟩
  exact ⟨N, hN N le_rfl⟩

/-- The scalar convergence target in the active-log-count route is proved. -/
theorem OneThresholdRelaxedScalarConvergenceTarget_proved :
    OneThresholdRelaxedScalarConvergenceTarget := by
  intro B0 hB0
  exact oneThresholdBootstrapRelaxedSeqConvergesToFour_proved (B0 := B0) hB0

/-- The active-log-count route now only needs the logarithmic-count payload. -/
structure ActiveRelevantLogCountPayloadWithoutScalar : Prop where
  logCountTarget : ClippedCanonicalLiveLossPrefixActiveRelevantLogCountTarget

/-- The scalar convergence proof fills the scalar field of the active-log-count
payload. -/
theorem activeRelevantLogCountFinalPayload_of_logCountPayloadWithoutScalar
    (P : ActiveRelevantLogCountPayloadWithoutScalar) :
    ActiveRelevantLogCountFinalPayload := by
  exact {
    logCountTarget := P.logCountTarget
    scalarConverges := OneThresholdRelaxedScalarConvergenceTarget_proved
  }

/-- Final wrapper after scalar convergence: only the log-count target remains. -/
theorem oneOverPiMeasureAtMost_four_of_activeRelevantLogCountPayloadWithoutScalar
    (P : ActiveRelevantLogCountPayloadWithoutScalar) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_activeRelevantLogCountFinalPayload
    (activeRelevantLogCountFinalPayload_of_logCountPayloadWithoutScalar P)

/-!
# Ratio-active geometric counting reduction

This layer records the pointwise growth facts behind the logarithmic
below-left active-count estimate, and packages the remaining finite
geometric-count theorem as one clean target.  No finite counting theorem is
asserted here.
-/

/-! ## Pointwise multiplicative growth from ratio-activity -/

/-- A convenient growth factor strictly between `1` and `nu - 1` when
`2 < nu`. -/
def endpointRatioActiveGrowthFactor (nu : ℝ) : ℝ := nu / 2

/-- The chosen growth factor is larger than `1` in the range `2 < nu`. -/
theorem one_lt_endpointRatioActiveGrowthFactor_of_two_lt
    {nu : ℝ} (hnu : 2 < nu) :
    1 < endpointRatioActiveGrowthFactor nu := by
  unfold endpointRatioActiveGrowthFactor
  nlinarith

/-- The chosen growth factor is at most `nu - 1` in the range `2 <= nu`. -/
theorem endpointRatioActiveGrowthFactor_le_nu_sub_one_of_two_le
    {nu : ℝ} (hnu : 2 ≤ nu) :
    endpointRatioActiveGrowthFactor nu ≤ nu - 1 := by
  unfold endpointRatioActiveGrowthFactor
  nlinarith

/-- Generic version: if `rho <= nu - 1`, then ratio-activity gives
`rho * X j <= X (j + 1)`. -/
theorem endpointRatioActiveIndex_factor_mul_le_succ
    {nu rho : ℝ} {X : ℕ → ℝ} {j : ℕ}
    (hX_nonneg : 0 ≤ X j)
    (hrho : rho ≤ nu - 1)
    (hactive : EndpointRatioActiveIndex nu X j) :
    rho * X j ≤ X (j + 1) := by
  unfold EndpointRatioActiveIndex at hactive
  have hmul : rho * X j ≤ (nu - 1) * X j := by
    exact mul_le_mul_of_nonneg_right hrho hX_nonneg
  exact le_trans hmul hactive

/-- In the range `2 < nu`, the fixed factor `nu / 2` gives multiplicative
growth at every ratio-active index. -/
theorem endpointRatioActiveIndex_growthFactor_mul_le_succ
    {nu : ℝ} {X : ℕ → ℝ} {j : ℕ}
    (hnu : 2 < nu)
    (hX_nonneg : 0 ≤ X j)
    (hactive : EndpointRatioActiveIndex nu X j) :
    endpointRatioActiveGrowthFactor nu * X j ≤ X (j + 1) := by
  exact endpointRatioActiveIndex_factor_mul_le_succ
    (nu := nu) (rho := endpointRatioActiveGrowthFactor nu)
    (X := X) (j := j)
    hX_nonneg
    (endpointRatioActiveGrowthFactor_le_nu_sub_one_of_two_le
      (nu := nu) (le_of_lt hnu))
    hactive

/-- If `i < j`, monotonicity propagates the active growth at `i` to `X j`. -/
theorem endpointRatioActiveIndex_growthFactor_mul_le_later
    {nu : ℝ} {X : ℕ → ℝ} {i j : ℕ}
    (hnu : 2 < nu)
    (hX_nonneg : 0 ≤ X i)
    (hmono : Monotone X)
    (hactive : EndpointRatioActiveIndex nu X i)
    (hij : i < j) :
    endpointRatioActiveGrowthFactor nu * X i ≤ X j := by
  have hsucc : endpointRatioActiveGrowthFactor nu * X i ≤ X (i + 1) :=
    endpointRatioActiveIndex_growthFactor_mul_le_succ
      (nu := nu) (X := X) (j := i) hnu hX_nonneg hactive
  have hle : X (i + 1) ≤ X j := by
    exact hmono (Nat.succ_le_of_lt hij)
  exact le_trans hsucc hle

/-- The dyadic-looking special case: if `3 <= nu`, then a ratio-active index
at least doubles `X`. -/
theorem endpointRatioActiveIndex_two_mul_le_succ_of_three_le
    {nu : ℝ} {X : ℕ → ℝ} {j : ℕ}
    (hnu : 3 ≤ nu)
    (hX_nonneg : 0 ≤ X j)
    (hactive : EndpointRatioActiveIndex nu X j) :
    2 * X j ≤ X (j + 1) := by
  exact endpointRatioActiveIndex_factor_mul_le_succ
    (nu := nu) (rho := 2) (X := X) (j := j)
    hX_nonneg (by linarith) hactive

/-- The doubling special case propagated to any later index. -/
theorem endpointRatioActiveIndex_two_mul_le_later_of_three_le
    {nu : ℝ} {X : ℕ → ℝ} {i j : ℕ}
    (hnu : 3 ≤ nu)
    (hX_nonneg : 0 ≤ X i)
    (hmono : Monotone X)
    (hactive : EndpointRatioActiveIndex nu X i)
    (hij : i < j) :
    2 * X i ≤ X j := by
  have hsucc : 2 * X i ≤ X (i + 1) :=
    endpointRatioActiveIndex_two_mul_le_succ_of_three_le
      (nu := nu) (X := X) (j := i) hnu hX_nonneg hactive
  have hle : X (i + 1) ≤ X j := hmono (Nat.succ_le_of_lt hij)
  exact le_trans hsucc hle

/-! ## Below-left activity gives an explicit `X_j = O(M)` bound -/

/-- A below-left active index has `X_j` bounded linearly by the cutoff. -/
theorem endpointRatioActiveBelowLeftIndex_X_le_cutoff
    {nu : ℝ} {X : ℕ → ℝ} {M j : ℕ}
    (hnu : 0 < nu)
    (hidx : EndpointRatioActiveBelowLeftIndex nu X M j) :
    X j ≤ ramanujanKappa * (M : ℝ) / nu := by
  rcases hidx with ⟨_hactive, hleft⟩
  unfold endpointSubwindowIntervalLeft at hleft
  have hkpos : 0 < ramanujanKappa := ramanujanKappa_pos
  have hmul : nu * X j ≤ ramanujanKappa * (M : ℝ) := by
    have h :
        ramanujanKappa * (nu * X j / ramanujanKappa) ≤
          ramanujanKappa * (M : ℝ) :=
      mul_le_mul_of_nonneg_left hleft (le_of_lt hkpos)
    have hk_ne : ramanujanKappa ≠ 0 := ne_of_gt hkpos
    have hcancel :
        ramanujanKappa * (nu * X j / ramanujanKappa) = nu * X j := by
      field_simp [hk_ne]
    simpa [hcancel] using h
  have hdiv :
      (nu * X j) / nu ≤ (ramanujanKappa * (M : ℝ)) / nu :=
    div_le_div_of_nonneg_right hmul (le_of_lt hnu)
  have hnu_ne : nu ≠ 0 := ne_of_gt hnu
  have hcancel :
      (nu * X j) / nu = X j := by
    field_simp [hnu_ne]
  simpa [hcancel, mul_comm, mul_left_comm, mul_assoc] using hdiv

/-- Two below-left active indices with `i < j` are separated multiplicatively in
`X`, with the factor `nu / 2`. -/
theorem endpointRatioActiveBelowLeftIndex_growthFactor_mul_le_later
    {nu : ℝ} {X : ℕ → ℝ} {M i j : ℕ}
    (hnu : 2 < nu)
    (hX_pos : ∀ n : ℕ, 0 < X n)
    (hmono : Monotone X)
    (hi : EndpointRatioActiveBelowLeftIndex nu X M i)
    (_hj : EndpointRatioActiveBelowLeftIndex nu X M j)
    (hij : i < j) :
    endpointRatioActiveGrowthFactor nu * X i ≤ X j := by
  exact endpointRatioActiveIndex_growthFactor_mul_le_later
    (nu := nu) (X := X) (i := i) (j := j)
    hnu (le_of_lt (hX_pos i)) hmono hi.1 hij

/-! ## The remaining finite geometric-count target -/

/-- The finite geometric-count theorem needed for the active-count route.

Mathematically this should follow from the pointwise lemmas above: in the range
`2 < nu`, active indices grow by the fixed factor `nu / 2 > 1`, while the
below-left condition gives `X_j <= O(M)`.  Hence the number of below-left active
indices is `O(log M)`. -/
def EndpointRatioActiveBelowLeftGeometricCountTarget : Prop :=
  ∀ (nu : ℝ) (X : ℕ → ℝ),
    2 < nu →
    (∀ j : ℕ, 0 < X j) →
    Monotone X →
      Nonempty (EndpointRatioActiveBelowLeftLogCountData nu X)

/-! ## Replace the log-count field by the geometric-count target -/

/-- Generic active-relevance data in which the log-count field is replaced by
positivity, monotonicity, and the finite geometric-count target. -/
structure EndpointSubwindowCutoffPrefixActiveRelevantGeometricCountData
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Type where
  K : ℕ → ℕ
  scaleErr : ℕ → ℝ
  LiveErr : ℕ → ℝ
  nu_pos : 0 < nu
  nu_gt_two : 2 < nu
  X_pos : ∀ j : ℕ, 0 < X j
  X_mono : Monotone X
  activeWitness : EndpointActiveRelevantWitnessExistence nu X
  lowActiveRelevantForcesVisible :
    EndpointLowRelevantForcesVisible nu x X H V (EndpointActiveRelevant nu X)
  delta_nonneg : 0 ≤ delta
  K_tendsto : Tendsto K atTop atTop
  relevantIndexLtPrefix :
    CutoffRelevantIndexLtPrefix K
      (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X))
  indexLeCutoff : CutoffRelevantIndexLeCutoff
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X))
  scaleBound : ∀ᶠ M : ℕ in atTop,
    endpointRatioScale X (K M) / ramanujanKappa
      ≤ ((M : ℝ) + 1) + scaleErr M
  scaleErrSublinear : EventuallySublinearCountError scaleErr
  liveErrSublinear : EventuallySublinearCountError LiveErr
  liveBudget : CutoffLiveBoundaryCountBudget
    (CutoffPrefixLiveAt nu x X K (EndpointActiveRelevant nu X)) eps LiveErr

/-- The geometric-count target supplies the log-count field. -/
def endpointSubwindowCutoffPrefixActiveRelevantLogCountData_of_geometricCountData
    (hgeom : EndpointRatioActiveBelowLeftGeometricCountTarget)
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (D : EndpointSubwindowCutoffPrefixActiveRelevantGeometricCountData
      X H V nu x delta eps) :
    EndpointSubwindowCutoffPrefixActiveRelevantLogCountData
      X H V nu x delta eps := {
  K := D.K
  scaleErr := D.scaleErr
  LiveErr := D.LiveErr
  nu_pos := D.nu_pos
  activeWitness := D.activeWitness
  lowActiveRelevantForcesVisible := D.lowActiveRelevantForcesVisible
