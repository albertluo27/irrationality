/-!
# Endpoint-subwindow interval-budget reduction

This layer replaces the abstract endpoint-subwindow density control field by a
standard real-interval counting package.
-/

/-! ## Real intervals representing endpoint subwindows -/

/-- Left endpoint, in shell-index scale, of the `j`th endpoint subwindow. -/
def endpointSubwindowIntervalLeft
    (nu : ℝ) (X : ℕ → ℝ) (j : ℕ) : ℝ :=
  nu * X j / ramanujanKappa

/-- Right endpoint, in shell-index scale, of the `j`th endpoint subwindow. -/
def endpointSubwindowIntervalRight
    (X : ℕ → ℝ) (j : ℕ) : ℝ :=
  endpointRatioScale X j / ramanujanKappa

/-- The natural upper-bound condition that a relevance relation must provide.

It says: if block `j` is relevant for shell `m`, then the Ramanujan denominator
cap at shell `m` lies below the active endpoint `(X_j + X_{j+1}) / nu`. -/
def EndpointSubwindowRelevanceUpperBound
    (X : ℕ → ℝ) (nu : ℝ) (Relevant : ℕ → ℕ → Prop) : Prop :=
  ∀ m j : ℕ,
    Relevant m j →
      ramanujanDenominatorCapLog nu m ≤ endpointRatioScale X j / nu

/-- The denominator-cap definition rewritten using the existing Ramanujan
slope `ramanujanKappa = 6 log 2`. -/
theorem ramanujanDenominatorCapLog_eq_kappa_div
    (nu : ℝ) (m : ℕ) :
    ramanujanDenominatorCapLog nu m = ramanujanKappa / nu * (m : ℝ) := by
  unfold ramanujanDenominatorCapLog ramanujanKappa spikeKappa
  ring

/-- A concrete endpoint subwindow lies inside its real interval once the
relevance relation supplies the active upper endpoint. -/
theorem endpointSubwindow_mem_realInterval_of_relevanceUpper
    {X : ℕ → ℝ} {nu x : ℝ} {Relevant : ℕ → ℕ → Prop}
    (hnu : 0 < nu)
    (hRelUpper : EndpointSubwindowRelevanceUpperBound X nu Relevant)
    {m j : ℕ}
    (hRel : Relevant m j)
    (hSub : EndpointSubwindow nu x X j m) :
    NatInRealInterval m
      (endpointSubwindowIntervalLeft nu X j)
      (endpointSubwindowIntervalRight X j) := by
  rcases hSub with ⟨_hleftCap, hXleCap⟩
  have hκ : 0 < ramanujanKappa := ramanujanKappa_pos
  have hcap : ramanujanDenominatorCapLog nu m = ramanujanKappa / nu * (m : ℝ) :=
    ramanujanDenominatorCapLog_eq_kappa_div nu m
  have hleft : endpointSubwindowIntervalLeft nu X j ≤ (m : ℝ) := by
    unfold endpointSubwindowIntervalLeft
    rw [hcap] at hXleCap
    have hmul : nu * X j ≤ nu * (ramanujanKappa / nu * (m : ℝ)) :=
      mul_le_mul_of_nonneg_left hXleCap (le_of_lt hnu)
    have hright : nu * (ramanujanKappa / nu * (m : ℝ)) =
        ramanujanKappa * (m : ℝ) := by
      field_simp [ne_of_gt hnu]
    rw [hright] at hmul
    exact (div_le_iff₀ hκ).mpr
      (by simpa [mul_comm, mul_left_comm, mul_assoc] using hmul)
  have hright : (m : ℝ) ≤ endpointSubwindowIntervalRight X j := by
    have hUpper := hRelUpper m j hRel
    rw [hcap] at hUpper
    unfold endpointSubwindowIntervalRight
    have hmul : nu * (ramanujanKappa / nu * (m : ℝ)) ≤
        nu * (endpointRatioScale X j / nu) :=
      mul_le_mul_of_nonneg_left hUpper (le_of_lt hnu)
    have hleftsimp : nu * (ramanujanKappa / nu * (m : ℝ)) =
        ramanujanKappa * (m : ℝ) := by
      field_simp [ne_of_gt hnu]
    have hrightsimp : nu * (endpointRatioScale X j / nu) =
        endpointRatioScale X j := by
      field_simp [ne_of_gt hnu]
    rw [hleftsimp, hrightsimp] at hmul
    exact (le_div_iff₀ hκ).mpr
      (by simpa [mul_comm, mul_left_comm, mul_assoc] using hmul)
  exact ⟨hleft, hright⟩

/-- The endpoint-subwindow union is pointwise dominated by the corresponding
real interval union. -/
theorem endpointSubwindowUnion_dominated_realIntervalUnion
    {X : ℕ → ℝ} {nu x : ℝ} {Relevant : ℕ → ℕ → Prop}
    (hnu : 0 < nu)
    (hRelUpper : EndpointSubwindowRelevanceUpperBound X nu Relevant) :
    Criteria.dominated
      (EndpointSubwindowUnion nu x X Relevant)
      (NatInRealIntervalUnion
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)) := by
  intro m hm
  rcases hm with ⟨j, hRel, hSub⟩
  exact ⟨j, endpointSubwindow_mem_realInterval_of_relevanceUpper
    (X := X) (nu := nu) (x := x) (Relevant := Relevant)
    hnu hRelUpper hRel hSub⟩

/-! ## Interval-budget proof of subwindow-union control -/

/-- Interval-budget data sufficient to prove endpoint-subwindow union control. -/
structure EndpointSubwindowIntervalBudgetData
    (X : ℕ → ℝ) (nu x delta : ℝ)
    (Relevant : ℕ → ℕ → Prop) : Type where
  Err : ℕ → ℝ
  nu_pos : 0 < nu
  relevanceUpper : EndpointSubwindowRelevanceUpperBound X nu Relevant
  activeCover : ActiveShadowIndicesCoverUnion
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
  activeSublinear : ActiveShadowCountSublinear
    (endpointSubwindowIntervalLeft nu X)
  errSublinear : EventuallySublinearCountError Err
  lengthBudget :
    ClippedEndpointWeightedAverageBound X nu delta →
      RealShadowLengthBudget
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        delta Err

/-- Endpoint-subwindow interval-budget data proves the abstract subwindow-union
control field. -/
theorem clippedEndpointSubwindowUnionControls_of_intervalBudgetData
    {X : ℕ → ℝ} {nu x delta : ℝ} {Relevant : ℕ → ℕ → Prop}
    (D : EndpointSubwindowIntervalBudgetData X nu x delta Relevant) :
    ClippedEndpointSubwindowUnionControls X nu x delta Relevant := by
  intro havg
  have hIntervalDensity : UpperNatDensityAtMost
      (NatInRealIntervalUnion
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)) delta :=
    upperDensityAtMost_of_realShadowLengthBudget
      (S := endpointSubwindowIntervalLeft nu X)
      (E := endpointSubwindowIntervalRight X)
      (δ := delta) (Err := D.Err)
      D.activeCover (D.lengthBudget havg) D.activeSublinear D.errSublinear
  exact Criteria.upperDensityAtMost_mono
    (endpointSubwindowUnion_dominated_realIntervalUnion
      (X := X) (nu := nu) (x := x) (Relevant := Relevant)
      D.nu_pos D.relevanceUpper)
    hIntervalDensity

