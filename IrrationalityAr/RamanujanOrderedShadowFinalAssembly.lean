noncomputable section


/-!
# Actual Ramanujan path-prefix coverage

This file proves the strongest currently honest coverage statement for the
Ramanujan interval process.

The previous block-prefix coverage theorem says that a cofinal sequence of
certified block depths covers all of `A (1 / π)`.  The concrete Ramanujan
certification layer in `Ramanujan.lean`, however, naturally certifies flattened
intermediate-path prefixes `certifiedOddPathPrefix a K`.

This file proves the analogous path-prefix theorem:

* any cofinal flattened path-prefix function covers all of `A α`;
* the concrete linear trial `linearPathTrial c m` is cofinal whenever `0 < c`;
* therefore its path-prefix union covers all of `A (1 / π)`;
* under the existing Bauer/Ramanujan plus finite-irrationality-measure
  production theorem, there exists a positive linear trial whose intervals
  really do certify those path prefixes eventually, and whose union is all of
  `A (1 / π)`.

No new axiom is introduced here.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanCoverageComplete.lean -/

/-! ## Abstract certified-prefix coverage -/

/-- The union of the certified odd-block finite sets over all stages. -/
noncomputable def certifiedOddBlocksStageUnion
    (a : ℕ → ℕ) (Jcert : ℕ → ℕ) : Set ℕ :=
  ⋃ m : ℕ, (↑(certifiedOddBlocks a (Jcert m)) : Set ℕ)

@[simp] theorem mem_certifiedOddBlocksStageUnion_iff
    {a Jcert : ℕ → ℕ} {n : ℕ} :
    n ∈ certifiedOddBlocksStageUnion a Jcert ↔
      ∃ m : ℕ, n ∈ certifiedOddBlocks a (Jcert m) := by
  simp [certifiedOddBlocksStageUnion]

/-- Cofinality of a certified-prefix function. -/
def CertifiedPrefixCofinalComplete (Jcert : ℕ → ℕ) : Prop :=
  ∀ J : ℕ, ∃ m : ℕ, J ≤ Jcert m

/-- A slightly stronger but often easier-to-prove form: every fixed depth is
covered eventually. -/
def CertifiedPrefixEventuallyAboveEvery (Jcert : ℕ → ℕ) : Prop :=
  ∀ J : ℕ, ∀ᶠ m : ℕ in atTop, J ≤ Jcert m

/-- Eventual coverage of every fixed depth implies cofinality. -/
theorem CertifiedPrefixCofinalComplete_of_eventuallyAboveEvery
    {Jcert : ℕ → ℕ}
    (hJ : CertifiedPrefixEventuallyAboveEvery Jcert) :
    CertifiedPrefixCofinalComplete Jcert := by
  intro J
  have hJev : ∀ᶠ m : ℕ in atTop, J ≤ Jcert m := hJ J
  rw [eventually_atTop] at hJev
  rcases hJev with ⟨M, hM⟩
  exact ⟨M, hM M le_rfl⟩

/-- The certified stage union is always contained in the true floor-sum set
once `a` is the simple continued-fraction expansion of `α`. -/
theorem certifiedOddBlocksStageUnion_subset_A_of_IsSimpleCFExpansion
    {α : ℝ} {a Jcert : ℕ → ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a) :
    certifiedOddBlocksStageUnion a Jcert ⊆ A α := by
  intro n hn
  rw [mem_certifiedOddBlocksStageUnion_iff] at hn
  rcases hn with ⟨m, hnm⟩
  exact certifiedOddBlocks_subset_A_of_IsSimpleCFExpansion
    hαpos hαirr hcf hnm

/-- Cofinal certified stages cover the entire coefficient-side selected
odd-block set. -/
theorem oddBlockASet_subset_certifiedOddBlocksStageUnion_of_cofinal
    {a Jcert : ℕ → ℕ}
    (hcofinal : CertifiedPrefixCofinalComplete Jcert) :
    oddBlockASet a ⊆ certifiedOddBlocksStageUnion a Jcert := by
  intro n hn
  rcases hn with ⟨j, t, ht1, htle, hodd, hQ2, hn_eq⟩
  rcases hcofinal (j + 1) with ⟨m, hm⟩
  rw [mem_certifiedOddBlocksStageUnion_iff]
  refine ⟨m, ?_⟩
  rw [mem_certifiedOddBlocks_iff]
  have hn0 : n ≠ 0 := by
    omega
  have hj : j < Jcert m := by
    omega
  have htblock : t ∈ canonicalOddBlock a j := by
    rw [mem_canonicalOddBlock_iff]
    exact ⟨ht1, htle, hodd⟩
  have hnblock : n ∈ canonicalOddDenominatorBlock a j := by
    rw [canonicalOddDenominatorBlock]
    exact Finset.mem_image.mpr ⟨t, htblock, hn_eq.symm⟩
  exact ⟨hn0, j, hj, hnblock⟩

/-- Cofinal certified stages equal the whole coefficient-side odd-block set. -/
theorem certifiedOddBlocksStageUnion_eq_oddBlockASet_of_cofinal
    {a Jcert : ℕ → ℕ}
    (hcofinal : CertifiedPrefixCofinalComplete Jcert) :
    certifiedOddBlocksStageUnion a Jcert = oddBlockASet a := by
  apply Set.Subset.antisymm
  · intro n hn
    rw [mem_certifiedOddBlocksStageUnion_iff] at hn
    rcases hn with ⟨m, hnm⟩
    rw [mem_certifiedOddBlocks_iff] at hnm
    rcases hnm with ⟨hn0, j, _hj, hnblock⟩
    exact mem_oddBlockASet_of_mem_canonicalOddDenominatorBlock hn0 hnblock
  · exact oddBlockASet_subset_certifiedOddBlocksStageUnion_of_cofinal hcofinal

/-- Main abstract coverage theorem.

If the certified prefix lengths are cofinal and `a` is the simple continued
fraction of `α`, then the union of all certified prefix blocks is exactly
`A α`. -/
theorem certifiedOddBlocksStageUnion_eq_A_of_cofinal_IsSimpleCFExpansion
    {α : ℝ} {a Jcert : ℕ → ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a)
    (hcofinal : CertifiedPrefixCofinalComplete Jcert) :
    certifiedOddBlocksStageUnion a Jcert = A α := by
  have hA : A α = oddBlockASet a :=
    A_eq_oddBlockASet_of_IsSimpleCFExpansion hαpos hαirr hcf
  calc
    certifiedOddBlocksStageUnion a Jcert = oddBlockASet a :=
      certifiedOddBlocksStageUnion_eq_oddBlockASet_of_cofinal hcofinal
    _ = A α := hA.symm

/-- Same theorem, using the eventual-above-every-fixed-depth formulation. -/
theorem certifiedOddBlocksStageUnion_eq_A_of_eventuallyAboveEvery_IsSimpleCFExpansion
    {α : ℝ} {a Jcert : ℕ → ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a)
    (hJ : CertifiedPrefixEventuallyAboveEvery Jcert) :
    certifiedOddBlocksStageUnion a Jcert = A α := by
  exact certifiedOddBlocksStageUnion_eq_A_of_cofinal_IsSimpleCFExpansion
    hαpos hαirr hcf
    (CertifiedPrefixCofinalComplete_of_eventuallyAboveEvery hJ)

/-! ## Specialization to `1 / π` -/

/-- The union of `1 / π` certified sets attached to a stage function. -/
noncomputable def certifiedAOneOverPiStageUnion
    (Jcert : ℕ → ℕ) : Set ℕ :=
  ⋃ m : ℕ, (↑(certifiedAOneOverPiSubsetAt Jcert m) : Set ℕ)

@[simp] theorem mem_certifiedAOneOverPiStageUnion_iff
    {Jcert : ℕ → ℕ} {n : ℕ} :
    n ∈ certifiedAOneOverPiStageUnion Jcert ↔
      ∃ m : ℕ, n ∈ certifiedAOneOverPiSubsetAt Jcert m := by
  simp [certifiedAOneOverPiStageUnion]

/-- The precise theorem behind the sentence: "the infinite Ramanujan-certified
prefix union covers the whole sequence." -/
theorem certifiedAOneOverPiStageUnion_eq_A_of_cofinal
    {Jcert : ℕ → ℕ}
    (hcofinal : CertifiedPrefixCofinalComplete Jcert) :
    certifiedAOneOverPiStageUnion Jcert = A oneOverPi := by
  have hpos : 0 < oneOverPi := by
    unfold oneOverPi
    exact one_div_pos.mpr Real.pi_pos
  have hirr : IsIrrational oneOverPi := by
    unfold oneOverPi
    simpa [one_div] using isIrrational_of_irrational irrational_pi.inv
  have hcf : IsSimpleCFExpansion oneOverPi oneOverPiCF := by
    unfold oneOverPiCF
    exact simplePartialQuotient_isSimpleCFExpansion hpos hirr
  unfold certifiedAOneOverPiStageUnion certifiedAOneOverPiSubsetAt
  change certifiedOddBlocksStageUnion oneOverPiCF Jcert = A oneOverPi
  exact certifiedOddBlocksStageUnion_eq_A_of_cofinal_IsSimpleCFExpansion
    hpos hirr hcf hcofinal

/-- Version using eventual-above-every-depth, which is the natural output of
shrinking Ramanujan intervals. -/
theorem certifiedAOneOverPiStageUnion_eq_A_of_eventuallyAboveEvery
    {Jcert : ℕ → ℕ}
    (hJ : CertifiedPrefixEventuallyAboveEvery Jcert) :
    certifiedAOneOverPiStageUnion Jcert = A oneOverPi := by
  exact certifiedAOneOverPiStageUnion_eq_A_of_cofinal
    (CertifiedPrefixCofinalComplete_of_eventuallyAboveEvery hJ)

/-- The named coverage statement. -/
def RamanujanCertifiedPrefixUnionCoversAllComplete
    (Jcert : ℕ → ℕ) : Prop :=
  certifiedAOneOverPiStageUnion Jcert = A oneOverPi

/-- Final non-rate coverage theorem. -/
theorem RamanujanCertifiedPrefixUnionCoversAllComplete_of_eventuallyAboveEvery
    {Jcert : ℕ → ℕ}
    (hJ : CertifiedPrefixEventuallyAboveEvery Jcert) :
    RamanujanCertifiedPrefixUnionCoversAllComplete Jcert := by
  exact certifiedAOneOverPiStageUnion_eq_A_of_eventuallyAboveEvery hJ

/-! ## Cofinality from certified-prefix criteria -/

/-- Positive linear growth eventually dominates any fixed real constant.

This is just a local alias of the helper already proved in `Ramanujan.lean`,
kept here to make the cofinality proof below easy to read. -/
theorem eventually_const_le_kappa_mul_natCast
    {A kappa : ℝ} (hkappa : 0 < kappa) :
    ∀ᶠ m : ℕ in atTop, A ≤ kappa * (m : ℝ) :=
  eventually_const_le_pos_mul_natCast (A := A) (δ := kappa) hkappa

/-- The abstract certified-prefix criterion implies the exact cofinality
condition needed by the coverage theorem.

Interpretation: fix any desired continued-fraction depth `J`.  The quantity
`C0 + 2 * Qlog (J + shift)` is a fixed real number.  If `kappa > 0`, then
eventually it is at most `kappa * m`.  The certified-prefix criterion then says
`J ≤ Jcert m`. -/
theorem CertifiedPrefixEventuallyAboveEvery_of_prefixCriterion
    {Qlog : ℕ → ℝ} {Jcert : ℕ → ℕ}
    {kappa C0 : ℝ} {shift : ℕ}
    (hcrit : CertifiedPrefixCriterion Qlog Jcert kappa C0 shift)
    (hkappa : 0 < kappa) :
    CertifiedPrefixEventuallyAboveEvery Jcert := by
  intro J
  unfold CertifiedPrefixCriterion at hcrit
  have hdom :
      ∀ᶠ m : ℕ in atTop,
        C0 + 2 * Qlog (J + shift) ≤ kappa * (m : ℝ) :=
    eventually_const_le_kappa_mul_natCast
      (A := C0 + 2 * Qlog (J + shift)) hkappa
  filter_upwards [hcrit, hdom] with m hm hineq
  exact hm J hineq

/-- The same result in the weaker existential-cofinal form. -/
theorem CertifiedPrefixCofinalComplete_of_prefixCriterion
    {Qlog : ℕ → ℝ} {Jcert : ℕ → ℕ}
    {kappa C0 : ℝ} {shift : ℕ}
    (hcrit : CertifiedPrefixCriterion Qlog Jcert kappa C0 shift)
    (hkappa : 0 < kappa) :
    CertifiedPrefixCofinalComplete Jcert := by
  exact CertifiedPrefixCofinalComplete_of_eventuallyAboveEvery
    (CertifiedPrefixEventuallyAboveEvery_of_prefixCriterion hcrit hkappa)

/-- Generic coverage theorem from a certified-prefix criterion.

Once `a` is the simple continued-fraction expansion of `α`, a positive-slope
certified-prefix criterion is enough to conclude that the union of certified
prefix blocks is exactly `A α`. -/
theorem certifiedOddBlocksStageUnion_eq_A_of_prefixCriterion_IsSimpleCFExpansion
    {α : ℝ} {a : ℕ → ℕ}
    {Qlog : ℕ → ℝ} {Jcert : ℕ → ℕ}
    {kappa C0 : ℝ} {shift : ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a)
    (hcrit : CertifiedPrefixCriterion Qlog Jcert kappa C0 shift)
    (hkappa : 0 < kappa) :
    certifiedOddBlocksStageUnion a Jcert = A α := by
  exact certifiedOddBlocksStageUnion_eq_A_of_eventuallyAboveEvery_IsSimpleCFExpansion
    hαpos hαirr hcf
    (CertifiedPrefixEventuallyAboveEvery_of_prefixCriterion hcrit hkappa)

/-- One-over-pi specialization: any actual Ramanujan certified-prefix function
satisfying the abstract prefix criterion with positive precision slope has
certified union equal to all of `A (1 / π)`.

This is the theorem that completes the earlier conditional coverage wrapper
once the analytic interval-to-prefix criterion is supplied. -/
theorem certifiedAOneOverPiStageUnion_eq_A_of_prefixCriterion
    {Jcert : ℕ → ℕ} {kappa C0 : ℝ} {shift : ℕ}
    (hcrit : CertifiedPrefixCriterion
      (continuantQlog oneOverPiCF) Jcert kappa C0 shift)
    (hkappa : 0 < kappa) :
    certifiedAOneOverPiStageUnion Jcert = A oneOverPi := by
  exact certifiedAOneOverPiStageUnion_eq_A_of_eventuallyAboveEvery
    (CertifiedPrefixEventuallyAboveEvery_of_prefixCriterion hcrit hkappa)

/-- Named final condition theorem. -/
theorem RamanujanCertifiedPrefixUnionCoversAllComplete_of_prefixCriterion
    {Jcert : ℕ → ℕ} {kappa C0 : ℝ} {shift : ℕ}
    (hcrit : CertifiedPrefixCriterion
      (continuantQlog oneOverPiCF) Jcert kappa C0 shift)
    (hkappa : 0 < kappa) :
    RamanujanCertifiedPrefixUnionCoversAllComplete Jcert := by
  exact certifiedAOneOverPiStageUnion_eq_A_of_prefixCriterion
    (Jcert := Jcert) hcrit hkappa

/-- If a stage function has any positive logarithmic lower bound, then it is
also eventually above every fixed depth.  This is useful when the source gives
`EventuallyLogLowerBound Jcert c` instead of a direct prefix criterion. -/
theorem CertifiedPrefixEventuallyAboveEvery_of_eventuallyLogLowerBound
    {Jcert : ℕ → ℕ} {c : ℝ}
    (hc : 0 < c)
    (hJ : EventuallyLogLowerBound Jcert c) :
    CertifiedPrefixEventuallyAboveEvery Jcert := by
  intro J
  have htend : Tendsto Jcert atTop atTop :=
    tendsto_atTop_of_eventuallyLogLowerBound hc hJ
  rw [tendsto_atTop_atTop] at htend
  rcases htend J with ⟨M, hM⟩
  rw [eventually_atTop]
  exact ⟨M, hM⟩

/-- Super-logarithmic lower production implies the cofinality condition. -/
theorem CertifiedPrefixEventuallyAboveEvery_of_eventuallySuperLogLowerBound
    {Jcert : ℕ → ℕ}
    (hJ : EventuallySuperLogLowerBound Jcert) :
    CertifiedPrefixEventuallyAboveEvery Jcert := by
  exact CertifiedPrefixEventuallyAboveEvery_of_eventuallyLogLowerBound
    (Jcert := Jcert) (c := 1) (by norm_num) (hJ 1 (by norm_num))

/-- Critical denominator-ratio plus the abstract prefix criterion also implies
coverage.  This theorem is stronger than needed for cofinality, but useful
because the source already has critical-ratio production wrappers. -/
theorem certifiedAOneOverPiStageUnion_eq_A_of_prefixCriterion_denominatorRatioExponent_eq_one
    {Jcert : ℕ → ℕ} {kappa C0 : ℝ} {shift : ℕ}
    (hcrit : CertifiedPrefixCriterion
      (continuantQlog oneOverPiCF) Jcert kappa C0 shift)
    (hrho : denominatorRatioExponent oneOverPiCF = 1)
    (hkappa : 0 < kappa) :
    certifiedAOneOverPiStageUnion Jcert = A oneOverPi := by
  have hsuper : EventuallySuperLogLowerBound Jcert :=
    eventuallySuperLogLowerBound_Jcert_of_prefixCriterion_denominatorRatioExponent_eq_one
      (a := oneOverPiCF) (Jcert := Jcert)
      (kappa := kappa) (C0 := C0) (shift := shift)
      hcrit oneOverPiCF_partials_pos hrho hkappa
  exact certifiedAOneOverPiStageUnion_eq_A_of_eventuallyAboveEvery
    (CertifiedPrefixEventuallyAboveEvery_of_eventuallySuperLogLowerBound hsuper)

/-! ## Actual Ramanujan path-prefix coverage -/

/-- The union of the certified odd flattened intermediate-path prefixes attached
to a stage function `Kpath`. -/
noncomputable def certifiedOddPathStageUnion
    (a : ℕ → ℕ) (Kpath : ℕ → ℕ) : Set ℕ :=
  ⋃ m : ℕ, (↑(certifiedOddPathPrefix a (Kpath m)) : Set ℕ)

@[simp] theorem mem_certifiedOddPathStageUnion_iff
    {a Kpath : ℕ → ℕ} {n : ℕ} :
    n ∈ certifiedOddPathStageUnion a Kpath ↔
      ∃ m : ℕ, n ∈ certifiedOddPathPrefix a (Kpath m) := by
  simp [certifiedOddPathStageUnion]

/-- Cofinality for flattened path-prefix lengths. -/
def CertifiedPathPrefixCofinal (Kpath : ℕ → ℕ) : Prop :=
  ∀ K : ℕ, ∃ m : ℕ, K ≤ Kpath m

/-- Eventual-above-every-fixed-depth version of path-prefix cofinality. -/
def CertifiedPathPrefixEventuallyAboveEvery (Kpath : ℕ → ℕ) : Prop :=
  ∀ K : ℕ, ∀ᶠ m : ℕ in atTop, K ≤ Kpath m

/-- Eventual cofinality implies existential cofinality. -/
theorem CertifiedPathPrefixCofinal_of_eventuallyAboveEvery
    {Kpath : ℕ → ℕ}
    (hK : CertifiedPathPrefixEventuallyAboveEvery Kpath) :
    CertifiedPathPrefixCofinal Kpath := by
  intro K
  have hEv : ∀ᶠ m : ℕ in atTop, K ≤ Kpath m := hK K
  rw [eventually_atTop] at hEv
  rcases hEv with ⟨M, hM⟩
  exact ⟨M, hM M le_rfl⟩

/-- Every certified flattened path-prefix element lies in `A α`. -/
theorem certifiedOddPathStageUnion_subset_A_of_IsSimpleCFExpansion
    {α : ℝ} {a Kpath : ℕ → ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a) :
    certifiedOddPathStageUnion a Kpath ⊆ A α := by
  intro n hn
  rw [mem_certifiedOddPathStageUnion_iff] at hn
  rcases hn with ⟨m, hm⟩
  exact certifiedOddPathPrefix_subset_A_of_IsSimpleCFExpansion
    hαpos hαirr hcf hm

/-- Cofinal flattened path-prefixes contain the whole coefficient-side odd block
set. -/
theorem oddBlockASet_subset_certifiedOddPathStageUnion_of_cofinal
    {a Kpath : ℕ → ℕ}
    (hpos : ∀ j : ℕ, 0 < a (j + 1))
    (hcofinal : CertifiedPathPrefixCofinal Kpath) :
    oddBlockASet a ⊆ certifiedOddPathStageUnion a Kpath := by
  intro n hn
  rcases hn with ⟨j, t, ht1, htle, hodd, hden, hn⟩
  let r : ℕ := flattenedPathIndex a j t
  rcases hcofinal (r + 1) with ⟨m, hm⟩
  have hrlt : r < Kpath m := by omega
  have hjle_start : j ≤ pathIndexStart a j :=
    self_le_pathIndexStart hpos j
  have hstart_le_r : pathIndexStart a j ≤ r := by
    dsimp [r]
    exact pathIndexStart_le_flattenedPathIndex a j t
  have hjlt : j < Kpath m := by omega
  have hidx : (j, t) ∈ canonicalOddPathPrefixIndices a (Kpath m) := by
    rw [mem_canonicalOddPathPrefixIndices_iff]
    exact ⟨hjlt, ht1, htle, hrlt, hodd, hden⟩
  rw [mem_certifiedOddPathStageUnion_iff]
  refine ⟨m, ?_⟩
  unfold certifiedOddPathPrefix
  rw [Finset.mem_image]
  exact ⟨(j, t), hidx, hn.symm⟩

/-- Cofinal flattened path-prefixes are exactly the coefficient-side odd block
set. -/
theorem certifiedOddPathStageUnion_eq_oddBlockASet_of_cofinal
    {a Kpath : ℕ → ℕ}
    (hpos : ∀ j : ℕ, 0 < a (j + 1))
    (hcofinal : CertifiedPathPrefixCofinal Kpath) :
    certifiedOddPathStageUnion a Kpath = oddBlockASet a := by
  apply Set.Subset.antisymm
  · intro n hn
    rw [mem_certifiedOddPathStageUnion_iff] at hn
    rcases hn with ⟨m, hm⟩
    exact certifiedOddPathPrefix_subset_oddBlockASet a (Kpath m) hm
  · exact oddBlockASet_subset_certifiedOddPathStageUnion_of_cofinal
      (a := a) (Kpath := Kpath) hpos hcofinal

/-- If `a` is the simple CF expansion of `α`, cofinal flattened path-prefixes
cover the whole floor-sum set. -/
theorem certifiedOddPathStageUnion_eq_A_of_cofinal_IsSimpleCFExpansion
    {α : ℝ} {a Kpath : ℕ → ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a)
    (hcofinal : CertifiedPathPrefixCofinal Kpath) :
    certifiedOddPathStageUnion a Kpath = A α := by
  have hA : A α = oddBlockASet a :=
    A_eq_oddBlockASet_of_IsSimpleCFExpansion hαpos hαirr hcf
  have hpos : ∀ j : ℕ, 0 < a (j + 1) := hcf.1
  calc
    certifiedOddPathStageUnion a Kpath = oddBlockASet a :=
      certifiedOddPathStageUnion_eq_oddBlockASet_of_cofinal
        (a := a) (Kpath := Kpath) hpos hcofinal
    _ = A α := hA.symm

/-- Eventual-above-every-depth version. -/
theorem certifiedOddPathStageUnion_eq_A_of_eventuallyAboveEvery_IsSimpleCFExpansion
    {α : ℝ} {a Kpath : ℕ → ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a)
    (hK : CertifiedPathPrefixEventuallyAboveEvery Kpath) :
    certifiedOddPathStageUnion a Kpath = A α := by
  exact certifiedOddPathStageUnion_eq_A_of_cofinal_IsSimpleCFExpansion
    hαpos hαirr hcf
    (CertifiedPathPrefixCofinal_of_eventuallyAboveEvery hK)

/-- The one-over-pi flattened path-prefix union. -/
noncomputable def certifiedAOneOverPiPathStageUnion
    (Kpath : ℕ → ℕ) : Set ℕ :=
  ⋃ m : ℕ, (↑(certifiedAOneOverPiPathSubsetAt Kpath m) : Set ℕ)

@[simp] theorem mem_certifiedAOneOverPiPathStageUnion_iff
    {Kpath : ℕ → ℕ} {n : ℕ} :
    n ∈ certifiedAOneOverPiPathStageUnion Kpath ↔
      ∃ m : ℕ, n ∈ certifiedAOneOverPiPathSubsetAt Kpath m := by
  simp [certifiedAOneOverPiPathStageUnion]

/-- The one-over-pi path-prefix union agrees with the generic path-stage union. -/
theorem certifiedAOneOverPiPathStageUnion_eq_generic
    (Kpath : ℕ → ℕ) :
    certifiedAOneOverPiPathStageUnion Kpath =
      certifiedOddPathStageUnion oneOverPiCF Kpath := by
  rfl

/-- Cofinal flattened path-prefixes cover all of `A (1 / π)`. -/
theorem certifiedAOneOverPiPathStageUnion_eq_A_of_cofinal
    {Kpath : ℕ → ℕ}
    (hcofinal : CertifiedPathPrefixCofinal Kpath) :
    certifiedAOneOverPiPathStageUnion Kpath = A oneOverPi := by
  have hpos : 0 < oneOverPi := by
    unfold oneOverPi
    exact one_div_pos.mpr Real.pi_pos
  have hirr : IsIrrational oneOverPi := by
    unfold oneOverPi
    simpa [one_div] using isIrrational_of_irrational irrational_pi.inv
  have hcf : IsSimpleCFExpansion oneOverPi oneOverPiCF := by
    unfold oneOverPiCF
    exact simplePartialQuotient_isSimpleCFExpansion hpos hirr
  change certifiedOddPathStageUnion oneOverPiCF Kpath = A oneOverPi
  exact certifiedOddPathStageUnion_eq_A_of_cofinal_IsSimpleCFExpansion
    hpos hirr hcf hcofinal

/-- Eventual-above-every-depth version for `1 / π`. -/
theorem certifiedAOneOverPiPathStageUnion_eq_A_of_eventuallyAboveEvery
    {Kpath : ℕ → ℕ}
    (hK : CertifiedPathPrefixEventuallyAboveEvery Kpath) :
    certifiedAOneOverPiPathStageUnion Kpath = A oneOverPi := by
  exact certifiedAOneOverPiPathStageUnion_eq_A_of_cofinal
    (CertifiedPathPrefixCofinal_of_eventuallyAboveEvery hK)

/-- A positive linear flattened path trial eventually exceeds every fixed path
depth. -/
theorem CertifiedPathPrefixEventuallyAboveEvery_linearPathTrial
    {c : ℝ} (hc : 0 < c) :
    CertifiedPathPrefixEventuallyAboveEvery (linearPathTrial c) := by
  intro K
  have hdom :
      ∀ᶠ m : ℕ in atTop, (K : ℝ) + 1 ≤ c * (m : ℝ) :=
    eventually_const_le_pos_mul_natCast (A := (K : ℝ) + 1) hc
  filter_upwards [hdom] with m hm
  have hfloor : c * (m : ℝ) - 1 ≤ (linearPathTrial c m : ℝ) :=
    linearPathTrial_cast_lower c m
  have hKreal : (K : ℝ) ≤ (linearPathTrial c m : ℝ) := by
    linarith
  exact_mod_cast hKreal

/-- Therefore the positive linear trial covers the whole path, hence all of
`A (1 / π)`. -/
theorem certifiedAOneOverPiPathStageUnion_linearTrial_eq_A
    {c : ℝ} (hc : 0 < c) :
    certifiedAOneOverPiPathStageUnion (linearPathTrial c) = A oneOverPi := by
  exact certifiedAOneOverPiPathStageUnion_eq_A_of_eventuallyAboveEvery
    (CertifiedPathPrefixEventuallyAboveEvery_linearPathTrial hc)

/-- Slope-specific actual statement: under the existing Ramanujan interval
certification hypotheses, the intervals eventually certify the positive linear
flattened path prefix, and the union of those certified path prefixes is the
