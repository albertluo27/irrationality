/-- Cutoff-aware final target implies the desired bound. -/
theorem oneOverPiMeasureAtMost_four_of_cutoffBudgetFinalTarget
    (h : ClippedCanonicalLiveLossCutoffBudgetFinalTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases h with ⟨B0, P⟩
  exact oneOverPiMeasureAtMost_four_of_cutoffBudgetFinalPackage P

/-!
# Quadratic clipped route with cutoff-aware endpoint budgets

The previous small-live endpoint route uses a static closed/live split.  This
cutoff-aware variant lets the closed and live endpoint relations depend on the
initial segment cutoff, matching the API of
`EndpointSubwindowCutoffRelevantClosedLiveBudgetData`.
-/

/-! ## Quadratic core data with cutoff-aware endpoint budget -/

/-- Quadratic core data using cutoff-aware endpoint budget data. -/
structure ClippedLayerCakeQuadraticCutoffBudgetCoreData (B : ℝ) : Type where
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate Hlog u vseq H V
      (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)
  bauer : BauerRamanujanIdentity
  finiteData :
    ClippedOneThresholdFiniteData X B (clippedLayerCakeTrialNu B)
  eps : ℝ
  eps_nonneg : 0 ≤ eps
  eps_lt_slack : eps < clippedLayerCakeQuadraticEffectiveSlack B
  cutoffBudget :
    EndpointSubwindowCutoffRelevantClosedLiveBudgetData
      X H V (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (clippedLayerCakeQuadraticEffectiveDelta B) eps

/-- Cutoff-budget quadratic core data supplies the clipped endpoint average at
the quadratic effective density. -/
theorem clippedEndpointAverageBound_of_quadraticCutoffBudgetCoreData
    {B : ℝ} (D : ClippedLayerCakeQuadraticCutoffBudgetCoreData B) :
    ClippedEndpointWeightedAverageBound D.X (clippedLayerCakeTrialNu B)
      (clippedLayerCakeQuadraticEffectiveDelta B) := by
  have hAvg :
      ClippedEndpointWeightedAverageBound D.X (clippedLayerCakeTrialNu B)
        (oneThresholdBootstrapDelta B (clippedLayerCakeTrialNu B)) :=
    clippedEndpointAverage_of_finiteData D.finiteData
  simpa [oneThresholdBootstrapDelta_trial_eq_clippedLayerCakeQuadraticEffectiveDelta]
    using hAvg

/-- One cutoff-budget quadratic core data package gives one strict quadratic
output bound. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_of_quadraticCutoffBudgetCoreData
    {B : ℝ} (hB : 4 < B)
    (D : ClippedLayerCakeQuadraticCutoffBudgetCoreData B) :
    OneOverPiMeasureStrictlyBelowEffectiveRaw
      (clippedLayerCakeQuadraticOutput B) := by
  have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
  have hnu2 : 2 < clippedLayerCakeTrialNu B := hcap.2.2.2.1
  have hnuM : clippedLayerCakeTrialNu B < clippedLayerCakeQuadraticOutput B :=
    hcap.2.2.2.2.1
  have htau : 0 < clippedLayerCakeCanonicalTau B :=
    clippedLayerCakeCanonicalTau_pos (B := B) hB
  have hx : shellSpikeContractionExponent
        (clippedLayerCakeCanonicalTau B) (clippedLayerCakeTrialNu B)
        (clippedLayerCakeQuadraticOutput B) < clippedLayerCakeCanonicalX B :=
    shellSpikeContractionExponent_lt_clippedLayerCakeCanonicalX_quadratic
      (B := B) hB
  have hx1 : clippedLayerCakeCanonicalX B < 1 :=
    clippedLayerCakeCanonicalX_lt_one (B := B) hB
  have hxθ : clippedLayerCakeCanonicalX B ≤
      shellSpikeGlobalExponent (clippedLayerCakeCanonicalTau B) := by
    rfl
  have havg := clippedEndpointAverageBound_of_quadraticCutoffBudgetCoreData D
  have hNV : UpperNatDensityAtMost
      (NonVisibleBadShell (clippedLayerCakeTrialNu B) D.H D.V
        (clippedLayerCakeCanonicalX B))
      (clippedLayerCakeQuadraticEffectiveDelta B + D.eps) :=
    nonVisibleBadDensity_of_endpointCutoffRelevantClosedLiveBudgetData
      D.cutoffBudget havg
  have hdens_nonneg :
      0 ≤ clippedLayerCakeQuadraticEffectiveDelta B + D.eps := by
    have hδ := clippedLayerCakeQuadraticEffectiveDelta_nonneg (B := B) hB
    linarith [D.eps_nonneg]
  have hgainOne :
      clippedLayerCakeQuadraticEffectiveDelta B + D.eps +
        clippedLayerCakeTrialNu B / clippedLayerCakeQuadraticOutput B <
          shellSpikeGoodDensityGain
            (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B) := by
    have hstrict := clippedLayerCakeQuadraticEffectiveDelta_liveGain
      (B := B) (eps := D.eps) hB D.eps_lt_slack
    have hgain := shellSpikeGoodDensityGain_clippedLayerCakeCanonicalX_eq_one
      (B := B) hB
    simpa [hgain] using hstrict
  have hgain' :
      clippedLayerCakeTrialNu B / clippedLayerCakeQuadraticOutput B +
          (clippedLayerCakeQuadraticEffectiveDelta B + D.eps)
        < shellSpikeGoodDensityGain
            (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B) := by
    linarith
  intro mu hmu
  exact oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    (mu := mu)
    (nu := clippedLayerCakeTrialNu B)
    (M := clippedLayerCakeQuadraticOutput B)
    (tau := clippedLayerCakeCanonicalTau B)
    (x := clippedLayerCakeCanonicalX B)
    (eps := clippedLayerCakeQuadraticEffectiveDelta B + D.eps)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    (H := D.H) (V := D.V)
    D.closureCert D.bauer hmu hnu2 hnuM htau hx hx1 hxθ
    hNV hdens_nonneg hgain'

/-! ## Iteration to the non-strict bound -/

/-- Cutoff-budget quadratic core data target for every strict cap above `4`. -/
def ClippedLayerCakeQuadraticCutoffBudgetCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        Nonempty (ClippedLayerCakeQuadraticCutoffBudgetCoreData B)

/-- Cutoff-budget data propagates strict bounds along quadratic iterates. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_quadraticIterate_of_cutoffBudgetCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticCutoffBudgetCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ n : ℕ,
      OneOverPiMeasureStrictlyBelowEffectiveRaw
        (clippedLayerCakeQuadraticIterate B0 n) := by
  intro n
  induction n with
  | zero =>
      simpa [clippedLayerCakeQuadraticIterate] using hStart
  | succ n ih =>
      have hBn : 4 < clippedLayerCakeQuadraticIterate B0 n :=
        four_lt_clippedLayerCakeQuadraticIterate hB0 n
      rcases hCore (clippedLayerCakeQuadraticIterate B0 n) hBn ih with ⟨D⟩
      have hStep :=
        oneOverPiMeasureStrictlyBelowEffectiveRaw_of_quadraticCutoffBudgetCoreData
          (B := clippedLayerCakeQuadraticIterate B0 n) hBn D
      simpa [clippedLayerCakeQuadraticIterate] using hStep

/-- Final wrapper: cutoff-budget quadratic core data implies `mu(1/pi) <= 4`. -/
theorem oneOverPi_irratMeasure_le_four_of_quadraticCutoffBudgetCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticCutoffBudgetCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ mu : ℝ,
      HasIrrationalityMeasure (1 / Real.pi) mu → mu ≤ 4 := by
  intro mu hmu
  by_contra hnot
  have hgt : 4 < mu := lt_of_not_ge hnot
  let eps0 : ℝ := (mu - 4) / 2
  have heps0 : 0 < eps0 := by
    unfold eps0
    linarith
  have hIter :=
    oneOverPiMeasureStrictlyBelowEffectiveRaw_quadraticIterate_of_cutoffBudgetCoreDataTarget
      hCore hB0 hStart
  have htend := tendsto_clippedLayerCakeQuadraticIterate (B0 := B0) hB0
  have hEventually :
      ∀ᶠ n : ℕ in atTop,
        clippedLayerCakeQuadraticIterate B0 n < 4 + eps0 := by
    have hlt : (4 : ℝ) < 4 + eps0 := by linarith
    exact (tendsto_order.1 htend).2 (4 + eps0) hlt
  rcases (eventually_atTop.1 hEventually) with ⟨N, hN⟩
  have hmu_lt_iter : mu < clippedLayerCakeQuadraticIterate B0 N :=
    hIter N mu hmu
  have hiter_lt : clippedLayerCakeQuadraticIterate B0 N < 4 + eps0 :=
    hN N le_rfl
  have hmu_lt : mu < 4 + eps0 := lt_trans hmu_lt_iter hiter_lt
  unfold eps0 at hmu_lt
  linarith

/-! ## One-over-pi tail-stable cutoff-budget endpoint target -/

/-- Tail-stable small-live endpoint geometry target using cutoff-aware
closed/live budget data.

The budget payload is `Nonempty` because
`EndpointSubwindowCutoffRelevantClosedLiveBudgetData ...` is a `Type`, not a
proposition. -/
def OneOverPiTailStableSmallLiveCutoffBudgetForClosureTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ D : OneOverPiTailStableOrderedEndpointClosureData B baseShift,
              ∀ s : ℕ,
                ∃ liveLoss : ℝ,
                  0 ≤ liveLoss ∧
                  liveLoss < clippedLayerCakeQuadraticEffectiveSlack B ∧
                  Nonempty
                    (EndpointSubwindowCutoffRelevantClosedLiveBudgetData
                      (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
                      (tailShiftSeq D.H s) (tailShiftSeq D.V s)
                      (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
                      (clippedLayerCakeQuadraticEffectiveDelta B) liveLoss)

/-- Final endpoint-geometry target with a cutoff-aware small-live budget. -/
def OneOverPiFinalEndpointGeometrySmallLiveCutoffBudgetTarget : Prop :=
  OneOverPiTailStableOrderedEndpointClosureForShiftTarget ∧
  OneOverPiTailStableSmallLiveCutoffBudgetForClosureTarget

/-- Construct one quadratic cutoff-budget core package from the final cutoff
endpoint target. -/
theorem clippedLayerCakeQuadraticCutoffBudgetCoreData_of_finalEndpointGeometrySmallLiveCutoffBudgetTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveCutoffBudgetTarget)
    {B : ℝ} (hB : 4 < B)
    (hBound : OneOverPiMeasureStrictlyBelowEffectiveRaw B) :
    Nonempty (ClippedLayerCakeQuadraticCutoffBudgetCoreData B) := by
  rcases hFinal with ⟨hClosure, hCutoff⟩
  have hRatioTarget : OneOverPiShiftedQlogRatioCapFromMeasureTarget :=
    oneOverPiShiftedQlogRatioCapFromMeasureTarget_of_denLogRatioBounded
      oneOverPiContinuantDenLogRatioBoundedTarget_of_finiteMeasure
  rcases hRatioTarget B hB hBound with ⟨baseShift, hCap⟩
  rcases hClosure B hB hBound baseShift hCap with ⟨D⟩
  rcases exists_tailShiftSeq_pos_and_ratioBoundedBy
      (X := oneOverPiShiftedQlog baseShift) (R := B - 1)
      (oneOverPiShiftedQlog_eventuallyPositiveLogScale baseShift) hCap with
    ⟨s, hXpos, hRatio⟩
  rcases hCutoff B hB hBound baseShift hCap D s with
    ⟨liveLoss, hlive_nonneg, hlive_lt, hBudget_nonempty⟩
  rcases hBudget_nonempty with ⟨hBudget⟩
  refine ⟨{
    X := tailShiftSeq (oneOverPiShiftedQlog baseShift) s
    H := tailShiftSeq D.H s
    V := tailShiftSeq D.V s
    Hlog := tailShiftSeq D.Hlog s
    u := tailShiftSeq D.u s
    vseq := tailShiftSeq D.vseq s
    closureCert := D.closureCert_tail s
    bauer := D.bauer
    finiteData := ?_
    eps := liveLoss
    eps_nonneg := hlive_nonneg
    eps_lt_slack := hlive_lt
    cutoffBudget := hBudget
  }⟩
  have hrange := clippedLayerCakeTrialNu_range (M := B) hB
  exact clippedOneThresholdFiniteData_of_ratioBounded
    (X := tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
    (B := B) (nu := clippedLayerCakeTrialNu B)
    hrange.1 (le_of_lt hrange.2)
    hXpos
    (monotone_tailShiftSeq
      (X := oneOverPiShiftedQlog baseShift) (N := s)
      (oneOverPiShiftedQlog_monotone baseShift))
    hRatio

/-- The final cutoff endpoint target supplies the generic quadratic
cutoff-budget core-data target. -/
theorem clippedLayerCakeQuadraticCutoffBudgetCoreDataTarget_of_finalEndpointGeometrySmallLiveCutoffBudgetTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveCutoffBudgetTarget) :
    ClippedLayerCakeQuadraticCutoffBudgetCoreDataTarget := by
  intro B hB hBound
  exact clippedLayerCakeQuadraticCutoffBudgetCoreData_of_finalEndpointGeometrySmallLiveCutoffBudgetTarget
    hFinal hB hBound

/-- Final cutoff-aware endpoint geometry implies the desired non-strict bound
for `1 / pi`. -/
theorem oneOverPiMeasureAtMost_four_of_finalEndpointGeometrySmallLiveCutoffBudgetTarget
