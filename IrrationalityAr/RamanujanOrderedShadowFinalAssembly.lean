    (clippedLayerCakeEffectiveArithmeticDataTarget_of_quadraticActiveMassCoreDataTarget
      hCore)
    hB0 hStart

/-!
## Geometric-core reduction for the quadratic active-mass route

The active-mass finite theorem is already proved from the successor identity,
so the core data only needs to supply positivity, monotonicity, and the ratio
cap for the selected log-denominator sequence.
-/

/-- The active-mass finite theorem is automatic from the already-proved
successor formula. -/
theorem clippedOneThresholdFiniteData_of_ratioBounded
    {X : ℕ → ℝ} {B nu : ℝ}
    (hnu2 : 2 < nu)
    (hnuB : nu ≤ B)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X)
    (hcap : RatioBoundedBy X (B - 1)) :
    ClippedOneThresholdFiniteData X B nu := by
  refine
    { nu_gt_two := hnu2
      nu_le_B := hnuB
      X_pos := hXpos
      X_mono := hmono
      ratio_cap := hcap
      active_finite := ?_ }
  have hVia := activeMassGeometricFiniteTargetViaInduction X nu
  exact (hVia (weightedActiveRatioMass_succ X nu)).2

/-- Geometric core data for the quadratic active-mass route.

Compared with `ClippedLayerCakeQuadraticActiveMassCoreData`, this structure
no longer asks for `ClippedOneThresholdFiniteData`; it asks only for the
geometric facts from which that finite data is constructed automatically. -/
structure ClippedLayerCakeQuadraticGeometricCoreData (B : ℝ) : Type where
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate Hlog u vseq H V
      (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)
  bauer : BauerRamanujanIdentity
  X_pos : ∀ j : ℕ, 0 < X j
  X_mono : Monotone X
  ratio_cap : RatioBoundedBy X (B - 1)
  clippedControls :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (clippedLayerCakeQuadraticEffectiveDelta B)

/-- Geometric core data constructs the previously introduced active-mass core
data. -/
def clippedLayerCakeQuadraticActiveMassCoreData_of_geometricCoreData
    {B : ℝ} (hB : 4 < B)
    (D : ClippedLayerCakeQuadraticGeometricCoreData B) :
    ClippedLayerCakeQuadraticActiveMassCoreData B where
  X := D.X
  H := D.H
  V := D.V
  Hlog := D.Hlog
  u := D.u
  vseq := D.vseq
  closureCert := D.closureCert
  bauer := D.bauer
  finiteData := by
    have hrange := clippedLayerCakeTrialNu_range (M := B) hB
    exact clippedOneThresholdFiniteData_of_ratioBounded
      (X := D.X) (B := B) (nu := clippedLayerCakeTrialNu B)
      hrange.1 (le_of_lt hrange.2) D.X_pos D.X_mono D.ratio_cap
  clippedControls := D.clippedControls

/-- Geometric-core target: for every strict cap above `4`, construct the
geometric data needed by the quadratic active-mass route. -/
def ClippedLayerCakeQuadraticGeometricCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        Nonempty (ClippedLayerCakeQuadraticGeometricCoreData B)

/-- Geometric core data implies the active-mass core target. -/
theorem clippedLayerCakeQuadraticActiveMassCoreDataTarget_of_geometricCoreDataTarget
    (hGeom : ClippedLayerCakeQuadraticGeometricCoreDataTarget) :
    ClippedLayerCakeQuadraticActiveMassCoreDataTarget := by
  intro B hB hBound
  rcases hGeom B hB hBound with ⟨D⟩
  exact ⟨clippedLayerCakeQuadraticActiveMassCoreData_of_geometricCoreData
    (B := B) hB D⟩

/-- Final wrapper from the geometric-core target. -/
theorem oneOverPi_irratMeasure_le_four_of_quadraticGeometricCoreDataTarget
    (hGeom : ClippedLayerCakeQuadraticGeometricCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ mu : ℝ,
      HasIrrationalityMeasure (1 / Real.pi) mu → mu ≤ 4 := by
  exact oneOverPi_irratMeasure_le_four_of_quadraticActiveMassCoreDataTarget
    (clippedLayerCakeQuadraticActiveMassCoreDataTarget_of_geometricCoreDataTarget
      hGeom)
    hB0 hStart

/-- Shifted log-denominator sequence for the continued fraction of `1 / pi`.
The shift lets later arithmetic proofs discard a finite initial segment. -/
noncomputable def oneOverPiShiftedQlog (shift : ℕ) (j : ℕ) : ℝ :=
  continuantQlog oneOverPiCF (j + shift)

/-- Concrete geometric core data using the actual shifted log-denominators of
`1 / pi`. -/
structure OneOverPiShiftedQuadraticGeometricCoreData (B : ℝ) : Type where
  shift : ℕ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate Hlog u vseq H V
      (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)
  bauer : BauerRamanujanIdentity
  X_pos : ∀ j : ℕ, 0 < oneOverPiShiftedQlog shift j
  X_mono : Monotone (oneOverPiShiftedQlog shift)
  ratio_cap : RatioBoundedBy (oneOverPiShiftedQlog shift) (B - 1)
  clippedControls :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      (oneOverPiShiftedQlog shift) H V
      (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (clippedLayerCakeQuadraticEffectiveDelta B)

/-- A shifted one-over-pi data package gives geometric core data. -/
def clippedLayerCakeQuadraticGeometricCoreData_of_oneOverPiShiftedData
    {B : ℝ} (D : OneOverPiShiftedQuadraticGeometricCoreData B) :
    ClippedLayerCakeQuadraticGeometricCoreData B where
