/-!
# Clipped scalar half-threshold closure

This layer closes the shell-spike scalar part of the clipped strict-slack route
by using the universal choice `tau = 1` and `x = 1 / 2`.  The remaining scalar
work is reduced to choosing `nu` and, in the live-loss branch, `eps`, so that
the one-line slack inequality holds.
-/

/-- At `tau = 1`, the global spike exponent is `1 / 2`. -/
theorem shellSpikeGlobalExponent_one_eq_half :
    shellSpikeGlobalExponent 1 = (1 / 2 : ℝ) := by
  norm_num [shellSpikeGlobalExponent]

/-- At `tau = 1` and `x = 1 / 2`, the predicted good-shell gain is `1`. -/
theorem shellSpikeGoodDensityGain_one_one_half :
    shellSpikeGoodDensityGain 1 (1 / 2 : ℝ) = 1 := by
  norm_num [shellSpikeGoodDensityGain]

/-- The contraction exponent at `tau = 1` is below `1 / 2` as soon as the
requested good-density ratio satisfies `nu / M < 1`. -/
theorem shellSpikeContractionExponent_one_lt_half_of_lt
    {nu M : ℝ}
    (hnu_pos : 0 < nu)
    (hnuM : nu < M) :
    shellSpikeContractionExponent 1 nu M < (1 / 2 : ℝ) := by
  have hM_pos : 0 < M := by linarith
  have hgamma_lt : nu / M < 1 := (div_lt_one hM_pos).mpr hnuM
  have hgamma_pos : 0 < nu / M := div_pos hnu_pos hM_pos
  unfold shellSpikeContractionExponent shellSpikeExponentForGain
    shellSpikeContractionGoodDensity
  norm_num
  change (1 + nu / M) / (3 + nu / M) < (1 / 2 : ℝ)
  have hden : 0 < 3 + nu / M := by linarith
  rw [div_lt_iff₀ hden]
  nlinarith

/-- Minimal scalar optimizer data for the live-loss branch after fixing
`tau = 1` and `x = 1 / 2`. -/
structure ClippedLiveLossScalarOptimizerData (B : ℝ) : Type where
  nu : ℝ
  eps : ℝ
  nu_gt_two : 2 < nu
  nu_lt_output : nu < oneThresholdBootstrapRelaxedMap B
  deltaeps_nonneg : 0 ≤ oneThresholdEndpointDelta B nu + eps
  gain_surplus_unit :
    nu / oneThresholdBootstrapRelaxedMap B +
        (oneThresholdEndpointDelta B nu + eps) < 1

/-- Live-loss scalar optimizer data gives the scalar data expected by the
component split. -/
def clippedStrictSlackScalarData_of_liveLossOptimizerData
    {B : ℝ}
    (D : ClippedLiveLossScalarOptimizerData B) :
    ClippedStrictSlackScalarData B := {
  nu := D.nu
  tau := 1
  x := 1 / 2
  eps := D.eps
  nu_gt_two := D.nu_gt_two
  nu_lt_output := D.nu_lt_output
  tau_pos := by norm_num
  x_contraction := by
    exact shellSpikeContractionExponent_one_lt_half_of_lt
      (nu := D.nu) (M := oneThresholdBootstrapRelaxedMap B)
      (lt_trans (by norm_num : (0 : ℝ) < 2) D.nu_gt_two) D.nu_lt_output
  x_lt_one := by norm_num
  x_le_global := by
    rw [shellSpikeGlobalExponent_one_eq_half]
  deltaeps_nonneg := D.deltaeps_nonneg
  gain_surplus := by
    rw [shellSpikeGoodDensityGain_one_one_half]
    exact D.gain_surplus_unit
}

/-- Scalar optimizer target for the live-loss branch. -/
def ClippedLiveLossScalarOptimizerDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedLiveLossScalarOptimizerData B)

/-- The live-loss scalar optimizer target closes the scalar-data target used by
`ClippedComponentFinalPackage`. -/
theorem clippedStrictSlackScalarDataTarget_of_liveLossOptimizerTarget
    (hopt : ClippedLiveLossScalarOptimizerDataTarget) :
    ClippedStrictSlackScalarDataTarget := by
  intro B hB hBound
  rcases hopt B hB hBound with ⟨D⟩
  exact ⟨clippedStrictSlackScalarData_of_liveLossOptimizerData D⟩

/-- Minimal scalar optimizer data for the zero-live branch after fixing
`tau = 1` and `x = 1 / 2`. -/
structure ClippedZeroLiveScalarOptimizerData (B : ℝ) : Type where
  nu : ℝ
  nu_gt_two : 2 < nu
  nu_le_B : nu ≤ B
  nu_lt_output : nu < oneThresholdBootstrapRelaxedMap B
  gain_surplus_unit_zero :
    nu / oneThresholdBootstrapRelaxedMap B + oneThresholdEndpointDelta B nu < 1

/-- Zero-live scalar optimizer data gives the zero-live scalar data expected by
the zero-live component split. -/
def clippedStrictSlackZeroLiveScalarData_of_optimizerData
    {B : ℝ}
    (D : ClippedZeroLiveScalarOptimizerData B) :
    ClippedStrictSlackZeroLiveScalarData B := {
  nu := D.nu
  tau := 1
  x := 1 / 2
  nu_gt_two := D.nu_gt_two
  nu_le_B := D.nu_le_B
  nu_lt_output := D.nu_lt_output
  tau_pos := by norm_num
  x_contraction := by
    exact shellSpikeContractionExponent_one_lt_half_of_lt
      (nu := D.nu) (M := oneThresholdBootstrapRelaxedMap B)
      (lt_trans (by norm_num : (0 : ℝ) < 2) D.nu_gt_two) D.nu_lt_output
  x_lt_one := by norm_num
  x_le_global := by
    rw [shellSpikeGlobalExponent_one_eq_half]
  gain_surplus_zero := by
    rw [shellSpikeGoodDensityGain_one_one_half]
    exact D.gain_surplus_unit_zero
}

/-- Scalar optimizer target for the zero-live branch. -/
def ClippedZeroLiveScalarOptimizerDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
