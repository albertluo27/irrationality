/-!
# Cutoff prefix sublinear reduction

This layer removes the `activeSublinear` field from the prefix-index endpoint
package.

The active-index count is mechanical once every cutoff-relevant active index is
below a prefix map `K M` and `K M = o(M)`.  This is the natural situation for
continued-fraction endpoint indices: the endpoint index grows logarithmically in
the shell cutoff, while the shell cutoff itself is linear.
-/

/-! ## Active-count sublinearity from a sublinear prefix map -/

/-- The cutoff-relevant active index set is contained in `Finset.range (K M)`
when the relevance relation is pointwise below the prefix map. -/
theorem cutoffRelevantActiveShadowIndexFinset_subset_prefix
    {S E : ℕ → ℝ} {RelevantAt : ℕ → ℕ → ℕ → Prop}
    {K : ℕ → ℕ}
    (hindex : CutoffRelevantIndexLtPrefix K RelevantAt)
    (M : ℕ) :
    CutoffRelevantActiveShadowIndexFinset S E RelevantAt M
      ⊆ Finset.range (K M) := by
  classical
  intro i hi
  dsimp [CutoffRelevantActiveShadowIndexFinset] at hi
  rw [Finset.mem_filter] at hi
  rcases hi.2 with ⟨m, _hmM, hRel, _hInt⟩
  exact Finset.mem_range.mpr (hindex M m i hRel)

/-- The cutoff-relevant active count is bounded by the prefix length. -/
theorem cutoffRelevantActiveShadowCount_le_prefix
    {S E : ℕ → ℝ} {RelevantAt : ℕ → ℕ → ℕ → Prop}
    {K : ℕ → ℕ}
    (hindex : CutoffRelevantIndexLtPrefix K RelevantAt)
    (M : ℕ) :
    (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ) ≤ (K M : ℝ) := by
  classical
  have hsubset := cutoffRelevantActiveShadowIndexFinset_subset_prefix
    (S := S) (E := E) (RelevantAt := RelevantAt) (K := K) hindex M
  have hcard :
      (CutoffRelevantActiveShadowIndexFinset S E RelevantAt M).card
        ≤ (Finset.range (K M)).card :=
    Finset.card_le_card hsubset
  dsimp [CutoffRelevantActiveShadowCount]
  simpa using (show
    ((CutoffRelevantActiveShadowIndexFinset S E RelevantAt M).card : ℝ)
      ≤ ((Finset.range (K M)).card : ℝ) from by exact_mod_cast hcard)

/-- If the prefix map is sublinear and every relevant index is below it, then the
cutoff-relevant active index count is sublinear. -/
theorem cutoffRelevantActiveShadowCountSublinear_of_prefixSublinear
    {S E : ℕ → ℝ} {RelevantAt : ℕ → ℕ → ℕ → Prop}
    {K : ℕ → ℕ}
    (hindex : CutoffRelevantIndexLtPrefix K RelevantAt)
    (hKsub : EventuallySublinearCountError (fun M : ℕ => (K M : ℝ))) :
    CutoffRelevantActiveShadowCountSublinear S E RelevantAt := by
  intro eps heps
  filter_upwards [hKsub eps heps] with M hKM
  exact le_trans
    (cutoffRelevantActiveShadowCount_le_prefix
      (S := S) (E := E) (RelevantAt := RelevantAt) (K := K) hindex M)
    hKM

/-! ## Scale-map data with prefix sublinearity included -/

/-- A scale-map package that includes the sublinearity of the prefix length. -/
structure CutoffEndpointSublinearScaleMapData
    (X : ℕ → ℝ) (nu delta : ℝ)
