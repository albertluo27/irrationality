    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_logLCFinalTarget h

/-- A self-contained copy of the logarithmic layer-cake loss used only for the
barrier proof below. -/
def logLCBarrierDelta (B nu : ℝ) : ℝ :=
  (1 / 2 : ℝ) * Real.log ((B - 2) / (nu - 2))

/-- The telescoping clipped loss is no worse than the logarithmic layer-cake
loss used in the barrier analysis. -/
theorem telescopingClippedEndpointDelta_le_logLCBarrierDelta
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu < B) :
    telescopingClippedEndpointDelta B nu ≤ logLCBarrierDelta B nu := by
  unfold telescopingClippedEndpointDelta logLCBarrierDelta
  let y : ℝ := (B - 2) / (nu - 2)
  have hypos : 0 < y := by
    have hnum : 0 < B - 2 := by linarith
    have hden : 0 < nu - 2 := by linarith
    exact div_pos hnum hden
  have hineq : 1 - 1 / y ≤ Real.log y := by
    have hinv :
        Real.log y⁻¹ ≤ y⁻¹ - 1 :=
      Real.log_le_sub_one_of_pos (inv_pos.mpr hypos)
    rw [Real.log_inv] at hinv
    rw [one_div]
    linarith
  have halg : (B - nu) / (2 * (B - 2)) = (1 / 2 : ℝ) * (1 - 1 / y) := by
    unfold y
    have hB2 : B - 2 ≠ 0 := by linarith
    have hnu2' : nu - 2 ≠ 0 := by linarith
    field_simp [hB2, hnu2']
    ring
  have hmul := mul_le_mul_of_nonneg_left hineq (by norm_num : (0 : ℝ) ≤ 1 / 2)
  simpa [halg, y] using hmul

/-- The layer-cake loss is monotone in the input cap `B`. -/
theorem logLCBarrierDelta_mono_left
    {B nu : ℝ} (hB : 4 ≤ B) (hnu2 : 2 < nu) :
    logLCBarrierDelta 4 nu ≤ logLCBarrierDelta B nu := by
  unfold logLCBarrierDelta
  have hdenpos : 0 < nu - 2 := by linarith
  have harg4pos : 0 < (4 - 2) / (nu - 2) := by
    exact div_pos (by norm_num) hdenpos
  have harg_le : (4 - 2) / (nu - 2) ≤ (B - 2) / (nu - 2) := by
    exact div_le_div_of_nonneg_right (by linarith) (le_of_lt hdenpos)
  have hlog_le :
      Real.log ((4 - 2) / (nu - 2)) ≤
        Real.log ((B - 2) / (nu - 2)) := by
    exact Real.log_le_log harg4pos harg_le
  nlinarith

/-- At input cap `B = 4`, the logarithmic scalar loss already saturates the
contraction threshold. -/
theorem one_le_logLCBarrierDelta_four_add_nu_div_four
    {nu : ℝ} (hnu2 : 2 < nu) (_hnu4 : nu < 4) :
    1 ≤ logLCBarrierDelta 4 nu + nu / 4 := by
  let u : ℝ := (nu - 2) / 2
  have hu_pos : 0 < u := by
    dsimp [u]
    nlinarith
  have hlog_le : Real.log u ≤ u - 1 :=
    Real.log_le_sub_one_of_pos hu_pos
  have hmain : 1 - u ≤ - Real.log u := by
    linarith
  have hdelta_eq : logLCBarrierDelta 4 nu = -(1 / 2 : ℝ) * Real.log u := by
    unfold logLCBarrierDelta
    have hratio : (4 - 2) / (nu - 2) = u⁻¹ := by
      dsimp [u]
      field_simp [show nu - 2 ≠ 0 by linarith]
      ring
    rw [hratio, Real.log_inv]
    ring
  have hnu_eq : nu / 4 = (1 + u) / 2 := by
    dsimp [u]
    field_simp
    ring
  rw [hdelta_eq, hnu_eq]
  nlinarith

/-- The generic logarithmic layer-cake method cannot produce a strict
contraction to any output `M ≤ 4`. -/
theorem not_logLC_strict_contraction_at_or_below_four
    {B M nu : ℝ}
    (hB : 4 ≤ B) (hMpos : 0 < M) (hM : M ≤ 4)
    (hnu2 : 2 < nu) (hnuM : nu < M) :
    ¬ (logLCBarrierDelta B nu + nu / M < 1) := by
  intro hstrict
  have hnu4 : nu < 4 := lt_of_lt_of_le hnuM hM
  have hdelta4 : 1 ≤ logLCBarrierDelta 4 nu + nu / 4 :=
    one_le_logLCBarrierDelta_four_add_nu_div_four hnu2 hnu4
  have hdelta_mono : logLCBarrierDelta 4 nu ≤ logLCBarrierDelta B nu :=
    logLCBarrierDelta_mono_left hB hnu2
  have hnu_pos : 0 < nu := by linarith
  have hdiv : nu / 4 ≤ nu / M := by
    exact div_le_div_of_nonneg_left hnu_pos.le hMpos hM
  have : 1 ≤ logLCBarrierDelta B nu + nu / M := by
    nlinarith
  linarith

/-- Human-facing summary theorem: `4` is the scalar barrier of the generic
logarithmic clipped layer-cake method. -/
theorem logLC_generic_method_has_four_barrier :
    ∀ {B M nu : ℝ},
      4 ≤ B → 0 < M → M ≤ 4 → 2 < nu → nu < M →
        ¬ (logLCBarrierDelta B nu + nu / M < 1) := by
  intro B M nu hB hMpos hM hnu2 hnuM
  exact not_logLC_strict_contraction_at_or_below_four
    hB hMpos hM hnu2 hnuM

/-!
# Clipped live-loss final bootstrap

The zero-live clipped repair asks for exact control of the live terminal
boundary.  This final layer only requires a live-boundary loss small enough to
fit inside the strict-slack gain budget.
-/

/-- Total density allowance in the clipped route with a live-boundary loss. -/
def clippedLiveLossTotalDelta (B nu eps : ℝ) : ℝ :=
  oneThresholdBootstrapDelta B nu + eps

/-- A data package for one strict-slack bootstrap step when the clipped
closed/live split has a live-boundary density loss `eps`. -/
structure ClippedOneThresholdStrictSlackStepDataWithLiveLoss (B : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  eps : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_lt_out : nu < (oneThresholdBootstrapRelaxedMap B)
  tau_pos : 0 < tau
  x_contraction :
    shellSpikeContractionExponent tau nu (oneThresholdBootstrapRelaxedMap B) < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  finiteData : ClippedOneThresholdFiniteData X B nu
  budgetSplit :
    ClippedEndpointBudgetSplitTarget
      X H V nu x (oneThresholdBootstrapDelta B nu) eps
  total_nonneg : 0 ≤ clippedLiveLossTotalDelta B nu eps
  total_gain :
    nu / oneThresholdBootstrapRelaxedMap B +
        clippedLiveLossTotalDelta B nu eps < shellSpikeGoodDensityGain tau x

/-- A live-loss strict-slack data package gives the one-step measure improvement
for an arbitrary measure witness `mu`. -/
theorem oneOverPiMeasure_lt_of_Bauer_clippedLiveLossStepData
    {B mu : ℝ}
    (D : ClippedOneThresholdStrictSlackStepDataWithLiveLoss B)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu) :
    mu < oneThresholdBootstrapRelaxedMap B := by
  have hAvg :
      ClippedEndpointWeightedAverageBound D.X D.nu
        (oneThresholdBootstrapDelta B D.nu) :=
    clippedEndpointAverage_of_finiteData D.finiteData
  have hNV :
      UpperNatDensityAtMost (NonVisibleBadShell D.nu D.H D.V D.x)
        (clippedLiveLossTotalDelta B D.nu D.eps) := by
    unfold clippedLiveLossTotalDelta
    exact nonVisibleBadDensity_of_budgetSplit_liveLoss
      (X := D.X) (H := D.H) (V := D.V)
      (nu := D.nu) (x := D.x)
      (delta := oneThresholdBootstrapDelta B D.nu) (eps := D.eps)
      D.budgetSplit hAvg
  exact oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    (mu := mu) (nu := D.nu) (M := oneThresholdBootstrapRelaxedMap B)
    (tau := D.tau) (x := D.x)
    (eps := clippedLiveLossTotalDelta B D.nu D.eps)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    (H := D.H) (V := D.V)
    D.closureCert D.bauer hmu D.nu_gt_two D.nu_lt_out D.tau_pos
    D.x_contraction D.x_lt_one D.x_le_global
    hNV D.total_nonneg D.total_gain

/-- Project target: realize a strict-slack one-step bootstrap while allowing a
controlled live-boundary density loss. -/
def ClippedOneThresholdStrictSlackStepDataWithLiveLossTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedOneThresholdStrictSlackStepDataWithLiveLoss B)

/-- The live-loss data target realizes the same abstract strict-slack one-step
bootstrap used by the final iteration theorem. -/
theorem oneThresholdStrictSlackStepRealized_of_clippedLiveLossDataTarget
    (hdata : ClippedOneThresholdStrictSlackStepDataWithLiveLossTarget) :
    OneThresholdBootstrapStrictSlackStepRealized := by
  intro B hB hBound mu hmu
  rcases hdata B hB hBound with ⟨D⟩
  exact oneOverPiMeasure_lt_of_Bauer_clippedLiveLossStepData
    (B := B) (mu := mu) D hmu

/-- Final package for the clipped route with positive live-boundary loss. -/
structure ClippedOneThresholdStrictSlackFinalPackageWithLiveLoss (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  stepData : ClippedOneThresholdStrictSlackStepDataWithLiveLossTarget
  relaxedMapAboveFour : OneThresholdBootstrapRelaxedMapAboveFour
  relaxedSeqConverges : OneThresholdBootstrapRelaxedSeqConvergesToFour B0

/-- Final live-loss clipped route to the non-strict bound `4`. -/
theorem oneOverPiMeasureAtMost_four_of_clippedLiveLossFinalPackage
    {B0 : ℝ}
    (P : ClippedOneThresholdStrictSlackFinalPackageWithLiveLoss B0) :
    OneOverPiMeasureAtMost 4 := by
  have hstep : OneThresholdBootstrapStrictSlackStepRealized :=
    oneThresholdStrictSlackStepRealized_of_clippedLiveLossDataTarget P.stepData
  exact oneOverPiMeasureAtMost_four_of_relaxedBootstrapSeq
    P.startBound P.startAboveFour hstep
    P.relaxedMapAboveFour P.relaxedSeqConverges

/-- Project-facing live-loss final target. -/
def ClippedOneThresholdStrictSlackFinalTargetWithLiveLoss : Prop :=
  ∃ B0 : ℝ, ClippedOneThresholdStrictSlackFinalPackageWithLiveLoss B0

/-- The live-loss final target implies the desired non-strict bound. -/
theorem oneOverPiMeasureAtMost_four_of_clippedLiveLossFinalTarget
    (h : ClippedOneThresholdStrictSlackFinalTargetWithLiveLoss) :
    OneOverPiMeasureAtMost 4 := by
  rcases h with ⟨B0, P⟩
  exact oneOverPiMeasureAtMost_four_of_clippedLiveLossFinalPackage P

