/-- Final endpoint geometry with sublinear closed-count error implies
`mu(1/pi) <= 4`. -/
theorem oneOverPiMeasureAtMost_four_of_finalEndpointGeometrySmallLiveBudgetWithErrorTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveBudgetWithErrorTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases exists_oneOverPiMeasureStrictlyBelowEffectiveRaw_of_finiteMeasure with
