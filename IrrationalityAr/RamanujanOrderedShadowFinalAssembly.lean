    certifiedAOneOverPiPathStageUnion (linearPathTrial c) = A oneOverPi := by
  constructor
  · exact eventually_intervalCertifiesIntermediatePathPrefix_linearTrial
      (μ := μ) (ν := ν) (c := c) (κ := κ)
      hκ hRam hμ hν hνpos hcpos hcgap
  · exact certifiedAOneOverPiPathStageUnion_linearTrial_eq_A hcpos

/-- Finite-measure existential wrapper: assuming Bauer's identity and a finite
irrationality-measure witness for `1 / π`, there exists a positive linear
Ramanujan-certified path-prefix process whose union is all of `A (1 / π)`. -/
