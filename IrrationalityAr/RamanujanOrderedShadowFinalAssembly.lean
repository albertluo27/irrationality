  rcases exists_knownOneOverPiMeasureBound_above_four with ⟨B0, hB0, hStart⟩
  exact ⟨B0, {
    startBound := hStart
    startAboveFour := hB0
    logCountTarget := P.logCountTarget
    relaxedMapAboveFour := oneThresholdBootstrapRelaxedMapAboveFour_proved
    relaxedSeqConverges := P.scalarConverges B0 hB0
