/-! ## 1. Abstract sublinear count errors -/

/-- An error term is sublinear on natural initial segments if it is eventually
bounded by every positive multiple of `N+1`. -/
def EventuallySublinearCountError (E : ℕ → ℝ) : Prop :=
  ∀ ε : ℝ, 0 < ε →
    ∀ᶠ N : ℕ in atTop, E N ≤ ε * ((N : ℝ) + 1)

/-- A linear upper-count budget with an explicit error term. -/
def UpperCountBudgetWithError
    (B : ℕ → Prop) (δ : ℝ) (E : ℕ → ℝ) : Prop :=
  ∀ᶠ N : ℕ in atTop,
    (natInitialSegmentCount B N : ℝ) ≤
      δ * ((N : ℝ) + 1) + E N

/-- A linear count budget with a sublinear error implies the corresponding
upper natural-density bound. -/
theorem upperNatDensityAtMost_of_countBudget_sublinearError
    {B : ℕ → Prop} {δ : ℝ} {E : ℕ → ℝ}
    (hbudget : UpperCountBudgetWithError B δ E)
    (herror : EventuallySublinearCountError E) :
    UpperNatDensityAtMost B δ := by
  intro ε hε
  have herr := herror ε hε
  filter_upwards [hbudget, herr] with N hcount hE
  calc
    (natInitialSegmentCount B N : ℝ)
        ≤ δ * ((N : ℝ) + 1) + E N := hcount
    _ ≤ δ * ((N : ℝ) + 1) + ε * ((N : ℝ) + 1) := by
      linarith
    _ = (δ + ε) * ((N : ℝ) + 1) := by ring

/-- A pointwise smaller error inherits sublinearity. -/
theorem EventuallySublinearCountError.mono
    {E F : ℕ → ℝ}
    (hE : EventuallySublinearCountError E)
    (hFE : ∀ᶠ N : ℕ in atTop, F N ≤ E N) :
    EventuallySublinearCountError F := by
  intro ε hε
  have hsmall := hE ε hε
  filter_upwards [hFE, hsmall] with N hFN hEN
  exact hFN.trans hEN

/-- The zero error is sublinear. -/
theorem eventuallySublinearCountError_zero :
    EventuallySublinearCountError (fun _ : ℕ => 0) := by
  intro ε hε
  filter_upwards [] with N
  have hnonneg : 0 ≤ (N : ℝ) + 1 := by positivity
  exact mul_nonneg (le_of_lt hε) hnonneg

/-- The sum of two sublinear count errors is sublinear. -/
theorem EventuallySublinearCountError.add
    {E F : ℕ → ℝ}
    (hE : EventuallySublinearCountError E)
    (hF : EventuallySublinearCountError F) :
    EventuallySublinearCountError (fun N => E N + F N) := by
  intro ε hε
  have hhalf : 0 < ε / 2 := by linarith
  have hE' := hE (ε / 2) hhalf
  have hF' := hF (ε / 2) hhalf
  filter_upwards [hE', hF'] with N hEN hFN
  calc
    E N + F N
        ≤ (ε / 2) * ((N : ℝ) + 1) +
          (ε / 2) * ((N : ℝ) + 1) := add_le_add hEN hFN
    _ = ε * ((N : ℝ) + 1) := by ring

/-- Multiplication by a fixed nonnegative scalar preserves sublinearity. -/
theorem EventuallySublinearCountError.const_mul
    {E : ℕ → ℝ} {C : ℝ}
    (hC : 0 ≤ C)
    (hE : EventuallySublinearCountError E) :
    EventuallySublinearCountError (fun N => C * E N) := by
  by_cases hC0 : C = 0
  · subst C
    simpa using eventuallySublinearCountError_zero
  · have hCpos : 0 < C := lt_of_le_of_ne hC (Ne.symm hC0)
    intro ε hε
    have hεC : 0 < ε / C := div_pos hε hCpos
    have hsmall := hE (ε / C) hεC
    filter_upwards [hsmall] with N hN
    have hmul := mul_le_mul_of_nonneg_left hN hC
    calc
      C * E N ≤ C * ((ε / C) * ((N : ℝ) + 1)) := hmul
      _ = ε * ((N : ℝ) + 1) := by field_simp [hC0]

/-! ## 2. Finite shadow budgets -/

/-- The exact finite statement whose proof remains after the one-step shadow
budget algebra: the shadow union has the predicted linear count bound up to a
sublinear component/rounding error. -/
def PredictedSpikeShadowFiniteBudget
    (Hlog u v : ℕ → ℝ) (tau x : ℝ) : Prop :=
  ∃ E : ℕ → ℝ,
    EventuallySublinearCountError E ∧
    UpperCountBudgetWithError
      (spikeShadowShellUnion Hlog u v x)
      (1 - shellSpikeGoodDensityGain tau x)
      E

/-- The finite count-budget target implies the existing project-facing
`PredictedSpikeShadowDensity` predicate. -/
theorem predictedSpikeShadowDensity_of_finiteBudget
    {Hlog u v : ℕ → ℝ} {tau x : ℝ}
    (hbudget : PredictedSpikeShadowFiniteBudget Hlog u v tau x) :
    PredictedSpikeShadowDensity Hlog u v tau x := by
  rcases hbudget with ⟨E, hE, hcount⟩
  unfold PredictedSpikeShadowDensity
  exact upperNatDensityAtMost_of_countBudget_sublinearError hcount hE

/-- Direct wrapper to the visible-spike density conclusion.  Future work can
supply a finite count budget instead of reasoning about asymptotic density
inside the continued-fraction proof. -/
theorem visibleBlockSpikeShell_density_deficit_of_finite_shadow_budget
    {Hlog u vseq H V : ℕ → ℝ} {tau x gain v M : ℝ}
    (hcover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x)
    (hbudget : PredictedSpikeShadowFiniteBudget Hlog u vseq tau x)
    (hgain_def : gain = shellSpikeGoodDensityGain tau x)
    (hgain_nonneg : 0 ≤ gain)
    (hgain_le_one : gain ≤ 1)
    (hvm : v / M < gain) :
    UpperNatDensityLessThan (VisibleBlockSpikeShell H V x) (1 - v / M) := by
  exact visibleBlockSpikeShell_density_deficit_of_shadow_density
    hcover (predictedSpikeShadowDensity_of_finiteBudget hbudget)
    hgain_def hgain_nonneg hgain_le_one hvm

/-- Bauer/Ramanujan measure-improvement wrapper whose only shadow input is a
finite count budget with sublinear error. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_visibleShellFiniteBudget
    {mu nu M tau x : ℝ}
    {Hlog u vseq H V : ℕ → ℝ}
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (hdom : ∀ m : ℕ,
      BadRamanujanTruncation nu m → VisibleBlockSpikeShell H V x m)
    (hcover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x)
    (hbudget : PredictedSpikeShadowFiniteBudget Hlog u vseq tau x)
    (hgain0 : 0 ≤ shellSpikeGoodDensityGain tau x)
    (hgain1 : shellSpikeGoodDensityGain tau x ≤ 1)
    (hgain : nu / M < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  exact oneOverPi_irratMeasure_lt_of_Bauer_visibleShellGain
    hBauer hmu hnu2 hnuM hdom hcover
    (predictedSpikeShadowDensity_of_finiteBudget hbudget)
    hgain0 hgain1 hgain

