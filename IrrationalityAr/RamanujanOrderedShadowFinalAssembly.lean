    P.startBound P.startAboveFour P.relaxedMapAboveFour
    P.relaxedSeqConverges P.actualQlogCofinalRelaxedSeqTarget

/-- Project-facing final target in the sequence-only actual-qlog cofinal-tail
form. -/
def ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalTarget :
    Prop :=
  ∃ B0 : ℝ,
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalPackage
      B0

/-- Final non-strict measure bound from the sequence-only cofinal-tail target. -/
theorem oneOverPiMeasureAtMost_four_of_activeLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalTarget
    (h :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases h with ⟨B0, P⟩
  exact
    oneOverPiMeasureAtMost_four_of_activeLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalPackage
      P

/-- Measure-witness form of the sequence-only actual-qlog route. -/
theorem oneOverPi_irratMeasure_le_four_of_activeLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalTarget
    (h :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogCofinalRelaxedSeqFinalTarget)
    {mu : ℝ}
