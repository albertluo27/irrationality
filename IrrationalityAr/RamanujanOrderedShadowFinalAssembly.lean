/-!
# Clipped atomic geometry through endpoint subwindows

This layer fixes the atomic closed predicate to the explicit endpoint-subwindow
union `EndpointSubwindowUnion nu x X Relevant`.
-/

/-! ## Small reusable density facts -/

/-- The empty predicate has upper density at most every nonnegative threshold. -/
theorem upperNatDensityAtMost_false {δ : ℝ} (hδ : 0 ≤ δ) :
    UpperNatDensityAtMost (fun _ : ℕ => False) δ := by
  intro ε hε
  filter_upwards [] with N
  have hcount :
      (natInitialSegmentCount (fun _ : ℕ => False) N : ℝ) = 0 := by
    simp [natInitialSegmentCount]
  have hN : 0 ≤ (N : ℝ) + 1 := by
    have hNc : 0 ≤ (N : ℝ) := by exact_mod_cast (Nat.zero_le N)
    linarith
  have hδε : 0 ≤ δ + ε := by linarith
  have hprod : 0 ≤ (δ + ε) * ((N : ℝ) + 1) :=
    mul_nonneg hδε hN
  simpa [hcount] using hprod

/-- The empty live-boundary predicate has density zero. -/
theorem liveBoundaryDensity_false_zero :
    LiveBoundaryDensityTarget (fun _ : ℕ => False) 0 := by
  exact upperNatDensityAtMost_false (by rfl)

/-! ## Endpoint-subwindow closed control -/

/-- Clipped average control for the explicit endpoint-subwindow union. -/
def ClippedEndpointSubwindowUnionControls
    (X : ℕ → ℝ) (nu x delta : ℝ)
    (Relevant : ℕ → ℕ → Prop) : Prop :=
  ClippedEndpointWeightedAverageBound X nu delta →
    UpperNatDensityAtMost (EndpointSubwindowUnion nu x X Relevant) delta

/-- Offset cover plus an optional live predicate gives the closed/live cover with
`Closed` chosen to be the endpoint-subwindow union. -/
theorem nonVisibleBadClosedLiveCover_of_offset_or_live
    {nu x : ℝ} {X H V : ℕ → ℝ}
    {Relevant : ℕ → ℕ → Prop} {Live : ℕ → Prop}
    (hOffsetOrLive : ∀ m : ℕ,
      NonVisibleBadShell nu H V x m →
        EndpointExceptionalByOffset nu x X Relevant m ∨ Live m)
    (hCover : EndpointExceptionalSubwindowCover nu x X Relevant) :
    NonVisibleBadClosedLiveCover nu x H V
      (EndpointSubwindowUnion nu x X Relevant) Live := by
  intro m hm
  rcases hOffsetOrLive m hm with hOffset | hLive
  · left
    rcases hCover m hOffset with ⟨j, hRel, hSub⟩
    exact ⟨j, hRel, hSub⟩
  · right
    exact hLive

/-- If non-visible bad shells always enter the offset endpoint case, then the
closed/live cover holds with empty live predicate. -/
theorem nonVisibleBadClosedLiveCover_of_offset_only
    {nu x : ℝ} {X H V : ℕ → ℝ}
    {Relevant : ℕ → ℕ → Prop}
    (hOffset : ∀ m : ℕ,
      NonVisibleBadShell nu H V x m →
        EndpointExceptionalByOffset nu x X Relevant m)
    (hCover : EndpointExceptionalSubwindowCover nu x X Relevant) :
    NonVisibleBadClosedLiveCover nu x H V
      (EndpointSubwindowUnion nu x X Relevant) (fun _ : ℕ => False) := by
  intro m hm
  left
  rcases hCover m (hOffset m hm) with ⟨j, hRel, hSub⟩
  exact ⟨j, hRel, hSub⟩

/-- Endpoint-subwindow control is exactly closed-control for the explicit closed
predicate. -/
theorem clippedClosedEndpointControls_of_subwindowUnionControls
    {X : ℕ → ℝ} {nu x delta : ℝ} {Relevant : ℕ → ℕ → Prop}
    (h : ClippedEndpointSubwindowUnionControls X nu x delta Relevant) :
    ClippedClosedEndpointControls X nu delta
      (EndpointSubwindowUnion nu x X Relevant) := by
  exact h

/-! ## Canonical live-loss subwindow data -/

/-- Canonical live-loss data with the closed predicate fixed to be the explicit
endpoint-subwindow union. -/
structure ClippedCanonicalLiveLossSubwindowData
