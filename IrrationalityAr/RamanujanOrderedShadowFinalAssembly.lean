/-!
# Clipped scalar optimizer bridge

After the half-threshold scalar closure, the scalar side has a zero-live
optimizer target and a live-loss optimizer target.  This bridge shows that
zero-live scalar data supplies live-loss scalar data by spending half of the
remaining strict slack as the live-boundary budget.
-/

/-- Canonical scalar algebra data using the strict-slack trial exponent.

This is a pure real-algebra target.  The intended witness is
`nu = oneThresholdStrictSlackTrialNu B`. -/
structure ClippedZeroLiveCanonicalScalarAlgebraData (B : ℝ) : Type where
  nu_gt_two : 2 < oneThresholdStrictSlackTrialNu B
  nu_le_B : oneThresholdStrictSlackTrialNu B ≤ B
  nu_lt_output :
    oneThresholdStrictSlackTrialNu B < oneThresholdBootstrapRelaxedMap B
  gain_surplus_zero :
    oneThresholdStrictSlackTrialNu B / oneThresholdBootstrapRelaxedMap B +
        oneThresholdEndpointDelta B (oneThresholdStrictSlackTrialNu B) < 1

/-- Canonical scalar algebra data gives zero-live scalar optimizer data. -/
def clippedZeroLiveScalarOptimizerData_of_canonicalAlgebraData
    {B : ℝ}
    (D : ClippedZeroLiveCanonicalScalarAlgebraData B) :
    ClippedZeroLiveScalarOptimizerData B := {
  nu := oneThresholdStrictSlackTrialNu B
  nu_gt_two := D.nu_gt_two
  nu_le_B := D.nu_le_B
  nu_lt_output := D.nu_lt_output
  gain_surplus_unit_zero := D.gain_surplus_zero
}

/-- Canonical scalar algebra target.  The current input bound is irrelevant for
this purely scalar target, but the target has the same arity as the project
scalar optimizer target so that it plugs into the final pipeline. -/
def ClippedZeroLiveCanonicalScalarAlgebraTarget : Prop :=
  ∀ B : ℝ,
    4 < B → Nonempty (ClippedZeroLiveCanonicalScalarAlgebraData B)

/-- The canonical scalar algebra target closes the zero-live scalar optimizer
target. -/
theorem clippedZeroLiveScalarOptimizerTarget_of_canonicalAlgebraTarget
    (halg : ClippedZeroLiveCanonicalScalarAlgebraTarget) :
    ClippedZeroLiveScalarOptimizerDataTarget := by
  intro B hB _hBound
  rcases halg B hB with ⟨D⟩
  exact ⟨clippedZeroLiveScalarOptimizerData_of_canonicalAlgebraData D⟩

/-- The strict slack left by a zero-live scalar optimizer. -/
def clippedZeroLiveScalarSlack (B nu : ℝ) : ℝ :=
  1 - (nu / oneThresholdBootstrapRelaxedMap B + oneThresholdEndpointDelta B nu)

/-- From zero-live scalar data, choose a small live-loss parameter equal to half
of the remaining strict slack. -/
def clippedLiveLossScalarOptimizerData_of_zeroLiveData
    {B : ℝ}
    (Z : ClippedZeroLiveScalarOptimizerData B) :
    ClippedLiveLossScalarOptimizerData B := {
  nu := Z.nu
  eps := clippedZeroLiveScalarSlack B Z.nu / 2
  nu_gt_two := Z.nu_gt_two
  nu_lt_output := Z.nu_lt_output
  deltaeps_nonneg := by
    have hdelta : 0 ≤ oneThresholdEndpointDelta B Z.nu :=
      oneThresholdEndpointDelta_nonneg Z.nu_gt_two Z.nu_le_B
    have hslack_pos : 0 < clippedZeroLiveScalarSlack B Z.nu := by
      unfold clippedZeroLiveScalarSlack
      linarith [Z.gain_surplus_unit_zero]
    have heps_nonneg : 0 ≤ clippedZeroLiveScalarSlack B Z.nu / 2 := by
      exact div_nonneg (le_of_lt hslack_pos) (by norm_num)
    linarith
  gain_surplus_unit := by
    unfold clippedZeroLiveScalarSlack
    linarith [Z.gain_surplus_unit_zero]
}

/-- Zero-live scalar data target implies live-loss scalar data target. -/
theorem clippedLiveLossScalarOptimizerTarget_of_zeroLiveTarget
    (hzero : ClippedZeroLiveScalarOptimizerDataTarget) :
    ClippedLiveLossScalarOptimizerDataTarget := by
  intro B hB hBound
  rcases hzero B hB hBound with ⟨Z⟩
  exact ⟨clippedLiveLossScalarOptimizerData_of_zeroLiveData Z⟩

/-- Canonical scalar algebra target implies the live-loss scalar optimizer
target. -/
theorem clippedLiveLossScalarOptimizerTarget_of_canonicalAlgebraTarget
    (halg : ClippedZeroLiveCanonicalScalarAlgebraTarget) :
    ClippedLiveLossScalarOptimizerDataTarget := by
  exact clippedLiveLossScalarOptimizerTarget_of_zeroLiveTarget
    (clippedZeroLiveScalarOptimizerTarget_of_canonicalAlgebraTarget halg)

/-- Final live-loss package using canonical scalar algebra. -/
structure ClippedCanonicalScalarLiveLossFinalPackage (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  scalarAlgebra : ClippedZeroLiveCanonicalScalarAlgebraTarget
