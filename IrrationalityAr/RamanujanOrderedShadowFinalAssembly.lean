      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ D : OneOverPiTailStableOrderedEndpointClosureData B baseShift,
              ∀ s : ℕ,
                ClippedEndpointCountBudgetSplitWithLiveLoss
                  (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
                  (tailShiftSeq D.H s) (tailShiftSeq D.V s)
                  (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
                  (clippedLayerCakeQuadraticEffectiveDelta B) 0

/-- Budget-level zero-live split gives the previously integrated zero-live split
for clipped control. -/
theorem oneOverPiTailStableClippedZeroLiveSplitForClosureTarget_of_budgetSplit
    (hBudget : OneOverPiTailStableClippedZeroLiveBudgetSplitForClosureTarget) :
    OneOverPiTailStableClippedZeroLiveSplitForClosureTarget := by
  intro B hB hBound baseShift hCap D s
  exact clippedEndpointControlsNonVisibleBadWithLiveLoss_of_countBudgetSplit
    (hBudget B hB hBound baseShift hCap D s)

/-- Combined final endpoint-geometry target in budget form. -/
def OneOverPiFinalEndpointGeometryBudgetSplitTarget : Prop :=
  OneOverPiTailStableOrderedEndpointClosureForShiftTarget ∧
  OneOverPiTailStableClippedZeroLiveBudgetSplitForClosureTarget

/-- The budget-form final endpoint geometry target implies the already
integrated final endpoint-geometry split target. -/
theorem oneOverPiFinalEndpointGeometrySplitTarget_of_budgetSplitTarget
    (h : OneOverPiFinalEndpointGeometryBudgetSplitTarget) :
    OneOverPiFinalEndpointGeometrySplitTarget := by
  rcases h with ⟨hClosure, hBudget⟩
  exact ⟨hClosure,
    oneOverPiTailStableClippedZeroLiveSplitForClosureTarget_of_budgetSplit
      hBudget⟩

/-- Final wrapper: budget-form endpoint geometry still implies
`μ(1/π) ≤ 4`. -/
theorem oneOverPi_irratMeasure_le_four_of_finalEndpointGeometryBudgetSplitTarget
    (h : OneOverPiFinalEndpointGeometryBudgetSplitTarget) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPi_irratMeasure_le_four_of_finalEndpointGeometrySplitTarget
    (oneOverPiFinalEndpointGeometrySplitTarget_of_budgetSplitTarget h)

/-!
# Small-live budget reduction for the clipped quadratic route

The currently integrated budget endpoint target asks for zero live-boundary
density.  The quadratic effective route has strict scalar slack, so zero live
loss is stronger than necessary.  This section proves a more flexible downstream
reduction: a closed endpoint count budget plus a sufficiently small
live-boundary upper density still gives the same final non-strict bound
`mu(1/pi) <= 4`.

No endpoint geometry is proved here.  The remaining work is isolated as a
small-live budget target.
-/

/-! ## Scalar live-loss slack -/

/-- Scalar slack left by the quadratic effective clipped layer-cake step. -/
def clippedLayerCakeQuadraticEffectiveSlack (B : ℝ) : ℝ :=
  1 -
    (clippedLayerCakeQuadraticEffectiveDelta B +
      clippedLayerCakeTrialNu B / clippedLayerCakeQuadraticOutput B)

/-- The quadratic effective step leaves positive live-loss room above `4`. -/
theorem clippedLayerCakeQuadraticEffectiveSlack_pos
    {B : ℝ} (hB : 4 < B) :
    0 < clippedLayerCakeQuadraticEffectiveSlack B := by
  unfold clippedLayerCakeQuadraticEffectiveSlack
  have hgain := clippedLayerCakeQuadraticEffectiveDelta_gain (B := B) hB
  linarith

/-- If `eps` is below the scalar slack, the live-loss version of the gain
inequality holds. -/
theorem clippedLayerCakeQuadraticEffectiveDelta_liveGain
    {B eps : ℝ} (_hB : 4 < B)
    (heps : eps < clippedLayerCakeQuadraticEffectiveSlack B) :
    clippedLayerCakeQuadraticEffectiveDelta B + eps +
        clippedLayerCakeTrialNu B / clippedLayerCakeQuadraticOutput B < 1 := by
  unfold clippedLayerCakeQuadraticEffectiveSlack at heps
  linarith

/-! ## Generic live-loss Bauer/Ramanujan step -/

/-- A clipped endpoint average at density `delta`, plus a count-budget split with
live loss `eps`, gives a strict one-step measure improvement whenever the scalar
inequality has room for `delta + eps`.

This theorem bypasses the older same-delta control predicate and uses the
already-proved density conclusion for budget splits directly. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_of_countBudgetLiveLossStep
    {Mout nu tau x delta eps : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hnu2 : 2 < nu) (hnuM : nu < Mout)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu Mout < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (havg : ClippedEndpointWeightedAverageBound X nu delta)
    (hsplit : ClippedEndpointCountBudgetSplitWithLiveLoss X H V nu x delta eps)
    (hdens_nonneg : 0 ≤ delta + eps)
    (hgain : delta + eps + nu / Mout < shellSpikeGoodDensityGain tau x) :
    OneOverPiMeasureStrictlyBelowEffectiveRaw Mout := by
  intro mu hmu
  have hNV : UpperNatDensityAtMost (NonVisibleBadShell nu H V x) (delta + eps) :=
    nonVisibleBadDensity_of_countBudgetSplit_liveLoss
      (X := X) (H := H) (V := V) (nu := nu) (x := x)
      (delta := delta) (eps := eps) hsplit havg
  have hgain' : nu / Mout + (delta + eps) < shellSpikeGoodDensityGain tau x := by
    linarith
  exact oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    (mu := mu) (nu := nu) (M := Mout) (tau := tau) (x := x)
    (eps := delta + eps)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hNV hdens_nonneg hgain'

/-! ## Quadratic active-mass core data with small live loss -/

/-- Quadratic active-mass core data allowing a small live-boundary density.

The endpoint average itself is still supplied by the proved one-threshold
active-mass theorem.  The live term is only used when passing from the budget
split to the non-visible-bad density. -/
structure ClippedLayerCakeQuadraticSmallLiveCoreData (B : ℝ) : Type where
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate Hlog u vseq H V
      (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)
  bauer : BauerRamanujanIdentity
  finiteData :
    ClippedOneThresholdFiniteData X B (clippedLayerCakeTrialNu B)
  eps : ℝ
  eps_nonneg : 0 ≤ eps
  eps_lt_slack : eps < clippedLayerCakeQuadraticEffectiveSlack B
  budgetSplit :
    ClippedEndpointCountBudgetSplitWithLiveLoss
      X H V (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (clippedLayerCakeQuadraticEffectiveDelta B) eps

/-- Small-live core data supplies the clipped endpoint average at the quadratic
effective density. -/
theorem clippedEndpointAverageBound_of_quadraticSmallLiveCoreData
    {B : ℝ} (D : ClippedLayerCakeQuadraticSmallLiveCoreData B) :
    ClippedEndpointWeightedAverageBound D.X (clippedLayerCakeTrialNu B)
      (clippedLayerCakeQuadraticEffectiveDelta B) := by
  have hAvg :
      ClippedEndpointWeightedAverageBound D.X (clippedLayerCakeTrialNu B)
        (oneThresholdBootstrapDelta B (clippedLayerCakeTrialNu B)) :=
    clippedEndpointAverage_of_finiteData D.finiteData
  simpa [oneThresholdBootstrapDelta_trial_eq_clippedLayerCakeQuadraticEffectiveDelta]
    using hAvg

/-- One small-live quadratic core data package gives one strict quadratic output
bound. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_of_quadraticSmallLiveCoreData
    {B : ℝ} (hB : 4 < B)
    (D : ClippedLayerCakeQuadraticSmallLiveCoreData B) :
    OneOverPiMeasureStrictlyBelowEffectiveRaw
      (clippedLayerCakeQuadraticOutput B) := by
  have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
  have hnu2 : 2 < clippedLayerCakeTrialNu B := hcap.2.2.2.1
  have hnuM : clippedLayerCakeTrialNu B < clippedLayerCakeQuadraticOutput B :=
    hcap.2.2.2.2.1
  have htau : 0 < clippedLayerCakeCanonicalTau B :=
    clippedLayerCakeCanonicalTau_pos (B := B) hB
  have hx : shellSpikeContractionExponent
        (clippedLayerCakeCanonicalTau B) (clippedLayerCakeTrialNu B)
        (clippedLayerCakeQuadraticOutput B) < clippedLayerCakeCanonicalX B :=
    shellSpikeContractionExponent_lt_clippedLayerCakeCanonicalX_quadratic
      (B := B) hB
  have hx1 : clippedLayerCakeCanonicalX B < 1 :=
    clippedLayerCakeCanonicalX_lt_one (B := B) hB
  have hxθ : clippedLayerCakeCanonicalX B ≤
      shellSpikeGlobalExponent (clippedLayerCakeCanonicalTau B) := by
    rfl
  have havg := clippedEndpointAverageBound_of_quadraticSmallLiveCoreData D
  have hdens_nonneg :
      0 ≤ clippedLayerCakeQuadraticEffectiveDelta B + D.eps := by
    have hδ := clippedLayerCakeQuadraticEffectiveDelta_nonneg (B := B) hB
    linarith [D.eps_nonneg]
  have hgainOne :
      clippedLayerCakeQuadraticEffectiveDelta B + D.eps +
        clippedLayerCakeTrialNu B / clippedLayerCakeQuadraticOutput B <
          shellSpikeGoodDensityGain
            (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B) := by
    have hstrict := clippedLayerCakeQuadraticEffectiveDelta_liveGain
      (B := B) (eps := D.eps) hB D.eps_lt_slack
    have hgain := shellSpikeGoodDensityGain_clippedLayerCakeCanonicalX_eq_one
      (B := B) hB
    simpa [hgain] using hstrict
  exact oneOverPiMeasureStrictlyBelowEffectiveRaw_of_countBudgetLiveLossStep
    (Mout := clippedLayerCakeQuadraticOutput B)
    (nu := clippedLayerCakeTrialNu B)
    (tau := clippedLayerCakeCanonicalTau B)
    (x := clippedLayerCakeCanonicalX B)
    (delta := clippedLayerCakeQuadraticEffectiveDelta B)
    (eps := D.eps)
    (X := D.X) (H := D.H) (V := D.V)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    D.closureCert D.bauer hnu2 hnuM htau hx hx1 hxθ
    havg D.budgetSplit hdens_nonneg hgainOne

/-! ## Iteration to `mu(1/pi) <= 4` with small live loss -/

/-- Small-live active-mass target for every strict cap above `4`. -/
def ClippedLayerCakeQuadraticSmallLiveCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        Nonempty (ClippedLayerCakeQuadraticSmallLiveCoreData B)

/-- Small-live data propagates strict bounds along the quadratic iterates. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_quadraticIterate_of_smallLiveCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticSmallLiveCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ n : ℕ,
      OneOverPiMeasureStrictlyBelowEffectiveRaw
        (clippedLayerCakeQuadraticIterate B0 n) := by
  intro n
  induction n with
  | zero =>
      simpa [clippedLayerCakeQuadraticIterate] using hStart
  | succ n ih =>
      have hBn : 4 < clippedLayerCakeQuadraticIterate B0 n :=
        four_lt_clippedLayerCakeQuadraticIterate hB0 n
      rcases hCore (clippedLayerCakeQuadraticIterate B0 n) hBn ih with ⟨D⟩
      have hStep :=
        oneOverPiMeasureStrictlyBelowEffectiveRaw_of_quadraticSmallLiveCoreData
          (B := clippedLayerCakeQuadraticIterate B0 n) hBn D
      simpa [clippedLayerCakeQuadraticIterate] using hStep

/-- Final wrapper: small-live quadratic core data still implies the non-strict
bound `mu(1/pi) <= 4`. -/
theorem oneOverPi_irratMeasure_le_four_of_quadraticSmallLiveCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticSmallLiveCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ mu : ℝ,
      HasIrrationalityMeasure (1 / Real.pi) mu → mu ≤ 4 := by
  intro mu hmu
  by_contra hnot
  have hgt : 4 < mu := lt_of_not_ge hnot
  let eps0 : ℝ := (mu - 4) / 2
  have heps0 : 0 < eps0 := by
    unfold eps0
    linarith
  have hIter :=
    oneOverPiMeasureStrictlyBelowEffectiveRaw_quadraticIterate_of_smallLiveCoreDataTarget
      hCore hB0 hStart
  have htend := tendsto_clippedLayerCakeQuadraticIterate (B0 := B0) hB0
  have hEventually :
      ∀ᶠ n : ℕ in atTop,
        clippedLayerCakeQuadraticIterate B0 n < 4 + eps0 := by
    have hlt : (4 : ℝ) < 4 + eps0 := by linarith
    exact (tendsto_order.1 htend).2 (4 + eps0) hlt
  rcases (eventually_atTop.1 hEventually) with ⟨N, hN⟩
  have hmu_lt_iter : mu < clippedLayerCakeQuadraticIterate B0 N :=
    hIter N mu hmu
  have hiter_lt : clippedLayerCakeQuadraticIterate B0 N < 4 + eps0 :=
    hN N le_rfl
  have hmu_lt : mu < 4 + eps0 := lt_trans hmu_lt_iter hiter_lt
  unfold eps0 at hmu_lt
  linarith

/-! ## One-over-pi final endpoint geometry target with small live loss -/

/-- Final endpoint-geometry budget target allowing a live-boundary density below
the quadratic scalar slack, rather than requiring zero live density. -/
def OneOverPiTailStableSmallLiveBudgetSplitForClosureTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ D : OneOverPiTailStableOrderedEndpointClosureData B baseShift,
              ∀ s : ℕ,
                ∃ liveLoss : ℝ,
                  0 ≤ liveLoss ∧
                  liveLoss < clippedLayerCakeQuadraticEffectiveSlack B ∧
                  ClippedEndpointCountBudgetSplitWithLiveLoss
                    (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
                    (tailShiftSeq D.H s) (tailShiftSeq D.V s)
                    (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
                    (clippedLayerCakeQuadraticEffectiveDelta B) liveLoss

/-- The zero-live budget target is a special case of the small-live target. -/
theorem oneOverPiTailStableSmallLiveBudgetSplitForClosureTarget_of_zeroLive
    (hZero : OneOverPiTailStableClippedZeroLiveBudgetSplitForClosureTarget) :
    OneOverPiTailStableSmallLiveBudgetSplitForClosureTarget := by
  intro B hB hBound baseShift hCap D s
  refine ⟨0, by norm_num, ?_, ?_⟩
  · exact clippedLayerCakeQuadraticEffectiveSlack_pos (B := B) hB
  · exact hZero B hB hBound baseShift hCap D s

/-- Final small-live endpoint geometry target. -/
def OneOverPiFinalEndpointGeometrySmallLiveBudgetTarget : Prop :=
  OneOverPiTailStableOrderedEndpointClosureForShiftTarget ∧
  OneOverPiTailStableSmallLiveBudgetSplitForClosureTarget

/-! ## Final conversion from small-live endpoint geometry -/

/-- Construct the quadratic small-live core data for one cap `B` from the final
endpoint-geometry small-live budget target.

The construction first chooses the ratio-cap shift supplied by the finite
measure reduction, then chooses one more tail shift so that qlog positivity and
the ratio cap are global.  The endpoint closure and small-live budget split are
the two fields of the final endpoint-geometry target. -/
theorem clippedLayerCakeQuadraticSmallLiveCoreData_of_finalEndpointGeometrySmallLiveBudgetTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveBudgetTarget)
    {B : ℝ} (hB : 4 < B)
    (hBound : OneOverPiMeasureStrictlyBelowEffectiveRaw B) :
    Nonempty (ClippedLayerCakeQuadraticSmallLiveCoreData B) := by
  rcases hFinal with ⟨hClosure, hSmallLive⟩
  have hRatioTarget : OneOverPiShiftedQlogRatioCapFromMeasureTarget :=
    oneOverPiShiftedQlogRatioCapFromMeasureTarget_of_denLogRatioBounded
      oneOverPiContinuantDenLogRatioBoundedTarget_of_finiteMeasure
  rcases hRatioTarget B hB hBound with ⟨baseShift, hCap⟩
  rcases hClosure B hB hBound baseShift hCap with ⟨D⟩
  rcases exists_tailShiftSeq_pos_and_ratioBoundedBy
      (X := oneOverPiShiftedQlog baseShift) (R := B - 1)
      (oneOverPiShiftedQlog_eventuallyPositiveLogScale baseShift) hCap with
    ⟨s, hXpos, hRatio⟩
  rcases hSmallLive B hB hBound baseShift hCap D s with
    ⟨liveLoss, hlive_nonneg, hlive_lt, hBudget⟩
  refine ⟨{
    X := tailShiftSeq (oneOverPiShiftedQlog baseShift) s
    H := tailShiftSeq D.H s
    V := tailShiftSeq D.V s
    Hlog := tailShiftSeq D.Hlog s
    u := tailShiftSeq D.u s
    vseq := tailShiftSeq D.vseq s
    closureCert := D.closureCert_tail s
    bauer := D.bauer
    finiteData := ?_
    eps := liveLoss
    eps_nonneg := hlive_nonneg
    eps_lt_slack := hlive_lt
    budgetSplit := hBudget
  }⟩
  have hrange := clippedLayerCakeTrialNu_range (M := B) hB
  exact clippedOneThresholdFiniteData_of_ratioBounded
    (X := tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
    (B := B) (nu := clippedLayerCakeTrialNu B)
    hrange.1 (le_of_lt hrange.2)
    hXpos
    (monotone_tailShiftSeq
      (X := oneOverPiShiftedQlog baseShift) (N := s)
      (oneOverPiShiftedQlog_monotone baseShift))
    hRatio

/-- The final endpoint-geometry small-live budget target supplies the generic
small-live quadratic core-data target. -/
theorem clippedLayerCakeQuadraticSmallLiveCoreDataTarget_of_finalEndpointGeometrySmallLiveBudgetTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveBudgetTarget) :
    ClippedLayerCakeQuadraticSmallLiveCoreDataTarget := by
  intro B hB hBound
  exact clippedLayerCakeQuadraticSmallLiveCoreData_of_finalEndpointGeometrySmallLiveBudgetTarget
    hFinal hB hBound

/-- The final endpoint-geometry small-live budget target implies the desired
non-strict bound for `1 / pi`. -/
theorem oneOverPiMeasureAtMost_four_of_finalEndpointGeometrySmallLiveBudgetTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveBudgetTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases exists_oneOverPiMeasureStrictlyBelowEffectiveRaw_of_finiteMeasure with
    ⟨B0, hB0, hStart⟩
  intro mu hmu
  exact oneOverPi_irratMeasure_le_four_of_quadraticSmallLiveCoreDataTarget
    (clippedLayerCakeQuadraticSmallLiveCoreDataTarget_of_finalEndpointGeometrySmallLiveBudgetTarget
      hFinal)
    hB0 hStart mu hmu

/-- Version stated directly for arbitrary project-level measure witnesses. -/
theorem oneOverPi_irratMeasure_le_four_of_finalEndpointGeometrySmallLiveBudgetTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveBudgetTarget)
    {mu : ℝ}
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu) :
    mu ≤ 4 := by
  exact oneOverPiMeasureAtMost_four_of_finalEndpointGeometrySmallLiveBudgetTarget
    hFinal mu hmu

/-!
# Endpoint geometry after isolating Bauer's identity

The final small-live endpoint target above includes `BauerRamanujanIdentity`
inside the ordered endpoint closure data.  This section isolates Bauer's
identity as an explicit external input, so the remaining endpoint target asks
only for endpoint closure geometry and the small-live clipped endpoint budget
split.
-/

/-! ## Isolated external Bauer input -/

/-- External Bauer--Ramanujan identity input.

This is intentionally isolated, like the finite-measure input for `1 / pi`.
It is the only new non-structural assumption in this endpoint-only reduction. -/
axiom bauerRamanujanIdentity_external : BauerRamanujanIdentity

/-! ## Ordered endpoint geometry without a Bauer field -/

/-- Ordered endpoint closure geometry data with Bauer's identity removed. -/
structure OneOverPiTailStableOrderedEndpointClosureGeometryData
    (B : ℝ) (baseShift : ℕ) : Type where
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert_tail :
    ∀ s : ℕ,
      OrderedEndpointClosureCertificate
        (tailShiftSeq Hlog s) (tailShiftSeq u s) (tailShiftSeq vseq s)
        (tailShiftSeq H s) (tailShiftSeq V s)
        (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)

/-- Add the isolated Bauer axiom to Bauer-free endpoint closure geometry data. -/
def oneOverPiTailStableOrderedEndpointClosureData_of_geometryData
    {B : ℝ} {baseShift : ℕ}
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift) :
    OneOverPiTailStableOrderedEndpointClosureData B baseShift where
  H := G.H
  V := G.V
  Hlog := G.Hlog
  u := G.u
  vseq := G.vseq
  bauer := bauerRamanujanIdentity_external
  closureCert_tail := G.closureCert_tail

/-- Bauer-free ordered endpoint closure target. -/
def OneOverPiTailStableOrderedEndpointClosureGeometryTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            Nonempty (OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)

/-- Bauer-free ordered endpoint closure geometry, plus the external Bauer
axiom, proves the integrated ordered endpoint closure target. -/
theorem oneOverPiTailStableOrderedEndpointClosureForShiftTarget_of_geometry
    (hGeom : OneOverPiTailStableOrderedEndpointClosureGeometryTarget) :
    OneOverPiTailStableOrderedEndpointClosureForShiftTarget := by
  intro B hB hBound baseShift hCap
  rcases hGeom B hB hBound baseShift hCap with ⟨G⟩
  exact ⟨oneOverPiTailStableOrderedEndpointClosureData_of_geometryData G⟩

/-! ## Small-live budget split for Bauer-free geometry data -/

/-- Small-live clipped endpoint budget splitting for Bauer-free endpoint
geometry. -/
def OneOverPiTailStableSmallLiveBudgetSplitForGeometryTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                ∃ liveLoss : ℝ,
                  0 ≤ liveLoss ∧
                  liveLoss < clippedLayerCakeQuadraticEffectiveSlack B ∧
                  ClippedEndpointCountBudgetSplitWithLiveLoss
                    (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
                    (tailShiftSeq G.H s) (tailShiftSeq G.V s)
                    (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
                    (clippedLayerCakeQuadraticEffectiveDelta B) liveLoss

/-- Bauer-free small-live budget geometry proves the integrated small-live
budget target after adding the external Bauer axiom. -/
theorem oneOverPiTailStableSmallLiveBudgetSplitForClosureTarget_of_geometry
    (hBudget : OneOverPiTailStableSmallLiveBudgetSplitForGeometryTarget) :
    OneOverPiTailStableSmallLiveBudgetSplitForClosureTarget := by
  intro B hB hBound baseShift hCap D s
  let G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift := {
    H := D.H
    V := D.V
    Hlog := D.Hlog
    u := D.u
    vseq := D.vseq
    closureCert_tail := D.closureCert_tail
  }
  simpa [G] using hBudget B hB hBound baseShift hCap G s

/-! ## Endpoint-only target and final measure wrappers -/

/-- Final endpoint geometry target after Bauer's identity has been isolated as
an external axiom. -/
def OneOverPiEndpointGeometryOnlySmallLiveBudgetTarget : Prop :=
  OneOverPiTailStableOrderedEndpointClosureGeometryTarget ∧
  OneOverPiTailStableSmallLiveBudgetSplitForGeometryTarget

/-- Endpoint-only target implies the previous final small-live endpoint target,
using the isolated Bauer axiom. -/
theorem oneOverPiFinalEndpointGeometrySmallLiveBudgetTarget_of_endpointOnlyTarget
    (h : OneOverPiEndpointGeometryOnlySmallLiveBudgetTarget) :
    OneOverPiFinalEndpointGeometrySmallLiveBudgetTarget := by
  rcases h with ⟨hGeom, hBudget⟩
  exact ⟨
    oneOverPiTailStableOrderedEndpointClosureForShiftTarget_of_geometry hGeom,
    oneOverPiTailStableSmallLiveBudgetSplitForClosureTarget_of_geometry hBudget
  ⟩

/-- Final non-strict measure bound from the endpoint-only small-live target,
with Bauer supplied by the isolated external axiom. -/
theorem oneOverPiMeasureAtMost_four_of_endpointOnlySmallLiveBudgetTarget
    (h : OneOverPiEndpointGeometryOnlySmallLiveBudgetTarget) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_finalEndpointGeometrySmallLiveBudgetTarget
    (oneOverPiFinalEndpointGeometrySmallLiveBudgetTarget_of_endpointOnlyTarget h)

/-- Version stated for an arbitrary project-level irrationality-measure witness. -/
