/-- Target using clipped interval budgets instead of an abstract subwindow-control
field. -/
def ClippedCanonicalLiveLossSubwindowClippedIntervalBudgetTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedCanonicalLiveLossSubwindowClippedIntervalBudgetData B hB)

/-- Clipped interval-budget live-loss target implies the integrated subwindow
target. -/
theorem canonicalLiveLossSubwindowTarget_of_clippedIntervalBudgetTarget
    (h : ClippedCanonicalLiveLossSubwindowClippedIntervalBudgetTarget) :
