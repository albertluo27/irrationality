/-!
# Telescoping cutoff-budget bridge

This compatibility layer connects the zero-live cutoff-budget split API to the
clean telescoping final route.  The finite endpoint average is supplied by
`clippedEndpointWeightedAverageBound_of_telescoping_global`; the cutoff-budget
input supplies the control bridge for non-visible bad shells.
-/

/-- A zero-live cutoff-budget split supplies the `controls` field needed by the
clean telescoping step data. -/
def TelescopingClippedStepDataClean.ofBudgetSplitZeroLive
    {B M : ℝ}
    {nu tau x : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (closure : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (bauer : BauerRamanujanIdentity)
    (nu_gt_two : 2 < nu)
    (nu_le_B : nu ≤ B)
    (nu_lt_M : nu < M)
    (tau_pos : 0 < tau)
    (x_gt_contraction : shellSpikeContractionExponent tau nu M < x)
    (x_lt_one : x < 1)
    (x_le_global : x ≤ shellSpikeGlobalExponent tau)
    (gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (X_pos : ∀ j : ℕ, 0 < X j)
    (X_mono : Monotone X)
    (ratio_cap : RatioBoundedBy X (B - 1))
    (budgetSplit :
      ClippedEndpointBudgetSplitWithLiveLoss
        X H V nu x (telescopingClippedEndpointDelta B nu) 0)
    (gain_strict :
      nu / M + telescopingClippedEndpointDelta B nu
        < shellSpikeGoodDensityGain tau x) :
    TelescopingClippedStepDataClean B M where
  nu := nu
  tau := tau
  x := x
  X := X
  H := H
  V := V
  Hlog := Hlog
  u := u
  vseq := vseq
  closure := closure
  bauer := bauer
  nu_gt_two := nu_gt_two
  nu_le_B := nu_le_B
  nu_lt_M := nu_lt_M
  tau_pos := tau_pos
  x_gt_contraction := x_gt_contraction
  x_lt_one := x_lt_one
  x_le_global := x_le_global
  gain_le_one := gain_le_one
  X_pos := X_pos
  X_mono := X_mono
  ratio_cap := ratio_cap
  controls :=
    clippedEndpointControlsNonVisibleBad_of_budgetSplit_zeroLive
      (X := X) (H := H) (V := V) (nu := nu) (x := x)
      (delta := telescopingClippedEndpointDelta B nu)
      budgetSplit
  gain_strict := gain_strict

/-- A proposition-valued one-step factory based on zero-live cutoff-budget
splits.  This is only a compatibility interface for fields already consumed by
the constructor above. -/
def TelescopingCutoffBudgetStepFactory (B M : ℝ) : Prop :=
  ∃ (nu tau x : ℝ) (X H V Hlog u vseq : ℕ → ℝ),
    OrderedEndpointClosureCertificate Hlog u vseq H V tau x ∧
    BauerRamanujanIdentity ∧
    2 < nu ∧
    nu ≤ B ∧
    nu < M ∧
    0 < tau ∧
    shellSpikeContractionExponent tau nu M < x ∧
    x < 1 ∧
    x ≤ shellSpikeGlobalExponent tau ∧
    shellSpikeGoodDensityGain tau x ≤ 1 ∧
    (∀ j : ℕ, 0 < X j) ∧
    Monotone X ∧
    RatioBoundedBy X (B - 1) ∧
    ClippedEndpointBudgetSplitWithLiveLoss
      X H V nu x (telescopingClippedEndpointDelta B nu) 0 ∧
    nu / M + telescopingClippedEndpointDelta B nu
      < shellSpikeGoodDensityGain tau x

/-- Geometry data for one telescoping cutoff-budget step after the scalar
exponent `nu` has already been chosen. -/
structure TelescopingCutoffBudgetGeometryForNu (B M nu : ℝ) : Type where
  tau : ℝ
  x : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closure : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_le_B : nu ≤ B
  tau_pos : 0 < tau
  x_gt_contraction : shellSpikeContractionExponent tau nu M < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  X_pos : ∀ j : ℕ, 0 < X j
  X_mono : Monotone X
  ratio_cap : RatioBoundedBy X (B - 1)
  budgetSplit :
    ClippedEndpointBudgetSplitWithLiveLoss
      X H V nu x (telescopingClippedEndpointDelta B nu) 0
  gain_strict :
    nu / M + telescopingClippedEndpointDelta B nu
      < shellSpikeGoodDensityGain tau x

/-- Chosen-`nu` geometry data gives the existing one-step factory. -/
theorem telescopingCutoffBudgetStepFactory_of_geometryForNu
    {B M nu : ℝ}
    (hnu2 : 2 < nu)
    (hnuM : nu < M)
    (G : TelescopingCutoffBudgetGeometryForNu B M nu) :
    TelescopingCutoffBudgetStepFactory B M := by
  refine ⟨nu, G.tau, G.x, G.X, G.H, G.V, G.Hlog, G.u, G.vseq, ?_⟩
  exact ⟨G.closure, G.bauer, hnu2, G.nu_le_B, hnuM,
    G.tau_pos, G.x_gt_contraction, G.x_lt_one, G.x_le_global,
    G.gain_le_one, G.X_pos, G.X_mono, G.ratio_cap,
    G.budgetSplit, G.gain_strict⟩

/-- The one-step factory gives the clean telescoping step data. -/
theorem telescopingClippedStepDataClean_of_cutoffBudgetStepFactory
    {B M : ℝ}
