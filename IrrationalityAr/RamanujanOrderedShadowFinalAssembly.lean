/-!
# Cutoff-aware relevant closed/live budgets

The static `Relevant m j` API cannot see the outer counting cutoff.  The
cutoff-aware repair below uses `RelevantAt M m j` and a live predicate
`LiveAt M m` to split each initial segment into a closed interval budget plus
a live boundary budget.
-/

/-- At cutoff `M`, shell `m` lies in a real interval with a cutoff-relevant
index. -/
def CutoffRelevantNatInRealIntervalUnion
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop)
    (M m : ℕ) : Prop :=
  ∃ i : ℕ, RelevantAt M m i ∧ NatInRealInterval m (S i) (E i)

/-- Cutoff-aware relevant active indices. -/
def CutoffRelevantActiveShadowIndexFinset
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun i =>
    ∃ m : ℕ, m ≤ M ∧ RelevantAt M m i ∧ NatInRealInterval m (S i) (E i)

/-- Count of cutoff-relevant active indices. -/
def CutoffRelevantActiveShadowCount
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop) (M : ℕ) : ℕ :=
  (CutoffRelevantActiveShadowIndexFinset S E RelevantAt M).card

/-- Shells up to `M` lying in the cutoff-relevant interval union. -/
def CutoffRelevantIntegerShadowUnionFinset
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun m =>
    CutoffRelevantNatInRealIntervalUnion S E RelevantAt M m

/-- Count of shells up to `M` in the cutoff-relevant interval union. -/
def CutoffRelevantIntegerShadowUnionCount
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop) (M : ℕ) : ℕ :=
  (CutoffRelevantIntegerShadowUnionFinset S E RelevantAt M).card

/-- The finite active-index list covers all cutoff-relevant interval witnesses
needed below cutoff `M`. -/
def CutoffRelevantActiveShadowIndicesCoverUnion
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop) : Prop :=
  ∀ M m : ℕ, m ≤ M →
    CutoffRelevantNatInRealIntervalUnion S E RelevantAt M m →
      ∃ i : ℕ,
        i ∈ CutoffRelevantActiveShadowIndexFinset S E RelevantAt M ∧
        RelevantAt M m i ∧ NatInRealInterval m (S i) (E i)

/-- Sublinearity of the cutoff-relevant active index count. -/
def CutoffRelevantActiveShadowCountSublinear
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop) : Prop :=
  ∀ ε : ℝ, 0 < ε →
    ∀ᶠ M : ℕ in atTop,
      (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ)
        ≤ ε * ((M : ℝ) + 1)

/-- A clipped real-length budget for cutoff-relevant active intervals. -/
def CutoffRelevantClippedRealShadowLengthBudget
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop)
    (δ : ℝ) (Err : ℕ → ℝ) : Prop :=
  ∀ᶠ M : ℕ in atTop,
    (∑ i ∈ CutoffRelevantActiveShadowIndexFinset S E RelevantAt M,
      clippedRealIntervalLength (S i) (E i) M)
      ≤ δ * ((M : ℝ) + 1) + Err M

/-- The cutoff-relevant active-count endpoint error is sublinear. -/
theorem cutoffRelevantActiveShadowCount_error_sublinear
    {S E : ℕ → ℝ} {RelevantAt : ℕ → ℕ → ℕ → Prop}
    (hS : CutoffRelevantActiveShadowCountSublinear S E RelevantAt) :
    EventuallySublinearCountError
      (fun M : ℕ => 2 *
        (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ)) := by
  exact EventuallySublinearCountError.const_mul
    (E := fun M : ℕ =>
      (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ))
    (C := 2) (by norm_num) hS

/-- The total cutoff-relevant closed-count error is sublinear. -/
theorem cutoffRelevantIntervalCounting_totalError_sublinear
    {S E : ℕ → ℝ} {RelevantAt : ℕ → ℕ → ℕ → Prop} {Err : ℕ → ℝ}
    (hErr : EventuallySublinearCountError Err)
    (hS : CutoffRelevantActiveShadowCountSublinear S E RelevantAt) :
    EventuallySublinearCountError
      (fun M : ℕ => Err M +
        2 * (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ)) := by
  exact EventuallySublinearCountError.add hErr
    (cutoffRelevantActiveShadowCount_error_sublinear hS)

/-- The cutoff-relevant union count is bounded by the sum of one-interval counts
over the cutoff-relevant active-index finset. -/
theorem cutoffRelevantIntegerShadowUnionCount_le_sum_interval_counts
    {S E : ℕ → ℝ} {RelevantAt : ℕ → ℕ → ℕ → Prop}
    (hcover : CutoffRelevantActiveShadowIndicesCoverUnion S E RelevantAt)
    (M : ℕ) :
    (CutoffRelevantIntegerShadowUnionCount S E RelevantAt M : ℝ)
      ≤ ∑ i ∈ CutoffRelevantActiveShadowIndexFinset S E RelevantAt M,
          ((IntegerIntervalPointFinset (S i) (E i) M).card : ℝ) := by
  classical
  let U : Finset ℕ := CutoffRelevantIntegerShadowUnionFinset S E RelevantAt M
  let F : ℕ → Finset ℕ := fun i => IntegerIntervalPointFinset (S i) (E i) M
  have hU : U ⊆ (CutoffRelevantActiveShadowIndexFinset S E RelevantAt M).biUnion F := by
    intro m hm
    dsimp [U, CutoffRelevantIntegerShadowUnionFinset] at hm
    rw [Finset.mem_filter] at hm
    have hmrange : m < M + 1 := by
      simpa [Finset.mem_range] using hm.1
    have hmle : m ≤ M := Nat.le_of_lt_succ hmrange
    rcases hcover M m hmle hm.2 with ⟨i, hi, _hRel, hInt⟩
    rw [Finset.mem_biUnion]
    refine ⟨i, hi, ?_⟩
    dsimp [F, IntegerIntervalPointFinset]
    rw [Finset.mem_filter]
    exact ⟨hm.1, hInt⟩
  calc
    (CutoffRelevantIntegerShadowUnionCount S E RelevantAt M : ℝ)
        = (U.card : ℝ) := rfl
    _ ≤ (((CutoffRelevantActiveShadowIndexFinset S E RelevantAt M).biUnion F).card : ℝ) := by
          exact_mod_cast Finset.card_le_card hU
    _ ≤ (∑ i ∈ CutoffRelevantActiveShadowIndexFinset S E RelevantAt M,
            (F i).card : ℕ) := by
          exact_mod_cast Finset.card_biUnion_le
    _ = ∑ i ∈ CutoffRelevantActiveShadowIndexFinset S E RelevantAt M,
          ((IntegerIntervalPointFinset (S i) (E i) M).card : ℝ) := by
          simp [F]

/-- Cutoff-relevant interval-union count using clipped interval lengths. -/
theorem cutoffRelevantIntegerShadowUnionCount_budget_of_clippedRealLengthBudget
    {S E : ℕ → ℝ} {RelevantAt : ℕ → ℕ → ℕ → Prop}
    {δ : ℝ} {Err : ℕ → ℝ}
    (hcover : CutoffRelevantActiveShadowIndicesCoverUnion S E RelevantAt)
    (hLength : CutoffRelevantClippedRealShadowLengthBudget S E RelevantAt δ Err) :
    ∀ᶠ M : ℕ in atTop,
      (CutoffRelevantIntegerShadowUnionCount S E RelevantAt M : ℝ)
        ≤ δ * ((M : ℝ) + 1) +
          (Err M + 2 *
            (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ)) := by
  classical
  filter_upwards [hLength] with M hLen
  calc
    (CutoffRelevantIntegerShadowUnionCount S E RelevantAt M : ℝ)
        ≤ ∑ i ∈ CutoffRelevantActiveShadowIndexFinset S E RelevantAt M,
            ((IntegerIntervalPointFinset (S i) (E i) M).card : ℝ) :=
          cutoffRelevantIntegerShadowUnionCount_le_sum_interval_counts hcover M
    _ ≤ ∑ i ∈ CutoffRelevantActiveShadowIndexFinset S E RelevantAt M,
            (clippedRealIntervalLength (S i) (E i) M + 2) := by
          exact Finset.sum_le_sum (fun i _hi =>
            integerIntervalPointFinset_card_le_clippedLength_add_two)
    _ = (∑ i ∈ CutoffRelevantActiveShadowIndexFinset S E RelevantAt M,
            clippedRealIntervalLength (S i) (E i) M)
          + 2 * (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ) := by
          rw [Finset.sum_add_distrib]
          simp [CutoffRelevantActiveShadowCount, mul_comm]
    _ ≤ δ * ((M : ℝ) + 1) + Err M +
          2 * (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ) := by
          linarith
    _ = δ * ((M : ℝ) + 1) +
          (Err M + 2 *
            (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ)) := by
          ring

/-- Cutoff-aware live-boundary shells up to `M`. -/
def CutoffLiveBoundaryFinset
    (LiveAt : ℕ → ℕ → Prop) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun m => LiveAt M m

/-- Cutoff-aware live-boundary count. -/
def CutoffLiveBoundaryCount
    (LiveAt : ℕ → ℕ → Prop) (M : ℕ) : ℕ :=
  (CutoffLiveBoundaryFinset LiveAt M).card

/-- A count budget for cutoff-aware live-boundary shells. -/
def CutoffLiveBoundaryCountBudget
    (LiveAt : ℕ → ℕ → Prop) (eps : ℝ) (Err : ℕ → ℝ) : Prop :=
  ∀ᶠ M : ℕ in atTop,
    (CutoffLiveBoundaryCount LiveAt M : ℝ)
      ≤ eps * ((M : ℝ) + 1) + Err M

/-- Every static bad shell below cutoff `M` is either closed at cutoff `M` or
live at cutoff `M`. -/
def CutoffClosedLiveInitialSegmentCover
    (B : ℕ → Prop) (S E : ℕ → ℝ)
    (RelevantAt : ℕ → ℕ → ℕ → Prop)
    (LiveAt : ℕ → ℕ → Prop) : Prop :=
  ∀ M m : ℕ, m ≤ M → B m →
    CutoffRelevantNatInRealIntervalUnion S E RelevantAt M m ∨ LiveAt M m

/-- Initial-segment count of a static bad set is bounded by the cutoff-closed
count plus the cutoff-live count. -/
theorem natInitialSegmentCount_le_cutoffClosed_add_live
    {B : ℕ → Prop} {S E : ℕ → ℝ}
    {RelevantAt : ℕ → ℕ → ℕ → Prop} {LiveAt : ℕ → ℕ → Prop}
    (hcover : CutoffClosedLiveInitialSegmentCover B S E RelevantAt LiveAt)
    (M : ℕ) :
    (natInitialSegmentCount B M : ℝ)
      ≤ (CutoffRelevantIntegerShadowUnionCount S E RelevantAt M : ℝ)
        + (CutoffLiveBoundaryCount LiveAt M : ℝ) := by
  classical
  let BF : Finset ℕ := (Finset.range (M + 1)).filter B
  let CF : Finset ℕ := CutoffRelevantIntegerShadowUnionFinset S E RelevantAt M
  let LF : Finset ℕ := CutoffLiveBoundaryFinset LiveAt M
  have hsub : BF ⊆ CF ∪ LF := by
    intro m hm
    dsimp [BF] at hm
    rw [Finset.mem_filter] at hm
    have hmrange : m < M + 1 := by
      simpa [Finset.mem_range] using hm.1
    have hmle : m ≤ M := Nat.le_of_lt_succ hmrange
    rcases hcover M m hmle hm.2 with hClosed | hLive
    · exact Finset.mem_union.mpr <| Or.inl <| by
        dsimp [CF, CutoffRelevantIntegerShadowUnionFinset]
        rw [Finset.mem_filter]
        exact ⟨hm.1, hClosed⟩
    · exact Finset.mem_union.mpr <| Or.inr <| by
        dsimp [LF, CutoffLiveBoundaryFinset]
        rw [Finset.mem_filter]
        exact ⟨hm.1, hLive⟩
  have hcard₁ : (BF.card : ℝ) ≤ ((CF ∪ LF).card : ℝ) := by
    exact_mod_cast Finset.card_le_card hsub
  have hcard₂ : ((CF ∪ LF).card : ℝ) ≤ (CF.card : ℝ) + (LF.card : ℝ) := by
    exact_mod_cast Finset.card_union_le CF LF
  calc
    (natInitialSegmentCount B M : ℝ) = (BF.card : ℝ) := rfl
    _ ≤ ((CF ∪ LF).card : ℝ) := hcard₁
    _ ≤ (CF.card : ℝ) + (LF.card : ℝ) := hcard₂
    _ = (CutoffRelevantIntegerShadowUnionCount S E RelevantAt M : ℝ)
        + (CutoffLiveBoundaryCount LiveAt M : ℝ) := rfl

/-- Cutoff-aware closed/live budgets imply a static upper-density bound. -/
theorem upperNatDensityAtMost_of_cutoffRelevantClosedLiveBudgets
    {B : ℕ → Prop} {S E : ℕ → ℝ}
    {RelevantAt : ℕ → ℕ → ℕ → Prop} {LiveAt : ℕ → ℕ → Prop}
    {δ eps : ℝ} {ClosedErr LiveErr : ℕ → ℝ}
    (hcover : CutoffClosedLiveInitialSegmentCover B S E RelevantAt LiveAt)
    (hactiveCover : CutoffRelevantActiveShadowIndicesCoverUnion S E RelevantAt)
    (hLength : CutoffRelevantClippedRealShadowLengthBudget
      S E RelevantAt δ ClosedErr)
    (hActiveSublinear : CutoffRelevantActiveShadowCountSublinear S E RelevantAt)
    (hClosedErr : EventuallySublinearCountError ClosedErr)
    (hLiveBudget : CutoffLiveBoundaryCountBudget LiveAt eps LiveErr)
    (hLiveErr : EventuallySublinearCountError LiveErr) :
    UpperNatDensityAtMost B (δ + eps) := by
  have hClosedCount :=
    cutoffRelevantIntegerShadowUnionCount_budget_of_clippedRealLengthBudget
      (S := S) (E := E) (RelevantAt := RelevantAt)
      (δ := δ) (Err := ClosedErr) hactiveCover hLength
  have hClosedTotalErr : EventuallySublinearCountError
      (fun M : ℕ => ClosedErr M +
        2 * (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ)) :=
    cutoffRelevantIntervalCounting_totalError_sublinear
      (S := S) (E := E) (RelevantAt := RelevantAt)
      hClosedErr hActiveSublinear
  have hTotalErr : EventuallySublinearCountError
      (fun M : ℕ =>
        (ClosedErr M +
          2 * (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ))
          + LiveErr M) :=
    EventuallySublinearCountError.add hClosedTotalErr hLiveErr
  apply upperNatDensityAtMost_of_countBudget_sublinearError
    (B := B) (δ := δ + eps)
    (E := fun M : ℕ =>
      (ClosedErr M +
        2 * (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ))
        + LiveErr M)
  · filter_upwards [hClosedCount, hLiveBudget] with M hClosed hLive
    have hsplit := natInitialSegmentCount_le_cutoffClosed_add_live
      (B := B) (S := S) (E := E)
      (RelevantAt := RelevantAt) (LiveAt := LiveAt) hcover M
    calc
      (natInitialSegmentCount B M : ℝ)
          ≤ (CutoffRelevantIntegerShadowUnionCount S E RelevantAt M : ℝ)
            + (CutoffLiveBoundaryCount LiveAt M : ℝ) := hsplit
      _ ≤ (δ * ((M : ℝ) + 1) +
              (ClosedErr M +
                2 * (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ)))
            + (eps * ((M : ℝ) + 1) + LiveErr M) := by
            linarith
      _ = (δ + eps) * ((M : ℝ) + 1) +
            ((ClosedErr M +
              2 * (CutoffRelevantActiveShadowCount S E RelevantAt M : ℝ))
              + LiveErr M) := by
            ring
  · exact hTotalErr

/-- Endpoint data using a cutoff-aware relevant relation and cutoff-aware live
predicate. -/
structure EndpointSubwindowCutoffRelevantClosedLiveBudgetData
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Type where
  RelevantAt : ℕ → ℕ → ℕ → Prop
  LiveAt : ℕ → ℕ → Prop
  ClosedErr : ℕ → ℝ
  LiveErr : ℕ → ℝ
  cover : CutoffClosedLiveInitialSegmentCover
    (NonVisibleBadShell nu H V x)
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    RelevantAt LiveAt
  activeCover : CutoffRelevantActiveShadowIndicesCoverUnion
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    RelevantAt
  activeSublinear : CutoffRelevantActiveShadowCountSublinear
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    RelevantAt
  closedErrSublinear : EventuallySublinearCountError ClosedErr
  liveErrSublinear : EventuallySublinearCountError LiveErr
  closedLengthBudget : ClippedEndpointWeightedAverageBound X nu delta →
    CutoffRelevantClippedRealShadowLengthBudget
      (endpointSubwindowIntervalLeft nu X)
      (endpointSubwindowIntervalRight X)
      RelevantAt delta ClosedErr
  liveBudget : CutoffLiveBoundaryCountBudget LiveAt eps LiveErr

/-- Endpoint cutoff-aware budget data proves the non-visible-bad density bound. -/
theorem nonVisibleBadDensity_of_endpointCutoffRelevantClosedLiveBudgetData
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (D : EndpointSubwindowCutoffRelevantClosedLiveBudgetData
      X H V nu x delta eps)
    (havg : ClippedEndpointWeightedAverageBound X nu delta) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) (delta + eps) := by
  exact upperNatDensityAtMost_of_cutoffRelevantClosedLiveBudgets
    (B := NonVisibleBadShell nu H V x)
    (S := endpointSubwindowIntervalLeft nu X)
    (E := endpointSubwindowIntervalRight X)
    (RelevantAt := D.RelevantAt)
    (LiveAt := D.LiveAt)
    (δ := delta) (eps := eps)
    (ClosedErr := D.ClosedErr) (LiveErr := D.LiveErr)
    D.cover D.activeCover (D.closedLengthBudget havg)
    D.activeSublinear D.closedErrSublinear D.liveBudget D.liveErrSublinear

/-- Canonical live-loss data with the endpoint geometry field replaced by a
cutoff-aware closed/live budget. -/
structure ClippedCanonicalLiveLossCutoffBudgetData
    (B : ℝ) (hB : 4 < B) : Type where
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate Hlog u vseq H V
      (clippedCanonicalStrictSlackScalarData B hB).tau
      (clippedCanonicalStrictSlackScalarData B hB).x
  nu_le_B : (clippedCanonicalStrictSlackScalarData B hB).nu ≤ B
  X_pos : ∀ j : ℕ, 0 < X j
  X_mono : Monotone X
  ratio_cap : RatioBoundedBy X (B - 1)
  cutoffBudget : EndpointSubwindowCutoffRelevantClosedLiveBudgetData
    X H V
    (clippedCanonicalStrictSlackScalarData B hB).nu
    (clippedCanonicalStrictSlackScalarData B hB).x
    (oneThresholdEndpointDelta B
      (clippedCanonicalStrictSlackScalarData B hB).nu)
    (clippedCanonicalStrictSlackScalarData B hB).eps
  bauer : BauerRamanujanIdentity

/-- Cutoff-aware budget data gives the same one-step measure improvement as the
previous live-loss wrappers. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_clippedCanonicalCutoffBudgetData
    {B : ℝ} {hB : 4 < B} {mu : ℝ}
    (D : ClippedCanonicalLiveLossCutoffBudgetData B hB)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu) :
    mu < oneThresholdBootstrapRelaxedMap B := by
  have hActiveData : ClippedOneThresholdActiveMassData D.X B
      (clippedCanonicalStrictSlackScalarData B hB).nu :=
    clippedOneThresholdActiveMassData_of_globalCap
      (X := D.X) (B := B)
      (nu := (clippedCanonicalStrictSlackScalarData B hB).nu)
      (clippedCanonicalStrictSlackScalarData B hB).nu_gt_two
      D.nu_le_B D.X_pos D.X_mono D.ratio_cap
  have hAvg : ClippedEndpointWeightedAverageBound D.X
      (clippedCanonicalStrictSlackScalarData B hB).nu
      (oneThresholdEndpointDelta B
        (clippedCanonicalStrictSlackScalarData B hB).nu) :=
    clippedEndpointAverage_of_activeMassData hActiveData
  have hNV : UpperNatDensityAtMost
      (NonVisibleBadShell
        (clippedCanonicalStrictSlackScalarData B hB).nu D.H D.V
        (clippedCanonicalStrictSlackScalarData B hB).x)
      (oneThresholdEndpointDelta B
          (clippedCanonicalStrictSlackScalarData B hB).nu +
        (clippedCanonicalStrictSlackScalarData B hB).eps) :=
    nonVisibleBadDensity_of_endpointCutoffRelevantClosedLiveBudgetData
      D.cutoffBudget hAvg
  exact oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    (mu := mu)
    (nu := (clippedCanonicalStrictSlackScalarData B hB).nu)
    (M := oneThresholdBootstrapRelaxedMap B)
    (tau := (clippedCanonicalStrictSlackScalarData B hB).tau)
    (x := (clippedCanonicalStrictSlackScalarData B hB).x)
    (eps := oneThresholdEndpointDelta B
        (clippedCanonicalStrictSlackScalarData B hB).nu +
      (clippedCanonicalStrictSlackScalarData B hB).eps)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    (H := D.H) (V := D.V)
    D.closureCert D.bauer hmu
    (clippedCanonicalStrictSlackScalarData B hB).nu_gt_two
    (clippedCanonicalStrictSlackScalarData B hB).nu_lt_output
    (clippedCanonicalStrictSlackScalarData B hB).tau_pos
    (clippedCanonicalStrictSlackScalarData B hB).x_contraction
    (clippedCanonicalStrictSlackScalarData B hB).x_lt_one
    (clippedCanonicalStrictSlackScalarData B hB).x_le_global
    hNV
    (clippedCanonicalStrictSlackScalarData B hB).deltaeps_nonneg
    (clippedCanonicalStrictSlackScalarData B hB).gain_surplus

/-- Target for cutoff-aware canonical live-loss budget data. -/
def ClippedCanonicalLiveLossCutoffBudgetTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedCanonicalLiveLossCutoffBudgetData B hB)

/-- Cutoff-aware target realizes the strict-slack step. -/
theorem oneThresholdBootstrapStrictSlackStepRealized_of_cutoffBudgetTarget
    (h : ClippedCanonicalLiveLossCutoffBudgetTarget) :
    OneThresholdBootstrapStrictSlackStepRealized := by
  intro B hB hBound mu hmu
  rcases h B hB hBound with ⟨D⟩
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedCanonicalCutoffBudgetData D hmu

/-- Final package using cutoff-aware budget data. -/
structure ClippedCanonicalLiveLossCutoffBudgetFinalPackage (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  cutoffBudget : ClippedCanonicalLiveLossCutoffBudgetTarget
