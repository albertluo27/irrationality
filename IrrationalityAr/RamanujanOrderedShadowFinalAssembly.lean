/-!
# Clipped geometry active-data reduction

This layer removes a bookkeeping field from the remaining canonical geometry
target: the active-mass data is derived from positivity, monotonicity, the
one-threshold active-mass induction theorem, and a ratio cap.
-/

/-! ## Tail shifts for denominator-log sequences -/

/-- Tail-shift a real sequence by `N`. -/
def tailShiftSeq (X : ℕ → ℝ) (N : ℕ) : ℕ → ℝ :=
  fun j => X (N + j)

/-- The logarithmic jump ratio of a shifted sequence is the shifted logarithmic
jump ratio of the original sequence. -/
theorem logJumpRatio_tailShiftSeq
    (X : ℕ → ℝ) (N j : ℕ) :
    logJumpRatio (tailShiftSeq X N) j = logJumpRatio X (N + j) := by
  unfold logJumpRatio tailShiftSeq
  simp [Nat.add_assoc]

/-- Monotonicity passes to a tail shift. -/
theorem monotone_tailShiftSeq
    {X : ℕ → ℝ} {N : ℕ}
    (hmono : Monotone X) :
    Monotone (tailShiftSeq X N) := by
  intro i j hij
  unfold tailShiftSeq
  exact hmono (Nat.add_le_add_left hij N)

/-- Eventual positivity and an eventual ratio cap become global properties on a
sufficiently far tail. -/
theorem exists_tailShiftSeq_pos_and_ratioBoundedBy
    {X : ℕ → ℝ} {R : ℝ}
    (hpos : ∀ᶠ j in Filter.atTop, 0 < X j)
    (hcap : EventuallyRatioBoundedBy X R) :
    ∃ N : ℕ,
      (∀ j : ℕ, 0 < tailShiftSeq X N j) ∧
      RatioBoundedBy (tailShiftSeq X N) R := by
  rcases (Filter.eventually_atTop.1 hpos) with ⟨Npos, hNpos⟩
  rcases (Filter.eventually_atTop.1 hcap) with ⟨Ncap, hNcap⟩
  refine ⟨max Npos Ncap, ?_, ?_⟩
  · intro j
    unfold tailShiftSeq
    exact hNpos (max Npos Ncap + j)
      (le_trans (Nat.le_max_left Npos Ncap) (Nat.le_add_right _ _))
  · intro j
    rw [logJumpRatio_tailShiftSeq]
    exact hNcap (max Npos Ncap + j)
      (le_trans (Nat.le_max_right Npos Ncap) (Nat.le_add_right _ _))

/-! ## Active-data closure -/

/-- The one-threshold active-mass bound follows from the already proved
successor formula and induction theorem. -/
theorem oneThresholdActiveMassTarget_of_pos_monotone
    {X : ℕ → ℝ} {nu : ℝ}
    (hnu : 2 < nu)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X) :
    OneThresholdActiveMassTarget X nu := by
  unfold OneThresholdActiveMassTarget WeightedActiveRatioBound
  have hroute := activeMassGeometricFiniteTargetViaInduction X nu
  have hsucc : WeightedActiveRatioMassSuccFormulaTarget X nu :=
    weightedActiveRatioMassSuccFormulaTarget X nu
  have hfinite : ActiveMassGeometricFiniteTarget X nu := (hroute hsucc).2
  exact Filter.Eventually.of_forall (fun J => hfinite hnu hXpos hmono J)

/-- Global positivity, monotonicity, and a global ratio cap construct the
clipped one-threshold active-mass data package. -/
def clippedOneThresholdActiveMassData_of_globalCap
    {X : ℕ → ℝ} {B nu : ℝ}
    (hnu : 2 < nu)
    (hnuB : nu ≤ B)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X)
    (hcap : RatioBoundedBy X (B - 1)) :
    ClippedOneThresholdActiveMassData X B nu := {
  nu_le_M := hnuB
  X_pos := hXpos
  ratio_cap := hcap
  active_mass := oneThresholdActiveMassTarget_of_pos_monotone hnu hXpos hmono
}

/-- Eventual positivity and an eventual ratio cap give active-mass data after a
sufficient tail shift. -/
theorem exists_tailShiftSeq_clippedOneThresholdActiveMassData
    {X : ℕ → ℝ} {B nu : ℝ}
    (hnu : 2 < nu)
    (hnuB : nu ≤ B)
    (hXpos : ∀ᶠ j in Filter.atTop, 0 < X j)
    (hmono : Monotone X)
    (hcap : EventuallyRatioBoundedBy X (B - 1)) :
    ∃ N : ℕ,
      ClippedOneThresholdActiveMassData (tailShiftSeq X N) B nu := by
  rcases exists_tailShiftSeq_pos_and_ratioBoundedBy
    (X := X) (R := B - 1) hXpos hcap with ⟨N, hposTail, hcapTail⟩
  exact ⟨N,
    clippedOneThresholdActiveMassData_of_globalCap
      (X := tailShiftSeq X N) (B := B) (nu := nu)
      hnu hnuB hposTail (monotone_tailShiftSeq hmono) hcapTail⟩

/-! ## Tail-stable one-over-pi geometric core reduction -/

/-- If a predicate holds eventually on `ℕ`, then after some shift it holds for
all tail indices. -/
theorem exists_tailShift_forall_of_eventually_atTop
    {P : ℕ → Prop} (hP : ∀ᶠ n in Filter.atTop, P n) :
    ∃ s : ℕ, ∀ j : ℕ, P (s + j) := by
  rcases Filter.eventually_atTop.1 hP with ⟨N, hN⟩
  refine ⟨N, ?_⟩
  intro j
  exact hN (N + j) (Nat.le_add_right N j)

/-- Tail-stable one-over-pi geometric data.

This is weaker than directly giving
`OneOverPiShiftedQuadraticGeometricCoreData`: positivity and ratio caps only
need to hold eventually, while the closure certificate and clipped bridge are
asked in a form stable under discarding one more finite initial segment. -/
structure OneOverPiTailStableQuadraticGeometricCoreData (B : ℝ) : Type where
  baseShift : ℕ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  bauer : BauerRamanujanIdentity
  X_pos_eventual : EventuallyPositiveLogScale (oneOverPiShiftedQlog baseShift)
  X_mono : Monotone (oneOverPiShiftedQlog baseShift)
  ratio_cap_eventual :
    EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1)
  closureCert_tail :
    ∀ s : ℕ,
      OrderedEndpointClosureCertificate
        (tailShiftSeq Hlog s) (tailShiftSeq u s) (tailShiftSeq vseq s)
        (tailShiftSeq H s) (tailShiftSeq V s)
        (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)
  clippedControls_tail :
    ∀ s : ℕ,
      ClippedEndpointWeightedAverageControlsNonVisibleBad
        (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
        (tailShiftSeq H s) (tailShiftSeq V s)
        (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
        (clippedLayerCakeQuadraticEffectiveDelta B)

/-- Tail-stable data gives the abstract geometric core data after choosing a
large enough tail shift. -/
def clippedLayerCakeQuadraticGeometricCoreData_of_tailStableData
    {B : ℝ} (D : OneOverPiTailStableQuadraticGeometricCoreData B) :
    ClippedLayerCakeQuadraticGeometricCoreData B := by
  let hTail := exists_tailShiftSeq_pos_and_ratioBoundedBy
      (X := oneOverPiShiftedQlog D.baseShift) (R := B - 1)
      D.X_pos_eventual D.ratio_cap_eventual
  let s : ℕ := Classical.choose hTail
  have hs :
      (∀ j : ℕ, 0 < tailShiftSeq (oneOverPiShiftedQlog D.baseShift) s j) ∧
        RatioBoundedBy (tailShiftSeq (oneOverPiShiftedQlog D.baseShift) s)
          (B - 1) :=
    Classical.choose_spec hTail
  exact
    { X := tailShiftSeq (oneOverPiShiftedQlog D.baseShift) s
      H := tailShiftSeq D.H s
      V := tailShiftSeq D.V s
      Hlog := tailShiftSeq D.Hlog s
      u := tailShiftSeq D.u s
      vseq := tailShiftSeq D.vseq s
      closureCert := D.closureCert_tail s
      bauer := D.bauer
      X_pos := hs.1
      X_mono := monotone_tailShiftSeq (X := oneOverPiShiftedQlog D.baseShift)
        (N := s) D.X_mono
      ratio_cap := hs.2
      clippedControls := D.clippedControls_tail s }

/-- Tail-stable target: the remaining arithmetic/geometric target after finite
initial segments have been separated from the genuine problem. -/
def OneOverPiTailStableQuadraticGeometricCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        Nonempty (OneOverPiTailStableQuadraticGeometricCoreData B)

/-- Tail-stable target implies the abstract geometric-core target. -/
theorem clippedLayerCakeQuadraticGeometricCoreDataTarget_of_tailStableTarget
    (hTail : OneOverPiTailStableQuadraticGeometricCoreDataTarget) :
    ClippedLayerCakeQuadraticGeometricCoreDataTarget := by
  intro B hB hBound
  rcases hTail B hB hBound with ⟨D⟩
  exact ⟨clippedLayerCakeQuadraticGeometricCoreData_of_tailStableData D⟩

/-- Final wrapper from the tail-stable target. -/
theorem oneOverPi_irratMeasure_le_four_of_tailStableQuadraticGeometricCoreDataTarget
    (hTail : OneOverPiTailStableQuadraticGeometricCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ mu : ℝ,
      HasIrrationalityMeasure (1 / Real.pi) mu → mu ≤ 4 := by
  exact oneOverPi_irratMeasure_le_four_of_quadraticGeometricCoreDataTarget
    (clippedLayerCakeQuadraticGeometricCoreDataTarget_of_tailStableTarget hTail)
    hB0 hStart

/-!
# Basic one-over-pi qlog reduction for the tail-stable geometric core

This layer removes automatic qlog nuisance fields from the tail-stable
geometric-core target.  Eventual positivity and monotonicity of the shifted
continued-fraction denominator log sequence are generic consequences of
positive partial quotients, leaving the eventual ratio cap as the genuine qlog
input.
-/

/-! ## Generic qlog positivity and monotonicity -/

/-- For positive partial quotients, the continuant denominator log is eventually
strictly positive. -/
theorem eventuallyPositiveLogScale_continuantQlog_of_partials_pos
    {a : ℕ → ℕ}
    (hpos : ∀ n : ℕ, 0 < a (n + 1)) :
    EventuallyPositiveLogScale (continuantQlog a) := by
  have hden_tendsto : Tendsto (fun n : ℕ => (continuantDen a n : ℝ)) atTop atTop :=
    tendsto_natCast_atTop_atTop.comp
      (continuantDen_tendsto_atTop_of_partials_pos hpos)
  have hgt : ∀ᶠ n : ℕ in atTop, (1 : ℝ) < (continuantDen a n : ℝ) :=
    hden_tendsto.eventually_gt_atTop 1
  filter_upwards [hgt] with n hn
  unfold continuantQlog
  exact Real.log_pos hn

/-- For positive partial quotients, the continuant denominator log is monotone. -/
theorem monotone_continuantQlog_of_partials_pos
    {a : ℕ → ℕ}
    (hpos : ∀ n : ℕ, 0 < a (n + 1)) :
    Monotone (continuantQlog a) := by
  intro m n hmn
  unfold continuantQlog
  have hm_pos_nat : 1 ≤ continuantDen a m :=
    one_le_continuantDen_of_partials_pos_global a hpos m
  have hm_pos : 0 < (continuantDen a m : ℝ) := by
    exact_mod_cast lt_of_lt_of_le Nat.zero_lt_one hm_pos_nat
  have hle_nat : continuantDen a m ≤ continuantDen a n :=
    continuantDen_mono_of_partials_pos_le a hpos hmn
  have hle : (continuantDen a m : ℝ) ≤ (continuantDen a n : ℝ) := by
    exact_mod_cast hle_nat
  exact Real.log_le_log hm_pos hle

/-- Eventual positivity is preserved by finite index shifts. -/
theorem EventuallyPositiveLogScale.addShift
    {X : ℕ → ℝ} {s : ℕ}
    (hX : EventuallyPositiveLogScale X) :
    EventuallyPositiveLogScale (fun j : ℕ => X (j + s)) := by
  rcases eventually_atTop.1 hX with ⟨N, hN⟩
  refine eventually_atTop.2 ⟨N, ?_⟩
  intro j hj
  exact hN (j + s) (by omega)

/-- Monotonicity is preserved by finite index shifts. -/
theorem Monotone.addShift
    {X : ℕ → ℝ} {s : ℕ}
    (hX : Monotone X) :
    Monotone (fun j : ℕ => X (j + s)) := by
  intro i j hij
  exact hX (by omega)

/-! ## Specialization to the shifted `1 / pi` qlog sequence -/

/-- Shifted `1 / pi` qlog is eventually positive. -/
theorem oneOverPiShiftedQlog_eventuallyPositiveLogScale
    (shift : ℕ) :
    EventuallyPositiveLogScale (oneOverPiShiftedQlog shift) := by
  have hbase : EventuallyPositiveLogScale (continuantQlog oneOverPiCF) :=
    eventuallyPositiveLogScale_continuantQlog_of_partials_pos
      oneOverPiCF_partials_pos
  simpa [oneOverPiShiftedQlog] using
    (EventuallyPositiveLogScale.addShift (X := continuantQlog oneOverPiCF)
      (s := shift) hbase)

/-- Shifted `1 / pi` qlog is monotone. -/
theorem oneOverPiShiftedQlog_monotone
    (shift : ℕ) :
    Monotone (oneOverPiShiftedQlog shift) := by
  have hbase : Monotone (continuantQlog oneOverPiCF) :=
    monotone_continuantQlog_of_partials_pos oneOverPiCF_partials_pos
  simpa [oneOverPiShiftedQlog] using
    (Monotone.addShift (X := continuantQlog oneOverPiCF)
      (s := shift) hbase)

/-! ## Reduced tail-stable endpoint-control target -/

/-- The only remaining qlog fact in the tail-stable route: the current strict
measure cap should imply the eventual log-jump ratio cap. -/
def OneOverPiShiftedQlogRatioCapFromMeasureTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∃ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1)

/-- Tail-stable endpoint data after removing automatic qlog positivity and
monotonicity. -/
structure OneOverPiTailStableEndpointControlData (B : ℝ) : Type where
  baseShift : ℕ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  bauer : BauerRamanujanIdentity
  ratio_cap_eventual :
    EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1)
  closureCert_tail :
    ∀ s : ℕ,
      OrderedEndpointClosureCertificate
        (tailShiftSeq Hlog s) (tailShiftSeq u s) (tailShiftSeq vseq s)
        (tailShiftSeq H s) (tailShiftSeq V s)
