    simpa [D.gain_eq_one] using D.scalar_strict

/-- Active mass plus a global ratio cap closes the clipped endpoint average.

This variant uses the already packaged `OneThresholdActiveMassTarget`, so it
does not require separately threading monotonicity or positivity through the
active-mass theorem. -/
theorem clippedEndpointWeightedAverageBound_of_activeMass_globalCap
    {X : ℕ → ℝ} {M nu : ℝ}
    (hnuM : nu ≤ M)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hcap : RatioBoundedBy X (M - 1))
    (hactive : OneThresholdActiveMassTarget X nu) :
    ClippedEndpointWeightedAverageBound X nu (oneThresholdEndpointDelta M nu) := by
  filter_upwards [hactive] with J hJ
  have hsum := endpointRatioExcessSum_le_cap_mul_weightedActiveRatioMass
    (X := X) (M := M) (nu := nu) hXpos hcap hnuM J
  have hcoef_nonneg : 0 ≤ M - nu := by linarith
  have hmul :
      (M - nu) * weightedActiveRatioMass X nu J
        ≤ (M - nu) * (oneThresholdActiveMassConstant nu * endpointRatioScale X J) := by
    exact mul_le_mul_of_nonneg_left hJ hcoef_nonneg
  have hrewrite :
      (M - nu) * (oneThresholdActiveMassConstant nu * endpointRatioScale X J)
        = oneThresholdEndpointDelta M nu * clippedEndpointScale X J := by
    unfold clippedEndpointScale oneThresholdEndpointDelta genericEndpointAverageDelta
      oneThresholdActiveMassConstant genericActiveMassConstant
    ring_nf
  unfold clippedEndpointExcessSum
  calc
    endpointRatioExcessSum nu X J
        ≤ (M - nu) * weightedActiveRatioMass X nu J := hsum
    _ ≤ (M - nu) * (oneThresholdActiveMassConstant nu * endpointRatioScale X J) := hmul
    _ = oneThresholdEndpointDelta M nu * clippedEndpointScale X J := hrewrite

/-- Repaired two-bound one-threshold package.  It uses the clipped average, not
the boundary-inclusive average. -/
def ClippedOneThresholdBootstrapPackage
    (B Mout nu tau x : ℝ) (X H V Hlog u vseq : ℕ → ℝ) : Prop :=
  ClippedEndpointWeightedAverageBound X nu (oneThresholdBootstrapDelta B nu) ∧
  ClippedEndpointWeightedAverageControlsNonVisibleBad
    X H V nu x (oneThresholdBootstrapDelta B nu) ∧
  0 ≤ oneThresholdBootstrapDelta B nu ∧
  oneThresholdBootstrapDelta B nu + nu / Mout < shellSpikeGoodDensityGain tau x

/-- The repaired clipped package feeds into the Bauer/Ramanujan contraction. -/
theorem oneOverPiMeasure_lt_of_Bauer_clippedOneThresholdBootstrapPackage
    {mu B Mout nu tau x : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < Mout)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu Mout < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (P : ClippedOneThresholdBootstrapPackage B Mout nu tau x X H V Hlog u vseq) :
    mu < Mout := by
  rcases P with ⟨hAvg, hCtrl, hDeltaNonneg, hDeltaGain⟩
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedEndpointWeightedAverage
    (mu := mu) (M := Mout) (nu := nu) (tau := tau) (x := x)
    (delta := oneThresholdBootstrapDelta B nu)
    (X := X) (H := H) (V := V) (Hlog := Hlog) (u := u) (vseq := vseq)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hgain_le_one
    hAvg hCtrl hDeltaNonneg (by simpa [add_comm] using hDeltaGain)

/-- Finite data that constructs the clipped endpoint average. -/
structure ClippedOneThresholdFiniteData (X : ℕ → ℝ) (B nu : ℝ) : Prop where
  nu_gt_two : 2 < nu
  nu_le_B : nu ≤ B
  X_pos : ∀ j : ℕ, 0 < X j
  X_mono : Monotone X
  ratio_cap : RatioBoundedBy X (B - 1)
  active_finite : ActiveMassGeometricFiniteTarget X nu

/-- Finite data produces the clipped average with the correct one-threshold
delta. -/
theorem clippedEndpointAverage_of_finiteData
    {X : ℕ → ℝ} {B nu : ℝ}
    (D : ClippedOneThresholdFiniteData X B nu) :
    ClippedEndpointWeightedAverageBound X nu (oneThresholdBootstrapDelta B nu) := by
  exact clippedEndpointWeightedAverageBound_of_activeMassFinite_global
    (X := X) (M := B) (nu := nu)
    D.nu_gt_two D.nu_le_B D.X_pos D.X_mono D.ratio_cap D.active_finite

/-- Finite data for the clipped average when the active-mass target is already
available directly. -/
structure ClippedOneThresholdActiveMassData (X : ℕ → ℝ) (M nu : ℝ) : Prop where
  nu_le_M : nu ≤ M
  X_pos : ∀ j : ℕ, 0 < X j
  ratio_cap : RatioBoundedBy X (M - 1)
  active_mass : OneThresholdActiveMassTarget X nu

/-- Active-mass data produces the clipped one-threshold average. -/
theorem clippedEndpointAverage_of_activeMassData
    {X : ℕ → ℝ} {M nu : ℝ}
    (D : ClippedOneThresholdActiveMassData X M nu) :
    ClippedEndpointWeightedAverageBound X nu (oneThresholdEndpointDelta M nu) := by
  exact clippedEndpointWeightedAverageBound_of_activeMass_globalCap
    (X := X) (M := M) (nu := nu)
    D.nu_le_M D.X_pos D.ratio_cap D.active_mass

/-!
# Layer-cake ratio-tail saving

The one-threshold active-mass estimate uses only the tail level `nu - 1`.  The
layer-cake route uses all ratio-tail levels in `[nu - 1, M - 1]`, giving the
clipped logarithmic density suggested by the integral of the generic tail
majorant.
-/

/-- The generic clipped tail majorant obtained from active-mass induction. -/
def genericClippedTailMajorant (t : ℝ) : ℝ :=
  1 / (2 * (t - 1))

/-- The active-mass induction theorem gives a tail bound at every threshold
`t > 1`, not only at `t = nu - 1`. -/
theorem weightedRatioTailMass_le_genericClippedTailMajorant
    {X : ℕ → ℝ} {t : ℝ}
    (ht : 1 < t)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X)
    (J : ℕ) :
    weightedRatioTailMass X t J
      ≤ genericClippedTailMajorant t * endpointRatioScale X J := by
  have hstrong : ActiveMassStrongInductionTarget X (t + 1) :=
    activeMassStrongInduction_of_succFormula
      (weightedActiveRatioMassSuccFormulaTarget X (t + 1))
  have hgeom : ActiveMassGeometricFiniteTarget X (t + 1) :=
    activeMassGeometricFinite_of_strongInduction hstrong
  have hmain := hgeom (by linarith) hXpos hmono J
  have hmass : weightedActiveRatioMass X (t + 1) J = weightedRatioTailMass X t J := by
    unfold weightedActiveRatioMass
    ring_nf
  have hconst : oneThresholdActiveMassConstant (t + 1) =
      genericClippedTailMajorant t := by
    unfold oneThresholdActiveMassConstant genericActiveMassConstant
      genericClippedTailMajorant
    ring_nf
  rw [hmass, hconst] at hmain
  exact hmain

/-- The generic clipped tail majorant supplies the finite partition tail bounds
whenever all left endpoints are above `1`. -/
theorem weightedRatioTailBoundOnPartition_genericClippedTailMajorant
    {K : ℕ} {X : ℕ → ℝ} {tpart : Fin (K + 1) → ℝ}
    (hleft : ∀ k : Fin K, 1 < partLeft tpart k)
    (hXpos : ∀ j : ℕ, 0 < X j)
    (hmono : Monotone X) :
    WeightedRatioTailBoundOnPartition X tpart genericClippedTailMajorant := by
  intro k
  exact Filter.Eventually.of_forall
    (fun J => weightedRatioTailMass_le_genericClippedTailMajorant
      (X := X) (t := partLeft tpart k) (hleft k) hXpos hmono J)

/-- The clipped logarithmic layer-cake endpoint density. -/
def clippedLayerCakeDelta (M nu : ℝ) : ℝ :=
  (1 / 2) * Real.log ((M - 2) / (nu - 2))

/-- The boundary-included logarithmic density obtained if the live terminal
boundary is paid for generically. -/
def boundaryIncludedLayerCakeDelta (M nu : ℝ) : ℝ :=
  ((M - 1) / M) * Real.log ((M - 2) / (nu - 2))

/-- The clipped logarithmic saving is strictly better than the one-threshold
linear saving, assuming the standard positive-ratio logarithmic inequality. -/
theorem clippedLayerCakeDelta_lt_genericEndpointAverageDelta_of_log_lt
    {M nu : ℝ}
    (hnu2 : 2 < nu)
    (hlog : Real.log ((M - 2) / (nu - 2))
        < ((M - 2) / (nu - 2)) - 1) :
    clippedLayerCakeDelta M nu < genericEndpointAverageDelta M nu := by
  have hmul :
      (1 / 2 : ℝ) * Real.log ((M - 2) / (nu - 2))
        < (1 / 2) * (((M - 2) / (nu - 2)) - 1) := by
    exact mul_lt_mul_of_pos_left hlog (by norm_num)
  have hrewrite :
      (1 / 2 : ℝ) * (((M - 2) / (nu - 2)) - 1)
        = genericEndpointAverageDelta M nu := by
    unfold genericEndpointAverageDelta
    field_simp [ne_of_gt (by linarith : 0 < nu - 2)]
    ring
  rw [hrewrite] at hmul
  simpa [clippedLayerCakeDelta] using hmul

/-- Strict condition for the clipped layer-cake saving to improve the current
bound `M` at exponent `nu`. -/
def ClippedLayerCakeStrictCondition (M nu : ℝ) : Prop :=
  2 < nu ∧ nu < M ∧ clippedLayerCakeDelta M nu + nu / M < 1

/-- Project-facing scalar target: for every `M > 4`, choose `nu` close enough to
`M` so the clipped logarithmic saving beats the contraction threshold. -/
def ClippedLayerCakeStrictConditionAboveFourTarget : Prop :=
  ∀ M : ℝ, 4 < M → ∃ nu : ℝ, ClippedLayerCakeStrictCondition M nu

/-- Boundary-included logarithmic saving condition.  This is separated because
it still needs extra endpoint arithmetic saving in the self-bootstrap range. -/
def BoundaryIncludedLayerCakeStrictCondition (M nu : ℝ) : Prop :=
  2 < nu ∧ nu < M ∧ boundaryIncludedLayerCakeDelta M nu + nu / M < 1

/-- Clipped finite layer-cake closure target. -/
def ClippedEndpointAverageBoundOfFiniteRatioTailPartitionTarget
    {K : ℕ} (X : ℕ → ℝ) (tpart : Fin (K + 1) → ℝ)
    (Phi : ℝ → ℝ) (nu R delta : ℝ) : Prop :=
  0 < K →
    StrictPartition K tpart →
    tpart ⟨0, Nat.succ_pos K⟩ = nu - 1 →
    tpart ⟨K, Nat.lt_succ_self K⟩ = R →
    (∀ j : ℕ, 0 ≤ X j) →
    EventuallyPositiveLogScale X →
    EventuallyRatioBoundedBy X R →
    WeightedRatioTailBoundOnPartition X tpart Phi →
    finiteTailUpperSum tpart Phi ≤ delta →
      ClippedEndpointWeightedAverageBound X nu delta

/-- The positive finite-tail endpoint-ratio target implies the clipped endpoint
average bound. -/
theorem clippedEndpointAverageBound_of_endpointRatioFiniteTailTarget
    {K : ℕ} {X : ℕ → ℝ} {tpart : Fin (K + 1) → ℝ}
    {Phi : ℝ → ℝ} {nu R delta : ℝ}
    (hFinite : EndpointRatioExcessSumFiniteTailUpperSumPositiveTarget
      X tpart Phi nu R)
    (hK : 0 < K)
    (hmono : StrictPartition K tpart)
    (hfirst : tpart ⟨0, Nat.succ_pos K⟩ = nu - 1)
    (hlast : tpart ⟨K, Nat.lt_succ_self K⟩ = R)
    (hXnonneg : ∀ j : ℕ, 0 ≤ X j)
    (hXpos : EventuallyPositiveLogScale X)
    (hRatioCap : EventuallyRatioBoundedBy X R)
    (hTail : WeightedRatioTailBoundOnPartition X tpart Phi)
    (hδ : finiteTailUpperSum tpart Phi ≤ delta) :
    ClippedEndpointWeightedAverageBound X nu delta := by
  have hEvent := hFinite hK hmono hfirst hlast hXpos hRatioCap hTail
  unfold ClippedEndpointWeightedAverageBound
  filter_upwards [hEvent] with J hJ
  have hscale_nonneg : 0 ≤ endpointRatioScale X J := by
    unfold endpointRatioScale
    have h0 := hXnonneg J
    have h1 := hXnonneg (J + 1)
    linarith
  calc
    clippedEndpointExcessSum X nu J
        = endpointRatioExcessSum nu X J := by
          rfl
    _ ≤ finiteTailUpperSum tpart Phi * endpointRatioScale X J := hJ
    _ ≤ delta * endpointRatioScale X J := by
          exact mul_le_mul_of_nonneg_right hδ hscale_nonneg
    _ = delta * clippedEndpointScale X J := by
          rfl

/-- Constructor for the clipped finite partition target from the endpoint-ratio
finite-tail target. -/
theorem clippedEndpointAverageBoundOfFiniteRatioTailPartitionTarget_of_endpointRatioTarget
    {K : ℕ} {X : ℕ → ℝ} {tpart : Fin (K + 1) → ℝ}
    {Phi : ℝ → ℝ} {nu R delta : ℝ}
    (hFinite : EndpointRatioExcessSumFiniteTailUpperSumPositiveTarget
      X tpart Phi nu R) :
    ClippedEndpointAverageBoundOfFiniteRatioTailPartitionTarget
      X tpart Phi nu R delta := by
  intro hK hpart hfirst hlast hXnonneg hXpos hRatioCap hTail hδ
  exact clippedEndpointAverageBound_of_endpointRatioFiniteTailTarget
    (X := X) (tpart := tpart) (Phi := Phi) (nu := nu) (R := R)
    (delta := delta) hFinite hK hpart hfirst hlast hXnonneg hXpos
    hRatioCap hTail hδ

/-- Layer-cake finite partition data with the generic clipped tail majorant. -/
def ClippedLayerCakeFinitePartitionData
    {K : ℕ} (X : ℕ → ℝ) (tpart : Fin (K + 1) → ℝ)
    (M nu delta : ℝ) : Prop :=
  0 < K ∧
  StrictPartition K tpart ∧
  tpart ⟨0, Nat.succ_pos K⟩ = nu - 1 ∧
  tpart ⟨K, Nat.lt_succ_self K⟩ = M - 1 ∧
  (∀ k : Fin K, 1 < partLeft tpart k) ∧
  (∀ j : ℕ, 0 ≤ X j) ∧
  (∀ j : ℕ, 0 < X j) ∧
  Monotone X ∧
  EventuallyPositiveLogScale X ∧
  EventuallyRatioBoundedBy X (M - 1) ∧
  finiteTailUpperSum tpart genericClippedTailMajorant ≤ delta ∧
  EndpointRatioExcessSumFiniteTailUpperSumPositiveTarget
    X tpart genericClippedTailMajorant nu (M - 1)

/-- Finite layer-cake data gives the clipped endpoint average bound. -/
theorem clippedEndpointAverageBound_of_layerCakeFinitePartitionData
    {K : ℕ} {X : ℕ → ℝ} {tpart : Fin (K + 1) → ℝ}
    {M nu delta : ℝ}
    (D : ClippedLayerCakeFinitePartitionData X tpart M nu delta) :
    ClippedEndpointWeightedAverageBound X nu delta := by
  rcases D with
    ⟨hK, hpart, hfirst, hlast, hleft, hXnonneg, hXposAll, hmono,
      hXposEv, hRatioCap, hδ, hFinite⟩
  have hTail : WeightedRatioTailBoundOnPartition X tpart genericClippedTailMajorant :=
    weightedRatioTailBoundOnPartition_genericClippedTailMajorant
      (X := X) (tpart := tpart) hleft hXposAll hmono
  exact clippedEndpointAverageBound_of_endpointRatioFiniteTailTarget
    (X := X) (tpart := tpart) (Phi := genericClippedTailMajorant)
    (nu := nu) (R := M - 1) (delta := delta)
    hFinite hK hpart hfirst hlast hXnonneg hXposEv hRatioCap hTail hδ

/-- If the clipped logarithmic layer-cake average and clipped bridge are
available, the existing Bauer/Ramanujan wrapper gives measure improvement. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_clippedLayerCakeSaving
    {mu M nu tau x : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (havg : ClippedEndpointWeightedAverageBound X nu
      (clippedLayerCakeDelta M nu))
    (hctrl : ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V nu x (clippedLayerCakeDelta M nu))
    (hdelta_nonneg : 0 ≤ clippedLayerCakeDelta M nu)
    (hstrict : clippedLayerCakeDelta M nu + nu / M
      < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedEndpointWeightedAverage
    (mu := mu) (M := M) (nu := nu) (tau := tau) (x := x)
    (delta := clippedLayerCakeDelta M nu)
    (X := X) (H := H) (V := V) (Hlog := Hlog) (u := u) (vseq := vseq)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ hgain_le_one
    havg hctrl hdelta_nonneg (by simpa [add_comm] using hstrict)

/-!
# Scalar strictness for the clipped layer-cake route

For every `M > 4`, choosing `nu = M - (M - 4) / 4` makes the clipped
logarithmic layer-cake density strictly smaller than the available gap
`1 - nu / M`.
-/

/-- A concrete trial exponent for the clipped layer-cake route. -/
def clippedLayerCakeTrialNu (M : ℝ) : ℝ :=
  M - (M - 4) / 4

/-- The trial exponent lies in the required range whenever `M > 4`. -/
theorem clippedLayerCakeTrialNu_range
    {M : ℝ} (hM : 4 < M) :
    2 < clippedLayerCakeTrialNu M ∧ clippedLayerCakeTrialNu M < M := by
  unfold clippedLayerCakeTrialNu
  constructor <;> nlinarith

/-- The trial exponent has denominator gap `(M - 4) / 4`. -/
theorem M_sub_clippedLayerCakeTrialNu
    (M : ℝ) :
    M - clippedLayerCakeTrialNu M = (M - 4) / 4 := by
  unfold clippedLayerCakeTrialNu
  ring

/-- Explicit formula for the elementary logarithmic upper majorant at the trial
exponent. -/
theorem clippedLayerCakeTrial_logMajorant_formula
    {M : ℝ} (hM : 4 < M) :
    (1 / 2) * (((M - 2) / (clippedLayerCakeTrialNu M - 2)) - 1)
      = (M - 4) / (2 * (3 * M - 4)) := by
  have hden : clippedLayerCakeTrialNu M - 2 = (3 * M - 4) / 4 := by
    unfold clippedLayerCakeTrialNu
    ring
  rw [hden]
  rw [eq_div_iff (show 2 * (3 * M - 4) ≠ 0 by nlinarith)]
  field_simp [show (3 * M - 4) / 4 ≠ 0 by nlinarith]
  field_simp [show M * 3 - 4 ≠ 0 by nlinarith]
  ring

/-- At the trial exponent, the logarithmic clipped layer-cake density is strictly
below the available gap `1 - nu / M`. -/
theorem clippedLayerCakeDelta_trial_lt_gap
    {M : ℝ} (hM : 4 < M) :
    clippedLayerCakeDelta M (clippedLayerCakeTrialNu M)
      < (M - clippedLayerCakeTrialNu M) / M := by
  have htrial_range := clippedLayerCakeTrialNu_range (M := M) hM
  have hnu2 : 2 < clippedLayerCakeTrialNu M := htrial_range.1
  have hM2pos : 0 < M - 2 := by nlinarith
  have hnu2pos : 0 < clippedLayerCakeTrialNu M - 2 := by linarith
  have hratio_pos : 0 < (M - 2) / (clippedLayerCakeTrialNu M - 2) :=
    div_pos hM2pos hnu2pos
  have hlogle :
      Real.log ((M - 2) / (clippedLayerCakeTrialNu M - 2))
        ≤ ((M - 2) / (clippedLayerCakeTrialNu M - 2)) - 1 :=
    Real.log_le_sub_one_of_pos hratio_pos
  have hhalf_nonneg : (0 : ℝ) ≤ 1 / 2 := by norm_num
  have hdelta_le :
      clippedLayerCakeDelta M (clippedLayerCakeTrialNu M)
        ≤ (1 / 2) * (((M - 2) / (clippedLayerCakeTrialNu M - 2)) - 1) := by
    unfold clippedLayerCakeDelta
    exact mul_le_mul_of_nonneg_left hlogle hhalf_nonneg
  have hmajorant_formula :=
    clippedLayerCakeTrial_logMajorant_formula (M := M) hM
  have hgap_formula :
      (M - clippedLayerCakeTrialNu M) / M = (M - 4) / (4 * M) := by
    rw [M_sub_clippedLayerCakeTrialNu]
    ring
  have hstrict_majorant :
      (M - 4) / (2 * (3 * M - 4)) < (M - 4) / (4 * M) := by
    have hnum : 0 < M - 4 := by nlinarith
    have hden1 : 0 < 2 * (3 * M - 4) := by nlinarith
    have hden2 : 0 < 4 * M := by nlinarith
    exact (div_lt_div_iff_of_pos_left hnum hden1 hden2).mpr (by nlinarith)
  calc
    clippedLayerCakeDelta M (clippedLayerCakeTrialNu M)
        ≤ (1 / 2) * (((M - 2) / (clippedLayerCakeTrialNu M - 2)) - 1) := hdelta_le
    _ = (M - 4) / (2 * (3 * M - 4)) := hmajorant_formula
    _ < (M - 4) / (4 * M) := hstrict_majorant
    _ = (M - clippedLayerCakeTrialNu M) / M := by rw [hgap_formula]

/-- Therefore the clipped layer-cake strict condition holds for the concrete
trial exponent. -/
theorem clippedLayerCakeStrictCondition_trial
    {M : ℝ} (hM : 4 < M) :
    ClippedLayerCakeStrictCondition M (clippedLayerCakeTrialNu M) := by
  have hrange := clippedLayerCakeTrialNu_range (M := M) hM
  refine ⟨hrange.1, hrange.2, ?_⟩
  have hMpos : 0 < M := by nlinarith
  have hgap := clippedLayerCakeDelta_trial_lt_gap (M := M) hM
  have hdiv_identity :
      clippedLayerCakeTrialNu M / M
        = 1 - (M - clippedLayerCakeTrialNu M) / M := by
    field_simp [ne_of_gt hMpos]
    ring
  rw [hdiv_identity]
  linarith

/-- The scalar calculus target for the clipped layer-cake route is closed. -/
theorem clippedLayerCakeStrictConditionAboveFourTarget_proved :
    ClippedLayerCakeStrictConditionAboveFourTarget := by
  intro M hM
  exact ⟨clippedLayerCakeTrialNu M,
    clippedLayerCakeStrictCondition_trial (M := M) hM⟩

/-- Nonnegativity of the clipped layer-cake density in the intended range. -/
theorem clippedLayerCakeDelta_nonneg
    {M nu : ℝ} (hnu2 : 2 < nu) (hnuM : nu ≤ M) :
    0 ≤ clippedLayerCakeDelta M nu := by
  unfold clippedLayerCakeDelta
  have hdenpos : 0 < nu - 2 := by linarith
  have hratio_ge_one : (1 : ℝ) ≤ (M - 2) / (nu - 2) := by
    field_simp [ne_of_gt hdenpos]
    linarith
  have hlog_nonneg : 0 ≤ Real.log ((M - 2) / (nu - 2)) :=
    Real.log_nonneg hratio_ge_one
  nlinarith

/-- The concrete trial exponent is actually above `4`, not merely above `2`. -/
theorem clippedLayerCakeTrialNu_gt_four
    {B : ℝ} (hB : 4 < B) :
    4 < clippedLayerCakeTrialNu B := by
  unfold clippedLayerCakeTrialNu
  nlinarith

/-- At the trial exponent, the logarithmic density is strictly below its linear
majorant. -/
theorem clippedLayerCakeDelta_trial_lt_majorant
    {B : ℝ} (hB : 4 < B) :
    clippedLayerCakeDelta B (clippedLayerCakeTrialNu B)
      < (B - 4) / (2 * (3 * B - 4)) := by
  have hrange := clippedLayerCakeTrialNu_range (M := B) hB
  have hB2pos : 0 < B - 2 := by nlinarith
  have hnu2pos : 0 < clippedLayerCakeTrialNu B - 2 := by linarith
  have hratio_pos : 0 < (B - 2) / (clippedLayerCakeTrialNu B - 2) :=
    div_pos hB2pos hnu2pos
  have hratio_ne : (B - 2) / (clippedLayerCakeTrialNu B - 2) ≠ 1 := by
    intro h
    have hmul : B - 2 = clippedLayerCakeTrialNu B - 2 := by
      have hcong := congrArg
        (fun y : ℝ => y * (clippedLayerCakeTrialNu B - 2)) h
      field_simp [ne_of_gt hnu2pos] at hcong
      linarith
    linarith
  have hlog : Real.log ((B - 2) / (clippedLayerCakeTrialNu B - 2))
      < (B - 2) / (clippedLayerCakeTrialNu B - 2) - 1 :=
    Real.log_lt_sub_one_of_pos hratio_pos hratio_ne
  have hdelta_lt :
      clippedLayerCakeDelta B (clippedLayerCakeTrialNu B)
        < (1 / 2) * (((B - 2) / (clippedLayerCakeTrialNu B - 2)) - 1) := by
    unfold clippedLayerCakeDelta
    exact mul_lt_mul_of_pos_left hlog (by norm_num)
  have hmajorant_formula := clippedLayerCakeTrial_logMajorant_formula (M := B) hB
  exact hdelta_lt.trans_eq hmajorant_formula

/-- The clipped logarithmic layer-cake density is strictly smaller than the old
one-threshold endpoint density whenever `2 < nu < B`. -/
theorem clippedLayerCakeDelta_lt_oneThresholdEndpointDelta
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu < B) :
    clippedLayerCakeDelta B nu < oneThresholdEndpointDelta B nu := by
  have hdenpos : 0 < nu - 2 := by linarith
  have hratio_pos : 0 < (B - 2) / (nu - 2) := by
    have hnum : 0 < B - 2 := by linarith
    exact div_pos hnum hdenpos
  have hratio_ne : (B - 2) / (nu - 2) ≠ 1 := by
    intro h
    have hmul : B - 2 = nu - 2 := by
      have hcong := congrArg (fun y : ℝ => y * (nu - 2)) h
      field_simp [ne_of_gt hdenpos] at hcong
      linarith
    linarith
  have hlog : Real.log ((B - 2) / (nu - 2))
      < (B - 2) / (nu - 2) - 1 :=
    Real.log_lt_sub_one_of_pos hratio_pos hratio_ne
  have hgeneric := clippedLayerCakeDelta_lt_genericEndpointAverageDelta_of_log_lt
    (M := B) (nu := nu) hnu2 hlog
  simpa [oneThresholdEndpointDelta] using hgeneric

/-- Non-strict comparison version, useful at the closed endpoint. -/
theorem clippedLayerCakeDelta_le_oneThresholdEndpointDelta
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu ≤ B) :
    clippedLayerCakeDelta B nu ≤ oneThresholdEndpointDelta B nu := by
  rcases lt_or_eq_of_le hnuB with hlt | heq
  · exact le_of_lt (clippedLayerCakeDelta_lt_oneThresholdEndpointDelta
      (B := B) (nu := nu) hnu2 hlt)
  · subst B
    unfold clippedLayerCakeDelta oneThresholdEndpointDelta genericEndpointAverageDelta
    have hden : nu - 2 ≠ 0 := by linarith
    field_simp [hden]
    simp

/-!
# Clipped layer-cake cap-to-output bootstrap step

This separates the current cap `B` from the new target/output `Mout`.  The
finite ratio-tail estimate is controlled by the old cap `B`, while the
Ramanujan density contraction targets the smaller output `Mout`.
-/

/-- The layer-cake output obtained from a cap `B` and trial exponent `nu`. -/
def clippedLayerCakeOutput (B nu : ℝ) : ℝ :=
  nu / (1 - clippedLayerCakeDelta B nu)

/-- The explicit bootstrap output from cap `B`. -/
def clippedLayerCakeTrialOutput (B : ℝ) : ℝ :=
  clippedLayerCakeOutput B (clippedLayerCakeTrialNu B)

/-- Two-parameter strict condition: the endpoint average is controlled using the
old cap `B`, while the density contraction targets `Mout`. -/
def ClippedLayerCakeCapStrictCondition (B Mout nu : ℝ) : Prop :=
  4 < B ∧ 4 < Mout ∧ Mout < B ∧
  2 < nu ∧ nu < Mout ∧
  clippedLayerCakeDelta B nu + nu / Mout < 1

/-- The denominator in the trial output is positive. -/
theorem one_sub_clippedLayerCakeDelta_trial_pos
    {B : ℝ} (hB : 4 < B) :
    0 < 1 - clippedLayerCakeDelta B (clippedLayerCakeTrialNu B) := by
  have hgap := clippedLayerCakeDelta_trial_lt_gap (M := B) hB
  have hrange := clippedLayerCakeTrialNu_range (M := B) hB
  have hBpos : 0 < B := by nlinarith
  have hgap_lt_one : (B - clippedLayerCakeTrialNu B) / B < 1 := by
    have hnu_pos : 0 < clippedLayerCakeTrialNu B := by linarith
    field_simp [ne_of_gt hBpos]
    linarith
  linarith

/-- The trial output is strictly below the current cap. -/
theorem clippedLayerCakeTrialOutput_lt_self
    {B : ℝ} (hB : 4 < B) :
    clippedLayerCakeTrialOutput B < B := by
  unfold clippedLayerCakeTrialOutput clippedLayerCakeOutput
  let nu := clippedLayerCakeTrialNu B
  let delta := clippedLayerCakeDelta B nu
  have hBpos : 0 < B := by nlinarith
  have hdenpos : 0 < 1 - delta := by
    simpa [nu, delta] using one_sub_clippedLayerCakeDelta_trial_pos (B := B) hB
  have hgap := clippedLayerCakeDelta_trial_lt_gap (M := B) hB
  have hgap' : delta < (B - nu) / B := by
    simpa [nu, delta] using hgap
  have hstrict : delta + nu / B < 1 := by
    have hrewrite : (B - nu) / B = 1 - nu / B := by
      field_simp [ne_of_gt hBpos]
    rw [hrewrite] at hgap'
    linarith
  have hnu_lt : nu < B * (1 - delta) := by
    have hmul : B * (delta + nu / B) < B * 1 :=
      mul_lt_mul_of_pos_left hstrict hBpos
    field_simp [ne_of_gt hBpos] at hmul
    linarith
  rw [div_lt_iff₀ hdenpos]
  exact hnu_lt

/-- The trial output is above `4`. -/
theorem four_lt_clippedLayerCakeTrialOutput
    {B : ℝ} (hB : 4 < B) :
    4 < clippedLayerCakeTrialOutput B := by
  unfold clippedLayerCakeTrialOutput clippedLayerCakeOutput
  let nu := clippedLayerCakeTrialNu B
  let delta := clippedLayerCakeDelta B nu
  have hrange := clippedLayerCakeTrialNu_range (M := B) hB
  have hnu4 : 4 < nu := by
    unfold nu clippedLayerCakeTrialNu
    nlinarith
  have hdenpos : 0 < 1 - delta := by
    simpa [nu, delta] using one_sub_clippedLayerCakeDelta_trial_pos (B := B) hB
  have hdelta_nonneg : 0 ≤ delta := by
    have hnu2 : 2 < nu := by simpa [nu] using hrange.1
    have hnu_le_B : nu ≤ B := by
      have hlt : nu < B := by simpa [nu] using hrange.2
      exact le_of_lt hlt
    simpa [nu, delta] using clippedLayerCakeDelta_nonneg
      (M := B) (nu := nu) hnu2 hnu_le_B
  have hden_le_one : 1 - delta ≤ 1 := by linarith
  have hnu_pos : 0 < nu := by linarith
  have hnu_le_output : nu ≤ nu / (1 - delta) := by
    rw [le_div_iff₀ hdenpos]
    nlinarith
  exact lt_of_lt_of_le hnu4 hnu_le_output

/-!
The exact output `nu / (1 - delta)` only gives equality in the density
contraction expression.  For strict Lean wrappers, use a relaxed output between
this value and the old cap.
-/

/-- A strict relaxed output chosen between the exact trial output and the old
cap. -/
def ClippedLayerCakeRelaxedOutputData (B Mout : ℝ) : Prop :=
  4 < B ∧ clippedLayerCakeTrialOutput B < Mout ∧ Mout < B

/-- Relaxed output data gives the strict cap condition. -/
theorem clippedLayerCakeCapStrictCondition_of_relaxedOutput
    {B Mout : ℝ}
    (D : ClippedLayerCakeRelaxedOutputData B Mout) :
    ClippedLayerCakeCapStrictCondition B Mout (clippedLayerCakeTrialNu B) := by
  rcases D with ⟨hB, hOutLt, hMoutLtB⟩
  unfold ClippedLayerCakeCapStrictCondition
  have hOut4 := four_lt_clippedLayerCakeTrialOutput (B := B) hB
  have hMout4 : 4 < Mout := lt_trans hOut4 hOutLt
  have hrange := clippedLayerCakeTrialNu_range (M := B) hB
  constructor
  · exact hB
  constructor
  · exact hMout4
  constructor
  · exact hMoutLtB
  constructor
  · exact hrange.1
  constructor
  · have hnu_lt_output : clippedLayerCakeTrialNu B < clippedLayerCakeTrialOutput B := by
      unfold clippedLayerCakeTrialOutput clippedLayerCakeOutput
      let nu := clippedLayerCakeTrialNu B
      let delta := clippedLayerCakeDelta B nu
      have hdenpos : 0 < 1 - delta := by
        simpa [nu, delta] using one_sub_clippedLayerCakeDelta_trial_pos (B := B) hB
      have hdelta_pos : 0 < delta := by
        have hnu2 : 2 < nu := by simpa [nu] using hrange.1
        have hnuB : nu < B := by simpa [nu] using hrange.2
        have hB2 : 0 < B - 2 := by nlinarith
        have hnu2pos : 0 < nu - 2 := by linarith
        have hratio_gt_one : 1 < (B - 2) / (nu - 2) := by
          field_simp [ne_of_gt hnu2pos]
          linarith
        have hlog_pos : 0 < Real.log ((B - 2) / (nu - 2)) :=
          Real.log_pos hratio_gt_one
        unfold delta clippedLayerCakeDelta
        nlinarith
      have hden_lt_one : 1 - delta < 1 := by linarith
      rw [lt_div_iff₀ hdenpos]
      nlinarith
    exact lt_trans hnu_lt_output hOutLt
  · unfold clippedLayerCakeTrialOutput clippedLayerCakeOutput at hOutLt
    let nu := clippedLayerCakeTrialNu B
    let delta := clippedLayerCakeDelta B nu
    have hdenpos : 0 < 1 - delta := by
      simpa [nu, delta] using one_sub_clippedLayerCakeDelta_trial_pos (B := B) hB
    have hnu_pos : 0 < nu := by
      have hnu2 : 2 < nu := by simpa [nu] using hrange.1
      linarith
    have hOutLt' : nu / (1 - delta) < Mout := by
      simpa [nu, delta, clippedLayerCakeOutput] using hOutLt
    have hmul : nu < Mout * (1 - delta) := by
      rw [div_lt_iff₀ hdenpos] at hOutLt'
      exact hOutLt'
    have hMout_pos : 0 < Mout := by linarith
    have hineq : nu / Mout < 1 - delta := by
      rw [div_lt_iff₀ hMout_pos]
      simpa [mul_comm] using hmul
    linarith

/-- The midpoint between the exact trial output and the old cap is a canonical
strict relaxed output. -/
def clippedLayerCakeMidOutput (B : ℝ) : ℝ :=
  (clippedLayerCakeTrialOutput B + B) / 2

/-- The midpoint output lies strictly between the exact output and the old cap. -/
theorem clippedLayerCakeRelaxedOutputData_mid
    {B : ℝ} (hB : 4 < B) :
    ClippedLayerCakeRelaxedOutputData B (clippedLayerCakeMidOutput B) := by
  unfold ClippedLayerCakeRelaxedOutputData clippedLayerCakeMidOutput
  have hlt := clippedLayerCakeTrialOutput_lt_self (B := B) hB
  constructor
  · exact hB
  constructor
  · linarith
  · linarith

/-- Therefore the midpoint relaxed output gives a strict cap-to-output
layer-cake condition. -/
theorem clippedLayerCakeCapStrictCondition_mid
    {B : ℝ} (hB : 4 < B) :
    ClippedLayerCakeCapStrictCondition B
      (clippedLayerCakeMidOutput B) (clippedLayerCakeTrialNu B) := by
  exact clippedLayerCakeCapStrictCondition_of_relaxedOutput
    (clippedLayerCakeRelaxedOutputData_mid (B := B) hB)

/-- Bauer/Ramanujan wrapper with separate old cap `B` and new output `Mout`.
The endpoint average is bounded using `clippedLayerCakeDelta B nu`, while the
final contraction targets `Mout`. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_clippedLayerCakeCapSaving
    {mu B Mout nu tau x : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuMout : nu < Mout)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu Mout < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (havg : ClippedEndpointWeightedAverageBound X nu
      (clippedLayerCakeDelta B nu))
    (hctrl : ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V nu x (clippedLayerCakeDelta B nu))
    (hdelta_nonneg : 0 ≤ clippedLayerCakeDelta B nu)
    (hstrict : clippedLayerCakeDelta B nu + nu / Mout
      < shellSpikeGoodDensityGain tau x) :
    mu < Mout := by
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedEndpointWeightedAverage
    (mu := mu) (M := Mout) (nu := nu) (tau := tau) (x := x)
    (delta := clippedLayerCakeDelta B nu)
    (X := X) (H := H) (V := V) (Hlog := Hlog) (u := u) (vseq := vseq)
    C hBauer hmu hnu2 hnuMout htau hx hx1 hxθ hgain_le_one
    havg hctrl hdelta_nonneg (by simpa [add_comm] using hstrict)

/-!
# Three-quarter clipped layer-cake bootstrap step

For caps above `6`, a fixed three-quarter threshold gives a sharper explicit
cap-to-output step than the midpoint relaxation.  It uses
`nu = 2 + (3 / 4) * (B - 2)` and output `(6 / 5) * nu`.
-/

/-- The three-quarter threshold exponent. -/
def clippedLayerCakeThreeQuarterNu (B : ℝ) : ℝ :=
  2 + (3 / 4) * (B - 2)

/-- The corresponding strict output, using the safe bound
`clippedLayerCakeDelta < 1 / 6`. -/
def clippedLayerCakeThreeQuarterOutput (B : ℝ) : ℝ :=
  (6 / 5) * clippedLayerCakeThreeQuarterNu B

/-- Closed formula for the three-quarter output. -/
theorem clippedLayerCakeThreeQuarterOutput_formula (B : ℝ) :
    clippedLayerCakeThreeQuarterOutput B = (9 / 10) * B + 3 / 5 := by
  unfold clippedLayerCakeThreeQuarterOutput clippedLayerCakeThreeQuarterNu
  ring

/-- Range of the three-quarter trial when `B > 6`. -/
theorem clippedLayerCakeThreeQuarterNu_range
    {B : ℝ} (hB : 6 < B) :
    2 < clippedLayerCakeThreeQuarterNu B ∧
      clippedLayerCakeThreeQuarterNu B < clippedLayerCakeThreeQuarterOutput B ∧
      clippedLayerCakeThreeQuarterOutput B < B := by
  have hB2 : 0 < B - 2 := by linarith
  have hnu_pos : 0 < clippedLayerCakeThreeQuarterNu B := by
    unfold clippedLayerCakeThreeQuarterNu
    nlinarith
  constructor
  · unfold clippedLayerCakeThreeQuarterNu
    nlinarith
  constructor
  · unfold clippedLayerCakeThreeQuarterOutput
    nlinarith
  · rw [clippedLayerCakeThreeQuarterOutput_formula]
    nlinarith

/-- The output is above `4` when `B > 6`. -/
theorem four_lt_clippedLayerCakeThreeQuarterOutput
    {B : ℝ} (hB : 6 < B) :
    4 < clippedLayerCakeThreeQuarterOutput B := by
  rw [clippedLayerCakeThreeQuarterOutput_formula]
  nlinarith

/-- The three-quarter ratio inside the layer-cake logarithm is exactly `4 / 3`. -/
theorem clippedLayerCakeThreeQuarter_logRatio
    {B : ℝ} (hB : 6 < B) :
    (B - 2) / (clippedLayerCakeThreeQuarterNu B - 2) = 4 / 3 := by
  have hB2 : B - 2 ≠ 0 := by linarith
  unfold clippedLayerCakeThreeQuarterNu
  field_simp [hB2]
  ring

/-- The scalar logarithmic saving at the three-quarter threshold is below
`1 / 6`. -/
theorem clippedLayerCakeDelta_threeQuarter_lt_one_sixth
    {B : ℝ} (hB : 6 < B) :
    clippedLayerCakeDelta B (clippedLayerCakeThreeQuarterNu B) < 1 / 6 := by
  have hlog : Real.log (4 / 3 : ℝ) < 1 / 3 := by
    have hpos : 0 < (4 / 3 : ℝ) := by norm_num
    have h := Real.log_lt_sub_one_of_pos hpos
    norm_num at h
    exact h
  unfold clippedLayerCakeDelta
  rw [clippedLayerCakeThreeQuarter_logRatio (B := B) hB]
  nlinarith

/-- The output ratio is exactly `5 / 6`. -/
theorem clippedLayerCakeThreeQuarter_ratio
    {B : ℝ} (hB : 6 < B) :
    clippedLayerCakeThreeQuarterNu B /
      clippedLayerCakeThreeQuarterOutput B = 5 / 6 := by
  have hnu_pos : 0 < clippedLayerCakeThreeQuarterNu B := by
    have hrange := clippedLayerCakeThreeQuarterNu_range (B := B) hB
    linarith [hrange.1]
  have hnu_ne : clippedLayerCakeThreeQuarterNu B ≠ 0 := ne_of_gt hnu_pos
  unfold clippedLayerCakeThreeQuarterOutput
  field_simp [hnu_ne]

/-- The three-quarter trial gives a strict cap-to-output layer-cake condition for
all caps above `6`. -/
theorem clippedLayerCakeCapStrictCondition_threeQuarter
    {B : ℝ} (hB : 6 < B) :
    ClippedLayerCakeCapStrictCondition B
      (clippedLayerCakeThreeQuarterOutput B)
      (clippedLayerCakeThreeQuarterNu B) := by
  unfold ClippedLayerCakeCapStrictCondition
  have hB4 : 4 < B := by linarith
  have hOut4 := four_lt_clippedLayerCakeThreeQuarterOutput (B := B) hB
  have hrange := clippedLayerCakeThreeQuarterNu_range (B := B) hB
  have hdelta := clippedLayerCakeDelta_threeQuarter_lt_one_sixth (B := B) hB
  have hratio := clippedLayerCakeThreeQuarter_ratio (B := B) hB
  constructor
  · exact hB4
  constructor
  · exact hOut4
  constructor
  · exact hrange.2.2
  constructor
  · exact hrange.1
  constructor
  · exact hrange.2.1
  · rw [hratio]
    linarith

/-- The three-quarter output improves any cap above `6`. -/
theorem clippedLayerCakeThreeQuarterOutput_lt_self
    {B : ℝ} (hB : 6 < B) :
    clippedLayerCakeThreeQuarterOutput B < B := by
  exact (clippedLayerCakeThreeQuarterNu_range (B := B) hB).2.2

/-- Bauer/Ramanujan wrapper specialized to the three-quarter layer-cake step.
This gives a sharper explicit output than the midpoint relaxation whenever the
current cap is above `6`. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_clippedLayerCakeThreeQuarterSaving
    {mu B tau x : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (hB : 6 < B)
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau
        (clippedLayerCakeThreeQuarterNu B)
        (clippedLayerCakeThreeQuarterOutput B) < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (havg : ClippedEndpointWeightedAverageBound X
      (clippedLayerCakeThreeQuarterNu B)
      (clippedLayerCakeDelta B (clippedLayerCakeThreeQuarterNu B)))
    (hctrl : ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V (clippedLayerCakeThreeQuarterNu B) x
      (clippedLayerCakeDelta B (clippedLayerCakeThreeQuarterNu B)))
    (hdelta_nonneg :
      0 ≤ clippedLayerCakeDelta B (clippedLayerCakeThreeQuarterNu B))
    (hstrictGain :
      clippedLayerCakeDelta B (clippedLayerCakeThreeQuarterNu B) +
        clippedLayerCakeThreeQuarterNu B /
          clippedLayerCakeThreeQuarterOutput B
        < shellSpikeGoodDensityGain tau x) :
    mu < clippedLayerCakeThreeQuarterOutput B := by
  have hrange := clippedLayerCakeThreeQuarterNu_range (B := B) hB
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedLayerCakeCapSaving
    (mu := mu) (B := B)
    (Mout := clippedLayerCakeThreeQuarterOutput B)
    (nu := clippedLayerCakeThreeQuarterNu B)
    (tau := tau) (x := x)
    (X := X) (H := H) (V := V)
    (Hlog := Hlog) (u := u) (vseq := vseq)
    C hBauer hmu hrange.1 hrange.2.1 htau hx hx1 hxθ hgain_le_one
    havg hctrl hdelta_nonneg hstrictGain

/-!
# Iteration of the explicit three-quarter clipped layer-cake step

The easy explicit three-quarter map is genuinely iterative above `6`, but its
fixed point is `6`, not `4`.  This records the exact iteration behavior and the
separate target needed for a variable/optimized layer-cake map converging to
`4`.
-/

/-- Iterates of the explicit three-quarter layer-cake output map. -/
def clippedLayerCakeThreeQuarterIterate (B : ℝ) : ℕ → ℝ
  | 0 => B
  | n + 1 =>
      clippedLayerCakeThreeQuarterOutput
        (clippedLayerCakeThreeQuarterIterate B n)

/-- The three-quarter map has fixed-point form around `6`. -/
theorem clippedLayerCakeThreeQuarterOutput_fixedPoint_form (B : ℝ) :
    clippedLayerCakeThreeQuarterOutput B =
      6 + (9 / 10) * (B - 6) := by
  rw [clippedLayerCakeThreeQuarterOutput_formula]
  ring

/-- Closed form for the nth iterate of the explicit three-quarter step. -/
theorem clippedLayerCakeThreeQuarterIterate_formula
    (B : ℝ) :
    ∀ n : ℕ,
      clippedLayerCakeThreeQuarterIterate B n =
        6 + ((9 / 10 : ℝ) ^ n) * (B - 6) := by
  intro n
  induction n with
  | zero =>
      simp [clippedLayerCakeThreeQuarterIterate]
  | succ n ih =>
      simp [clippedLayerCakeThreeQuarterIterate, ih,
        clippedLayerCakeThreeQuarterOutput_fixedPoint_form]
      ring

/-- If the starting cap is above `6`, every three-quarter iterate remains above
`6`. -/
theorem six_lt_clippedLayerCakeThreeQuarterIterate
    {B : ℝ} (hB : 6 < B) :
    ∀ n : ℕ, 6 < clippedLayerCakeThreeQuarterIterate B n := by
  intro n
  rw [clippedLayerCakeThreeQuarterIterate_formula]
  have hpow : 0 < ((9 / 10 : ℝ) ^ n) := by
    exact pow_pos (by norm_num) n
  have hdiff : 0 < B - 6 := by linarith
  nlinarith [mul_pos hpow hdiff]

/-- The explicit three-quarter iterate is strictly decreasing as long as the
starting cap is above `6`. -/
theorem clippedLayerCakeThreeQuarterIterate_strict_decreasing
    {B : ℝ} (hB : 6 < B) :
    ∀ n : ℕ,
      clippedLayerCakeThreeQuarterIterate B (n + 1) <
        clippedLayerCakeThreeQuarterIterate B n := by
  intro n
  rw [clippedLayerCakeThreeQuarterIterate_formula,
    clippedLayerCakeThreeQuarterIterate_formula]
  have hpow : 0 < ((9 / 10 : ℝ) ^ n) := by
    exact pow_pos (by norm_num) n
  have hdiff : 0 < B - 6 := by linarith
  rw [pow_succ]
  nlinarith

/-- Every iterate above `6` is an admissible input for the next three-quarter
step. -/
theorem clippedLayerCakeThreeQuarterIterate_step_condition
    {B : ℝ} (hB : 6 < B) :
    ∀ n : ℕ,
      6 < clippedLayerCakeThreeQuarterIterate B n ∧
      clippedLayerCakeThreeQuarterOutput
        (clippedLayerCakeThreeQuarterIterate B n) <
        clippedLayerCakeThreeQuarterIterate B n := by
  intro n
  have h6 := six_lt_clippedLayerCakeThreeQuarterIterate (B := B) hB n
  exact ⟨h6,
    clippedLayerCakeThreeQuarterOutput_lt_self (B :=
      clippedLayerCakeThreeQuarterIterate B n) h6⟩

/-- The explicit three-quarter map improves above `6`, but convergence to `4`
requires a variable or optimized layer-cake map. -/
def ClippedLayerCakeVariableIterationToFourTarget : Prop :=
  ∃ Φ : ℝ → ℝ,
    (∀ B : ℝ, 4 < B → 4 < Φ B ∧ Φ B < B) ∧
    (∀ B0 : ℝ, 4 < B0 → Filter.Tendsto
      (fun n : ℕ =>
        Nat.rec (motive := fun _ => ℝ) B0 (fun _ B => Φ B) n)
      Filter.atTop (nhds 4))

/-- The elementary half-gap map toward `4`. -/
def clippedLayerCakeHalfGapMap (B : ℝ) : ℝ :=
  4 + (B - 4) / 2

/-- The half-gap map stays strictly between `4` and its input whenever the input
is above `4`. -/
theorem clippedLayerCakeHalfGapMap_range
    {B : ℝ} (hB : 4 < B) :
    4 < clippedLayerCakeHalfGapMap B ∧ clippedLayerCakeHalfGapMap B < B := by
  unfold clippedLayerCakeHalfGapMap
  constructor <;> linarith

/-- Iterates of the half-gap map. -/
def clippedLayerCakeHalfGapIterate (B : ℝ) : ℕ → ℝ
  | 0 => B
  | n + 1 => clippedLayerCakeHalfGapMap (clippedLayerCakeHalfGapIterate B n)

/-- Closed form for the half-gap iterates. -/
theorem clippedLayerCakeHalfGapIterate_formula
    (B : ℝ) :
    ∀ n : ℕ,
      clippedLayerCakeHalfGapIterate B n =
        4 + ((1 / 2 : ℝ) ^ n) * (B - 4) := by
  intro n
  induction n with
  | zero =>
      simp [clippedLayerCakeHalfGapIterate]
  | succ n ih =>
      simp [clippedLayerCakeHalfGapIterate, clippedLayerCakeHalfGapMap, ih]
      rw [pow_succ]
      ring

/-- The half-gap iterates tend to `4`. -/
theorem tendsto_clippedLayerCakeHalfGapIterate
    (B : ℝ) :
    Tendsto (fun n : ℕ => clippedLayerCakeHalfGapIterate B n)
      atTop (nhds 4) := by
  have hpow : Tendsto (fun n : ℕ => ((1 / 2 : ℝ) ^ n)) atTop (nhds 0) := by
    exact tendsto_pow_atTop_nhds_zero_of_norm_lt_one
      (by norm_num : ‖(1 / 2 : ℝ)‖ < 1)
  have hmul : Tendsto (fun n : ℕ => ((1 / 2 : ℝ) ^ n) * (B - 4))
      atTop (nhds 0) := by
    simpa using hpow.mul_const (B - 4)
  have hadd : Tendsto (fun n : ℕ => 4 + ((1 / 2 : ℝ) ^ n) * (B - 4))
      atTop (nhds (4 + 0)) := by
    exact tendsto_const_nhds.add hmul
  have hformula :
      (fun n : ℕ => clippedLayerCakeHalfGapIterate B n) =
        fun n : ℕ => 4 + ((1 / 2 : ℝ) ^ n) * (B - 4) := by
    funext n
    exact clippedLayerCakeHalfGapIterate_formula B n
  simpa [hformula] using hadd

/-- The recursive form in `ClippedLayerCakeVariableIterationToFourTarget` is the
same as `clippedLayerCakeHalfGapIterate`. -/
theorem clippedLayerCakeHalfGapIterate_eq_natRec
    (B : ℝ) :
    (fun n : ℕ =>
      Nat.rec (motive := fun _ => ℝ) B
        (fun _ Bcur => clippedLayerCakeHalfGapMap Bcur) n)
      = clippedLayerCakeHalfGapIterate B := by
  funext n
  induction n with
  | zero => simp [clippedLayerCakeHalfGapIterate]
  | succ n ih => simp [clippedLayerCakeHalfGapIterate, ih]

/-- The currently encoded variable-iteration-to-four target is provable. -/
theorem clippedLayerCakeVariableIterationToFourTarget_proved :
    ClippedLayerCakeVariableIterationToFourTarget := by
  refine ⟨clippedLayerCakeHalfGapMap, ?_, ?_⟩
  · intro B hB
    exact clippedLayerCakeHalfGapMap_range hB
  · intro B0 _hB0
    rw [clippedLayerCakeHalfGapIterate_eq_natRec]
    exact tendsto_clippedLayerCakeHalfGapIterate B0

/-- A stronger target: the iteration map should also be certified by whatever
step-realization predicate one chooses for the clipped layer-cake route. -/
def ClippedLayerCakeRealizedVariableIterationToFourTarget
    (RealizedStep : ℝ → ℝ → Prop) : Prop :=
  ∃ Φ : ℝ → ℝ,
    (∀ B : ℝ, 4 < B → 4 < Φ B ∧ Φ B < B ∧ RealizedStep B (Φ B)) ∧
    (∀ B0 : ℝ, 4 < B0 → Tendsto
      (fun n : ℕ =>
        Nat.rec (motive := fun _ => ℝ) B0 (fun _ B => Φ B) n)
      atTop (nhds 4))

/-!
# A realized quadratic clipped layer-cake step

This section records a concrete output map realized by the clipped layer-cake
cap-to-output theorem.  Convergence of the quadratic iterates is left as an
explicit target.
-/

/-- The elementary logarithmic majorant used at the trial exponent. -/
def clippedLayerCakeTrialMajorant (B : ℝ) : ℝ :=
  (B - 4) / (2 * (3 * B - 4))

/-- The trial layer-cake density is bounded by the elementary majorant. -/
theorem clippedLayerCakeDelta_trial_le_majorant
    {B : ℝ} (hB : 4 < B) :
    clippedLayerCakeDelta B (clippedLayerCakeTrialNu B)
      ≤ clippedLayerCakeTrialMajorant B := by
  unfold clippedLayerCakeTrialMajorant
  exact le_of_lt (clippedLayerCakeDelta_trial_lt_majorant (B := B) hB)

/-- Closed form for the denominator after replacing the logarithm by the
majorant. -/
theorem one_sub_clippedLayerCakeTrialMajorant_eq
    {B : ℝ} (hB : 4 < B) :
    1 - clippedLayerCakeTrialMajorant B =
      (5 * B - 4) / (2 * (3 * B - 4)) := by
  unfold clippedLayerCakeTrialMajorant
  have hden : 2 * (3 * B - 4) ≠ 0 := by nlinarith
  calc
    1 - (B - 4) / (2 * (3 * B - 4))
        = (2 * (3 * B - 4)) / (2 * (3 * B - 4)) -
            (B - 4) / (2 * (3 * B - 4)) := by
          rw [div_self hden]
    _ = (2 * (3 * B - 4) - (B - 4)) / (2 * (3 * B - 4)) := by
          rw [div_sub_div_same]
    _ = (5 * B - 4) / (2 * (3 * B - 4)) := by
          ring

/-- The denominator after replacing the logarithm by the elementary majorant is
positive. -/
theorem one_sub_clippedLayerCakeTrialMajorant_pos
    {B : ℝ} (hB : 4 < B) :
    0 < 1 - clippedLayerCakeTrialMajorant B := by
  rw [one_sub_clippedLayerCakeTrialMajorant_eq (B := B) hB]
  exact div_pos (by nlinarith) (by nlinarith)

/-- The trial output after replacing the logarithm by the majorant has a simple
closed form. -/
theorem clippedLayerCakeMajorantOutput_formula
    {B : ℝ} (hB : 4 < B) :
    clippedLayerCakeTrialNu B / (1 - clippedLayerCakeTrialMajorant B)
      = ((3 * B + 4) * (3 * B - 4)) / (2 * (5 * B - 4)) := by
  rw [one_sub_clippedLayerCakeTrialMajorant_eq (B := B) hB]
  unfold clippedLayerCakeTrialNu
  have hden1 : 5 * B - 4 ≠ 0 := by nlinarith
  have hden2 : 3 * B - 4 ≠ 0 := by nlinarith
  have hden3 : 2 * (3 * B - 4) ≠ 0 := by nlinarith
  have hden4 : 2 * (5 * B - 4) ≠ 0 := by nlinarith
  field_simp [hden1, hden2, hden3, hden4]
  ring

/-- A simple realized output below the current cap.  The gap decrease is
quadratic in `B - 4`. -/
def clippedLayerCakeQuadraticOutput (B : ℝ) : ℝ :=
  B - (B - 4)^2 / (8 * (3 * B - 4))

/-- The quadratic output stays strictly between `4` and `B`. -/
theorem clippedLayerCakeQuadraticOutput_range
    {B : ℝ} (hB : 4 < B) :
    4 < clippedLayerCakeQuadraticOutput B ∧
      clippedLayerCakeQuadraticOutput B < B := by
  unfold clippedLayerCakeQuadraticOutput
  have hden : 0 < 8 * (3 * B - 4) := by nlinarith
  constructor
  · have hsmall : (B - 4)^2 / (8 * (3 * B - 4)) < B - 4 := by
      rw [div_lt_iff₀ hden]
      nlinarith
    linarith
  · have hpos : 0 < (B - 4)^2 / (8 * (3 * B - 4)) := by
      exact div_pos (sq_pos_of_ne_zero (by linarith)) hden
    linarith

/-- The majorant output sits below the quadratic output. -/
theorem clippedLayerCakeMajorantOutput_lt_quadraticOutput
    {B : ℝ} (hB : 4 < B) :
    clippedLayerCakeTrialNu B / (1 - clippedLayerCakeTrialMajorant B)
      < clippedLayerCakeQuadraticOutput B := by
  rw [clippedLayerCakeMajorantOutput_formula (B := B) hB]
  have hLpos : 0 < 2 * (5 * B - 4) := by nlinarith
  have hQdenpos : 0 < 8 * (3 * B - 4) := by nlinarith
  rw [div_lt_iff₀ hLpos]
  unfold clippedLayerCakeQuadraticOutput
  rw [sub_mul]
  rw [lt_sub_iff_add_lt]
  rw [div_mul_eq_mul_div]
  have hdiv_bound :
      (B - 4)^2 * (2 * (5 * B - 4)) / (8 * (3 * B - 4)) <
        B * (2 * (5 * B - 4)) - (3 * B + 4) * (3 * B - 4) := by
    rw [div_lt_iff₀ hQdenpos]
    nlinarith
  linarith

/-- The exact trial output is below the quadratic relaxed output. -/
theorem clippedLayerCakeTrialOutput_lt_quadraticOutput
    {B : ℝ} (hB : 4 < B) :
    clippedLayerCakeTrialOutput B < clippedLayerCakeQuadraticOutput B := by
  let nu := clippedLayerCakeTrialNu B
  let delta := clippedLayerCakeDelta B nu
  let maj := clippedLayerCakeTrialMajorant B
  have hnu_pos : 0 < nu := by
    have hrange := clippedLayerCakeTrialNu_range (M := B) hB
    linarith [hrange.1]
  have hden_delta : 0 < 1 - delta := by
    simpa [nu, delta] using one_sub_clippedLayerCakeDelta_trial_pos (B := B) hB
  have hden_maj : 0 < 1 - maj := by
    simpa [maj] using one_sub_clippedLayerCakeTrialMajorant_pos (B := B) hB
  have hdelta_le_maj : delta ≤ maj := by
    simpa [nu, delta, maj] using clippedLayerCakeDelta_trial_le_majorant (B := B) hB
  have hden_le : 1 - maj ≤ 1 - delta := by linarith
  have hquot_le : nu / (1 - delta) ≤ nu / (1 - maj) := by
    exact div_le_div_of_nonneg_left (le_of_lt hnu_pos) hden_maj hden_le
  have hquot_lt : nu / (1 - maj) < clippedLayerCakeQuadraticOutput B := by
    simpa [nu, maj] using
      clippedLayerCakeMajorantOutput_lt_quadraticOutput (B := B) hB
  unfold clippedLayerCakeTrialOutput clippedLayerCakeOutput
  exact lt_of_le_of_lt hquot_le hquot_lt

/-- The quadratic output is valid relaxed output data. -/
theorem clippedLayerCakeRelaxedOutputData_quadratic
    {B : ℝ} (hB : 4 < B) :
    ClippedLayerCakeRelaxedOutputData B
      (clippedLayerCakeQuadraticOutput B) := by
  unfold ClippedLayerCakeRelaxedOutputData
  exact ⟨hB,
    clippedLayerCakeTrialOutput_lt_quadraticOutput (B := B) hB,
    (clippedLayerCakeQuadraticOutput_range (B := B) hB).2⟩

/-- The quadratic output is realized by the clipped layer-cake cap strictness
condition. -/
theorem clippedLayerCakeCapStrictCondition_quadratic
    {B : ℝ} (hB : 4 < B) :
    ClippedLayerCakeCapStrictCondition B
      (clippedLayerCakeQuadraticOutput B)
      (clippedLayerCakeTrialNu B) := by
  exact clippedLayerCakeCapStrictCondition_of_relaxedOutput
    (clippedLayerCakeRelaxedOutputData_quadratic (B := B) hB)

/-- Step-realization predicate for the clipped layer-cake scalar route. -/
def ClippedLayerCakeScalarRealizedStep (B Mout : ℝ) : Prop :=
  ∃ nu : ℝ, ClippedLayerCakeCapStrictCondition B Mout nu

/-- The quadratic output realizes one scalar clipped layer-cake step. -/
theorem clippedLayerCakeScalarRealizedStep_quadratic
    {B : ℝ} (hB : 4 < B) :
    ClippedLayerCakeScalarRealizedStep B
      (clippedLayerCakeQuadraticOutput B) := by
  exact ⟨clippedLayerCakeTrialNu B,
    clippedLayerCakeCapStrictCondition_quadratic (B := B) hB⟩

/-- Iterates of the quadratic output map. -/
def clippedLayerCakeQuadraticIterate (B : ℝ) : ℕ → ℝ
  | 0 => B
  | n + 1 => clippedLayerCakeQuadraticOutput
      (clippedLayerCakeQuadraticIterate B n)

/-- Gap recurrence for the quadratic map. -/
theorem clippedLayerCakeQuadratic_gap_formula (B : ℝ) :
    clippedLayerCakeQuadraticOutput B - 4 =
      (B - 4) - (B - 4)^2 / (8 * (3 * B - 4)) := by
  unfold clippedLayerCakeQuadraticOutput
  ring

/-- The recursive form in the realized variable target is the same as
`clippedLayerCakeQuadraticIterate`. -/
theorem clippedLayerCakeQuadraticIterate_eq_natRec
    (B : ℝ) :
    (fun n : ℕ =>
      Nat.rec (motive := fun _ => ℝ) B
        (fun _ Bcur => clippedLayerCakeQuadraticOutput Bcur) n)
      = clippedLayerCakeQuadraticIterate B := by
  funext n
  induction n with
  | zero => simp [clippedLayerCakeQuadraticIterate]
  | succ n ih => simp [clippedLayerCakeQuadraticIterate, ih]

/-- The remaining analytic/order target: the realized quadratic iterates tend to
`4`. -/
def ClippedLayerCakeQuadraticIterationToFourTarget : Prop :=
  ∀ B0 : ℝ, 4 < B0 →
    Tendsto (fun n : ℕ => clippedLayerCakeQuadraticIterate B0 n)
      atTop (nhds 4)

/-- If the quadratic convergence target is closed, then the stronger realized
variable iteration target follows with the scalar realized-step predicate. -/
theorem clippedLayerCakeRealizedVariableIterationToFourTarget_of_quadratic
    (hconv : ClippedLayerCakeQuadraticIterationToFourTarget) :
    ClippedLayerCakeRealizedVariableIterationToFourTarget
      ClippedLayerCakeScalarRealizedStep := by
  refine ⟨clippedLayerCakeQuadraticOutput, ?_, ?_⟩
  · intro B hB
    have hrange := clippedLayerCakeQuadraticOutput_range (B := B) hB
    exact ⟨hrange.1, hrange.2,
      clippedLayerCakeScalarRealizedStep_quadratic (B := B) hB⟩
  · intro B0 hB0
    rw [clippedLayerCakeQuadraticIterate_eq_natRec]
    exact hconv B0 hB0

/-- Every quadratic iterate stays above `4` when the initial cap is above `4`. -/
theorem four_lt_clippedLayerCakeQuadraticIterate
    {B0 : ℝ} (hB0 : 4 < B0) :
    ∀ n : ℕ, 4 < clippedLayerCakeQuadraticIterate B0 n := by
  intro n
  induction n with
  | zero =>
      simpa [clippedLayerCakeQuadraticIterate] using hB0
  | succ n ih =>
      simpa [clippedLayerCakeQuadraticIterate] using
        (clippedLayerCakeQuadraticOutput_range (B :=
          clippedLayerCakeQuadraticIterate B0 n) ih).1

/-- Every quadratic iterate is at most the initial cap. -/
theorem clippedLayerCakeQuadraticIterate_le_initial
    {B0 : ℝ} (hB0 : 4 < B0) :
    ∀ n : ℕ, clippedLayerCakeQuadraticIterate B0 n ≤ B0 := by
  intro n
  induction n with
  | zero =>
      simp [clippedLayerCakeQuadraticIterate]
  | succ n ih =>
      have hgt : 4 < clippedLayerCakeQuadraticIterate B0 n :=
        four_lt_clippedLayerCakeQuadraticIterate hB0 n
      have hlt : clippedLayerCakeQuadraticOutput
          (clippedLayerCakeQuadraticIterate B0 n)
            < clippedLayerCakeQuadraticIterate B0 n :=
        (clippedLayerCakeQuadraticOutput_range (B :=
          clippedLayerCakeQuadraticIterate B0 n) hgt).2
      simp [clippedLayerCakeQuadraticIterate]
      exact le_trans (le_of_lt hlt) ih

/-- Gap positivity for the quadratic iterates. -/
theorem clippedLayerCakeQuadraticIterate_gap_pos
    {B0 : ℝ} (hB0 : 4 < B0) (n : ℕ) :
    0 < clippedLayerCakeQuadraticIterate B0 n - 4 := by
  have h := four_lt_clippedLayerCakeQuadraticIterate hB0 n
  linarith

/-- Gap upper bound by the initial gap. -/
theorem clippedLayerCakeQuadraticIterate_gap_le_initial_gap
    {B0 : ℝ} (hB0 : 4 < B0) (n : ℕ) :
    clippedLayerCakeQuadraticIterate B0 n - 4 ≤ B0 - 4 := by
  have hle := clippedLayerCakeQuadraticIterate_le_initial hB0 n
  linarith

/-- Closed form for one quadratic gap step in the gap variable. -/
theorem clippedLayerCakeQuadratic_gap_aux
    {y : ℝ} (hy : 0 < y) :
    y - y ^ 2 / (24 * y + 64) =
      y * (23 * y + 64) / (24 * y + 64) := by
  have hden : 24 * y + 64 ≠ 0 := by nlinarith
  field_simp [hden]
  ring

/-- Reciprocal identity for one quadratic gap step in the gap variable. -/
theorem clippedLayerCakeQuadratic_reciprocal_gap_aux
    {y : ℝ} (hy : 0 < y) :
    1 / (y - y ^ 2 / (24 * y + 64)) =
      1 / y + 1 / (23 * y + 64) := by
  rw [clippedLayerCakeQuadratic_gap_aux hy]
  have hy0 : y ≠ 0 := ne_of_gt hy
  have hden1 : 24 * y + 64 ≠ 0 := by nlinarith
  have hden2 : 23 * y + 64 ≠ 0 := by nlinarith
  have hprod : y * (23 * y + 64) ≠ 0 := by positivity
  field_simp [hy0, hden1, hden2, hprod]
  ring

/-- Exact reciprocal increment for one quadratic step. -/
theorem clippedLayerCakeQuadraticOutput_reciprocal_gap_formula
    {B : ℝ} (hB : 4 < B) :
    1 / (clippedLayerCakeQuadraticOutput B - 4)
      = 1 / (B - 4) + 1 / (23 * (B - 4) + 64) := by
  rw [clippedLayerCakeQuadratic_gap_formula]
  have hdeneq : 8 * (3 * B - 4) = 24 * (B - 4) + 64 := by ring
  rw [hdeneq]
  exact clippedLayerCakeQuadratic_reciprocal_gap_aux (by linarith : 0 < B - 4)

/-- A uniform lower bound for the reciprocal gap increment, using the initial
cap as the upper bound for all later iterates. -/
theorem clippedLayerCakeQuadraticIterate_reciprocal_step_lower
    {B0 : ℝ} (hB0 : 4 < B0) (n : ℕ) :
    1 / (23 * (B0 - 4) + 64)
      ≤
    1 / (clippedLayerCakeQuadraticIterate B0 (n + 1) - 4) -
      1 / (clippedLayerCakeQuadraticIterate B0 n - 4) := by
  let Bn := clippedLayerCakeQuadraticIterate B0 n
  have hBn_gt : 4 < Bn := four_lt_clippedLayerCakeQuadraticIterate hB0 n
  have hBn_le : Bn ≤ B0 := clippedLayerCakeQuadraticIterate_le_initial hB0 n
  have hdenBn_pos : 0 < 23 * (Bn - 4) + 64 := by nlinarith
  have hden_le : 23 * (Bn - 4) + 64 ≤ 23 * (B0 - 4) + 64 := by
    nlinarith
  have hrecip :
      1 / (23 * (B0 - 4) + 64)
        ≤ 1 / (23 * (Bn - 4) + 64) := by
    exact one_div_le_one_div_of_le hdenBn_pos hden_le
  have hformula := clippedLayerCakeQuadraticOutput_reciprocal_gap_formula
    (B := Bn) hBn_gt
  have hstep_eq :
      1 / (clippedLayerCakeQuadraticIterate B0 (n + 1) - 4) -
          1 / (clippedLayerCakeQuadraticIterate B0 n - 4)
        = 1 / (23 * (Bn - 4) + 64) := by
    calc
      1 / (clippedLayerCakeQuadraticIterate B0 (n + 1) - 4) -
          1 / (clippedLayerCakeQuadraticIterate B0 n - 4)
          = 1 / (clippedLayerCakeQuadraticOutput Bn - 4) -
              1 / (Bn - 4) := by
                simp [clippedLayerCakeQuadraticIterate, Bn]
      _ = 1 / (23 * (Bn - 4) + 64) := by
                linarith [hformula]
  rw [hstep_eq]
  exact hrecip

/-- Reciprocal gaps grow at least linearly. -/
theorem clippedLayerCakeQuadraticIterate_reciprocal_lower
    {B0 : ℝ} (hB0 : 4 < B0) :
    ∀ n : ℕ,
      1 / (B0 - 4) + (n : ℝ) * (1 / (23 * (B0 - 4) + 64))
        ≤ 1 / (clippedLayerCakeQuadraticIterate B0 n - 4) := by
  intro n
  let c : ℝ := 1 / (23 * (B0 - 4) + 64)
  induction n with
  | zero =>
      simp [clippedLayerCakeQuadraticIterate]
  | succ n ih =>
      have hstep := clippedLayerCakeQuadraticIterate_reciprocal_step_lower
        (B0 := B0) hB0 n
      have hleft :
          1 / (B0 - 4) + ((n + 1 : ℕ) : ℝ) * c =
            (1 / (B0 - 4) + (n : ℝ) * c) + c := by
        norm_num [Nat.cast_add, Nat.cast_one]
        ring_nf
      calc
        1 / (B0 - 4) + ((n + 1 : ℕ) : ℝ) *
            (1 / (23 * (B0 - 4) + 64))
            = (1 / (B0 - 4) + (n : ℝ) * c) + c := by
                simpa [c] using hleft
        _ ≤ 1 / (clippedLayerCakeQuadraticIterate B0 n - 4) + c := by
                linarith
        _ ≤ 1 / (clippedLayerCakeQuadraticIterate B0 (n + 1) - 4) := by
                dsimp [c]
                linarith

/-- The reciprocal-linear majorant tends to zero. -/
theorem tendsto_quadratic_reciprocal_linear_majorant
    {B0 : ℝ} (hB0 : 4 < B0) :
    Tendsto
      (fun n : ℕ =>
        1 / (1 / (B0 - 4) + (n : ℝ) *
          (1 / (23 * (B0 - 4) + 64))))
      atTop (nhds 0) := by
  let c : ℝ := 1 / (23 * (B0 - 4) + 64)
  have hcpos : 0 < c := by
    dsimp [c]
    positivity
  have hn : Tendsto (fun n : ℕ => (n : ℝ)) atTop atTop :=
    tendsto_natCast_atTop_atTop
  have hmul : Tendsto (fun n : ℕ => c * (n : ℝ)) atTop atTop :=
    Filter.Tendsto.const_mul_atTop hcpos hn
  have hden : Tendsto
      (fun n : ℕ => c * (n : ℝ) + 1 / (B0 - 4))
      atTop atTop :=
    Filter.Tendsto.atTop_add hmul tendsto_const_nhds
  have hquot : Tendsto
      (fun n : ℕ =>
        (1 : ℝ) / (c * (n : ℝ) + 1 / (B0 - 4)))
      atTop (nhds 0) :=
    tendsto_const_nhds.div_atTop hden
  simpa [c, mul_comm, add_comm, add_left_comm, add_assoc] using hquot

/-- The quadratic iterate gaps are bounded above by the reciprocal-linear
majorant. -/
theorem clippedLayerCakeQuadraticIterate_gap_le_reciprocal_linear_majorant
    {B0 : ℝ} (hB0 : 4 < B0) :
    ∀ n : ℕ,
      clippedLayerCakeQuadraticIterate B0 n - 4
        ≤ 1 / (1 / (B0 - 4) + (n : ℝ) *
          (1 / (23 * (B0 - 4) + 64))) := by
  intro n
  let gap := clippedLayerCakeQuadraticIterate B0 n - 4
  let A := 1 / (B0 - 4) + (n : ℝ) *
    (1 / (23 * (B0 - 4) + 64))
  have hgap_pos : 0 < gap := by
    simpa [gap] using clippedLayerCakeQuadraticIterate_gap_pos hB0 n
  have hA_pos : 0 < A := by
    have h0 : 0 < 1 / (B0 - 4) := by positivity
    have hc : 0 ≤ (n : ℝ) * (1 / (23 * (B0 - 4) + 64)) := by
      positivity
    dsimp [A]
    exact add_pos_of_pos_of_nonneg h0 hc
  have hrecip : A ≤ 1 / gap := by
    simpa [A, gap] using
      clippedLayerCakeQuadraticIterate_reciprocal_lower (B0 := B0) hB0 n
  have hmul : A * gap ≤ 1 := by
    have h := mul_le_mul_of_nonneg_right hrecip (le_of_lt hgap_pos)
    have hone : (1 / gap) * gap = 1 := by
      field_simp [ne_of_gt hgap_pos]
    exact le_trans h hone.le
  rw [le_div_iff₀ hA_pos]
  simpa [gap, A, mul_comm, mul_left_comm, mul_assoc] using hmul

/-- The gaps of the quadratic iterates tend to zero. -/
theorem tendsto_clippedLayerCakeQuadraticIterate_gap_zero
    {B0 : ℝ} (hB0 : 4 < B0) :
    Tendsto
      (fun n : ℕ => clippedLayerCakeQuadraticIterate B0 n - 4)
      atTop (nhds 0) := by
  exact squeeze_zero
    (fun n => le_of_lt (clippedLayerCakeQuadraticIterate_gap_pos hB0 n))
    (clippedLayerCakeQuadraticIterate_gap_le_reciprocal_linear_majorant hB0)
    (tendsto_quadratic_reciprocal_linear_majorant hB0)

/-- The quadratic realized clipped layer-cake iterates tend to `4`. -/
theorem tendsto_clippedLayerCakeQuadraticIterate
    {B0 : ℝ} (hB0 : 4 < B0) :
    Tendsto (fun n : ℕ => clippedLayerCakeQuadraticIterate B0 n)
      atTop (nhds 4) := by
  have hgap := tendsto_clippedLayerCakeQuadraticIterate_gap_zero hB0
  have hadd : Tendsto
      (fun n : ℕ => (clippedLayerCakeQuadraticIterate B0 n - 4) + 4)
      atTop (nhds (0 + 4)) :=
    hgap.add tendsto_const_nhds
  convert hadd using 1
  · ext n
    ring
  · norm_num

/-- Closure of the remaining quadratic convergence target. -/
theorem clippedLayerCakeQuadraticIterationToFourTarget_proved :
    ClippedLayerCakeQuadraticIterationToFourTarget := by
  intro B0 hB0
  exact tendsto_clippedLayerCakeQuadraticIterate hB0

/-- Therefore the quadratic scalar route realizes the stronger variable-iteration
target. -/
theorem clippedLayerCakeRealizedVariableIterationToFourTarget_quadratic_proved :
    ClippedLayerCakeRealizedVariableIterationToFourTarget
      ClippedLayerCakeScalarRealizedStep := by
  exact clippedLayerCakeRealizedVariableIterationToFourTarget_of_quadratic
    clippedLayerCakeQuadraticIterationToFourTarget_proved

/-!
# Arithmetic realization wrapper for the clipped layer-cake quadratic descent

This layer separates the genuinely arithmetic existence target from the proved
fact that such data realizes the quadratic cap descent.
-/

/-- Arbitrarily-close-above bound.  This is the iteration output before turning
it into a non-strict `≤` statement. -/
def OneOverPiMeasureArbitrarilyBelow (C : ℝ) : Prop :=
  ∀ eps : ℝ, 0 < eps → OneOverPiMeasureStrictlyBelow (C + eps)

/-- Full arithmetic data that realizes one clipped layer-cake cap step
`B -> Mout`.

The scalar part is `ClippedLayerCakeCapStrictCondition B Mout nu`; the remaining
fields are exactly the Ramanujan/spike certificate, the clipped endpoint average,
and the clipped non-visible-bad bridge needed by the existing Bauer wrapper. -/
structure ClippedLayerCakeArithmeticStepData (B Mout : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  capStrict : ClippedLayerCakeCapStrictCondition B Mout nu
  nu_gt_two : 2 < nu
  nu_lt_out : nu < Mout
  tau_pos : 0 < tau
  x_contraction : shellSpikeContractionExponent tau nu Mout < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  endpointAverage :
    ClippedEndpointWeightedAverageBound X nu (clippedLayerCakeDelta B nu)
  clippedControls :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V nu x (clippedLayerCakeDelta B nu)
  delta_nonneg : 0 ≤ clippedLayerCakeDelta B nu
  delta_gain : clippedLayerCakeDelta B nu + nu / Mout < shellSpikeGoodDensityGain tau x

/-- One-step arithmetic data gives the corresponding strict measure bound. -/
theorem oneOverPiMeasureStrictlyBelow_of_clippedLayerCakeArithmeticStepData
    {B Mout : ℝ}
    (D : ClippedLayerCakeArithmeticStepData B Mout) :
    OneOverPiMeasureStrictlyBelow Mout := by
  intro mu hmu
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedLayerCakeCapSaving
    (mu := mu) (B := B) (Mout := Mout) (nu := D.nu)
    (tau := D.tau) (x := D.x)
    (X := D.X) (H := D.H) (V := D.V)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    D.closureCert D.bauer hmu D.nu_gt_two D.nu_lt_out D.tau_pos
    D.x_contraction D.x_lt_one D.x_le_global D.gain_le_one
    D.endpointAverage D.clippedControls D.delta_nonneg
    (by linarith [D.delta_gain])

/-- The genuine remaining arithmetic target.

Given a current strict cap `B > 4`, and assuming that cap is already known for
`1/π`, produce the endpoint/partition/spike data realizing the quadratic output.
This is not proved here: it is exactly the non-scalar arithmetic work still
missing from the project. -/
def ClippedLayerCakeArithmeticDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedLayerCakeArithmeticStepData B (clippedLayerCakeQuadraticOutput B))

/-- The provable arithmetic-realization target: the data target realizes one
quadratic cap improvement for the actual measure bound. -/
def ClippedLayerCakeArithmeticRealizationTarget : Prop :=
  ClippedLayerCakeArithmeticDataTarget →
    ∀ B : ℝ,
      4 < B →
        OneOverPiMeasureStrictlyBelow B →
          OneOverPiMeasureStrictlyBelow (clippedLayerCakeQuadraticOutput B)

/-- The arithmetic-realization target is proved by unpacking the supplied data
and applying the existing clipped layer-cake Bauer/Ramanujan wrapper. -/
theorem clippedLayerCakeArithmeticRealizationTarget_proved :
    ClippedLayerCakeArithmeticRealizationTarget := by
  intro hData B hB hBound
  rcases hData B hB hBound with ⟨D⟩
  exact oneOverPiMeasureStrictlyBelow_of_clippedLayerCakeArithmeticStepData D

/-- If the data target holds and `B0` is an initial strict cap, then every
quadratic iterate is also a strict cap. -/
theorem oneOverPiMeasureStrictlyBelow_quadraticIterate_of_dataTarget
    (hData : ClippedLayerCakeArithmeticDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelow B0) :
    ∀ n : ℕ,
      OneOverPiMeasureStrictlyBelow
        (clippedLayerCakeQuadraticIterate B0 n) := by
  intro n
  induction n with
  | zero =>
      simpa [clippedLayerCakeQuadraticIterate] using hStart
  | succ n ih =>
      have hBn : 4 < clippedLayerCakeQuadraticIterate B0 n :=
        four_lt_clippedLayerCakeQuadraticIterate hB0 n
      have hReal := clippedLayerCakeArithmeticRealizationTarget_proved
        hData (clippedLayerCakeQuadraticIterate B0 n) hBn ih
      simpa [clippedLayerCakeQuadraticIterate] using hReal

/-- If the data target holds and there is some initial strict cap above `4`, then
all project-level irrationality-measure values of `1/π` are strictly below
`4 + eps` for every positive `eps`. -/
theorem oneOverPiMeasureArbitrarilyBelowFour_of_clippedLayerCakeArithmeticDataTarget
    (hData : ClippedLayerCakeArithmeticDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelow B0) :
    OneOverPiMeasureArbitrarilyBelow 4 := by
  intro eps heps mu hmu
  have hIter := oneOverPiMeasureStrictlyBelow_quadraticIterate_of_dataTarget
    hData hB0 hStart
  have htend := tendsto_clippedLayerCakeQuadraticIterate (B0 := B0) hB0
  have hEventually :
      ∀ᶠ n : ℕ in atTop,
        clippedLayerCakeQuadraticIterate B0 n < 4 + eps := by
    have hlt : (4 : ℝ) < 4 + eps := by linarith
    exact (tendsto_order.1 htend).2 (4 + eps) hlt
  rcases (eventually_atTop.1 hEventually) with ⟨N, hN⟩
  have hmu_lt_iter : mu < clippedLayerCakeQuadraticIterate B0 N :=
    hIter N mu hmu
  have hiter_lt : clippedLayerCakeQuadraticIterate B0 N < 4 + eps :=
    hN N le_rfl
  exact lt_trans hmu_lt_iter hiter_lt

/-- The arithmetic data target plus one initial strict cap implies the non-strict
final bound `μ(1 / π) ≤ 4`. -/
theorem oneOverPiMeasureAtMost_four_of_clippedLayerCakeArithmeticDataTarget
    (hData : ClippedLayerCakeArithmeticDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelow B0) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_arbitrarily_close
    (oneOverPiMeasureArbitrarilyBelowFour_of_clippedLayerCakeArithmeticDataTarget
      hData hB0 hStart)

/-- A lower-level step package whose endpoint average is produced from finite
layer-cake partition data. -/
structure ClippedLayerCakeArithmeticFinitePartitionStepData
    {K : ℕ} (B Mout : ℝ) (tpart : Fin (K + 1) → ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  capStrict : ClippedLayerCakeCapStrictCondition B Mout nu
  nu_gt_two : 2 < nu
  nu_lt_out : nu < Mout
  tau_pos : 0 < tau
  x_contraction : shellSpikeContractionExponent tau nu Mout < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  finitePartition :
    ClippedLayerCakeFinitePartitionData X tpart B nu (clippedLayerCakeDelta B nu)
  clippedControls :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V nu x (clippedLayerCakeDelta B nu)
  delta_nonneg : 0 ≤ clippedLayerCakeDelta B nu
  delta_gain : clippedLayerCakeDelta B nu + nu / Mout < shellSpikeGoodDensityGain tau x

/-- Finite partition step data constructs full arithmetic step data. -/
def clippedLayerCakeArithmeticStepData_of_finitePartitionStepData
    {K : ℕ} {B Mout : ℝ} {tpart : Fin (K + 1) → ℝ}
    (D : ClippedLayerCakeArithmeticFinitePartitionStepData B Mout tpart) :
    ClippedLayerCakeArithmeticStepData B Mout := {
  nu := D.nu
  tau := D.tau
  x := D.x
  X := D.X
  H := D.H
  V := D.V
  Hlog := D.Hlog
  u := D.u
  vseq := D.vseq
  closureCert := D.closureCert
  bauer := D.bauer
  capStrict := D.capStrict
  nu_gt_two := D.nu_gt_two
  nu_lt_out := D.nu_lt_out
  tau_pos := D.tau_pos
  x_contraction := D.x_contraction
  x_lt_one := D.x_lt_one
  x_le_global := D.x_le_global
  gain_le_one := D.gain_le_one
  endpointAverage := clippedEndpointAverageBound_of_layerCakeFinitePartitionData
    (X := D.X) (tpart := tpart) (M := B) (nu := D.nu)
    (delta := clippedLayerCakeDelta B D.nu) D.finitePartition
  clippedControls := D.clippedControls
  delta_nonneg := D.delta_nonneg
  delta_gain := D.delta_gain
}

/-- A finite-partition data target implies the main arithmetic data target. -/
def ClippedLayerCakeArithmeticFinitePartitionDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        ∃ K : ℕ,
          ∃ tpart : Fin (K + 1) → ℝ,
            Nonempty
              (ClippedLayerCakeArithmeticFinitePartitionStepData
                B (clippedLayerCakeQuadraticOutput B) tpart)

/-- Finite-partition arithmetic data is enough for the main data target. -/
theorem clippedLayerCakeArithmeticDataTarget_of_finitePartitionDataTarget
    (hFinite : ClippedLayerCakeArithmeticFinitePartitionDataTarget) :
    ClippedLayerCakeArithmeticDataTarget := by
  intro B hB hBound
  rcases hFinite B hB hBound with ⟨K, tpart, Dnonempty⟩
  rcases Dnonempty with ⟨D⟩
  exact ⟨clippedLayerCakeArithmeticStepData_of_finitePartitionStepData
    (B := B) (Mout := clippedLayerCakeQuadraticOutput B) (tpart := tpart) D⟩

/-!
# Canonical scalar reduction for `ClippedLayerCakeArithmeticDataTarget`

This layer fixes the scalar choices for the quadratic clipped layer-cake step.
The remaining target is only the non-scalar arithmetic core: endpoint closure,
finite partition data, and the clipped endpoint/non-visible-bad bridge.
-/

/-! ## Canonical scalar spike choice -/

/-- The canonical `tau` associated to a current cap `B`. -/
def clippedLayerCakeCanonicalTau (B : ℝ) : ℝ :=
  B - 2

/-- The canonical endpoint spike exponent associated to `B`. -/
def clippedLayerCakeCanonicalX (B : ℝ) : ℝ :=
  shellSpikeGlobalExponent (clippedLayerCakeCanonicalTau B)

/-- The canonical `tau` is positive in the range `B > 4`. -/
theorem clippedLayerCakeCanonicalTau_pos {B : ℝ} (hB : 4 < B) :
    0 < clippedLayerCakeCanonicalTau B := by
  unfold clippedLayerCakeCanonicalTau
  linarith

/-- The global spike exponent is strictly below `1`. -/
theorem shellSpikeGlobalExponent_lt_one {tau : ℝ} (htau : 0 < tau) :
    shellSpikeGlobalExponent tau < 1 := by
  unfold shellSpikeGlobalExponent
  have hden : 0 < tau + 1 := by linarith
  rw [div_lt_one hden]
  linarith

/-- At the global spike exponent, the good-density gain is exactly `1`. -/
theorem shellSpikeGoodDensityGain_globalExponent_eq_one
    {tau : ℝ} (htau : 0 < tau) :
    shellSpikeGoodDensityGain tau (shellSpikeGlobalExponent tau) = 1 := by
  unfold shellSpikeGoodDensityGain shellSpikeGlobalExponent
  have htau_ne : tau ≠ 0 := ne_of_gt htau
  have hden1 : tau + 1 ≠ 0 := by linarith
  have hden2 : tau ^ 2 * (1 - tau / (tau + 1)) ≠ 0 := by
    have htau2 : tau ^ 2 ≠ 0 := pow_ne_zero 2 htau_ne
    have h1 : 1 - tau / (tau + 1) = 1 / (tau + 1) := by
      field_simp [hden1]
      ring
    rw [h1]
    exact mul_ne_zero htau2 (one_div_ne_zero hden1)
  field_simp [htau_ne, hden1, hden2]
  ring

/-- The inverse-gain exponent is strictly below the global exponent whenever the
requested gain `gamma` is strictly below `1`. -/
theorem shellSpikeExponentForGain_lt_globalExponent_of_lt_one
    {tau gamma : ℝ}
    (htau : 0 < tau) (hgamma_nonneg : 0 ≤ gamma) (hgamma_lt_one : gamma < 1) :
    shellSpikeExponentForGain tau gamma < shellSpikeGlobalExponent tau := by
  unfold shellSpikeExponentForGain shellSpikeGlobalExponent
  have hdenA : 0 < 2 * tau + 1 + gamma * tau ^ 2 := by
    have hbase : 0 < 2 * tau + 1 := by nlinarith
    have htau2_nonneg : 0 ≤ tau ^ 2 := sq_nonneg tau
    have htail : 0 ≤ gamma * tau ^ 2 := mul_nonneg hgamma_nonneg htau2_nonneg
    linarith
  have hdenB : 0 < tau + 1 := by linarith
  rw [div_lt_div_iff₀ hdenA hdenB]
  have htau2_pos : 0 < tau ^ 2 := sq_pos_of_ne_zero (ne_of_gt htau)
  nlinarith

/-- The canonical `x` is below `1`. -/
theorem clippedLayerCakeCanonicalX_lt_one {B : ℝ} (hB : 4 < B) :
    clippedLayerCakeCanonicalX B < 1 := by
  exact shellSpikeGlobalExponent_lt_one
    (clippedLayerCakeCanonicalTau_pos (B := B) hB)

/-- The canonical good-density gain is exactly `1`. -/
theorem shellSpikeGoodDensityGain_clippedLayerCakeCanonicalX_eq_one
    {B : ℝ} (hB : 4 < B) :
    shellSpikeGoodDensityGain
      (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B) = 1 := by
  unfold clippedLayerCakeCanonicalX
  exact shellSpikeGoodDensityGain_globalExponent_eq_one
    (clippedLayerCakeCanonicalTau_pos (B := B) hB)

/-- The canonical `x` is above the contraction exponent for the quadratic output. -/
theorem shellSpikeContractionExponent_lt_clippedLayerCakeCanonicalX_quadratic
    {B : ℝ} (hB : 4 < B) :
    shellSpikeContractionExponent
        (clippedLayerCakeCanonicalTau B)
        (clippedLayerCakeTrialNu B)
        (clippedLayerCakeQuadraticOutput B)
      < clippedLayerCakeCanonicalX B := by
  let tau := clippedLayerCakeCanonicalTau B
  let nu := clippedLayerCakeTrialNu B
  let Mout := clippedLayerCakeQuadraticOutput B
  have hcap : ClippedLayerCakeCapStrictCondition B Mout nu := by
    simpa [Mout, nu] using clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
  rcases hcap with ⟨_hB, _hMout4, _hMout_lt_B, hnu2, hnu_lt_Mout, _hstrict⟩
  have htau : 0 < tau := by
    simpa [tau] using clippedLayerCakeCanonicalTau_pos (B := B) hB
  have hMout_pos : 0 < Mout := by linarith
  have hgamma_nonneg : 0 ≤ nu / Mout := by
    exact le_of_lt (div_pos (by linarith) hMout_pos)
  have hgamma_lt_one : nu / Mout < 1 := by
    rw [div_lt_one hMout_pos]
    exact hnu_lt_Mout
  have h := shellSpikeExponentForGain_lt_globalExponent_of_lt_one
    (tau := tau) (gamma := nu / Mout) htau hgamma_nonneg hgamma_lt_one
  simpa [shellSpikeContractionExponent, shellSpikeContractionGoodDensity,
    clippedLayerCakeCanonicalX, tau, nu, Mout] using h

/-! ## Canonical arithmetic core data -/

/-- The non-scalar arithmetic core needed to realize the quadratic clipped
layer-cake step at cap `B`, after all scalar choices have been made canonically.

This is still a genuine arithmetic package: it contains the ordered endpoint
closure certificate, finite partition data, and the clipped non-visible-bad
bridge. -/
structure ClippedLayerCakeCanonicalArithmeticCoreData (B : ℝ) : Type where
  K : ℕ
  tpart : Fin (K + 1) → ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate Hlog u vseq H V
      (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)
  bauer : BauerRamanujanIdentity
  finitePartition :
    ClippedLayerCakeFinitePartitionData X tpart B
      (clippedLayerCakeTrialNu B)
      (clippedLayerCakeDelta B (clippedLayerCakeTrialNu B))
  clippedControls :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (clippedLayerCakeDelta B (clippedLayerCakeTrialNu B))

/-- Canonical core data constructs the full arithmetic step data used by the
already-integrated arithmetic-realization wrapper. -/
def clippedLayerCakeArithmeticStepData_of_canonicalCoreData
    {B : ℝ} (hB : 4 < B)
    (D : ClippedLayerCakeCanonicalArithmeticCoreData B) :
    ClippedLayerCakeArithmeticStepData B (clippedLayerCakeQuadraticOutput B) where
  nu := clippedLayerCakeTrialNu B
  tau := clippedLayerCakeCanonicalTau B
  x := clippedLayerCakeCanonicalX B
  X := D.X
  H := D.H
  V := D.V
  Hlog := D.Hlog
  u := D.u
  vseq := D.vseq
  closureCert := D.closureCert
  bauer := D.bauer
  capStrict := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
  nu_gt_two := by
    have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
    exact hcap.2.2.2.1
  nu_lt_out := by
    have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
    exact hcap.2.2.2.2.1
  tau_pos := clippedLayerCakeCanonicalTau_pos (B := B) hB
  x_contraction :=
    shellSpikeContractionExponent_lt_clippedLayerCakeCanonicalX_quadratic
      (B := B) hB
  x_lt_one := clippedLayerCakeCanonicalX_lt_one (B := B) hB
  x_le_global := by
    rfl
  gain_le_one := by
    exact shellSpikeGoodDensityGain_le_one
      (clippedLayerCakeCanonicalTau_pos (B := B) hB)
      (clippedLayerCakeCanonicalX_lt_one (B := B) hB)
      (by rfl)
  endpointAverage := by
    exact clippedEndpointAverageBound_of_layerCakeFinitePartitionData
      (X := D.X) (tpart := D.tpart) (M := B)
      (nu := clippedLayerCakeTrialNu B)
      (delta := clippedLayerCakeDelta B (clippedLayerCakeTrialNu B))
      D.finitePartition
  clippedControls := D.clippedControls
  delta_nonneg := by
    have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
    have hnu2 : 2 < clippedLayerCakeTrialNu B := hcap.2.2.2.1
    have hnu_lt_out : clippedLayerCakeTrialNu B < clippedLayerCakeQuadraticOutput B :=
      hcap.2.2.2.2.1
    have hout_lt_B : clippedLayerCakeQuadraticOutput B < B := hcap.2.2.1
    exact clippedLayerCakeDelta_nonneg (M := B) (nu := clippedLayerCakeTrialNu B)
      hnu2 (le_of_lt (lt_trans hnu_lt_out hout_lt_B))
  delta_gain := by
    have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
    have hstrict :
        clippedLayerCakeDelta B (clippedLayerCakeTrialNu B) +
            clippedLayerCakeTrialNu B / clippedLayerCakeQuadraticOutput B < 1 :=
      hcap.2.2.2.2.2
    have hgain := shellSpikeGoodDensityGain_clippedLayerCakeCanonicalX_eq_one
      (B := B) hB
    simpa [hgain] using hstrict

/-- The remaining canonical arithmetic-core target.

This is the precise non-scalar statement still needed: for every strict cap
`B > 4`, produce finite partition data and the clipped endpoint bridge at the
canonical scalar choices. -/
def ClippedLayerCakeCanonicalArithmeticCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedLayerCakeCanonicalArithmeticCoreData B)

/-- Canonical core data proves the main arithmetic data target. -/
theorem clippedLayerCakeArithmeticDataTarget_of_canonicalCoreDataTarget
    (hCore : ClippedLayerCakeCanonicalArithmeticCoreDataTarget) :
    ClippedLayerCakeArithmeticDataTarget := by
  intro B hB hBound
  rcases hCore B hB hBound with ⟨D⟩
  exact ⟨clippedLayerCakeArithmeticStepData_of_canonicalCoreData
    (B := B) hB D⟩

/-- Consequently, the canonical core target is enough to obtain the already
integrated `≤ 4` conclusion. -/
theorem oneOverPiMeasureAtMost_four_of_canonicalCoreDataTarget
    (hCore : ClippedLayerCakeCanonicalArithmeticCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelow B0) :
    OneOverPiMeasureAtMost 4 := by
  exact oneOverPiMeasureAtMost_four_of_clippedLayerCakeArithmeticDataTarget
    (clippedLayerCakeArithmeticDataTarget_of_canonicalCoreDataTarget hCore)
    hB0 hStart

/-!
# Effective-delta repair for the clipped layer-cake arithmetic data

The canonical core target above uses the exact logarithmic density
`clippedLayerCakeDelta B (clippedLayerCakeTrialNu B)`.  Finite left-endpoint
partitions naturally produce a slightly larger effective density, and the
quadratic output has spare room for this repaired allowance.
-/

/-! ## Effective one-step data with a flexible density allowance -/

/-- A raw strict upper bound for any project-level irrationality-measure value of
`1 / pi`. -/
def OneOverPiMeasureStrictlyBelowEffectiveRaw (B : ℝ) : Prop :=
  ∀ mu : ℝ, HasIrrationalityMeasure (1 / Real.pi) mu → mu < B

/-- Flexible effective one-step data for the clipped endpoint route.

The density allowance is an explicit field `delta`, rather than being fixed to
the exact logarithmic integral. -/
structure ClippedLayerCakeEffectiveStepData (B Mout : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  delta : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_lt_out : nu < Mout
  tau_pos : 0 < tau
  x_contraction : shellSpikeContractionExponent tau nu Mout < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  endpointAverage : ClippedEndpointWeightedAverageBound X nu delta
  clippedControls : ClippedEndpointWeightedAverageControlsNonVisibleBad X H V nu x delta
  delta_nonneg : 0 ≤ delta
  delta_gain : delta + nu / Mout < shellSpikeGoodDensityGain tau x

/-- Effective one-step data gives the advertised strict measure improvement. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_of_effectiveStepData
    {B Mout : ℝ}
    (D : ClippedLayerCakeEffectiveStepData B Mout) :
    OneOverPiMeasureStrictlyBelowEffectiveRaw Mout := by
  intro mu hmu
  have hgain :
      D.nu / Mout + D.delta < shellSpikeGoodDensityGain D.tau D.x := by
    linarith [D.delta_gain]
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedEndpointWeightedAverage
    (mu := mu) (M := Mout) (nu := D.nu) (tau := D.tau) (x := D.x)
    (delta := D.delta)
    (X := D.X) (H := D.H) (V := D.V)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    D.closureCert D.bauer hmu D.nu_gt_two D.nu_lt_out D.tau_pos
    D.x_contraction D.x_lt_one D.x_le_global D.gain_le_one
    D.endpointAverage D.clippedControls D.delta_nonneg hgain

/-! ## The quadratic effective density allowance -/

/-- The finite-partition density allowance used by the quadratic output. -/
def clippedLayerCakeQuadraticEffectiveDelta (B : ℝ) : ℝ :=
  clippedLayerCakeTrialMajorant B

/-- The quadratic effective density is nonnegative above `4`. -/
theorem clippedLayerCakeQuadraticEffectiveDelta_nonneg
    {B : ℝ} (hB : 4 < B) :
    0 ≤ clippedLayerCakeQuadraticEffectiveDelta B := by
  unfold clippedLayerCakeQuadraticEffectiveDelta clippedLayerCakeTrialMajorant
  have hnum : 0 < B - 4 := by linarith
  have hden : 0 < 2 * (3 * B - 4) := by nlinarith
  exact le_of_lt (div_pos hnum hden)

/-- The quadratic output has enough room for the effective majorant. -/
theorem clippedLayerCakeQuadraticEffectiveDelta_gain
    {B : ℝ} (hB : 4 < B) :
    clippedLayerCakeQuadraticEffectiveDelta B +
        clippedLayerCakeTrialNu B / clippedLayerCakeQuadraticOutput B < 1 := by
  let maj := clippedLayerCakeTrialMajorant B
  let nu := clippedLayerCakeTrialNu B
  let Q := clippedLayerCakeQuadraticOutput B
  have hQpos : 0 < Q := by
    have hrange := clippedLayerCakeQuadraticOutput_range (B := B) hB
    exact lt_trans (by norm_num : (0 : ℝ) < 4) hrange.1
  have hdenpos : 0 < 1 - maj := by
    simpa [maj] using one_sub_clippedLayerCakeTrialMajorant_pos (B := B) hB
  have hOut : nu / (1 - maj) < Q := by
    simpa [nu, maj, Q] using
      clippedLayerCakeMajorantOutput_lt_quadraticOutput (B := B) hB
  have hnu_lt : nu < Q * (1 - maj) :=
    (div_lt_iff₀ hdenpos).mp hOut
  have hnu_div_lt : nu / Q < 1 - maj :=
    (div_lt_iff₀ hQpos).mpr (by
      simpa [mul_comm, mul_left_comm, mul_assoc] using hnu_lt)
  unfold clippedLayerCakeQuadraticEffectiveDelta
  change maj + nu / Q < 1
  linarith

/-! ## Canonical quadratic core data with effective density -/

/-- Canonical arithmetic core data for the quadratic output, using the effective
finite-partition density rather than the exact integral density. -/
structure ClippedLayerCakeQuadraticEffectiveCoreData (B : ℝ) : Type where
  K : ℕ
  tpart : Fin (K + 1) → ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate Hlog u vseq H V
      (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)
  bauer : BauerRamanujanIdentity
  finitePartition :
    ClippedLayerCakeFinitePartitionData X tpart B
      (clippedLayerCakeTrialNu B)
      (clippedLayerCakeQuadraticEffectiveDelta B)
  clippedControls :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (clippedLayerCakeQuadraticEffectiveDelta B)

/-- Effective canonical core data constructs one flexible effective step. -/
def clippedLayerCakeEffectiveStepData_of_quadraticCoreData
    {B : ℝ} (hB : 4 < B)
    (D : ClippedLayerCakeQuadraticEffectiveCoreData B) :
    ClippedLayerCakeEffectiveStepData B (clippedLayerCakeQuadraticOutput B) where
  nu := clippedLayerCakeTrialNu B
  tau := clippedLayerCakeCanonicalTau B
  x := clippedLayerCakeCanonicalX B
  delta := clippedLayerCakeQuadraticEffectiveDelta B
  X := D.X
  H := D.H
  V := D.V
  Hlog := D.Hlog
  u := D.u
  vseq := D.vseq
  closureCert := D.closureCert
  bauer := D.bauer
  nu_gt_two := by
    have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
    exact hcap.2.2.2.1
  nu_lt_out := by
    have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
    exact hcap.2.2.2.2.1
  tau_pos := clippedLayerCakeCanonicalTau_pos (B := B) hB
  x_contraction :=
    shellSpikeContractionExponent_lt_clippedLayerCakeCanonicalX_quadratic
      (B := B) hB
  x_lt_one := clippedLayerCakeCanonicalX_lt_one (B := B) hB
  x_le_global := by
    rfl
  gain_le_one := by
    exact shellSpikeGoodDensityGain_le_one
      (clippedLayerCakeCanonicalTau_pos (B := B) hB)
      (clippedLayerCakeCanonicalX_lt_one (B := B) hB)
      (by rfl)
  endpointAverage := by
    exact clippedEndpointAverageBound_of_layerCakeFinitePartitionData
      (X := D.X) (tpart := D.tpart) (M := B)
      (nu := clippedLayerCakeTrialNu B)
      (delta := clippedLayerCakeQuadraticEffectiveDelta B)
      D.finitePartition
  clippedControls := D.clippedControls
  delta_nonneg := clippedLayerCakeQuadraticEffectiveDelta_nonneg (B := B) hB
  delta_gain := by
    have hgain := shellSpikeGoodDensityGain_clippedLayerCakeCanonicalX_eq_one
      (B := B) hB
    have hstrict := clippedLayerCakeQuadraticEffectiveDelta_gain (B := B) hB
    simpa [hgain] using hstrict

/-- Effective arithmetic data target for the quadratic layer-cake route. -/
def ClippedLayerCakeEffectiveArithmeticDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        Nonempty
          (ClippedLayerCakeEffectiveStepData B
            (clippedLayerCakeQuadraticOutput B))

/-- The remaining non-scalar target after the effective-delta repair. -/
def ClippedLayerCakeQuadraticEffectiveCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        Nonempty (ClippedLayerCakeQuadraticEffectiveCoreData B)

/-- Effective core data gives the effective arithmetic data target. -/
theorem clippedLayerCakeEffectiveArithmeticDataTarget_of_quadraticCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticEffectiveCoreDataTarget) :
    ClippedLayerCakeEffectiveArithmeticDataTarget := by
  intro B hB hBound
  rcases hCore B hB hBound with ⟨D⟩
  exact ⟨clippedLayerCakeEffectiveStepData_of_quadraticCoreData
    (B := B) hB D⟩

/-! ## Iteration to the non-strict bound `4` from effective data -/

/-- Effective data propagates strict bounds along all quadratic iterates. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_quadraticIterate
    (hData : ClippedLayerCakeEffectiveArithmeticDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ n : ℕ,
      OneOverPiMeasureStrictlyBelowEffectiveRaw
        (clippedLayerCakeQuadraticIterate B0 n) := by
  intro n
  induction n with
  | zero =>
      simpa [clippedLayerCakeQuadraticIterate] using hStart
  | succ n ih =>
      have hBn : 4 < clippedLayerCakeQuadraticIterate B0 n :=
        four_lt_clippedLayerCakeQuadraticIterate hB0 n
      rcases hData (clippedLayerCakeQuadraticIterate B0 n) hBn ih with ⟨D⟩
      have hStep := oneOverPiMeasureStrictlyBelowEffectiveRaw_of_effectiveStepData D
      simpa [clippedLayerCakeQuadraticIterate] using hStep

/-- Effective data plus any starting strict cap above `4` proves that every
measure value of `1 / pi` is at most `4`. -/
theorem oneOverPi_irratMeasure_le_four_of_effectiveArithmeticDataTarget
    (hData : ClippedLayerCakeEffectiveArithmeticDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ mu : ℝ,
      HasIrrationalityMeasure (1 / Real.pi) mu → mu ≤ 4 := by
  intro mu hmu
  by_contra hnot
  have hgt : 4 < mu := lt_of_not_ge hnot
  let eps : ℝ := (mu - 4) / 2
  have heps : 0 < eps := by
    unfold eps
    linarith
  have hIter := oneOverPiMeasureStrictlyBelowEffectiveRaw_quadraticIterate
    hData hB0 hStart
  have htend := tendsto_clippedLayerCakeQuadraticIterate (B0 := B0) hB0
  have hEventually :
      ∀ᶠ n : ℕ in atTop,
        clippedLayerCakeQuadraticIterate B0 n < 4 + eps := by
    have hlt : (4 : ℝ) < 4 + eps := by linarith
    exact (tendsto_order.1 htend).2 (4 + eps) hlt
  rcases (eventually_atTop.1 hEventually) with ⟨N, hN⟩
  have hmu_lt_iter : mu < clippedLayerCakeQuadraticIterate B0 N :=
    hIter N mu hmu
  have hiter_lt : clippedLayerCakeQuadraticIterate B0 N < 4 + eps :=
    hN N le_rfl
  have hmu_lt : mu < 4 + eps := lt_trans hmu_lt_iter hiter_lt
  unfold eps at hmu_lt
  linarith

/-- Final wrapper from the effective core target. -/
theorem oneOverPi_irratMeasure_le_four_of_quadraticEffectiveCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticEffectiveCoreDataTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
    ∀ mu : ℝ,
      HasIrrationalityMeasure (1 / Real.pi) mu → mu ≤ 4 := by
  exact oneOverPi_irratMeasure_le_four_of_effectiveArithmeticDataTarget
    (clippedLayerCakeEffectiveArithmeticDataTarget_of_quadraticCoreDataTarget hCore)
    hB0 hStart

/-!
# Effective quadratic layer-cake route via active-mass data

At the canonical trial exponent, the quadratic effective density allowance is
exactly the one-threshold clipped active-mass density.  Thus the effective
quadratic route can be realized from active-mass finite data without building an
explicit finite layer-cake partition.
-/

/-! ## Effective density equals the one-threshold clipped density -/

/-- At the canonical trial exponent, the quadratic effective density allowance
is exactly the one-threshold clipped active-mass density. -/
theorem clippedLayerCakeQuadraticEffectiveDelta_eq_oneThresholdBootstrapDelta
    (B : ℝ) :
    clippedLayerCakeQuadraticEffectiveDelta B =
      oneThresholdBootstrapDelta B (clippedLayerCakeTrialNu B) := by
  unfold clippedLayerCakeQuadraticEffectiveDelta clippedLayerCakeTrialMajorant
    oneThresholdBootstrapDelta clippedLayerCakeTrialNu
  by_cases h : 3 * B - 4 = 0
  · have hnu : (B - (B - 4) / 4) - 2 = 0 := by nlinarith
    have hden : 2 * (3 * B - 4) = 0 := by nlinarith
    simp [hden, hnu]
  · have hnu_ne : (B - (B - 4) / 4) - 2 ≠ 0 := by
      intro hz
      apply h
      nlinarith
    field_simp [h, hnu_ne]
    ring

/-- The same identity in the reverse direction, convenient for rewriting an
already-built one-threshold average into the effective quadratic delta. -/
theorem oneThresholdBootstrapDelta_trial_eq_clippedLayerCakeQuadraticEffectiveDelta
    (B : ℝ) :
    oneThresholdBootstrapDelta B (clippedLayerCakeTrialNu B) =
      clippedLayerCakeQuadraticEffectiveDelta B := by
  exact (clippedLayerCakeQuadraticEffectiveDelta_eq_oneThresholdBootstrapDelta B).symm

/-! ## Active-mass core data -/

/-- The remaining arithmetic data needed to realize the quadratic effective
step using active-mass data.

The field `finiteData` supplies the endpoint average with
`delta = oneThresholdBootstrapDelta B nu`; the scalar identity above rewrites it
to the quadratic effective delta. -/
structure ClippedLayerCakeQuadraticActiveMassCoreData (B : ℝ) : Type where
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert :
    OrderedEndpointClosureCertificate Hlog u vseq H V
      (clippedLayerCakeCanonicalTau B) (clippedLayerCakeCanonicalX B)
  bauer : BauerRamanujanIdentity
  finiteData :
    ClippedOneThresholdFiniteData X B (clippedLayerCakeTrialNu B)
  clippedControls :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (clippedLayerCakeQuadraticEffectiveDelta B)

/-- Active-mass finite data gives the effective clipped endpoint average needed
by the quadratic route. -/
theorem clippedEndpointAverageBound_of_quadraticActiveMassCoreData
    {B : ℝ} (D : ClippedLayerCakeQuadraticActiveMassCoreData B) :
    ClippedEndpointWeightedAverageBound D.X (clippedLayerCakeTrialNu B)
      (clippedLayerCakeQuadraticEffectiveDelta B) := by
  have hAvg :
      ClippedEndpointWeightedAverageBound D.X (clippedLayerCakeTrialNu B)
        (oneThresholdBootstrapDelta B (clippedLayerCakeTrialNu B)) :=
    clippedEndpointAverage_of_finiteData D.finiteData
  simpa [oneThresholdBootstrapDelta_trial_eq_clippedLayerCakeQuadraticEffectiveDelta]
    using hAvg

/-- Active-mass core data constructs one effective quadratic step. -/
def clippedLayerCakeEffectiveStepData_of_quadraticActiveMassCoreData
    {B : ℝ} (hB : 4 < B)
    (D : ClippedLayerCakeQuadraticActiveMassCoreData B) :
    ClippedLayerCakeEffectiveStepData B (clippedLayerCakeQuadraticOutput B) where
  nu := clippedLayerCakeTrialNu B
  tau := clippedLayerCakeCanonicalTau B
  x := clippedLayerCakeCanonicalX B
  delta := clippedLayerCakeQuadraticEffectiveDelta B
  X := D.X
  H := D.H
  V := D.V
  Hlog := D.Hlog
  u := D.u
  vseq := D.vseq
  closureCert := D.closureCert
  bauer := D.bauer
  nu_gt_two := by
    have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
    exact hcap.2.2.2.1
  nu_lt_out := by
    have hcap := clippedLayerCakeCapStrictCondition_quadratic (B := B) hB
    exact hcap.2.2.2.2.1
  tau_pos := clippedLayerCakeCanonicalTau_pos (B := B) hB
  x_contraction :=
    shellSpikeContractionExponent_lt_clippedLayerCakeCanonicalX_quadratic
      (B := B) hB
  x_lt_one := clippedLayerCakeCanonicalX_lt_one (B := B) hB
  x_le_global := by
    rfl
  gain_le_one := by
    exact shellSpikeGoodDensityGain_le_one
      (clippedLayerCakeCanonicalTau_pos (B := B) hB)
      (clippedLayerCakeCanonicalX_lt_one (B := B) hB)
      (by rfl)
  endpointAverage :=
    clippedEndpointAverageBound_of_quadraticActiveMassCoreData D
  clippedControls := D.clippedControls
  delta_nonneg := clippedLayerCakeQuadraticEffectiveDelta_nonneg (B := B) hB
  delta_gain := by
    have hgain := shellSpikeGoodDensityGain_clippedLayerCakeCanonicalX_eq_one
      (B := B) hB
    have hstrict := clippedLayerCakeQuadraticEffectiveDelta_gain (B := B) hB
    simpa [hgain] using hstrict

/-! ## Target reduction and final wrapper -/

/-- Active-mass arithmetic target for the effective quadratic layer-cake route. -/
def ClippedLayerCakeQuadraticActiveMassCoreDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        Nonempty (ClippedLayerCakeQuadraticActiveMassCoreData B)

/-- Active-mass core data gives the effective arithmetic data target. -/
theorem clippedLayerCakeEffectiveArithmeticDataTarget_of_quadraticActiveMassCoreDataTarget
    (hCore : ClippedLayerCakeQuadraticActiveMassCoreDataTarget) :
    ClippedLayerCakeEffectiveArithmeticDataTarget := by
  intro B hB hBound
