/-!
# Ratio-active count below endpoint-left cutoff

The previous ratio-active reduction bounded the cutoff-relevant active count by
all ratio-active indices in `Finset.range (M + 1)`.  This refinement keeps the
scale condition coming from interval membership: a cutoff-relevant witness below
shell cutoff `M` also has endpoint-left coordinate at most `M`.
-/

/-! ## Ratio-active indices below the endpoint-left cutoff -/

/-- Ratio-active index whose endpoint-left coordinate lies below cutoff `M`. -/
def EndpointRatioActiveBelowLeftIndex
    (nu : ℝ) (X : ℕ → ℝ) (M j : ℕ) : Prop :=
  EndpointRatioActiveIndex nu X j ∧
    endpointSubwindowIntervalLeft nu X j ≤ (M : ℝ)

/-- Finite set of ratio-active indices below the endpoint-left cutoff. -/
def EndpointRatioActiveBelowLeftIndexFinset
    (nu : ℝ) (X : ℕ → ℝ) (M : ℕ) : Finset ℕ := by
  classical
  exact (Finset.range (M + 1)).filter fun j =>
    EndpointRatioActiveBelowLeftIndex nu X M j

/-- Count of ratio-active indices below the endpoint-left cutoff. -/
def EndpointRatioActiveBelowLeftCount
    (nu : ℝ) (X : ℕ → ℝ) (M : ℕ) : ℕ :=
  (EndpointRatioActiveBelowLeftIndexFinset nu X M).card

/-- Cutoff-prefix endpoint-active relevance plus interval membership gives a
ratio-active index below the endpoint-left cutoff. -/
theorem cutoffPrefixEndpointActiveRelevant_implies_ratioActiveBelowLeft
    {nu : ℝ} {X : ℕ → ℝ} {K : ℕ → ℕ}
    {M m j : ℕ}
    (hnu : 0 < nu)
    (hmM : m ≤ M)
    (hRel : CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X) M m j)
    (hInt : NatInRealInterval m
      (endpointSubwindowIntervalLeft nu X j)
      (endpointSubwindowIntervalRight X j)) :
    EndpointRatioActiveBelowLeftIndex nu X M j := by
  refine ⟨?_, ?_⟩
  · exact cutoffPrefixEndpointActiveRelevant_implies_ratioActive
      (nu := nu) (X := X) (K := K)
      (M := M) (m := m) (j := j) hnu hRel
  · exact le_trans hInt.1 (by exact_mod_cast hmM)

/-! ## Cutoff active count is bounded by the below-left ratio count -/

/-- Every cutoff-relevant active index for the endpoint-active relation is a
ratio-active-below-left index. -/
theorem cutoffRelevantActiveShadowIndexFinset_subset_endpointRatioActiveBelowLeft
    {nu : ℝ} {X : ℕ → ℝ} {K : ℕ → ℕ}
    (hnu : 0 < nu) (M : ℕ) :
    CutoffRelevantActiveShadowIndexFinset
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X)) M
      ⊆ EndpointRatioActiveBelowLeftIndexFinset nu X M := by
  classical
  intro j hj
  dsimp [CutoffRelevantActiveShadowIndexFinset] at hj
  rw [Finset.mem_filter] at hj
  rcases hj with ⟨hjRange, hWitness⟩
  rcases hWitness with ⟨m, hmM, hRel, hInt⟩
  dsimp [EndpointRatioActiveBelowLeftIndexFinset]
  rw [Finset.mem_filter]
  exact ⟨hjRange,
    cutoffPrefixEndpointActiveRelevant_implies_ratioActiveBelowLeft
      (nu := nu) (X := X) (K := K)
      (M := M) (m := m) (j := j) hnu hmM hRel hInt⟩

/-- The cutoff-relevant active count is bounded by the below-left ratio-active
count. -/
theorem cutoffRelevantActiveShadowCount_le_endpointRatioActiveBelowLeftCount
    {nu : ℝ} {X : ℕ → ℝ} {K : ℕ → ℕ}
    (hnu : 0 < nu) (M : ℕ) :
    CutoffRelevantActiveShadowCount
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X)) M
      ≤ EndpointRatioActiveBelowLeftCount nu X M := by
  classical
  unfold CutoffRelevantActiveShadowCount EndpointRatioActiveBelowLeftCount
  exact Finset.card_le_card
    (cutoffRelevantActiveShadowIndexFinset_subset_endpointRatioActiveBelowLeft
      (nu := nu) (X := X) (K := K) hnu M)

