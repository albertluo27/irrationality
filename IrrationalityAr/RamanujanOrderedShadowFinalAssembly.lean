/-! ## Merged from IrrationalityAr/RamanujanCoverageBoundsSandbox.lean -/

/-- Improved explicit exponential checkpoint lower bound for `ACount (1 / π)` from explicit finite-measure coverage.

This theorem selects `ν = max (μ + 1) 3`, sets
`c₀ = (11/2 log 2) / (ν log φ)`, `ρ₀ = (5/2 log 2) / (ν log φ)`, and `Λ₀ = 4 log 2` in the explicit
certification machinery.
-/
theorem exists_eventually_ACount_oneOverPi_floorExp_lower_of_Bauer_finiteMeasure_explicit
    (hBauer : BauerRamanujanIdentity)
    (hfin : HasFiniteIrrationalityMeasure (1 / Real.pi)) :
    ∃ ρ Λ : ℝ,
      0 < ρ ∧ 3 * Real.log 2 < Λ ∧
      ∀ᶠ m : ℕ in atTop,
        ρ * (m : ℝ) ≤
          (ACount (1 / Real.pi)
            (Nat.floor (Real.exp (Λ * (m : ℝ))) : ℕ) : ℝ) := by
  rcases hfin with ⟨μ, hμ⟩
  let ν0 : ℝ := max (μ + 1) 3
  let c0 : ℝ := (11 * Real.log 2 / 2) / (ν0 * Real.log Real.goldenRatio)
  let ρ0 : ℝ := (5 * Real.log 2 / 2) / (ν0 * Real.log Real.goldenRatio)
  let Λ0 : ℝ := 4 * Real.log 2
  have hlog2pos : 0 < Real.log 2 := Real.log_pos (by norm_num : (1 : ℝ) < 2)
  have hφpos : 0 < Real.log Real.goldenRatio := log_goldenRatio_pos
  have hν0 : μ < ν0 := by
    dsimp [ν0]
    exact lt_of_lt_of_le (by linarith) (le_max_left _ _)
  have hν0_ge : (3 : ℝ) ≤ ν0 := by
    dsimp [ν0]
    exact le_max_right _ _
  have hν0pos : 0 < ν0 := by
    nlinarith [hν0_ge]
  have hdenpos : 0 < ν0 * Real.log Real.goldenRatio := by
    exact mul_pos hν0pos hφpos
  have hc0pos : 0 < c0 := by
    dsimp [c0]
    have h11log2pos : 0 < 11 * Real.log 2 / 2 := by
      nlinarith [hlog2pos]
    exact div_pos h11log2pos hdenpos
  have hρ0pos : 0 < ρ0 := by
    dsimp [ρ0]
    positivity
  have hρ0lt : ρ0 < c0 / 2 := by
    dsimp [ρ0, c0]
    have hmul_num : (5 : ℝ) * Real.log 2 / 2 < (11 : ℝ) * Real.log 2 / 2 / 2 := by
      nlinarith [hlog2pos]
    have hden : 0 < ν0 * Real.log Real.goldenRatio := by
      exact mul_pos hν0pos hφpos
    have hdenne : ν0 * Real.log Real.goldenRatio ≠ 0 := ne_of_gt hden
    field_simp [hdenne]
    nlinarith [hmul_num]
  have hc0_upper : c0 < (6 * Real.log 2) / (ν0 * Real.log Real.goldenRatio) := by
    dsimp [c0]
    have hnum : (11 * Real.log 2 / 2) < (6 * Real.log 2) := by
      nlinarith [hlog2pos]
    exact div_lt_div_of_pos_right hnum hdenpos
  have hΛ0 : 3 * Real.log 2 < Λ0 := by
    dsimp [Λ0]
    nlinarith
  have hΛ0_height : c0 * Real.log Real.goldenRatio < Λ0 := by
    have hν0ne : ν0 ≠ 0 := ne_of_gt hν0pos
    have hφne : Real.log Real.goldenRatio ≠ 0 := ne_of_gt hφpos
    have hmul : c0 * Real.log Real.goldenRatio = (11 * Real.log 2) / (2 * ν0) := by
      dsimp [c0]
      field_simp [hν0ne, hφne]
    rw [hmul]
    have hdenpos' : 0 < 2 * ν0 := by positivity
    rw [div_lt_iff₀ hdenpos']
    have hmul_lt : (11 : ℝ) * Real.log 2 < 2 * (ν0 * (4 * Real.log 2)) := by
      have hnum : (11 : ℝ) < 8 * ν0 := by nlinarith [hν0_ge]
      calc
        (11 : ℝ) * Real.log 2 < (8 * ν0) * Real.log 2 := by
          exact mul_lt_mul_of_pos_right hnum hlog2pos
        _ = 2 * (ν0 * (4 * Real.log 2)) := by ring
    simpa [Λ0, mul_assoc, mul_left_comm, mul_comm] using hmul_lt
  have hAcount :
      ∀ᶠ m : ℕ in atTop,
        ρ0 * (m : ℝ) ≤ ((AOneOverPiBelowExp Λ0 m).card : ℝ) := by
    have hcert :
        ∀ᶠ m : ℕ in atTop,
          IntervalCertifiesIntermediatePathPrefix
            (1 / Real.pi) oneOverPiCF
            ramanujanPiL ramanujanPiU
            (linearPathTrial c0 m) m
          ∧
            ρ0 * (m : ℝ) ≤
              (((certifiedOddPathPrefix oneOverPiCF
                  (linearPathTrial c0 m)).filter
                (fun x : ℕ => (x : ℝ) ≤ Real.exp (Λ0 * (m : ℝ)))).card : ℝ) :=
      eventuallyManyCertifiedAOneOverPiPathBelowExp_concrete_boundary_slope
        (μ := μ) (ν := ν0) (c := c0) (ρ := ρ0) (Λ := Λ0)
        hBauer hμ hν0 hν0pos hc0pos hc0_upper hρ0lt hΛ0_height
    exact eventually_AOneOverPiBelowExp_card_lower_of_certified
      (c := c0) (ρ := ρ0) (Λ := Λ0) hcert
  refine ⟨ρ0, Λ0, hρ0pos, hΛ0, ?_⟩
  filter_upwards [hAcount] with m hm
  have hcast :
      ((AOneOverPiBelowExp Λ0 m).card : ℝ) ≤
        (ACount (1 / Real.pi) (Nat.floor (Real.exp (Λ0 * (m : ℝ))) : ℕ) : ℝ) :=
    by
      exact_mod_cast (AOneOverPiBelowExp_card_le_ACount_floor_exp (Λ := Λ0) m)
  exact hm.trans hcast

/-- Promoted explicit logarithmic lower bound for `ACount (1 / π)` (re-exported from
the finite-measure Ramanujan pipeline). -/
theorem promoted_ACount_oneOverPi_log_lower_of_Bauer_finiteMeasure_explicit
    (hBauer : BauerRamanujanIdentity)
    (hfin : HasFiniteIrrationalityMeasure (1 / Real.pi)) :
    ∃ c : ℝ, 0 < c ∧
      ∀ᶠ N : ℕ in atTop, c * Real.log N ≤ (ACount (1 / Real.pi) N : ℝ) := by
  rcases hfin with ⟨μ, hμ⟩
  let ν0 : ℝ := max (μ + 1) 3
  let c0 : ℝ := (11 * Real.log 2 / 2) / (ν0 * Real.log Real.goldenRatio)
  let ρ0 : ℝ := (5 * Real.log 2 / 2) / (ν0 * Real.log Real.goldenRatio)
  let Λ0 : ℝ := 4 * Real.log 2
  let c : ℝ := 5 / (16 * ν0 * Real.log Real.goldenRatio)
  have hlog2pos : 0 < Real.log 2 := Real.log_pos (by norm_num : (1 : ℝ) < 2)
  have hφpos : 0 < Real.log Real.goldenRatio := log_goldenRatio_pos
  have hν0 : μ < ν0 := by
    dsimp [ν0]
    exact lt_of_lt_of_le (by linarith) (le_max_left _ _)
  have hν0_ge : (3 : ℝ) ≤ ν0 := by
    dsimp [ν0]
    exact le_max_right _ _
  have hν0pos : 0 < ν0 := by
    nlinarith [hν0_ge]
  have hdenpos : 0 < ν0 * Real.log Real.goldenRatio := by
    exact mul_pos hν0pos hφpos
  have hΛ0 : 3 * Real.log 2 < Λ0 := by
    dsimp [Λ0]
    nlinarith [hlog2pos]
  have hcpos : 0 < c := by
    dsimp [c]
    positivity
  have hAcountExp :
      ∀ᶠ m : ℕ in atTop,
        ρ0 * (m : ℝ) ≤ ((AOneOverPiBelowExp Λ0 m).card : ℝ) := by
    have hcert :
        ∀ᶠ m : ℕ in atTop,
          IntervalCertifiesIntermediatePathPrefix
            (1 / Real.pi) oneOverPiCF
            ramanujanPiL ramanujanPiU
            (linearPathTrial c0 m) m
          ∧
            ρ0 * (m : ℝ) ≤
              (((certifiedOddPathPrefix oneOverPiCF
                  (linearPathTrial c0 m)).filter
                (fun x : ℕ => (x : ℝ) ≤ Real.exp (Λ0 * (m : ℝ)))).card : ℝ) :=
      eventuallyManyCertifiedAOneOverPiPathBelowExp_concrete_boundary_slope
        (μ := μ) (ν := ν0) (c := c0) (ρ := ρ0) (Λ := Λ0)
        hBauer hμ hν0 hν0pos
        (by
          dsimp [c0]
          have h11log2pos : 0 < 11 * Real.log 2 / 2 := by
            nlinarith [hlog2pos]
          exact div_pos h11log2pos hdenpos)
        (by
          dsimp [c0]
          have hnum : (11 : ℝ) * Real.log 2 / 2 < 6 * Real.log 2 := by
            nlinarith [hlog2pos]
          exact (div_lt_div_of_pos_right hnum (mul_pos hν0pos hφpos))
        )
        (by
          dsimp [ρ0, c0]
          have hν0ne : ν0 ≠ 0 := ne_of_gt hν0pos
          have hφne : Real.log Real.goldenRatio ≠ 0 := ne_of_gt hφpos
          have hden : 0 < ν0 * Real.log Real.goldenRatio := mul_pos hν0pos hφpos
          have hdenne : ν0 * Real.log Real.goldenRatio ≠ 0 := ne_of_gt hden
          have hmul_num : (5 : ℝ) * Real.log 2 / 2 < (11 : ℝ) * Real.log 2 / 2 / 2 := by
            nlinarith [hlog2pos]
          field_simp [hν0ne, hφne, hdenne]
          nlinarith [hmul_num])
        (by
          have hν0ne : ν0 ≠ 0 := ne_of_gt hν0pos
          have hφne : Real.log Real.goldenRatio ≠ 0 := ne_of_gt hφpos
          have hmul : c0 * Real.log Real.goldenRatio = (11 * Real.log 2) / (2 * ν0) := by
            dsimp [c0]
            field_simp [hν0ne, hφne]
          rw [hmul]
          have hdenpos' : 0 < 2 * ν0 := by positivity
          rw [div_lt_iff₀ hdenpos']
          have hmul_lt : (11 : ℝ) * Real.log 2 < 2 * (ν0 * (4 * Real.log 2)) := by
            have hnum : (11 : ℝ) < 8 * ν0 := by nlinarith [hν0_ge]
            calc
              (11 : ℝ) * Real.log 2 < (8 * ν0) * Real.log 2 := by
                exact mul_lt_mul_of_pos_right hnum hlog2pos
              _ = 2 * (ν0 * (4 * Real.log 2)) := by ring
          simpa [Λ0, mul_assoc, mul_left_comm, mul_comm] using hmul_lt)
    exact eventually_AOneOverPiBelowExp_card_lower_of_certified
      (c := c0) (ρ := ρ0) (Λ := Λ0) hcert
  have hAcount :
      ∀ᶠ m : ℕ in atTop,
        ρ0 * (m : ℝ) ≤
          (ACount (1 / Real.pi)
            (Nat.floor (Real.exp (Λ0 * (m : ℝ))) : ℕ) : ℝ) := by
    filter_upwards [hAcountExp] with m hm
    exact hm.trans (by
      exact_mod_cast (AOneOverPiBelowExp_card_le_ACount_floor_exp (Λ := Λ0) m))
  rw [Filter.eventually_atTop] at hAcount
  rcases hAcount with ⟨N₀, hN₀⟩
  let N0 : ℕ := Nat.floor (Real.exp (Λ0 * (N₀ : ℝ))) + 1
  let N₁ : ℕ := Nat.floor (Real.exp (2 * Λ0)) + 1
  have hc : c = ρ0 / (2 * Λ0) := by
    dsimp [c, c0, ρ0, Λ0]
    have hlog2ne : Real.log 2 ≠ 0 := ne_of_gt hlog2pos
    field_simp [ne_of_gt hν0pos, ne_of_gt hφpos, hlog2ne]
    ring
  refine ⟨c, hcpos, ?_⟩
  rw [Filter.eventually_atTop]
  refine ⟨Nat.max (Nat.max N₀ N0) N₁, ?_⟩
  intro N hNmax
  have hN₀' : N₀ ≤ N := by
    exact (Nat.le_max_left N₀ N0).trans ((Nat.le_max_left (Nat.max N₀ N0) N₁).trans hNmax)
  have hN0' : N0 ≤ N := by
    have hN00 : N0 ≤ Nat.max N₀ N0 := Nat.le_max_right _ _
    have hN000 : Nat.max N₀ N0 ≤ Nat.max (Nat.max N₀ N0) N₁ := Nat.le_max_left _ _
    have hN000' : Nat.max (Nat.max N₀ N0) N₁ ≤ N := hNmax
    exact hN00.trans (hN000.trans hN000')
  have hN₁' : N₁ ≤ N := by
    have hN₁₀ : N₁ ≤ Nat.max (Nat.max N₀ N0) N₁ := Nat.le_max_right _ _
    exact hN₁₀.trans hNmax
  have hN₁pos : 1 ≤ N₁ := by
    dsimp [N₁]
    exact Nat.succ_le_succ (Nat.zero_le _)
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (hN₁pos.trans hN₁')
  let m : ℕ := Nat.floor (Real.log (N : ℝ) / Λ0)
  have hm_ge_N₀ : N₀ ≤ m := by
    have hExp_lt : Real.exp (Λ0 * (N₀ : ℝ)) < (N : ℝ) := by
      have hlt_floor : Real.exp (Λ0 * (N₀ : ℝ)) < (Nat.floor (Real.exp (Λ0 * (N₀ : ℝ))) + 1) := by
        simpa [Nat.cast_add, Nat.cast_one] using
          (Nat.lt_floor_add_one (Real.exp (Λ0 * (N₀ : ℝ))))
      have hNfloor : Nat.floor (Real.exp (Λ0 * (N₀ : ℝ))) + 1 ≤ N := by
        simpa [N0] using hN0'
      have hfloor_le : ((Nat.floor (Real.exp (Λ0 * (N₀ : ℝ))) : ℕ) : ℝ) + 1 ≤ (N : ℝ) := by
        exact_mod_cast hNfloor
      exact lt_of_lt_of_le hlt_floor (by
        simpa [Nat.cast_add, Nat.cast_one, add_assoc, add_left_comm, add_comm] using hfloor_le)
    have hlog_lt : Λ0 * (N₀ : ℝ) < Real.log (N : ℝ) := by
      simpa [Real.log_exp] using (Real.log_lt_log (Real.exp_pos _) hExp_lt)
    have hM0' : (N₀ : ℝ) ≤ Real.log (N : ℝ) / Λ0 := by
      have hΛ0pos : 0 < Λ0 := by
        dsimp [Λ0]
        nlinarith [hlog2pos]
      have hΛ0ne : Λ0 ≠ 0 := ne_of_gt hΛ0pos
      have htmp' : (N₀ : ℝ) * Λ0 ≤ Real.log (N : ℝ) := by
        simpa [mul_comm] using (le_of_lt hlog_lt)
      have htmp'' : (N₀ : ℝ) * Λ0 * Λ0⁻¹ ≤ (Real.log (N : ℝ)) * Λ0⁻¹ := by
        exact mul_le_mul_of_nonneg_right htmp' (inv_nonneg.mpr (le_of_lt hΛ0pos))
      simpa [div_eq_mul_inv, hΛ0ne, mul_assoc, mul_left_comm, mul_comm] using htmp''
    exact Nat.le_floor hM0'
  have hcheckpoint :
      ρ0 * (m : ℝ) ≤
        (ACount (1 / Real.pi) (Nat.floor (Real.exp (Λ0 * (m : ℝ))) : ℕ) : ℝ) :=
    hN₀ m hm_ge_N₀
  have hle_arg : Real.exp (Λ0 * (m : ℝ)) ≤ (N : ℝ) := by
    have hmul : (m : ℝ) ≤ Real.log (N : ℝ) / Λ0 := by
      have hN1R : (1 : ℝ) ≤ (N : ℝ) := by
        exact_mod_cast (hN₁pos.trans hN₁')
      exact Nat.floor_le (by
        apply div_nonneg
        · exact Real.log_nonneg hN1R
        · have hΛ0pos : 0 < Λ0 := by
            dsimp [Λ0]
            nlinarith [hlog2pos]
          exact le_of_lt hΛ0pos)
    have hmul' : (m : ℝ) * Λ0 ≤ Real.log (N : ℝ) / Λ0 * Λ0 := by
      exact mul_le_mul_of_nonneg_right hmul (le_of_lt (by
        have hΛ0pos : 0 < Λ0 := by
          dsimp [Λ0]
          nlinarith [hlog2pos]
        exact hΛ0pos))
    have hmul'' : (m : ℝ) * Λ0 ≤ Real.log (N : ℝ) := by
      have hΛ00 : Λ0 ≠ 0 := ne_of_gt (by
        dsimp [Λ0]
        nlinarith [hlog2pos])
      have hrewrite : Real.log (N : ℝ) / Λ0 * Λ0 = Real.log (N : ℝ) := by
        field_simp [hΛ00]
      simpa [hrewrite] using hmul'
    have hExp_le_log : Real.exp (Λ0 * (m : ℝ)) ≤ Real.exp (Real.log (N : ℝ)) :=
      (Real.exp_le_exp).2 (by simpa [mul_comm] using hmul'')
    simpa [Real.exp_log hNpos] using hExp_le_log
  have hfloor_le : Nat.floor (Real.exp (Λ0 * (m : ℝ))) ≤ N := by
    have hcast : ((Nat.floor (Real.exp (Λ0 * (m : ℝ))) : ℕ) : ℝ) ≤ (N : ℝ) := by
      exact (Nat.floor_le (by positivity : (0 : ℝ) ≤ Real.exp (Λ0 * (m : ℝ)))).trans hle_arg
    exact_mod_cast hcast
  have hMono :
      (ACount (1 / Real.pi) (Nat.floor (Real.exp (Λ0 * (m : ℝ))) : ℕ) : ℝ) ≤
        (ACount (1 / Real.pi) N : ℝ) := by
    exact_mod_cast (natSetCount_mono (S := A (1 / Real.pi)) hfloor_le)
  have hm_le : Real.log (N : ℝ) / Λ0 - 1 ≤ m := by
    have hfloor_lt : Real.log (N : ℝ) / Λ0 < (m : ℝ) + 1 := by
      exact Nat.lt_floor_add_one (Real.log (N : ℝ) / Λ0)
    nlinarith
  have hdiv₂ : (2 : ℝ) ≤ Real.log (N : ℝ) / Λ0 := by
    have htmp : (2 : ℝ) * Λ0 ≤ Real.log (N : ℝ) := by
      have hExp : Real.exp (2 * Λ0) ≤ (N : ℝ) := by
        have hExp_lt : Real.exp (2 * Λ0) < (Nat.floor (Real.exp (2 * Λ0)) + 1) := by
          simpa [Nat.cast_add, Nat.cast_one] using
            (Nat.lt_floor_add_one (Real.exp (2 * Λ0)))
        have hfloor_le : (Nat.floor (Real.exp (2 * Λ0)) + 1) ≤ N := by
          simpa [N₁] using hN₁'
        have hfloor_leR : ((Nat.floor (Real.exp (2 * Λ0)) : ℕ) : ℝ) + 1 ≤ (N : ℝ) := by
          exact_mod_cast hfloor_le
        exact le_of_lt (lt_of_lt_of_le hExp_lt (by
          simpa [Nat.cast_add, Nat.cast_one, add_assoc, add_left_comm, add_comm] using hfloor_leR))
      have hlogExp : Real.log (Real.exp (2 * Λ0)) ≤ Real.log (N : ℝ) := by
        exact Real.log_le_log (Real.exp_pos _) hExp
      simpa [Real.log_exp] using hlogExp
    have hΛ0pos : 0 < Λ0 := by
      dsimp [Λ0]
      nlinarith [hlog2pos]
    have htmp' : (2 : ℝ) * Λ0 * Λ0⁻¹ ≤ Real.log (N : ℝ) * Λ0⁻¹ := by
      exact mul_le_mul_of_nonneg_right htmp (inv_nonneg.mpr (le_of_lt hΛ0pos))
    have hΛ0ne : Λ0 ≠ 0 := ne_of_gt hΛ0pos
    simpa [div_eq_mul_inv, hΛ0ne, mul_assoc, mul_left_comm, mul_comm] using htmp'
  have hρ0pos : 0 < ρ0 := by
    dsimp [ρ0]
    positivity
  have hmulρ : c * Real.log (N : ℝ) ≤ ρ0 * (m : ℝ) := by
    have hscale : c * Real.log (N : ℝ) ≤ ρ0 * (Real.log (N : ℝ) / Λ0 - 1) := by
      have htmp : c * Real.log (N : ℝ) = (ρ0 / 2) * (Real.log (N : ℝ) / Λ0) := by
        rw [hc]
        have hΛ0pos : 0 < Λ0 := by
          dsimp [Λ0]
          nlinarith [hlog2pos]
        field_simp [ne_of_gt hΛ0pos]
      rw [htmp]
      have hΛ0pos : 0 < Λ0 := by
        dsimp [Λ0]
        nlinarith [hlog2pos]
      nlinarith [hdiv₂, hρ0pos]
    exact hscale.trans (mul_le_mul_of_nonneg_left hm_le (le_of_lt hρ0pos))
  exact hmulρ.trans (hcheckpoint.trans hMono)


/-!
# Ramanujan shell spike-covering scaffold

This file packages the shell-spike-covering program discussed in the chat.

The completed parts are deliberately abstract and reusable:

* logarithmic spike-shadow intervals;
* the elementary implication from a block-scale spike certificate to membership
  in its shadow interval;
* pointwise shadow-cover transfer to upper-density bounds;
* the algebraic threshold functions
  `tau / (2 * tau + 1)`, `tau / (tau + 1)`, and the predicted good-density gain;
* wrappers turning a proved shadow-density estimate into a strict
  `< 1 - v / M` bad-shell density statement.

The hard project-specific parts are left as theorem-shaped predicates, not
axioms.  In particular, the remaining mathematical work is to prove that actual
visible block spikes for `1 / π` satisfy the abstract shadow-cover hypotheses,
and then to prove the shadow-density formula from the recurrence inequalities
for continued-fraction denominators.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanShellSpikeCovering.lean -/

/-! ## 1. Logarithmic shell scale and spike shadows -/

/-- Left endpoint of the logarithmic spike shadow attached to a block with
`u = log q_j` and threshold exponent `x`.

Mathematically this is `u / (1 - x)`. -/
def spikeShadowStart (u x : ℝ) : ℝ := u / (1 - x)

/-- Right endpoint of the logarithmic spike shadow attached to a block with
`v = log a_{j+1}` and threshold exponent `x`.

Mathematically this is `v / x`. -/
def spikeShadowEnd (v x : ℝ) : ℝ := v / x

/-- Log-scale spike shadow for a single continued-fraction block. -/
def spikeShadowLog (u v : ℕ → ℝ) (x : ℝ) (j : ℕ) : Set ℝ :=
  Set.Icc (spikeShadowStart (u j) x) (spikeShadowEnd (v j) x)

/-- Shell-index shadow: shell `m` is in block `j`'s shadow if the logarithmic
height `Hlog m` lies in the block's log shadow. -/
def spikeShadowShell (Hlog u v : ℕ → ℝ) (x : ℝ) (j : ℕ) : Set ℕ :=
  {m : ℕ | Hlog m ∈ spikeShadowLog u v x j}

/-- Union of all spike-shadow shell sets. -/
def spikeShadowShellUnion (Hlog u v : ℕ → ℝ) (x : ℝ) : ℕ → Prop :=
  fun m => ∃ j : ℕ, m ∈ spikeShadowShell Hlog u v x j

/-- A local algebraic certificate that block data `(u,v)` can produce an
`H^x`-spike at logarithmic height `h`.

The two inequalities are the abstract version of:

* many visible intermediate denominators force `q_j ≤ H^{1-x}`;
* a long enough block forces `a_{j+1} ≥ H^x`.
-/
def BlockCanSpikeAt (u v h x : ℝ) : Prop :=
  u ≤ (1 - x) * h ∧ x * h ≤ v

/-- The elementary conversion from a local spike certificate to shadow
membership. -/
theorem mem_spikeShadowLog_of_BlockCanSpikeAt
    {u v h x : ℝ}
    (hx0 : 0 < x) (hx1 : x < 1)
    (hsp : BlockCanSpikeAt u v h x) :
    h ∈ Set.Icc (spikeShadowStart u x) (spikeShadowEnd v x) := by
  rcases hsp with ⟨hu, hv⟩
  constructor
  · have hden : 0 < 1 - x := by linarith
    rw [spikeShadowStart]
    exact (div_le_iff₀ hden).mpr (by simpa [mul_comm] using hu)
  · rw [spikeShadowEnd]
    exact (le_div_iff₀ hx0).mpr (by simpa [mul_comm] using hv)

/-- Pointwise shadow-cover predicate for a bad-shell criterion. -/
def BadShellsCoveredByShadows
    (Bad : ℕ → Prop) (Hlog u v : ℕ → ℝ) (x : ℝ) : Prop :=
  ∀ m : ℕ, Bad m → spikeShadowShellUnion Hlog u v x m

/-- A convenient way to prove shadow cover: produce a block-scale spike
certificate for each bad shell. -/
theorem BadShellsCoveredByShadows_of_block_certificate
    {Bad : ℕ → Prop} {Hlog u v : ℕ → ℝ} {x : ℝ}
    (hx0 : 0 < x) (hx1 : x < 1)
    (hcert : ∀ m : ℕ, Bad m →
      ∃ j : ℕ, BlockCanSpikeAt (u j) (v j) (Hlog m) x) :
    BadShellsCoveredByShadows Bad Hlog u v x := by
  intro m hm
  rcases hcert m hm with ⟨j, hj⟩
  refine ⟨j, ?_⟩
  exact mem_spikeShadowLog_of_BlockCanSpikeAt hx0 hx1 hj

/-! ## 2. Density transfer from shadows to bad shells -/

/-- If every bad shell is contained in the shadow union, upper-density bounds
for the shadow union transfer to the bad shells. -/
theorem upperDensity_badShells_atMost_of_shadowCover
    {Bad : ℕ → Prop} {Hlog u v : ℕ → ℝ} {x δ : ℝ}
    (hcover : BadShellsCoveredByShadows Bad Hlog u v x)
    (hshadow : UpperNatDensityAtMost (spikeShadowShellUnion Hlog u v x) δ) :
    UpperNatDensityAtMost Bad δ := by
  exact Criteria.upperDensityAtMost_mono hcover hshadow

/-- Strict-density wrapper in the requested form `< 1 - v / M`. -/
theorem upperDensity_badShells_lt_one_sub_v_div_M
    {Bad : ℕ → Prop} {δ v M : ℝ}
    (hδ0 : 0 ≤ δ)
    (hδlt : δ < 1 - v / M)
    (hbad : UpperNatDensityAtMost Bad δ) :
    UpperNatDensityLessThan Bad (1 - v / M) := by
  exact ⟨δ, hδ0, hδlt, hbad⟩

/-- Combined shadow-cover and strict-density wrapper. -/
theorem upperDensity_badShells_lt_one_sub_v_div_M_of_shadow
    {Bad : ℕ → Prop} {Hlog u vseq : ℕ → ℝ} {x δ v M : ℝ}
    (hcover : BadShellsCoveredByShadows Bad Hlog u vseq x)
    (hshadow : UpperNatDensityAtMost (spikeShadowShellUnion Hlog u vseq x) δ)
    (hδ0 : 0 ≤ δ)
    (hδlt : δ < 1 - v / M) :
    UpperNatDensityLessThan Bad (1 - v / M) := by
  exact upperDensity_badShells_lt_one_sub_v_div_M hδ0 hδlt
    (upperDensity_badShells_atMost_of_shadowCover hcover hshadow)

/-! ## 3. Threshold algebra -/

/-- If `tau = M - 2`, then `tau / (2 * tau + 1)` is the predicted threshold
above which spike shadows have a positive good-shell density under the current
one-step recurrence analysis. -/
def shellSpikeSeparationThreshold (tau : ℝ) : ℝ :=
  tau / (2 * tau + 1)

/-- The global block exponent corresponding to `tau`. -/
def shellSpikeGlobalExponent (tau : ℝ) : ℝ :=
  tau / (tau + 1)

/-- Predicted lower density of good shells for threshold exponent `x`, under
`v_j / u_j ≤ tau` and the worst-case shadow-overlap recurrence.

The bad-shell upper-density prediction is `1 - shellSpikeGoodDensityGain tau x`.
-/
def shellSpikeGoodDensityGain (tau x : ℝ) : ℝ :=
  (x * (2 * tau + 1) - tau) / (tau ^ 2 * (1 - x))

/-- Positivity of the good-density gain above the separation threshold. -/
theorem shellSpikeGoodDensityGain_pos
    {tau x : ℝ}
    (htau : 0 < tau)
    (hx : shellSpikeSeparationThreshold tau < x)
    (hx1 : x < 1) :
    0 < shellSpikeGoodDensityGain tau x := by
  have hden1 : 0 < 2 * tau + 1 := by nlinarith
  have hden2 : 0 < tau ^ 2 * (1 - x) := by
    have htau2 : 0 < tau ^ 2 := sq_pos_of_ne_zero (ne_of_gt htau)
    have h1x : 0 < 1 - x := by linarith
    exact mul_pos htau2 h1x
  have hnum : 0 < x * (2 * tau + 1) - tau := by
    rw [shellSpikeSeparationThreshold] at hx
    have hmul : tau < x * (2 * tau + 1) := (div_lt_iff₀ hden1).mp hx
    linarith
  rw [shellSpikeGoodDensityGain]
  exact div_pos hnum hden2

/-- The predicted good-density gain is at most `1` up to the global exponent.
The hypothesis `x < 1` is passed explicitly to keep this lemma purely algebraic
and avoid proving the harmless fact `tau / (tau + 1) < 1` each time. -/
theorem shellSpikeGoodDensityGain_le_one
    {tau x : ℝ}
    (htau : 0 < tau)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau) :
    shellSpikeGoodDensityGain tau x ≤ 1 := by
  have hden : 0 < tau ^ 2 * (1 - x) := by
    have htau2 : 0 < tau ^ 2 := sq_pos_of_ne_zero (ne_of_gt htau)
    have h1x : 0 < 1 - x := by linarith
    exact mul_pos htau2 h1x
  rw [shellSpikeGoodDensityGain]
  rw [div_le_iff₀ hden]
  have hdenpos : 0 < tau + 1 := by linarith
  have hxτ : x * (tau + 1) ≤ tau := by
    rw [shellSpikeGlobalExponent] at hxθ
    exact (le_div_iff₀ hdenpos).mp hxθ
  nlinarith

/-- At `x = 1 / 2`, the good-density gain simplifies to `1 / tau^2`.
This is the clean square-root good-shell statement. -/
theorem shellSpikeGoodDensityGain_one_half
    {tau : ℝ} (htau : tau ≠ 0) :
    shellSpikeGoodDensityGain tau (1 / 2) = 1 / tau ^ 2 := by
  rw [shellSpikeGoodDensityGain]
  field_simp [htau]
  ring

/-- If a shadow-density theorem proves the predicted density, then any rational
`v / M` below the predicted good-density gain gives the requested strict
`< 1 - v / M` spike-covering statement. -/
theorem upperDensity_badShells_lt_one_sub_v_div_M_of_predicted_shadow_density
    {Bad : ℕ → Prop} {Hlog u vseq : ℕ → ℝ} {x tau v M : ℝ}
    (hcover : BadShellsCoveredByShadows Bad Hlog u vseq x)
    (hshadow :
      UpperNatDensityAtMost
        (spikeShadowShellUnion Hlog u vseq x)
        (1 - shellSpikeGoodDensityGain tau x))
    (_hgain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau x)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (hvm : v / M < shellSpikeGoodDensityGain tau x) :
    UpperNatDensityLessThan Bad (1 - v / M) := by
  have hδ0 : 0 ≤ 1 - shellSpikeGoodDensityGain tau x := by
    nlinarith [hgain_le_one]
  have hδlt : 1 - shellSpikeGoodDensityGain tau x < 1 - v / M := by
    linarith
  exact upperDensity_badShells_lt_one_sub_v_div_M_of_shadow
    hcover hshadow hδ0 hδlt

/-! ## 4. Project-facing predicates for the remaining hard steps -/

/-- The actual bad shell predicate at height sequence `H` and visible block
maximum sequence `V`: the shell is bad at exponent `x` when `V_m > H_m^x`.
This is kept abstract so the file can be used both with exactness heights and
with other geometric shell systems. -/
def VisibleBlockSpikeShell (H V : ℕ → ℝ) (x : ℝ) (m : ℕ) : Prop :=
  (H m) ^ x < V m

/-- The main missing analytic-combinatorial theorem for the actual
Ramanujan/continued-fraction data: actual visible-block spikes are covered by
logarithmic spike shadows. -/
def ActualSpikeShellsHaveShadowCover
    (Hlog u v : ℕ → ℝ) (V H : ℕ → ℝ) (x : ℝ) : Prop :=
  BadShellsCoveredByShadows (VisibleBlockSpikeShell H V x) Hlog u v x

/-- The main missing deterministic density theorem for the shadows.  A future
proof should derive this from:

* `u (j+1) ≥ u j + v j`,
* `0 ≤ v j ≤ tau * u j` eventually,
* monotonicity of `Hlog`,
* asymptotic linearity of `Hlog m`.
-/
def PredictedSpikeShadowDensity
    (Hlog u v : ℕ → ℝ) (tau x : ℝ) : Prop :=
  UpperNatDensityAtMost
    (spikeShadowShellUnion Hlog u v x)
    (1 - shellSpikeGoodDensityGain tau x)

/-- Final project-facing wrapper: once the actual shadow cover and the predicted
shadow-density theorem are proved, the requested strict spike-density deficit
follows. -/
theorem visibleBlockSpikeShell_density_deficit_of_shadow_density
    {Hlog u vseq H V : ℕ → ℝ} {tau x gain v M : ℝ}
    (hcover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x)
    (hshadow : PredictedSpikeShadowDensity Hlog u vseq tau x)
    (hgain_def : gain = shellSpikeGoodDensityGain tau x)
    (hgain_nonneg : 0 ≤ gain)
    (hgain_le_one : gain ≤ 1)
    (hvm : v / M < gain) :
    UpperNatDensityLessThan (VisibleBlockSpikeShell H V x) (1 - v / M) := by
  subst gain
  exact upperDensity_badShells_lt_one_sub_v_div_M_of_predicted_shadow_density
    hcover hshadow hgain_nonneg hgain_le_one hvm


/-!
# Extensions for the Ramanujan shell spike-covering scaffold

This file supplies the small algebra and transfer wrappers used by the
completion layer.  It introduces no project-specific axioms: the hard inputs
remain the shadow-cover and predicted-shadow-density predicates from
`RamanujanShellSpikeCovering`.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanShellSpikeCoveringExtensions.lean -/

/-! ## Normalized shadow-budget algebra -/

/-- Normalized right-end factor for a shadow with block ratio `r = v/u`.
If the normalized start is `S = u / (1 - x)`, then the right endpoint is
`shellSpikeNormalizedEnd r x * S`. -/
def shellSpikeNormalizedEnd (r x : ℝ) : ℝ :=
  r * (1 - x) / x

/-- Normalized length factor for a shadow with block ratio `r = v/u`. -/
def shellSpikeNormalizedLength (r x : ℝ) : ℝ :=
  shellSpikeNormalizedEnd r x - 1

/-- The carry coefficient for the one-step normalized shadow budget. -/
def shellSpikeCarry (tau x : ℝ) : ℝ :=
  (1 - x) / x - 1 / tau

/-- The predicted bad-shell density coefficient. -/
def shellSpikeBadDensity (tau x : ℝ) : ℝ :=
  1 - shellSpikeGoodDensityGain tau x

/-- The carry coefficient is nonnegative throughout the admissible exponent
range `0 < x <= tau / (tau + 1)`. -/
theorem shellSpikeCarry_nonneg
    {tau x : ℝ}
    (htau : 0 < tau)
    (hx0 : 0 < x)
    (hxθ : x ≤ shellSpikeGlobalExponent tau) :
    0 ≤ shellSpikeCarry tau x := by
  have hden : 0 < tau + 1 := by linarith
  have hxτ : x * (tau + 1) ≤ tau := by
    rw [shellSpikeGlobalExponent] at hxθ
    exact (le_div_iff₀ hden).mp hxθ
  rw [shellSpikeCarry]
  rw [sub_nonneg]
  rw [div_le_div_iff₀ htau hx0]
  nlinarith

/-- Extremal carry-step identity at `r = tau`. -/
theorem shellSpikeCarry_step_identity
    {tau x : ℝ}
    (htau : tau ≠ 0) (hx : x ≠ 0) :
    shellSpikeCarry tau x * (1 + tau) -
      (shellSpikeCarry tau x + shellSpikeNormalizedLength tau x) = 0 := by
  rw [shellSpikeCarry, shellSpikeNormalizedLength, shellSpikeNormalizedEnd]
  field_simp [htau, hx]
  ring_nf

/-- One-step carry budget for an admissible normalized schedule. -/
theorem shellSpike_budget_step
    {tau x r C S Snext : ℝ}
    (htau : 0 < tau)
    (_hx0 : 0 < x)
    (hcarry : 0 ≤ shellSpikeCarry tau x)
    (hS : 0 ≤ S)
    (hr : r ≤ tau)
    (hC : C ≤ shellSpikeCarry tau x * S)
    (hnext : (1 + r) * S ≤ Snext) :
    C + shellSpikeNormalizedLength r x * S ≤
      shellSpikeCarry tau x * Snext := by
  have hmul_next :
      shellSpikeCarry tau x * ((1 + r) * S) ≤
        shellSpikeCarry tau x * Snext :=
    mul_le_mul_of_nonneg_left hnext hcarry
  have hlocal :
      shellSpikeNormalizedLength r x ≤ shellSpikeCarry tau x * r := by
    have hdiff :
        shellSpikeNormalizedLength r x - shellSpikeCarry tau x * r =
          r / tau - 1 := by
      rw [shellSpikeNormalizedLength, shellSpikeNormalizedEnd, shellSpikeCarry]
      ring_nf
    have hdiv : r / tau ≤ 1 := (div_le_one htau).2 hr
    linarith
  have hlocalS :
      shellSpikeNormalizedLength r x * S ≤
        (shellSpikeCarry tau x * r) * S :=
    mul_le_mul_of_nonneg_right hlocal hS
  calc
    C + shellSpikeNormalizedLength r x * S
        ≤ shellSpikeCarry tau x * S +
          (shellSpikeCarry tau x * r) * S := by
            exact add_le_add hC hlocalS
    _ = shellSpikeCarry tau x * ((1 + r) * S) := by ring
    _ ≤ shellSpikeCarry tau x * Snext := hmul_next

/-- Extremal endpoint identity at `r = tau`. -/
theorem shellSpike_endpoint_slack_identity
    {tau x : ℝ}
    (htau : tau ≠ 0) (hx : x ≠ 0) (hx1 : x ≠ 1) :
    shellSpikeBadDensity tau x * shellSpikeNormalizedEnd tau x -
      (shellSpikeCarry tau x + shellSpikeNormalizedLength tau x) = 0 := by
  have h1x : 1 - x ≠ 0 := by
    intro h
    apply hx1
    linarith
  rw [shellSpikeBadDensity, shellSpikeGoodDensityGain, shellSpikeCarry,
    shellSpikeNormalizedLength, shellSpikeNormalizedEnd]
  field_simp [htau, hx, h1x]
  ring

/-- Endpoint budget for one shadow after the carry term is available. -/
theorem shellSpike_budget_at_endpoint
    {tau x r C S : ℝ}
    (htau : 0 < tau)
    (hx0 : 0 < x)
    (hxsep : shellSpikeSeparationThreshold tau < x)
    (hx1 : x < 1)
    (hS : 0 ≤ S)
    (hr : r ≤ tau)
    (hC : C ≤ shellSpikeCarry tau x * S) :
    C + shellSpikeNormalizedLength r x * S ≤
      shellSpikeBadDensity tau x * (shellSpikeNormalizedEnd r x * S) := by
  have hgain_pos : 0 < shellSpikeGoodDensityGain tau x := by
    exact shellSpikeGoodDensityGain_pos htau hxsep hx1
  have hlocal :
      shellSpikeCarry tau x + shellSpikeNormalizedLength r x ≤
        shellSpikeBadDensity tau x * shellSpikeNormalizedEnd r x := by
    have hA_nonneg : 0 ≤ (1 - x) / x := by
      exact le_of_lt (div_pos (by linarith) hx0)
    have hcoeff_nonneg :
        0 ≤ shellSpikeGoodDensityGain tau x * ((1 - x) / x) :=
      mul_nonneg (le_of_lt hgain_pos) hA_nonneg
    have hrsub : r - tau ≤ 0 := by linarith
    have hdiff :
        shellSpikeCarry tau x + shellSpikeNormalizedLength r x -
            shellSpikeBadDensity tau x * shellSpikeNormalizedEnd r x =
          shellSpikeGoodDensityGain tau x * ((1 - x) / x) * (r - tau) := by
      have h1x : 1 - x ≠ 0 := by
        linarith
      rw [shellSpikeBadDensity, shellSpikeGoodDensityGain, shellSpikeCarry,
        shellSpikeNormalizedLength, shellSpikeNormalizedEnd]
      field_simp [ne_of_gt htau, ne_of_gt hx0, h1x]
      ring
    have hterm :
        shellSpikeGoodDensityGain tau x * ((1 - x) / x) * (r - tau) ≤ 0 :=
      mul_nonpos_of_nonneg_of_nonpos hcoeff_nonneg hrsub
    linarith
  have hlocalS :
      (shellSpikeCarry tau x + shellSpikeNormalizedLength r x) * S ≤
        (shellSpikeBadDensity tau x * shellSpikeNormalizedEnd r x) * S :=
    mul_le_mul_of_nonneg_right hlocal hS
  calc
    C + shellSpikeNormalizedLength r x * S
        ≤ shellSpikeCarry tau x * S +
          shellSpikeNormalizedLength r x * S := by
            linarith
    _ = (shellSpikeCarry tau x + shellSpikeNormalizedLength r x) * S := by ring
    _ ≤ (shellSpikeBadDensity tau x * shellSpikeNormalizedEnd r x) * S := hlocalS
    _ = shellSpikeBadDensity tau x * (shellSpikeNormalizedEnd r x * S) := by ring

/-! ## Inverting the predicted gain -/

/-- The threshold exponent whose predicted good-density gain is `gamma`.

Solving

```text
gamma = (x * (2 * tau + 1) - tau) / (tau^2 * (1 - x))
```

for `x` gives this expression. -/
def shellSpikeExponentForGain (tau gamma : ℝ) : ℝ :=
  (tau + gamma * tau ^ 2) / (2 * tau + 1 + gamma * tau ^ 2)

/-- If `x` lies above the inverse-gain exponent, then the predicted gain is
strictly larger than `gamma`. -/
theorem gain_lt_of_exponentForGain_lt
    {tau gamma x : ℝ}
    (htau : 0 < tau)
    (hgamma : 0 ≤ gamma)
    (hx : shellSpikeExponentForGain tau gamma < x)
    (hx1 : x < 1) :
    gamma < shellSpikeGoodDensityGain tau x := by
  have htau2 : 0 < tau ^ 2 := sq_pos_of_ne_zero (ne_of_gt htau)
  have h1x : 0 < 1 - x := by linarith
  have hden : 0 < tau ^ 2 * (1 - x) := mul_pos htau2 h1x
  have hD : 0 < 2 * tau + 1 + gamma * tau ^ 2 := by
    have hbase : 0 < 2 * tau + 1 := by nlinarith
    have htail : 0 ≤ gamma * tau ^ 2 := mul_nonneg hgamma (le_of_lt htau2)
    nlinarith
  have hmul :
      tau + gamma * tau ^ 2 <
        x * (2 * tau + 1 + gamma * tau ^ 2) := by
    rw [shellSpikeExponentForGain] at hx
    exact (div_lt_iff₀ hD).mp hx
  rw [shellSpikeGoodDensityGain]
  exact (lt_div_iff₀ hden).mpr (by nlinarith)

/-! ## Transfer to Ramanujan density contraction -/

/-- If bad Ramanujan truncations are pointwise dominated by visible spike
shells, and the visible spike shells have the strict density deficit supplied by
the shadow-cover program, then Bauer's identity and the Ramanujan density
contraction theorem improve the known irrationality-measure bound. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_visibleShellGain
    {mu nu M tau x : ℝ}
    {Hlog u vseq H V : ℕ → ℝ}
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (hdom : ∀ m : ℕ,
      BadRamanujanTruncation nu m → VisibleBlockSpikeShell H V x m)
    (hcover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x)
    (hshadow : PredictedSpikeShadowDensity Hlog u vseq tau x)
    (hgain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau x)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (hgain_gt : nu / M < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  have hvisible :
      UpperNatDensityLessThan (VisibleBlockSpikeShell H V x) (1 - nu / M) :=
    upperDensity_badShells_lt_one_sub_v_div_M_of_predicted_shadow_density
      (Bad := VisibleBlockSpikeShell H V x)
      hcover hshadow hgain_nonneg hgain_le_one hgain_gt
  have hbad :
      UpperNatDensityLessThan (BadRamanujanTruncation nu) (1 - nu / M) :=
    UpperNatDensityLessThan_of_subset hdom hvisible
  exact oneOverPi_irratMeasure_lt_knownBound_of_Bauer_badDensity_lt
    hBauer hmu hnu2 hnuM hbad


/-!
# Completed wrappers for the Ramanujan shell-spike program

This file contains the next layer after
`RamanujanShellSpikeCoveringExtensions.lean`.

The previous file proves the shadow geometry, gain spectrum, budget algebra,
and the exact deficit left by a known irrationality-measure bound.  This file
packages those results into the most directly usable theorem forms:

* a contraction-threshold exponent `shellSpikeContractionExponent`;
* a direct proof that choosing `x` above that exponent gives the good-density
  gain needed by Ramanujan density contraction;
* direct strict-density wrappers for shadow unions and visible spike shells;
* a final Bauer/Ramanujan wrapper: once bad truncations are dominated by
  visible spike shells and the predicted shadow-density theorem is supplied,
  a choice of `x` above the contraction exponent improves the measure bound.

No axioms are introduced here.  The remaining mathematical inputs are still the
project-facing predicates already isolated in the earlier modules:

* `ActualSpikeShellsHaveShadowCover`,
* `PredictedSpikeShadowDensity`,
* pointwise domination of `BadRamanujanTruncation` by the chosen visible spike
  shell predicate.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanShellSpikeCoveringCompletion.lean -/

/-! ## 1. The contraction exponent -/

/-- The good-density target required by the Ramanujan density-contraction
criterion for a trial exponent `nu` and a known bound `M`. -/
def shellSpikeContractionGoodDensity (nu M : ℝ) : ℝ :=
  nu / M

/-- The spike exponent whose predicted good-density gain is exactly `nu / M`.
Choosing any threshold exponent strictly larger than this gives enough good
shell density to cross the Ramanujan contraction threshold. -/
def shellSpikeContractionExponent (tau nu M : ℝ) : ℝ :=
  shellSpikeExponentForGain tau (shellSpikeContractionGoodDensity nu M)

/-- The contraction good-density target is positive when `nu` and `M` are
positive. -/
theorem shellSpikeContractionGoodDensity_pos
    {nu M : ℝ} (hnu : 0 < nu) (hM : 0 < M) :
    0 < shellSpikeContractionGoodDensity nu M := by
  unfold shellSpikeContractionGoodDensity
  exact div_pos hnu hM

/-- If `x` is strictly above the contraction exponent, then the predicted
shell-spike good-density gain is strictly larger than the contraction target
`nu / M`. -/
theorem shellSpikeGoodDensityGain_gt_contractionTarget_of_exponent_lt
    {tau nu M x : ℝ}
    (htau : 0 < tau) (hnu : 0 < nu) (hM : 0 < M)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1) :
    shellSpikeContractionGoodDensity nu M <
      shellSpikeGoodDensityGain tau x := by
  have hx' :
      shellSpikeExponentForGain tau (shellSpikeContractionGoodDensity nu M) < x := by
    simpa [shellSpikeContractionExponent] using hx
  have hgamma : 0 ≤ shellSpikeContractionGoodDensity nu M :=
    le_of_lt (shellSpikeContractionGoodDensity_pos hnu hM)
  exact gain_lt_of_exponentForGain_lt htau hgamma hx' hx1

/-- The same inequality, written in the concrete form used by the density
contraction theorem. -/
theorem shellSpikeGoodDensityGain_gt_nu_div_M_of_exponent_lt
    {tau nu M x : ℝ}
    (htau : 0 < tau) (hnu : 0 < nu) (hM : 0 < M)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1) :
    nu / M < shellSpikeGoodDensityGain tau x := by
  simpa [shellSpikeContractionGoodDensity] using
    shellSpikeGoodDensityGain_gt_contractionTarget_of_exponent_lt
      (tau := tau) (nu := nu) (M := M) (x := x)
      htau hnu hM hx hx1

/-- Above the contraction exponent, the predicted gain is nonnegative. -/
theorem shellSpikeGoodDensityGain_nonneg_of_contractionExponent_lt
    {tau nu M x : ℝ}
    (htau : 0 < tau) (hnu : 0 < nu) (hM : 0 < M)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1) :
    0 ≤ shellSpikeGoodDensityGain tau x := by
  have hposTarget : 0 < nu / M := div_pos hnu hM
  have hgain : nu / M < shellSpikeGoodDensityGain tau x :=
    shellSpikeGoodDensityGain_gt_nu_div_M_of_exponent_lt
      htau hnu hM hx hx1
  exact le_of_lt (hposTarget.trans hgain)

/-! ## 2. Direct density wrappers -/

/-- If the predicted shadow-density theorem holds and the predicted gain is
larger than a target `gamma`, then the shadow union has strict upper density
less than `1 - gamma`. -/
theorem shadowUnion_densityLessThan_of_predictedShadowDensity_of_gain_gt
    {Hlog u vseq : ℕ → ℝ} {tau x gamma : ℝ}
    (hshadow : PredictedSpikeShadowDensity Hlog u vseq tau x)
    (hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1)
    (hgain_gt : gamma < shellSpikeGoodDensityGain tau x) :
    UpperNatDensityLessThan
      (spikeShadowShellUnion Hlog u vseq x) (1 - gamma) := by
  refine ⟨1 - shellSpikeGoodDensityGain tau x, ?_, ?_, hshadow⟩
  · linarith
  · linarith

/-- Specialization of the previous wrapper to the Ramanujan contraction target
`gamma = nu / M`. -/
theorem shadowUnion_densityLessThan_contractionTarget
    {Hlog u vseq : ℕ → ℝ} {tau nu M x : ℝ}
    (htau : 0 < tau) (hnu : 0 < nu) (hM : 0 < M)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hshadow : PredictedSpikeShadowDensity Hlog u vseq tau x) :
    UpperNatDensityLessThan
      (spikeShadowShellUnion Hlog u vseq x) (1 - nu / M) := by
  have hgain_gt : nu / M < shellSpikeGoodDensityGain tau x :=
    shellSpikeGoodDensityGain_gt_nu_div_M_of_exponent_lt
      htau hnu hM hx hx1
  have hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1 :=
    shellSpikeGoodDensityGain_le_one htau hx1 hxθ
  exact shadowUnion_densityLessThan_of_predictedShadowDensity_of_gain_gt
    hshadow hgain_le_one hgain_gt

/-- If actual visible spike shells are covered by shadows, and `x` is above
the contraction exponent, then visible spike shells have strict upper density
less than `1 - nu / M`. -/
theorem visibleSpikeShell_densityLessThan_contractionTarget
    {Hlog u vseq H V : ℕ → ℝ} {tau nu M x : ℝ}
    (htau : 0 < tau) (hnu : 0 < nu) (hM : 0 < M)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hcover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x)
    (hshadow : PredictedSpikeShadowDensity Hlog u vseq tau x) :
    UpperNatDensityLessThan (VisibleBlockSpikeShell H V x) (1 - nu / M) := by
  have hgain_gt : nu / M < shellSpikeGoodDensityGain tau x :=
    shellSpikeGoodDensityGain_gt_nu_div_M_of_exponent_lt
      htau hnu hM hx hx1
  have hgain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau x :=
    shellSpikeGoodDensityGain_nonneg_of_contractionExponent_lt
      htau hnu hM hx hx1
  have hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1 :=
    shellSpikeGoodDensityGain_le_one htau hx1 hxθ
  exact upperDensity_badShells_lt_one_sub_v_div_M_of_predicted_shadow_density
    (Bad := VisibleBlockSpikeShell H V x)
    hcover hshadow hgain_nonneg hgain_le_one hgain_gt

/-- More general visible-shell wrapper with an arbitrary requested rational-like
saving `v / M`.  This is the theorem one uses to produce statements such as
`upper density < 1 - 1/3`. -/
theorem visibleSpikeShell_densityLessThan_one_sub_v_div_M_of_exponentForGain
    {Hlog u vseq H V : ℕ → ℝ} {tau x v M : ℝ}
    (htau : 0 < tau)
    (hvm_nonneg : 0 ≤ v / M)
    (hx : shellSpikeExponentForGain tau (v / M) < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hcover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x)
    (hshadow : PredictedSpikeShadowDensity Hlog u vseq tau x) :
    UpperNatDensityLessThan (VisibleBlockSpikeShell H V x) (1 - v / M) := by
  have hgain_gt : v / M < shellSpikeGoodDensityGain tau x :=
    gain_lt_of_exponentForGain_lt htau hvm_nonneg hx hx1
  have hgain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau x := by
    exact le_of_lt ((lt_of_le_of_lt hvm_nonneg hgain_gt))
  have hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1 :=
    shellSpikeGoodDensityGain_le_one htau hx1 hxθ
  exact upperDensity_badShells_lt_one_sub_v_div_M_of_predicted_shadow_density
    (Bad := VisibleBlockSpikeShell H V x)
    hcover hshadow hgain_nonneg hgain_le_one hgain_gt

/-! ## 3. Bauer/Ramanujan measure-improvement wrappers -/

/-- Final contraction wrapper in exponent form: if bad Ramanujan truncations are
pointwise dominated by visible spike shells, if the actual spike shells are
covered by shadows, and if the predicted shadow-density theorem holds, then any
threshold exponent `x` strictly above the contraction exponent improves the
known measure bound. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_visibleShellGain_contractionExponent
    {mu nu M tau x : ℝ}
    {Hlog u vseq H V : ℕ → ℝ}
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hdom : ∀ m : ℕ,
      BadRamanujanTruncation nu m → VisibleBlockSpikeShell H V x m)
    (hcover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x)
    (hshadow : PredictedSpikeShadowDensity Hlog u vseq tau x) :
    mu < M := by
  have hnu : 0 < nu := by linarith
  have hM : 0 < M := hnu.trans hnuM
  have hgain_gt : nu / M < shellSpikeGoodDensityGain tau x :=
    shellSpikeGoodDensityGain_gt_nu_div_M_of_exponent_lt
      htau hnu hM hx hx1
  have hgain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau x :=
    shellSpikeGoodDensityGain_nonneg_of_contractionExponent_lt
      htau hnu hM hx hx1
  have hgain_le_one : shellSpikeGoodDensityGain tau x ≤ 1 :=
    shellSpikeGoodDensityGain_le_one htau hx1 hxθ
  exact oneOverPi_irratMeasure_lt_of_Bauer_visibleShellGain
    (mu := mu) (nu := nu) (M := M) (tau := tau) (x := x)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    hBauer hmu hnu2 hnuM hdom hcover hshadow
    hgain_nonneg hgain_le_one hgain_gt

/-- The same final contraction wrapper, but with the requested density saving
`v / Mden` already built into the exponent choice.  It is useful for formalizing
statements of the form `upper density < 1 - v/Mden` before feeding them into
another implication. -/
theorem visibleSpikeShell_densityLessThan_one_sub_v_div_Mden
    {Hlog u vseq H V : ℕ → ℝ} {tau x v Mden : ℝ}
    (htau : 0 < tau)
    (hvM_nonneg : 0 ≤ v / Mden)
    (hx : shellSpikeExponentForGain tau (v / Mden) < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hcover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H x)
    (hshadow : PredictedSpikeShadowDensity Hlog u vseq tau x) :
    UpperNatDensityLessThan (VisibleBlockSpikeShell H V x) (1 - v / Mden) :=
  visibleSpikeShell_densityLessThan_one_sub_v_div_M_of_exponentForGain
    htau hvM_nonneg hx hx1 hxθ hcover hshadow

/-! ## 4. Convenient square-root corollary form -/

/-- At the square-root threshold, predicted shadow density gives a strict bad
shell deficit of any `v / M` below `1 / tau^2`, provided the gain is at most
one.  The hypothesis `1 ≤ tau^2` is the natural project case when
`tau = M - 2` and the known bound `M` is at least `3`.  For smaller `tau`, use
the general exponent/gain wrapper instead. -/
theorem visibleSpikeShell_squareRoot_densityLessThan_one_sub_v_div_M
    {Hlog u vseq H V : ℕ → ℝ} {tau v M : ℝ}
    (htau : 0 < tau)
    (htau_sq : 1 ≤ tau ^ 2)
    (hvm : v / M < 1 / tau ^ 2)
    (hcover : ActualSpikeShellsHaveShadowCover Hlog u vseq V H (1 / 2))
    (hshadow : PredictedSpikeShadowDensity Hlog u vseq tau (1 / 2)) :
    UpperNatDensityLessThan (VisibleBlockSpikeShell H V (1 / 2)) (1 - v / M) := by
  have hgain_eq : shellSpikeGoodDensityGain tau (1 / 2) = 1 / tau ^ 2 :=
    shellSpikeGoodDensityGain_one_half (ne_of_gt htau)
  have hgain_nonneg : 0 ≤ shellSpikeGoodDensityGain tau (1 / 2) := by
    rw [hgain_eq]
    exact div_nonneg (by norm_num) (sq_nonneg tau)
  have hgain_le_one : shellSpikeGoodDensityGain tau (1 / 2) ≤ 1 := by
    rw [hgain_eq]
    have ht2pos : 0 < tau ^ 2 := sq_pos_of_pos htau
    exact (div_le_one ht2pos).2 htau_sq
  have hvm_gain : v / M < shellSpikeGoodDensityGain tau (1 / 2) := by
    rw [hgain_eq]
    exact hvm
  exact upperDensity_badShells_lt_one_sub_v_div_M_of_predicted_shadow_density
    (Bad := VisibleBlockSpikeShell H V (1 / 2))
    hcover hshadow hgain_nonneg hgain_le_one hvm_gain


/-!
# Unified shell-spike covering layer

This file merges the three follow-on shell-spike scaffolds:

* `RamanujanShellSpikeCoveringActual.lean`
* `RamanujanShellSpikeCoveringDensityBudget.lean`
* `RamanujanShellSpikeCoveringCumulative.lean`

The unified module keeps the whole next shell-spike route in one place:

1. actual visible canonical block spikes produce logarithmic spike shadows;
2. finite count budgets with sublinear error imply predicted shell density;
3. normalized shadow-length budgets iterate over an admissible shadow schedule.

No new project-level assumptions are intended in this merged scaffold.
-/

open Filter
open scoped BigOperators Topology


/-! ## Merged from IrrationalityAr/RamanujanShellSpikeCoveringUnified.lean -/

/-!
## Merged body from `RamanujanShellSpikeCoveringActual.lean`
