/-- Bounded one-over-pi continuant log-jump ratio plus tail-stable endpoint
geometry imply the final `mu(1/pi) <= 4` conclusion through the integrated
route. -/
theorem oneOverPi_irratMeasure_le_four_of_denLogRatioBounded_and_endpointGeometry
    (hbdd : OneOverPiContinuantDenLogRatioBoundedTarget)
    (hGeom : OneOverPiTailStableEndpointGeometryForShiftTarget)
    {B0 : ℝ} (hB0 : 4 < B0)
    (hStart : OneOverPiMeasureStrictlyBelowEffectiveRaw B0) :
