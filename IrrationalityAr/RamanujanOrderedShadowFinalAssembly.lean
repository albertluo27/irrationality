    (∀ N : ℕ, 1 ≤ N →
      Nat.log 3 ((N + 1) / 2) + 1 ≤ ACount α N) ∧
      (fun N : ℕ => (ACount α N : ℝ)) =o[atTop]
        (fun N : ℕ => (N : ℝ)) := by
  exact ACount_log_lower_and_zeroDensity (α := α) hαirr

