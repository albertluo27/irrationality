  liveDensity :
    LiveBoundaryDensityTarget Live
      (clippedCanonicalStrictSlackScalarData B hB).eps
  bauer : BauerRamanujanIdentity

/-- Convert clipped interval-budget live-loss data into the integrated subwindow
package. -/
def clippedCanonicalLiveLossSubwindowData_of_clippedIntervalBudgetData
    {B : ℝ} {hB : 4 < B}
    (D : ClippedCanonicalLiveLossSubwindowClippedIntervalBudgetData B hB) :
    ClippedCanonicalLiveLossSubwindowData B hB := {
  X := D.X
  H := D.H
  V := D.V
  Hlog := D.Hlog
  u := D.u
