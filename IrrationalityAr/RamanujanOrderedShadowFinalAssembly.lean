/-!
# Active-relevant log-count plus prefix-log bridge

This compatibility layer connects the fixed `EndpointActiveRelevant`
logarithmic-count route with the prefix-log-index route.  If the active
log-count package also carries a logarithmic bound for its cutoff map `K`, then
it supplies the prefix-log-index package directly.
-/

/-! ## Endpoint data bridge -/

/-- Active-relevant logarithmic-count data together with a logarithmic
prefix-depth bound for its cutoff map. -/
structure EndpointSubwindowCutoffPrefixActiveRelevantLogCountWithPrefixLogData
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Type where
  base : EndpointSubwindowCutoffPrefixActiveRelevantLogCountData
    X H V nu x delta eps
  K_logBound : EventualPrefixLogBound base.K

/-- Active-relevant log-count data with a prefix-log bound constructs the
prefix-log-index endpoint data. -/
def endpointSubwindowCutoffPrefixLogIndexData_of_activeRelevantLogCountWithPrefixLogData
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (D : EndpointSubwindowCutoffPrefixActiveRelevantLogCountWithPrefixLogData
      X H V nu x delta eps) :
    EndpointSubwindowCutoffPrefixLogIndexData X H V nu x delta eps := by
  let Dbelow : EndpointSubwindowCutoffPrefixActiveRelevantBelowLeftData
      X H V nu x delta eps :=
    endpointSubwindowCutoffPrefixActiveRelevantBelowLeftData_of_logCountData
      D.base
  let Ddirect : EndpointSubwindowCutoffPrefixActiveRelevantDirectData
      X H V nu x delta eps :=
    endpointSubwindowCutoffPrefixActiveRelevantDirectData_of_belowLeftData
      Dbelow
  let I : EndpointSubwindowCutoffPrefixIndexData X H V nu x delta eps :=
    endpointSubwindowCutoffPrefixIndexData_of_activeRelevantData Ddirect
  refine {
    RelevantAt :=
      CutoffPrefixClosedRelevantAt D.base.K (EndpointActiveRelevant nu X)
    LiveAt :=
      CutoffPrefixLiveAt nu x X D.base.K (EndpointActiveRelevant nu X)
    LiveErr := D.base.LiveErr
    cover := ?_
    indexLeCutoff := ?_
    scaleMap := {
      K := D.base.K
      scaleErr := D.base.scaleErr
      delta_nonneg := D.base.delta_nonneg
      K_tendsto := D.base.K_tendsto
      K_logBound := D.K_logBound
      relevantIndexLtPrefix := D.base.relevantIndexLtPrefix
      scaleBound := D.base.scaleBound
      scaleErrSublinear := D.base.scaleErrSublinear
    }
    liveErrSublinear := D.base.liveErrSublinear
    liveBudget := D.base.liveBudget
  }
  · simpa [Dbelow, Ddirect, I] using I.cover
  · simpa [Dbelow, Ddirect, I] using I.indexLeCutoff

