/-- Final wrapper through the direct active-count route. -/
theorem oneOverPiMeasureAtMost_four_of_directActiveFinalTarget
    (h : ClippedCanonicalLiveLossPrefixWitnessDirectActiveFinalTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases h with ⟨B0, P⟩
  exact oneOverPiMeasureAtMost_four_of_directActiveFinalPackage P

/-!
# Active relevant relation for endpoint witnesses

This layer fixes the remaining relevance relation to the natural
endpoint-active one.  The resulting target replaces the generic
`BaseRelevant` relation by the two endpoint inequalities used by the interval
budget and below-cap witness interfaces.
-/

/-! ## The active relevance relation -/

/-- Endpoint-active relevance for shell `m` and index `j`.

The two inequalities are exactly the endpoint facts used later:
`X j <= cap(m)` and `cap(m) <= (X j + X (j + 1)) / nu`.
-/
def EndpointActiveRelevant
    (nu : ℝ) (X : ℕ → ℝ) (m j : ℕ) : Prop :=
  X j ≤ ramanujanDenominatorCapLog nu m ∧
    ramanujanDenominatorCapLog nu m ≤ endpointRatioScale X j / nu

/-- Active relevance immediately supplies the interval-budget relevance upper
bound. -/
theorem endpointActiveRelevant_relevanceUpper
    (nu : ℝ) (X : ℕ → ℝ) :
    EndpointSubwindowRelevanceUpperBound X nu
      (EndpointActiveRelevant nu X) := by
  intro m j hRel
  exact hRel.2

/-- Existence of an active-relevant witness gives the below-cap witness field. -/
def EndpointActiveRelevantWitnessExistence
    (nu : ℝ) (X : ℕ → ℝ) : Prop :=
  ∀ m : ℕ,
    BadRamanujanTruncation nu m →
      ∃ j : ℕ, EndpointActiveRelevant nu X m j

/-- Active-relevant witness existence implies the generic below-cap witness
interface. -/
theorem endpointRelevantBelowCapWitness_of_activeRelevantExistence
    {nu : ℝ} {X : ℕ → ℝ}
    (h : EndpointActiveRelevantWitnessExistence nu X) :
    EndpointRelevantBelowCapWitness nu X (EndpointActiveRelevant nu X) := by
  intro m hBad
  rcases h m hBad with ⟨j, hRel⟩
  exact ⟨j, hRel, hRel.1⟩

/-! ## Direct-active witness data with the fixed relevance relation -/

/-- Witness/direct-active endpoint data after fixing `BaseRelevant` to the
endpoint-active relation. -/
structure EndpointSubwindowCutoffPrefixActiveRelevantDirectData
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Type where
  K : ℕ → ℕ
  scaleErr : ℕ → ℝ
  LiveErr : ℕ → ℝ
  nu_pos : 0 < nu
  activeWitness : EndpointActiveRelevantWitnessExistence nu X
  lowActiveRelevantForcesVisible :
    EndpointLowRelevantForcesVisible nu x X H V (EndpointActiveRelevant nu X)
  activeCount : CutoffRelevantActiveCountDirectData
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X))
  delta_nonneg : 0 ≤ delta
  K_tendsto : Tendsto K atTop atTop
  relevantIndexLtPrefix :
    CutoffRelevantIndexLtPrefix K
      (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X))
  indexLeCutoff : CutoffRelevantIndexLeCutoff
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    (CutoffPrefixClosedRelevantAt K (EndpointActiveRelevant nu X))
  scaleBound : ∀ᶠ M : ℕ in atTop,
    endpointRatioScale X (K M) / ramanujanKappa
      ≤ ((M : ℝ) + 1) + scaleErr M
  scaleErrSublinear : EventuallySublinearCountError scaleErr
  liveErrSublinear : EventuallySublinearCountError LiveErr
  liveBudget : CutoffLiveBoundaryCountBudget
    (CutoffPrefixLiveAt nu x X K (EndpointActiveRelevant nu X)) eps LiveErr

/-- Fixed active-relevance data constructs the existing direct-active witness
package. -/
def endpointSubwindowCutoffPrefixWitnessDirectActiveData_of_activeRelevantData
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (D : EndpointSubwindowCutoffPrefixActiveRelevantDirectData
      X H V nu x delta eps) :
    EndpointSubwindowCutoffPrefixWitnessDirectActiveData
      X H V nu x delta eps := {
  BaseRelevant := EndpointActiveRelevant nu X
  K := D.K
  scaleErr := D.scaleErr
  LiveErr := D.LiveErr
  nu_pos := D.nu_pos
  belowCapWitness :=
    endpointRelevantBelowCapWitness_of_activeRelevantExistence D.activeWitness
  lowRelevantForcesVisible := D.lowActiveRelevantForcesVisible
  relevanceUpper := endpointActiveRelevant_relevanceUpper nu X
  delta_nonneg := D.delta_nonneg
  K_tendsto := D.K_tendsto
  relevantIndexLtPrefix := D.relevantIndexLtPrefix
  indexLeCutoff := D.indexLeCutoff
  activeCount := D.activeCount
  scaleBound := D.scaleBound
  scaleErrSublinear := D.scaleErrSublinear
  liveErrSublinear := D.liveErrSublinear
  liveBudget := D.liveBudget
}

/-- The same fixed-relevance data constructs the prefix-index data package. -/
def endpointSubwindowCutoffPrefixIndexData_of_activeRelevantData
