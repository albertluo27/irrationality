/-!
# Clipped interval-budget repair for endpoint subwindows

The previous interval-budget interface used full real interval lengths.  The
endpoint route naturally proves a clipped budget at the cutoff `M`, charging
only the visible portion of each interval below that cutoff.
-/

/-! ## Generic clipped real-shadow budget -/

/-- A clipped real-length budget up to an integer cutoff.  Only the portion of
`[S i, E i]` lying below the current cutoff `M` is charged. -/
def ClippedRealShadowLengthBudget
    (S E : ℕ → ℝ) (δ : ℝ) (Err : ℕ → ℝ) : Prop :=
  ∀ᶠ M : ℕ in atTop,
    (∑ i ∈ ActiveShadowIndexFinset S M,
      clippedRealIntervalLength (S i) (E i) M)
      ≤ δ * ((M : ℝ) + 1) + Err M

/-- Clipped interval length is no larger than the corresponding full positive
interval length. -/
theorem clippedRealIntervalLength_le_fullLength
    (left right : ℝ) (M : ℕ) :
    clippedRealIntervalLength left right M ≤ max 0 (right - left) := by
  unfold clippedRealIntervalLength
  have h : min right (M : ℝ) - left ≤ right - left := by
    exact sub_le_sub_right (min_le_left right (M : ℝ)) left
  exact max_le_max (le_refl (0 : ℝ)) h

/-- A full real-shadow budget implies the clipped version.  This keeps the new
interface compatible with the previously integrated full-budget package. -/
theorem clippedRealShadowLengthBudget_of_realShadowLengthBudget
    {S E : ℕ → ℝ} {δ : ℝ} {Err : ℕ → ℝ}
    (h : RealShadowLengthBudget S E δ Err) :
    ClippedRealShadowLengthBudget S E δ Err := by
  filter_upwards [h] with M hM
  calc
    (∑ i ∈ ActiveShadowIndexFinset S M,
      clippedRealIntervalLength (S i) (E i) M)
        ≤ ∑ i ∈ ActiveShadowIndexFinset S M,
            max 0 (E i - S i) := by
          exact Finset.sum_le_sum (fun i _hi =>
            clippedRealIntervalLength_le_fullLength (S i) (E i) M)
    _ ≤ δ * ((M : ℝ) + 1) + Err M := hM

/-- Integer shell count budget from clipped real lengths and the active-count
rounding error. -/
theorem integerShadowUnionCount_budget_of_clippedRealLengthBudget
    {S E : ℕ → ℝ} {δ : ℝ} {Err : ℕ → ℝ}
    (hcover : ActiveShadowIndicesCoverUnion S E)
    (hLength : ClippedRealShadowLengthBudget S E δ Err) :
    ∀ᶠ M : ℕ in atTop,
      (IntegerShadowUnionCount S E M : ℝ)
        ≤ δ * ((M : ℝ) + 1) +
          (Err M + 2 * (ActiveShadowCount S M : ℝ)) := by
  classical
  filter_upwards [hLength] with M hLen
  calc
    (IntegerShadowUnionCount S E M : ℝ)
        ≤ ∑ i ∈ ActiveShadowIndexFinset S M,
            (clippedRealIntervalLength (S i) (E i) M + 2) := by
          exact integerShadowUnionCount_le_sum_clipped_interval_counts M hcover
    _ = (∑ i ∈ ActiveShadowIndexFinset S M,
            clippedRealIntervalLength (S i) (E i) M)
          + 2 * (ActiveShadowCount S M : ℝ) := by
          rw [Finset.sum_add_distrib]
          simp [ActiveShadowIndexFinset, ActiveShadowCount, mul_comm]
    _ ≤ δ * ((M : ℝ) + 1) + Err M +
          2 * (ActiveShadowCount S M : ℝ) := by
          linarith
    _ = δ * ((M : ℝ) + 1) +
          (Err M + 2 * (ActiveShadowCount S M : ℝ)) := by
          ring

/-- A clipped real-length budget plus sublinear active count gives the same
upper-density conclusion as the full-length budget. -/
theorem upperDensityAtMost_of_clippedRealShadowLengthBudget
    {S E : ℕ → ℝ} {δ : ℝ} {Err : ℕ → ℝ}
    (hcover : ActiveShadowIndicesCoverUnion S E)
    (hLength : ClippedRealShadowLengthBudget S E δ Err)
    (hActive : ActiveShadowCountSublinear S)
    (hErr : EventuallySublinearCountError Err) :
    UpperNatDensityAtMost (NatInRealIntervalUnion S E) δ := by
  have hCount := integerShadowUnionCount_budget_of_clippedRealLengthBudget
    (S := S) (E := E) (δ := δ) (Err := Err) hcover hLength
  have hTotalErr : EventuallySublinearCountError
      (fun M : ℕ => Err M + 2 * (ActiveShadowCount S M : ℝ)) :=
    intervalCounting_totalError_sublinear hErr hActive
  apply upperNatDensityAtMost_of_countBudget_sublinearError
    (B := NatInRealIntervalUnion S E)
    (δ := δ)
    (E := fun M : ℕ => Err M + 2 * (ActiveShadowCount S M : ℝ))
  · filter_upwards [hCount] with M hM
    simpa [IntegerShadowUnionCount_eq_natInitialSegmentCount] using hM
  · exact hTotalErr

/-! ## Endpoint-subwindow control from clipped interval budgets -/

/-- Endpoint-subwindow data using a clipped interval-length budget. -/
structure EndpointSubwindowClippedIntervalBudgetData
    (X : ℕ → ℝ) (nu x delta : ℝ)
    (Relevant : ℕ → ℕ → Prop) : Type where
  Err : ℕ → ℝ
  nu_pos : 0 < nu
  relevanceUpper : EndpointSubwindowRelevanceUpperBound X nu Relevant
  activeCover : ActiveShadowIndicesCoverUnion
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
  activeSublinear : ActiveShadowCountSublinear
    (endpointSubwindowIntervalLeft nu X)
  errSublinear : EventuallySublinearCountError Err
  clippedLengthBudget :
    ClippedEndpointWeightedAverageBound X nu delta →
      ClippedRealShadowLengthBudget
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)
        delta Err

/-- Clipped interval-budget data proves the abstract subwindow-union control
field. -/
theorem clippedEndpointSubwindowUnionControls_of_clippedIntervalBudgetData
    {X : ℕ → ℝ} {nu x delta : ℝ} {Relevant : ℕ → ℕ → Prop}
    (D : EndpointSubwindowClippedIntervalBudgetData X nu x delta Relevant) :
    ClippedEndpointSubwindowUnionControls X nu x delta Relevant := by
  intro havg
  have hIntervalDensity : UpperNatDensityAtMost
      (NatInRealIntervalUnion
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X)) delta :=
    upperDensityAtMost_of_clippedRealShadowLengthBudget
      (S := endpointSubwindowIntervalLeft nu X)
      (E := endpointSubwindowIntervalRight X)
      (δ := delta) (Err := D.Err)
      D.activeCover (D.clippedLengthBudget havg)
      D.activeSublinear D.errSublinear
  exact Criteria.upperDensityAtMost_mono
    (endpointSubwindowUnion_dominated_realIntervalUnion
      (X := X) (nu := nu) (x := x) (Relevant := Relevant)
      D.nu_pos D.relevanceUpper)
    hIntervalDensity

/-- The previously integrated full interval-budget data also gives clipped
interval-budget data. -/
def endpointSubwindowClippedIntervalBudgetData_of_full
    {X : ℕ → ℝ} {nu x delta : ℝ} {Relevant : ℕ → ℕ → Prop}
    (D : EndpointSubwindowIntervalBudgetData X nu x delta Relevant) :
    EndpointSubwindowClippedIntervalBudgetData X nu x delta Relevant := {
  Err := D.Err
  nu_pos := D.nu_pos
  relevanceUpper := D.relevanceUpper
  activeCover := D.activeCover
  activeSublinear := D.activeSublinear
  errSublinear := D.errSublinear
  clippedLengthBudget := fun havg =>
    clippedRealShadowLengthBudget_of_realShadowLengthBudget
      (D.lengthBudget havg)
}

/-! ## Canonical live-loss packages with clipped interval budgets -/

/-- Canonical live-loss subwindow data with the density field replaced by a
clipped interval-budget package. -/
structure ClippedCanonicalLiveLossSubwindowClippedIntervalBudgetData
