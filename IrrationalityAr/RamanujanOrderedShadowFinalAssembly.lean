/-! ## Small-live budget route: concrete source-level input package -/

/-- A local budget certificate for one shifted ordered endpoint geometry system. -/
structure EntropyReciprocalBudgetCertificate
    (B : ℝ) (hB : 4 < B)
    (baseShift : ℕ)
    (G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift)
    (s : ℕ) : Type where
  liveLoss : ℝ
  liveLoss_nonneg : 0 ≤ liveLoss
  liveLoss_lt_slack : liveLoss < clippedLayerCakeQuadraticEffectiveSlack B
  budgetSplit :
    ClippedEndpointCountBudgetSplitWithLiveLoss
      (tailShiftSeq (oneOverPiShiftedQlog baseShift) s)
      (tailShiftSeq G.H s) (tailShiftSeq G.V s)
      (clippedLayerCakeTrialNu B) (clippedLayerCakeCanonicalX B)
      (clippedLayerCakeQuadraticEffectiveDelta B) liveLoss

/-- Concrete small-live budget target. -/
def EntropyReciprocalSmallLiveBudgetBridgeTarget : Prop :=
  ∀ B : ℝ,
    ∀ hB : 4 < B,
      OneOverPiMeasureStrictlyBelowEffectiveRaw B →
        ∀ baseShift : ℕ,
          EventuallyRatioBoundedBy (oneOverPiShiftedQlog baseShift) (B - 1) →
            ∀ G : OneOverPiTailStableOrderedEndpointClosureGeometryData B baseShift,
              ∀ s : ℕ,
                Nonempty
                  (EntropyReciprocalBudgetCertificate B hB baseShift G s)

/-- Pure adapter: the concrete budget bridge gives the existing source small-live
budget target. -/
theorem smallLiveBudgetTarget_of_entropyReciprocalBridge
    (hBridge : EntropyReciprocalSmallLiveBudgetBridgeTarget) :
    OneOverPiTailStableSmallLiveBudgetSplitForGeometryTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hBridge B hB hBound baseShift hCap G s with ⟨C⟩
  exact ⟨C.liveLoss, C.liveLoss_nonneg, C.liveLoss_lt_slack, C.budgetSplit⟩

/-- Extract the concrete budget certificate from the existing source small-live
budget target. -/
theorem entropyReciprocalBridge_of_smallLiveBudgetTarget
    (hBudget : OneOverPiTailStableSmallLiveBudgetSplitForGeometryTarget) :
    EntropyReciprocalSmallLiveBudgetBridgeTarget := by
  intro B hB hBound baseShift hCap G s
  rcases hBudget B hB hBound baseShift hCap G s with
    ⟨liveLoss, hnonneg, hlt, hsplit⟩
  exact ⟨{
    liveLoss := liveLoss
    liveLoss_nonneg := hnonneg
    liveLoss_lt_slack := hlt
    budgetSplit := hsplit
  }⟩

