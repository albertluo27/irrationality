/-!
# Clipped raw-data component reduction

This layer opens `ClippedActiveMassLiveLossStrictSlackRawDataTarget` into two
independent pieces:

* scalar strict-slack parameters;
* geometric/active-mass/live-loss data for those parameters.

It also provides a zero-live specialization.  The endpoint geometry and
live-boundary estimates remain explicit targets.
-/

/-- Scalar parameters for one clipped active-mass/live-loss strict-slack step. -/
structure ClippedStrictSlackScalarData (B : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  eps : ℝ
  nu_gt_two : 2 < nu
  nu_lt_output : nu < oneThresholdBootstrapRelaxedMap B
  tau_pos : 0 < tau
  x_contraction :
    shellSpikeContractionExponent tau nu (oneThresholdBootstrapRelaxedMap B) < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  deltaeps_nonneg : 0 ≤ oneThresholdEndpointDelta B nu + eps
  gain_surplus :
    nu / oneThresholdBootstrapRelaxedMap B +
        (oneThresholdEndpointDelta B nu + eps)
      < shellSpikeGoodDensityGain tau x

/-- Geometric and active-mass data for fixed scalar parameters. -/
structure ClippedActiveMassLiveLossGeometryData
    (B nu tau x eps : ℝ) : Type where
