/-!
# Cutoff prefix index-cover reduction

This layer removes two bookkeeping fields from the cutoff prefix-budget target.
The active-index cover and prefix-index cover follow from pointwise index facts,
leaving the endpoint geometry and live-boundary count budget as the genuine
remaining inputs.
-/

/-! ## Active-index cover from a pointwise cutoff index bound -/

/-- Every cutoff-relevant interval witness below cutoff `M` has index at most
`M`, so it appears in the finite active-index search range. -/
def CutoffRelevantIndexLeCutoff
    (S E : ℕ → ℝ) (RelevantAt : ℕ → ℕ → ℕ → Prop) : Prop :=
  ∀ M m i : ℕ,
    m ≤ M →
    RelevantAt M m i →
    NatInRealInterval m (S i) (E i) →
      i ≤ M

/-- The active-index cover follows from the pointwise cutoff index bound. -/
theorem cutoffRelevantActiveShadowIndicesCoverUnion_of_indexLeCutoff
    {S E : ℕ → ℝ} {RelevantAt : ℕ → ℕ → ℕ → Prop}
    (hindex : CutoffRelevantIndexLeCutoff S E RelevantAt) :
    CutoffRelevantActiveShadowIndicesCoverUnion S E RelevantAt := by
  classical
  intro M m hmM hUnion
  rcases hUnion with ⟨i, hRel, hInt⟩
  refine ⟨i, ?_, hRel, hInt⟩
  dsimp [CutoffRelevantActiveShadowIndexFinset]
  rw [Finset.mem_filter]
  refine ⟨Finset.mem_range.mpr ?_, ?_⟩
  · exact Nat.lt_succ_of_le (hindex M m i hmM hRel hInt)
  · exact ⟨m, hmM, hRel, hInt⟩

/-! ## Prefix-scale map data with pointwise index bound -/

/-- Every cutoff-relevant index is below the chosen prefix length `K M`. -/
def CutoffRelevantIndexLtPrefix
    (K : ℕ → ℕ) (RelevantAt : ℕ → ℕ → ℕ → Prop) : Prop :=
  ∀ M m i : ℕ, RelevantAt M m i → i < K M

/-- A lighter prefix-scale package storing a pointwise index bound instead of
the eventual active-finset index-cover field. -/
structure CutoffEndpointScaleMapData
    (X : ℕ → ℝ) (nu delta : ℝ)
    (RelevantAt : ℕ → ℕ → ℕ → Prop) : Type where
  K : ℕ → ℕ
  scaleErr : ℕ → ℝ
  delta_nonneg : 0 ≤ delta
  K_tendsto : Tendsto K atTop atTop
  relevantIndexLtPrefix : CutoffRelevantIndexLtPrefix K RelevantAt
  scaleBound : ∀ᶠ M : ℕ in atTop,
    endpointRatioScale X (K M) / ramanujanKappa
      ≤ ((M : ℝ) + 1) + scaleErr M
  scaleErrSublinear : EventuallySublinearCountError scaleErr

/-- Pointwise prefix-index control gives the eventual active-finset index-cover
field required by `CutoffEndpointPrefixScaleBudgetData`. -/
theorem cutoffRelevantActiveIndex_lt_prefix_of_pointwise
    {X : ℕ → ℝ} {nu delta : ℝ}
    {RelevantAt : ℕ → ℕ → ℕ → Prop}
    (D : CutoffEndpointScaleMapData X nu delta RelevantAt) :
    ∀ᶠ M : ℕ in atTop,
      ∀ i : ℕ,
        i ∈ CutoffRelevantActiveShadowIndexFinset
          (endpointSubwindowIntervalLeft nu X)
          (endpointSubwindowIntervalRight X)
          RelevantAt M → i < D.K M := by
  classical
  filter_upwards [] with M i hi
  dsimp [CutoffRelevantActiveShadowIndexFinset] at hi
  rw [Finset.mem_filter] at hi
  rcases hi.2 with ⟨m, _hmM, hRel, _hInt⟩
  exact D.relevantIndexLtPrefix M m i hRel

/-- The lighter scale-map package constructs the full prefix-scale budget data. -/
def cutoffEndpointPrefixScaleBudgetData_of_scaleMapData
    {X : ℕ → ℝ} {nu delta : ℝ}
    {RelevantAt : ℕ → ℕ → ℕ → Prop}
    (D : CutoffEndpointScaleMapData X nu delta RelevantAt) :
    CutoffEndpointPrefixScaleBudgetData X nu delta RelevantAt := {
  K := D.K
  scaleErr := D.scaleErr
  delta_nonneg := D.delta_nonneg
  K_tendsto := D.K_tendsto
  indexCover := cutoffRelevantActiveIndex_lt_prefix_of_pointwise D
  scaleBound := D.scaleBound
  scaleErrSublinear := D.scaleErrSublinear
}

/-! ## Endpoint prefix-budget data with active-cover bookkeeping removed -/

/-- Prefix-budget endpoint data with active-cover and prefix-index-cover fields
replaced by pointwise facts. -/
structure EndpointSubwindowCutoffPrefixIndexData
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Type where
  RelevantAt : ℕ → ℕ → ℕ → Prop
  LiveAt : ℕ → ℕ → Prop
  LiveErr : ℕ → ℝ
  cover : CutoffClosedLiveInitialSegmentCover
    (NonVisibleBadShell nu H V x)
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    RelevantAt LiveAt
  indexLeCutoff : CutoffRelevantIndexLeCutoff
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    RelevantAt
  activeSublinear : CutoffRelevantActiveShadowCountSublinear
    (endpointSubwindowIntervalLeft nu X)
    (endpointSubwindowIntervalRight X)
    RelevantAt
  scaleMap : CutoffEndpointScaleMapData X nu delta RelevantAt
  liveErrSublinear : EventuallySublinearCountError LiveErr
  liveBudget : CutoffLiveBoundaryCountBudget LiveAt eps LiveErr

/-- The index-data package constructs the previous prefix-budget package. -/
def endpointSubwindowCutoffPrefixBudgetData_of_indexData
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (D : EndpointSubwindowCutoffPrefixIndexData X H V nu x delta eps) :
