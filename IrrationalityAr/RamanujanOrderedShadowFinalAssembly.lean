/-!
# Ratio-cap-from-measure reduction for the clipped layer-cake route

This closes the formal part of `OneOverPiShiftedQlogRatioCapFromMeasureTarget`.
The remaining analytic input is boundedness of the continuant log-jump ratio
for the canonical continued fraction of `1 / pi`.
-/

/-! ## Public one-over-pi continued-fraction expansion -/

/-- The project coefficient sequence `oneOverPiCF` is the simple continued
fraction expansion of `1 / pi`. -/
theorem oneOverPiCF_isSimpleCFExpansion_public :
    IsSimpleCFExpansion oneOverPi oneOverPiCF := by
  have hpos : 0 < oneOverPi := by
    unfold oneOverPi
    exact one_div_pos.mpr Real.pi_pos
  have hirr : IsIrrational oneOverPi := by
    unfold oneOverPi
    simpa [one_div] using invPi_isIrrational
  unfold oneOverPiCF
  exact simplePartialQuotient_isSimpleCFExpansion hpos hirr

/-! ## Denominator-ratio exponent from a strict measure cap -/

/-- Boundedness hypothesis for the one-over-pi continuant log-jump ratio. -/
def OneOverPiContinuantDenLogRatioBoundedTarget : Prop :=
  IsBoundedUnder (fun x y : ℝ => x ≤ y) atTop
    (continuantDenLogRatio oneOverPiCF)

/-- If the one-over-pi continuant log-jump ratio is bounded above, then any
strict project-level measure cap `B` forces the denominator-ratio exponent below
`B - 1`. -/
theorem denominatorRatioExponent_oneOverPiCF_lt_of_measureStrictlyBelow_of_bounded
    {B : ℝ}
    (hbdd : OneOverPiContinuantDenLogRatioBoundedTarget)
    (hBound : OneOverPiMeasureStrictlyBelowEffectiveRaw B) :
    denominatorRatioExponent oneOverPiCF < B - 1 := by
  have hmetric :
      HasIrrationalityMeasure oneOverPi
        (1 + denominatorRatioExponent oneOverPiCF) :=
    irrationalityMeasure_eq_one_add_denominatorRatioExponent_of_bounded
      oneOverPiCF_isSimpleCFExpansion_public hbdd
  have hlt : 1 + denominatorRatioExponent oneOverPiCF < B := by
    have h := hBound (1 + denominatorRatioExponent oneOverPiCF) hmetric
    simpa [oneOverPi] using h
  linarith

/-! ## Limsup-to-eventual qlog ratio cap -/

/-- A strict denominator-ratio exponent bound gives an eventual ratio cap for
`continuantQlog`. -/
theorem eventuallyRatioBoundedBy_continuantQlog_of_denominatorRatioExponent_lt
    {a : ℕ → ℕ} {R : ℝ}
    (hbdd : IsBoundedUnder (fun x y : ℝ => x ≤ y) atTop
      (continuantDenLogRatio a))
    (hrho : denominatorRatioExponent a < R) :
    EventuallyRatioBoundedBy (continuantQlog a) R := by
  have hratio_lt :
      ∀ᶠ n : ℕ in atTop, continuantDenLogRatio a n < R :=
    Filter.eventually_lt_of_limsup_lt (by
      simpa [denominatorRatioExponent] using hrho) hbdd
  filter_upwards [hratio_lt] with n hn
  have hle : continuantDenLogRatio a n ≤ R := le_of_lt hn
  simpa [EventuallyRatioBoundedBy, continuantDenLogRatio, continuantQlog,
    logJumpRatio] using hle

/-- A strict denominator-ratio exponent bound gives the shifted `1 / pi` qlog
ratio cap, with shift `0`. -/
theorem eventuallyRatioBoundedBy_oneOverPiShiftedQlog_zero_of_denominatorRatioExponent_lt
    {R : ℝ}
    (hbdd : OneOverPiContinuantDenLogRatioBoundedTarget)
    (hrho : denominatorRatioExponent oneOverPiCF < R) :
    EventuallyRatioBoundedBy (oneOverPiShiftedQlog 0) R := by
  have h := eventuallyRatioBoundedBy_continuantQlog_of_denominatorRatioExponent_lt
    (a := oneOverPiCF) (R := R) hbdd hrho
  simpa [oneOverPiShiftedQlog] using h

/-- With the boundedness target, the ratio-cap-from-measure target is proved. -/
theorem oneOverPiShiftedQlogRatioCapFromMeasureTarget_of_denLogRatioBounded
    (hbdd : OneOverPiContinuantDenLogRatioBoundedTarget) :
    OneOverPiShiftedQlogRatioCapFromMeasureTarget := by
  intro B _hB hBound
  have hrho : denominatorRatioExponent oneOverPiCF < B - 1 :=
    denominatorRatioExponent_oneOverPiCF_lt_of_measureStrictlyBelow_of_bounded
      (B := B) hbdd hBound
  refine ⟨0, ?_⟩
  exact eventuallyRatioBoundedBy_oneOverPiShiftedQlog_zero_of_denominatorRatioExponent_lt
    (R := B - 1) hbdd hrho

