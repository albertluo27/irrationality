/-- Repaired strict-slack step data.  This replaces the old endpoint package by
finite clipped one-threshold data plus the clipped non-visible-bad bridge. -/
structure ClippedOneThresholdStrictSlackStepData (B : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_lt_out : nu < (oneThresholdBootstrapRelaxedMap B)
  tau_pos : 0 < tau
  x_contraction :
    shellSpikeContractionExponent tau nu (oneThresholdBootstrapRelaxedMap B) < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau
  gain_le_one : shellSpikeGoodDensityGain tau x ≤ 1
  finiteData : ClippedOneThresholdFiniteData X B nu
  clippedControls :
    ClippedEndpointWeightedAverageControlsNonVisibleBad
      X H V nu x (oneThresholdBootstrapDelta B nu)
  delta_nonneg : 0 ≤ oneThresholdBootstrapDelta B nu
  delta_gain :
    oneThresholdBootstrapDelta B nu + nu / oneThresholdBootstrapRelaxedMap B
      < shellSpikeGoodDensityGain tau x

/-- A clipped strict-slack data structure constructs the repaired clipped
bootstrap package. -/
theorem clippedOneThresholdBootstrapPackage_of_stepData
    {B : ℝ} (D : ClippedOneThresholdStrictSlackStepData B) :
    ClippedOneThresholdBootstrapPackage B (oneThresholdBootstrapRelaxedMap B)
      D.nu D.tau D.x D.X D.H D.V D.Hlog D.u D.vseq := by
  exact ⟨
    clippedEndpointAverage_of_finiteData D.finiteData,
    D.clippedControls,
    D.delta_nonneg,
    D.delta_gain
  ⟩

/-- Repaired target: construct clipped strict-slack data from an input bound. -/
def ClippedOneThresholdStrictSlackStepDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedOneThresholdStrictSlackStepData B)

/-- Clipped strict-slack data realizes the strict-slack one-step bootstrap. -/
theorem oneThresholdStrictSlackStepRealized_of_clippedDataTarget
    (hdata : ClippedOneThresholdStrictSlackStepDataTarget) :
    OneThresholdBootstrapStrictSlackStepRealized := by
  intro B hB hBound mu hmu
  rcases hdata B hB hBound with ⟨D⟩
  exact oneOverPiMeasure_lt_of_Bauer_clippedOneThresholdBootstrapPackage
    (mu := mu) (B := B) (Mout := oneThresholdBootstrapRelaxedMap B)
    (nu := D.nu) (tau := D.tau) (x := D.x)
    (X := D.X) (H := D.H) (V := D.V)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    D.closureCert D.bauer hmu D.nu_gt_two D.nu_lt_out D.tau_pos
    D.x_contraction D.x_lt_one D.x_le_global D.gain_le_one
    (clippedOneThresholdBootstrapPackage_of_stepData D)

/-- Final package for the repaired clipped route. -/
structure ClippedOneThresholdStrictSlackFinalPackage (B0 : ℝ) : Prop where
  startBound : KnownOneOverPiMeasureBound B0
  startAboveFour : 4 < B0
  stepData : ClippedOneThresholdStrictSlackStepDataTarget
  relaxedMapAboveFour : OneThresholdBootstrapRelaxedMapAboveFour
  relaxedSeqConverges : OneThresholdBootstrapRelaxedSeqConvergesToFour B0

/-- Final repaired clipped route to the non-strict bound `4`. -/
theorem oneOverPiMeasureAtMost_four_of_clippedStrictSlackFinalPackage
    {B0 : ℝ}
    (P : ClippedOneThresholdStrictSlackFinalPackage B0) :
    OneOverPiMeasureAtMost 4 := by
  have hstep : OneThresholdBootstrapStrictSlackStepRealized :=
    oneThresholdStrictSlackStepRealized_of_clippedDataTarget P.stepData
  exact oneOverPiMeasureAtMost_four_of_relaxedBootstrapSeq
    P.startBound P.startAboveFour hstep
    P.relaxedMapAboveFour P.relaxedSeqConverges

/-- Project-facing final repaired target. -/
def ClippedOneThresholdStrictSlackFinalTarget : Prop :=
  ∃ B0 : ℝ, ClippedOneThresholdStrictSlackFinalPackage B0

/-- The repaired final target implies the desired non-strict bound. -/
theorem oneOverPiMeasureAtMost_four_of_clippedStrictSlackFinalTarget
    (h : ClippedOneThresholdStrictSlackFinalTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases h with ⟨B0, P⟩
  exact oneOverPiMeasureAtMost_four_of_clippedStrictSlackFinalPackage P

/-!
# Clipped endpoint mimic: closed part plus live-boundary part

The clipped endpoint bridge is split into a completed closed part and a live
terminal-boundary part.  The closed part is controlled by the clipped endpoint
average; the live part is controlled by a separate density estimate.
-/

/-- A cover saying every non-visible bad shell is either already in the closed
clipped endpoint part, or belongs to the live terminal-boundary part. -/
def NonVisibleBadClosedLiveCover
    (nu x : ℝ) (H V : ℕ → ℝ)
    (Closed Live : ℕ → Prop) : Prop :=
  ∀ m : ℕ,
    NonVisibleBadShell nu H V x m → Closed m ∨ Live m

/-- The part of the clipped bridge that mimics the old proof: the closed or
completed endpoint contribution is controlled by the clipped average. -/
def ClippedClosedEndpointControls
    (X : ℕ → ℝ) (nu delta : ℝ) (Closed : ℕ → Prop) : Prop :=
  ClippedEndpointWeightedAverageBound X nu delta →
    UpperNatDensityAtMost Closed delta

/-- The live terminal-boundary contribution must be controlled separately. -/
def LiveBoundaryDensityTarget
    (Live : ℕ → Prop) (eps : ℝ) : Prop :=
  UpperNatDensityAtMost Live eps

/-- Closed clipped control plus a live-boundary density estimate gives a full
non-visible bad-shell density estimate, with additive loss `delta + eps`. -/
theorem nonVisibleBadDensity_of_clippedClosedLiveCover
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    {Closed Live : ℕ → Prop}
    (hcover : NonVisibleBadClosedLiveCover nu x H V Closed Live)
    (hclosed : ClippedClosedEndpointControls X nu delta Closed)
    (havg : ClippedEndpointWeightedAverageBound X nu delta)
    (hlive : LiveBoundaryDensityTarget Live eps) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) (delta + eps) := by
  have hClosedDensity : UpperNatDensityAtMost Closed delta := hclosed havg
  have hUnion : UpperNatDensityAtMost (fun m => Closed m ∨ Live m) (delta + eps) :=
    upperNatDensityAtMost_or hClosedDensity hlive
  exact Criteria.upperDensityAtMost_mono hcover hUnion

/-- If the live boundary has density `0`, then the clipped bridge recovers the
same density level `delta` up to the algebraic equality `delta+0`. -/
theorem nonVisibleBadDensity_of_clippedClosedLiveCover_zeroLive
    {X H V : ℕ → ℝ} {nu x delta : ℝ}
    {Closed Live : ℕ → Prop}
    (hcover : NonVisibleBadClosedLiveCover nu x H V Closed Live)
    (hclosed : ClippedClosedEndpointControls X nu delta Closed)
    (havg : ClippedEndpointWeightedAverageBound X nu delta)
    (hlive0 : LiveBoundaryDensityTarget Live 0) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) delta := by
  have h := nonVisibleBadDensity_of_clippedClosedLiveCover
    (X := X) (H := H) (V := V) (nu := nu) (x := x)
    (delta := delta) (eps := 0)
    (Closed := Closed) (Live := Live)
    hcover hclosed havg hlive0
  simpa using h

/-- A safer replacement for `ClippedEndpointWeightedAverageControlsNonVisibleBad`:
there exist closed and live predicates such that the non-visible bad shell is
covered by their union, the closed part is controlled by clipped averaging, and
the live part has density at most `eps`. -/
def ClippedEndpointControlsNonVisibleBadWithLiveLoss
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Prop :=
  ∃ Closed Live : ℕ → Prop,
    NonVisibleBadClosedLiveCover nu x H V Closed Live ∧
    ClippedClosedEndpointControls X nu delta Closed ∧
    LiveBoundaryDensityTarget Live eps

/-- The previous target follows from the split with zero live-boundary density. -/
theorem clippedEndpointControlsNonVisibleBad_of_split_zeroLive
    {X H V : ℕ → ℝ} {nu x delta : ℝ}
    (hsplit : ClippedEndpointControlsNonVisibleBadWithLiveLoss
      X H V nu x delta 0) :
    ClippedEndpointWeightedAverageControlsNonVisibleBad X H V nu x delta := by
  intro havg
  rcases hsplit with ⟨Closed, Live, hcover, hclosed, hlive0⟩
  exact nonVisibleBadDensity_of_clippedClosedLiveCover_zeroLive
    (X := X) (H := H) (V := V) (nu := nu) (x := x)
    (delta := delta) (Closed := Closed) (Live := Live)
    hcover hclosed havg hlive0

/-- With positive live-boundary loss, feed the larger density level
`delta + eps` into the final contraction.  This packages the non-visible bad
density conclusion. -/
theorem nonVisibleBadDensity_of_split_liveLoss
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (hsplit : ClippedEndpointControlsNonVisibleBadWithLiveLoss
      X H V nu x delta eps)
    (havg : ClippedEndpointWeightedAverageBound X nu delta) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) (delta + eps) := by
  rcases hsplit with ⟨Closed, Live, hcover, hclosed, hlive⟩
  exact nonVisibleBadDensity_of_clippedClosedLiveCover
    (X := X) (H := H) (V := V) (nu := nu) (x := x)
    (delta := delta) (eps := eps) (Closed := Closed) (Live := Live)
    hcover hclosed havg hlive

/-- Target: construct the closed/live split from the actual endpoint geometry. -/
def ClippedClosedLiveGeometricSplitTarget
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Prop :=
  ClippedEndpointControlsNonVisibleBadWithLiveLoss X H V nu x delta eps

/-- Target: prove the live-boundary term has zero upper density, or at least a
small enough density loss for the strict-slack bootstrap. -/
def LiveBoundarySmallEnoughForBootstrapTarget
    (X H V : ℕ → ℝ) (nu x delta eps Mout tau : ℝ) : Prop :=
  0 ≤ eps ∧ delta + eps + nu / Mout < shellSpikeGoodDensityGain tau x

/-!
# Clipped endpoint bridge budget closure

The clipped endpoint average does not itself choose which shell indices are
covered by endpoint intervals.  This layer isolates that geometric content as a
closed-part count budget plus a separate live-boundary density estimate.
-/

/-- A closed-endpoint count budget with an explicit error term, produced from a
clipped endpoint average bound. -/
def ClippedClosedEndpointCountBudgetWithError
    (X : ℕ → ℝ) (nu delta : ℝ) (Closed : ℕ → Prop) (E : ℕ → ℝ) : Prop :=
  ClippedEndpointWeightedAverageBound X nu delta →
    UpperCountBudgetWithError Closed delta E

/-- The zero-error version of the closed endpoint count budget. -/
def ClippedClosedEndpointCountBudget
    (X : ℕ → ℝ) (nu delta : ℝ) (Closed : ℕ → Prop) : Prop :=
  ClippedEndpointWeightedAverageBound X nu delta →
    ∀ᶠ N : ℕ in atTop,
      (natInitialSegmentCount Closed N : ℝ) ≤
        delta * ((N : ℝ) + 1)

/-- A zero-error closed count budget is a count budget with zero error. -/
theorem clippedClosedEndpointCountBudgetWithError_zero
    {X : ℕ → ℝ} {nu delta : ℝ} {Closed : ℕ → Prop}
    (h : ClippedClosedEndpointCountBudget X nu delta Closed) :
    ClippedClosedEndpointCountBudgetWithError X nu delta Closed (fun _ => 0) := by
  intro havg
  have hbudget0 := h havg
  filter_upwards [hbudget0] with N hN
  simpa using hN

/-- A closed endpoint count budget with sublinear error proves the closed-control
predicate used by the clipped closed/live split. -/
theorem clippedClosedEndpointControls_of_countBudgetWithError
    {X : ℕ → ℝ} {nu delta : ℝ} {Closed : ℕ → Prop} {E : ℕ → ℝ}
    (hbudget : ClippedClosedEndpointCountBudgetWithError X nu delta Closed E)
    (hE : EventuallySublinearCountError E) :
    ClippedClosedEndpointControls X nu delta Closed := by
  intro havg
  exact upperNatDensityAtMost_of_countBudget_sublinearError (hbudget havg) hE

/-- A zero-error closed endpoint count budget proves the closed-control
predicate. -/
theorem clippedClosedEndpointControls_of_countBudget
    {X : ℕ → ℝ} {nu delta : ℝ} {Closed : ℕ → Prop}
    (hbudget : ClippedClosedEndpointCountBudget X nu delta Closed) :
    ClippedClosedEndpointControls X nu delta Closed := by
  exact clippedClosedEndpointControls_of_countBudgetWithError
    (X := X) (nu := nu) (delta := delta) (Closed := Closed)
    (E := fun _ => 0)
    (clippedClosedEndpointCountBudgetWithError_zero hbudget)
    eventuallySublinearCountError_zero

/-- Closed count budget plus live-boundary density gives the full non-visible bad
shell density with additive live loss. -/
theorem nonVisibleBadDensity_of_clippedClosedBudget_liveLoss
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    {Closed Live : ℕ → Prop}
    (hcover : NonVisibleBadClosedLiveCover nu x H V Closed Live)
    (hbudget : ClippedClosedEndpointCountBudget X nu delta Closed)
    (havg : ClippedEndpointWeightedAverageBound X nu delta)
    (hlive : LiveBoundaryDensityTarget Live eps) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) (delta + eps) := by
  exact nonVisibleBadDensity_of_clippedClosedLiveCover
    (X := X) (H := H) (V := V) (nu := nu) (x := x)
    (delta := delta) (eps := eps)
    (Closed := Closed) (Live := Live)
    hcover (clippedClosedEndpointControls_of_countBudget hbudget) havg hlive

/-- Closed count budget plus zero-density live boundary recovers the clipped
non-visible-bad bridge with no extra loss. -/
theorem clippedEndpointControlsNonVisibleBad_of_closedBudget_zeroLive
    {X H V : ℕ → ℝ} {nu x delta : ℝ}
    {Closed Live : ℕ → Prop}
    (hcover : NonVisibleBadClosedLiveCover nu x H V Closed Live)
    (hbudget : ClippedClosedEndpointCountBudget X nu delta Closed)
    (hlive0 : LiveBoundaryDensityTarget Live 0) :
    ClippedEndpointWeightedAverageControlsNonVisibleBad X H V nu x delta := by
  intro havg
  exact nonVisibleBadDensity_of_clippedClosedLiveCover_zeroLive
    (X := X) (H := H) (V := V) (nu := nu) (x := x)
    (delta := delta) (Closed := Closed) (Live := Live)
    hcover (clippedClosedEndpointControls_of_countBudget hbudget) havg hlive0

/-- Budget form of the split target with live loss. -/
def ClippedEndpointBudgetSplitWithLiveLoss
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Prop :=
  ∃ Closed Live : ℕ → Prop,
    NonVisibleBadClosedLiveCover nu x H V Closed Live ∧
    ClippedClosedEndpointCountBudget X nu delta Closed ∧
    LiveBoundaryDensityTarget Live eps

/-- The budget split implies the previously introduced split target. -/
theorem clippedEndpointControlsNonVisibleBadWithLiveLoss_of_budgetSplit
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (hsplit : ClippedEndpointBudgetSplitWithLiveLoss X H V nu x delta eps) :
    ClippedEndpointControlsNonVisibleBadWithLiveLoss X H V nu x delta eps := by
  rcases hsplit with ⟨Closed, Live, hcover, hbudget, hlive⟩
  exact ⟨Closed, Live, hcover, clippedClosedEndpointControls_of_countBudget hbudget, hlive⟩

/-- Zero-live budget split gives the repaired clipped bridge directly. -/
theorem clippedEndpointControlsNonVisibleBad_of_budgetSplit_zeroLive
    {X H V : ℕ → ℝ} {nu x delta : ℝ}
    (hsplit : ClippedEndpointBudgetSplitWithLiveLoss X H V nu x delta 0) :
    ClippedEndpointWeightedAverageControlsNonVisibleBad X H V nu x delta := by
  exact clippedEndpointControlsNonVisibleBad_of_split_zeroLive
    (clippedEndpointControlsNonVisibleBadWithLiveLoss_of_budgetSplit hsplit)

/-- With positive live-boundary loss, the budget split gives the corresponding
non-visible bad density estimate. -/
theorem nonVisibleBadDensity_of_budgetSplit_liveLoss
    {X H V : ℕ → ℝ} {nu x delta eps : ℝ}
    (hsplit : ClippedEndpointBudgetSplitWithLiveLoss X H V nu x delta eps)
    (havg : ClippedEndpointWeightedAverageBound X nu delta) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x) (delta + eps) := by
  exact nonVisibleBadDensity_of_split_liveLoss
    (clippedEndpointControlsNonVisibleBadWithLiveLoss_of_budgetSplit hsplit)
    havg

/-- The geometric localization target needed to mimic the old endpoint proof on
the closed part.  It should construct `Closed` and prove a zero-error or
sublinear-error count budget for it. -/
def ClippedClosedEndpointLocalizationBudgetTarget
    (X H V : ℕ → ℝ) (nu x delta : ℝ) : Prop :=
  ∃ Closed Live : ℕ → Prop,
    NonVisibleBadClosedLiveCover nu x H V Closed Live ∧
    ClippedClosedEndpointCountBudget X nu delta Closed

/-- The full geometric target with a controlled live-boundary loss. -/
def ClippedEndpointBudgetSplitTarget
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Prop :=
  ClippedEndpointBudgetSplitWithLiveLoss X H V nu x delta eps

/-!
# Clipped bridge status

The fully generic clipped closure is the closed/live split above.  The remaining
bridge input is geometric: prove a closed clipped endpoint budget together with
zero or sufficiently small live-boundary density.
-/

/-- Boundary-inclusive one-threshold delta under input cap `B`. -/
def clippedBridgeBoundaryDelta (B nu : ℝ) : ℝ :=
  oneThresholdBoundaryDelta B nu

/-- Prefix/clipped one-threshold delta under input cap `B`. -/
def clippedBridgePrefixDelta (B nu : ℝ) : ℝ :=
  oneThresholdEndpointDelta B nu

/-- Self-bootstrap contraction threshold. -/
def clippedBridgeSelfThreshold (B nu : ℝ) : ℝ :=
  endpointContractionThreshold B nu

/-- The boundary-inclusive generic delta exceeds the self-bootstrap threshold
throughout the range `2 < nu < B`. -/
theorem clippedBridgeBoundaryDelta_ge_selfThreshold
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu < B) :
    clippedBridgeSelfThreshold B nu ≤ clippedBridgeBoundaryDelta B nu := by
  simpa [clippedBridgeSelfThreshold, clippedBridgeBoundaryDelta] using
    endpointContractionThreshold_le_oneThresholdBoundaryDelta
      (B := B) (nu := nu) hnu2 hnuB

/-- Therefore the boundary-inclusive generic estimate cannot produce the strict
self-bootstrap inequality. -/
theorem not_clippedBridgeBoundary_selfBootstrap
    {B nu : ℝ} (hnu2 : 2 < nu) (hnuB : nu < B) :
    ¬ clippedBridgeBoundaryDelta B nu < clippedBridgeSelfThreshold B nu := by
  intro h
  exact not_lt_of_ge (clippedBridgeBoundaryDelta_ge_selfThreshold
    (B := B) (nu := nu) hnu2 hnuB) h

/-- The clipped prefix delta can be useful, but only if the live boundary is
controlled separately.  This is the scalar strict-slack condition with live
loss `eps`. -/
def ClippedPrefixWithLiveLossStrictCondition (B Mout nu eps : ℝ) : Prop :=
  clippedBridgePrefixDelta B nu + eps + nu / Mout < 1

/-- If live loss is zero, the strict condition reduces to the prefix delta
condition. -/
theorem clippedPrefixStrictCondition_zeroLive_iff
    {B Mout nu : ℝ} :
    ClippedPrefixWithLiveLossStrictCondition B Mout nu 0 ↔
      clippedBridgePrefixDelta B nu + nu / Mout < 1 := by
  unfold ClippedPrefixWithLiveLossStrictCondition
  constructor <;> intro h <;> linarith

/-- The exact remaining non-generic bridge statement.  This target requires
endpoint localization and live-boundary arithmetic. -/
def ClippedBridgeRemainingTarget
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Prop :=
  ClippedEndpointBudgetSplitWithLiveLoss X H V nu x delta eps ∧
    0 ≤ eps

/-- If the remaining bridge target is supplied and the live loss is zero, then
the existing clipped bridge follows. -/
theorem clippedEndpointControls_of_remainingTarget_zeroLive
    {X H V : ℕ → ℝ} {nu x delta : ℝ}
    (h : ClippedBridgeRemainingTarget X H V nu x delta 0) :
    ClippedEndpointWeightedAverageControlsNonVisibleBad X H V nu x delta := by
  exact clippedEndpointControlsNonVisibleBad_of_budgetSplit_zeroLive h.1

/-!
# Clipped live-boundary barrier

The clipped route is not closed by the generic terminal-boundary estimate alone:
if the live boundary is allowed to have the full boundary-inclusive
one-threshold size, its allowance is already at least the self-bootstrap
threshold.  A genuine endpoint, residue, ratio-tail, or cosine saving is needed.
-/

/-- The self-bootstrap contraction threshold attached to an input bound `B`. -/
def oneThresholdSelfThreshold (B nu : ℝ) : ℝ :=
  endpointContractionThreshold B nu

/-- The generic boundary-inclusive live loss produced by charging the terminal
interval using only the cap `r_j ≤ B - 1`. -/
def genericClippedLiveBoundaryLoss (B nu : ℝ) : ℝ :=
  oneThresholdBoundaryDelta B nu

/-- The generic live-boundary loss is at least the self-bootstrap threshold. -/
theorem genericClippedLiveBoundaryLoss_ge_selfThreshold
    {B nu : ℝ}
    (_hB : 4 < B) (hnu2 : 2 < nu) (hnuB : nu < B) :
    oneThresholdSelfThreshold B nu ≤
      genericClippedLiveBoundaryLoss B nu := by
  simpa [oneThresholdSelfThreshold, genericClippedLiveBoundaryLoss] using
    endpointContractionThreshold_le_oneThresholdBoundaryDelta
      (B := B) (nu := nu) hnu2 hnuB

/-- Therefore the generic boundary loss cannot itself be strictly below the
self-bootstrap threshold. -/
theorem not_genericClippedLiveBoundaryLoss_lt_selfThreshold
    {B nu : ℝ}
    (hB : 4 < B) (hnu2 : 2 < nu) (hnuB : nu < B) :
    ¬ genericClippedLiveBoundaryLoss B nu < oneThresholdSelfThreshold B nu := by
  intro hlt
  have hle := genericClippedLiveBoundaryLoss_ge_selfThreshold
    (B := B) (nu := nu) hB hnu2 hnuB
  exact not_lt_of_ge hle hlt

/-- Adding a nonnegative live-loss term cannot restore strictness if the live
boundary is only controlled by the generic terminal-boundary estimate. -/
theorem not_genericBoundary_plus_nonneg_loss_lt_selfThreshold
    {B nu eps : ℝ}
    (hB : 4 < B) (hnu2 : 2 < nu) (hnuB : nu < B)
    (heps : 0 ≤ eps) :
    ¬ genericClippedLiveBoundaryLoss B nu + eps <
        oneThresholdSelfThreshold B nu := by
  intro hlt
  have hle := genericClippedLiveBoundaryLoss_ge_selfThreshold
    (B := B) (nu := nu) hB hnu2 hnuB
  linarith

/-- Replacement target: a genuinely pi-specific live-boundary saving over the
generic terminal-boundary loss. -/
def LiveBoundarySavingTarget (B nu eps : ℝ) : Prop :=
  0 ≤ eps ∧
  eps < oneThresholdSelfThreshold B nu

/-- Numerical live-boundary target for a self-bootstrap step. -/
def LiveBoundaryStrictSlackNumericalTarget (B nu eps : ℝ) : Prop :=
  2 < nu ∧ nu < B ∧ 0 ≤ eps ∧
  eps < oneThresholdSelfThreshold B nu

/-!
# Clipped endpoint live-loss final wrappers

After the clipped active-mass closure, the finite endpoint part is closed.  The
remaining endpoint geometry may produce either zero live-boundary loss or a
small positive live-boundary loss; these wrappers pay for that additive term.
-/

/-- The active-mass clipped average plus a closed/live split gives a
non-visible-bad density estimate with additive live-boundary loss. -/
theorem nonVisibleBadDensity_of_clippedActiveMassData_split_liveLoss
    {X H V : ℕ → ℝ} {B nu x eps : ℝ}
    (D : ClippedOneThresholdActiveMassData X B nu)
    (hsplit : ClippedEndpointControlsNonVisibleBadWithLiveLoss
      X H V nu x (oneThresholdEndpointDelta B nu) eps) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x)
      (oneThresholdEndpointDelta B nu + eps) := by
  have havg : ClippedEndpointWeightedAverageBound X nu
      (oneThresholdEndpointDelta B nu) :=
    clippedEndpointAverage_of_activeMassData D
  exact nonVisibleBadDensity_of_split_liveLoss
    (X := X) (H := H) (V := V) (nu := nu) (x := x)
    (delta := oneThresholdEndpointDelta B nu) (eps := eps)
    hsplit havg

/-- If the live-boundary loss is zero, the clipped active-mass data and the
closed/live split recover the clipped non-visible-bad density with the original
one-threshold delta. -/
theorem nonVisibleBadDensity_of_clippedActiveMassData_split_zeroLive
    {X H V : ℕ → ℝ} {B nu x : ℝ}
    (D : ClippedOneThresholdActiveMassData X B nu)
    (hsplit : ClippedEndpointControlsNonVisibleBadWithLiveLoss
      X H V nu x (oneThresholdEndpointDelta B nu) 0) :
    UpperNatDensityAtMost (NonVisibleBadShell nu H V x)
      (oneThresholdEndpointDelta B nu) := by
  have h := nonVisibleBadDensity_of_clippedActiveMassData_split_liveLoss
    (X := X) (H := H) (V := V) (B := B) (nu := nu) (x := x)
    (eps := 0) D hsplit
  simpa using h

/-- A small live loss can be absorbed by strict slack. -/
theorem clipped_liveLoss_gain_of_lt_slack
    {nu M tau x delta eps : ℝ}
    (h : eps < shellSpikeGoodDensityGain tau x - (nu / M + delta)) :
    nu / M + (delta + eps) < shellSpikeGoodDensityGain tau x := by
  linarith

/-- Final Bauer/Ramanujan wrapper with clipped active mass and live-boundary
loss.  The final gain condition has to pay for the additive loss
`oneThresholdEndpointDelta B nu + eps`. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_clippedActiveMass_liveLoss
    {mu B M nu tau x eps : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (D : ClippedOneThresholdActiveMassData X B nu)
    (hSplit : ClippedEndpointControlsNonVisibleBadWithLiveLoss
      X H V nu x (oneThresholdEndpointDelta B nu) eps)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hdeltaeps_nonneg : 0 ≤ oneThresholdEndpointDelta B nu + eps)
    (hgain_surplus :
      nu / M + (oneThresholdEndpointDelta B nu + eps)
        < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  have hNV : UpperNatDensityAtMost (NonVisibleBadShell nu H V x)
      (oneThresholdEndpointDelta B nu + eps) :=
    nonVisibleBadDensity_of_clippedActiveMassData_split_liveLoss
      (X := X) (H := H) (V := V) (B := B) (nu := nu) (x := x)
      (eps := eps) D hSplit
  exact oneOverPi_irratMeasure_lt_of_Bauer_nonVisibleBadDensity
    (mu := mu) (nu := nu) (M := M) (tau := tau) (x := x)
    (eps := oneThresholdEndpointDelta B nu + eps)
    (Hlog := Hlog) (u := u) (vseq := vseq) (H := H) (V := V)
    C hBauer hmu hnu2 hnuM htau hx hx1 hxθ
    hNV hdeltaeps_nonneg hgain_surplus

/-- Zero-live special case of the clipped active-mass final wrapper. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_clippedActiveMass_zeroLive
    {mu B M nu tau x : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (C : OrderedEndpointClosureCertificate Hlog u vseq H V tau x)
    (D : ClippedOneThresholdActiveMassData X B nu)
    (hSplit : ClippedEndpointControlsNonVisibleBadWithLiveLoss
      X H V nu x (oneThresholdEndpointDelta B nu) 0)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau)
    (hB_le : nu ≤ B)
    (hgain_surplus :
      nu / M + oneThresholdEndpointDelta B nu
        < shellSpikeGoodDensityGain tau x) :
    mu < M := by
  have hdelta_nonneg : 0 ≤ oneThresholdEndpointDelta B nu :=
    oneThresholdEndpointDelta_nonneg hnu2 hB_le
  have hdeltaeps_nonneg : 0 ≤ oneThresholdEndpointDelta B nu + 0 := by
    simpa using hdelta_nonneg
  have hgain :
      nu / M + (oneThresholdEndpointDelta B nu + 0)
        < shellSpikeGoodDensityGain tau x := by
    simpa using hgain_surplus
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedActiveMass_liveLoss
    (mu := mu) (B := B) (M := M) (nu := nu) (tau := tau) (x := x)
    (eps := 0) (X := X) (H := H) (V := V)
    (Hlog := Hlog) (u := u) (vseq := vseq)
    C D hSplit hBauer hmu hnu2 hnuM htau hx hx1 hxθ
    hdeltaeps_nonneg hgain

/-- Data package for a clipped active-mass/live-loss step. -/
structure ClippedActiveMassLiveLossStepData
    (B M nu tau x eps : ℝ)
    (X H V Hlog u vseq : ℕ → ℝ) : Prop where
  closureCert : OrderedEndpointClosureCertificate Hlog u vseq H V tau x
  activeData : ClippedOneThresholdActiveMassData X B nu
  split : ClippedEndpointControlsNonVisibleBadWithLiveLoss
    X H V nu x (oneThresholdEndpointDelta B nu) eps
  deltaeps_nonneg : 0 ≤ oneThresholdEndpointDelta B nu + eps
  gain_surplus :
    nu / M + (oneThresholdEndpointDelta B nu + eps)
      < shellSpikeGoodDensityGain tau x

/-- The live-loss step data feeds the final Bauer/Ramanujan contraction. -/
theorem oneOverPi_irratMeasure_lt_of_Bauer_clippedActiveMassLiveLossStepData
    {mu B M nu tau x eps : ℝ}
    {X H V Hlog u vseq : ℕ → ℝ}
    (P : ClippedActiveMassLiveLossStepData B M nu tau x eps X H V Hlog u vseq)
    (hBauer : BauerRamanujanIdentity)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu)
    (hnu2 : 2 < nu) (hnuM : nu < M)
    (htau : 0 < tau)
    (hx : shellSpikeContractionExponent tau nu M < x)
    (hx1 : x < 1)
    (hxθ : x ≤ shellSpikeGlobalExponent tau) :
    mu < M := by
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedActiveMass_liveLoss
    (mu := mu) (B := B) (M := M) (nu := nu) (tau := tau) (x := x)
    (eps := eps) (X := X) (H := H) (V := V)
    (Hlog := Hlog) (u := u) (vseq := vseq)
    P.closureCert P.activeData P.split hBauer hmu hnu2 hnuM htau hx hx1 hxθ
    P.deltaeps_nonneg P.gain_surplus

/-!
# Clipped active-mass live-loss strict-slack bootstrap

This layer specializes the clipped active-mass/live-loss one-step data to the
relaxed strict-slack output map, then feeds it into the existing iteration to
the non-strict bound `4`.
-/

/-- Data for one strict-slack step using the clipped active-mass/live-loss
wrapper.  The output exponent is the relaxed map of the current input bound. -/
structure ClippedActiveMassLiveLossStrictSlackStepData (B : ℝ) : Type where
  nu : ℝ
  tau : ℝ
  x : ℝ
  eps : ℝ
  X : ℕ → ℝ
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  stepData :
    ClippedActiveMassLiveLossStepData B (oneThresholdBootstrapRelaxedMap B)
      nu tau x eps X H V Hlog u vseq
  bauer : BauerRamanujanIdentity
  nu_gt_two : 2 < nu
  nu_lt_output : nu < (oneThresholdBootstrapRelaxedMap B)
  tau_pos : 0 < tau
  x_contraction :
    shellSpikeContractionExponent tau nu (oneThresholdBootstrapRelaxedMap B) < x
  x_lt_one : x < 1
  x_le_global : x ≤ shellSpikeGlobalExponent tau

/-- The remaining one-step construction target after the clipped/live-loss
closures. -/
def ClippedActiveMassLiveLossStrictSlackStepDataTarget : Prop :=
  ∀ B : ℝ,
    4 < B →
      OneOverPiMeasureStrictlyBelow B →
        Nonempty (ClippedActiveMassLiveLossStrictSlackStepData B)

/-- A clipped active-mass/live-loss strict-slack step gives the relaxed one-step
measure improvement. -/
theorem oneOverPiMeasure_lt_relaxedMap_of_clippedActiveMassLiveLossStrictSlackStepData
    {B mu : ℝ}
    (D : ClippedActiveMassLiveLossStrictSlackStepData B)
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu) :
    mu < oneThresholdBootstrapRelaxedMap B := by
  exact oneOverPi_irratMeasure_lt_of_Bauer_clippedActiveMassLiveLossStepData
    (mu := mu) (B := B) (M := oneThresholdBootstrapRelaxedMap B)
    (nu := D.nu) (tau := D.tau) (x := D.x) (eps := D.eps)
    (X := D.X) (H := D.H) (V := D.V)
    (Hlog := D.Hlog) (u := D.u) (vseq := D.vseq)
    D.stepData D.bauer hmu D.nu_gt_two D.nu_lt_output D.tau_pos
    D.x_contraction D.x_lt_one D.x_le_global

/-- The clipped active-mass/live-loss step-data target realizes the abstract
strict-slack one-step predicate used by the final relaxed iteration. -/
theorem oneThresholdBootstrapStrictSlackStepRealized_of_clippedActiveMassLiveLossTarget
    (hdata : ClippedActiveMassLiveLossStrictSlackStepDataTarget) :
    OneThresholdBootstrapStrictSlackStepRealized := by
  intro B hB hBound mu hmu
  rcases hdata B hB hBound with ⟨D⟩
  exact oneOverPiMeasure_lt_relaxedMap_of_clippedActiveMassLiveLossStrictSlackStepData
    (B := B) (mu := mu) D hmu

/-- Final package for the clipped active-mass/live-loss strict-slack route. -/
structure ClippedActiveMassLiveLossStrictSlackFinalPackage (B0 : ℝ) : Prop where
