  intro B hB hBound
  rcases h B hB hBound with ⟨D⟩
  refine ⟨?_⟩
  exact {
    X := D.X
    H := D.H
    V := D.V
    Hlog := D.Hlog
    u := D.u
    vseq := D.vseq
    Relevant := D.Relevant
    Live := D.Live
    closureCert := D.closureCert
    nu_le_B := D.nu_le_B
    X_pos := D.X_pos
    X_mono := D.X_mono
    ratio_cap := D.ratio_cap
    offsetOrLive := D.offsetOrLive
