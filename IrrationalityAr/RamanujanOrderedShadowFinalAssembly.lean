/-!
## Denominator-log ratio boundedness from finite measure

This closes the ratio-cap side left by the tail-stable clipped layer-cake
route.  The only non-geometric input used here is the isolated project axiom
that `1 / pi` has finite irrationality measure.
-/

/-- A finite irrationality-measure witness bounds the continued-fraction
convergent denominator log-jump ratios eventually. -/
theorem continuantDenLogRatio_eventually_le_of_hasIrrationalityMeasure
    {α μ : ℝ} {a : ℕ → ℕ}
    (hcf : IsSimpleCFExpansion α a)
    (hμ : HasIrrationalityMeasure α μ) :
    ∀ᶠ n : ℕ in atTop, continuantDenLogRatio a n ≤ μ := by
  by_contra hnot
  have hfreq_not : ∃ᶠ n : ℕ in atTop,
      ¬ continuantDenLogRatio a n ≤ μ :=
    Filter.not_eventually.mp hnot
  have hfreq_gt : ∃ᶠ n : ℕ in atTop,
      μ < continuantDenLogRatio a n :=
    hfreq_not.mono fun _ hn => lt_of_not_ge hn
  have hfreq_ratio : ∃ᶠ n : ℕ in atTop,
      (μ + 1) - 1 < continuantDenLogRatio a n := by
    simpa using hfreq_gt
  have hfreq_approx : ∃ᶠ q : ℕ in atTop,
      ∃ p : ℤ,
        0 < q ∧
          |α - (p : ℝ) / (q : ℝ)| < (q : ℝ) ^ (-(μ + 1)) :=
    lower_clause_from_frequently_large_denominatorRatio
      (α := α) (a := a) (ν := μ + 1) hcf hfreq_ratio
  have hupper : ∀ᶠ q : ℕ in atTop,
      ∀ p : ℤ,
      0 < q →
        ¬ |α - (p : ℝ) / (q : ℝ)| < (q : ℝ) ^ (-(μ + 1)) :=
    hμ.2 (μ + 1) (by linarith)
  have hfalse : ∃ᶠ q : ℕ in atTop, False :=
    (hfreq_approx.and_eventually hupper).mono fun _ hq => by
      rcases hq with ⟨⟨p, hqpos, hlt⟩, hbad⟩
      exact hbad p hqpos hlt
  exact (Filter.frequently_false atTop) hfalse

/-- A finite irrationality-measure witness gives bounded denominator
log-ratio. -/
theorem continuantDenLogRatio_isBoundedUnder_of_hasIrrationalityMeasure
    {α μ : ℝ} {a : ℕ → ℕ}
    (hcf : IsSimpleCFExpansion α a)
    (hμ : HasIrrationalityMeasure α μ) :
    Filter.IsBoundedUnder (fun x y : ℝ => x ≤ y) atTop
      (continuantDenLogRatio a) := by
  exact Filter.isBoundedUnder_of_eventually_le (a := μ)
    (continuantDenLogRatio_eventually_le_of_hasIrrationalityMeasure
      (α := α) (μ := μ) (a := a) hcf hμ)

/-- The isolated finite-measure axiom for `1 / pi` closes the remaining bounded
continuant denominator-log-ratio target. -/
theorem oneOverPiContinuantDenLogRatioBoundedTarget_of_finiteMeasure :
    OneOverPiContinuantDenLogRatioBoundedTarget := by
  rcases oneOverPi_hasFiniteIrrationalityMeasure with ⟨μ, hμ⟩
  exact continuantDenLogRatio_isBoundedUnder_of_hasIrrationalityMeasure
    (α := 1 / Real.pi) (μ := μ) (a := oneOverPiCF)
    oneOverPiCF_isSimpleCFExpansion_public hμ

/-- The finite-measure axiom also supplies some strict effective starting cap
above `4`, by uniqueness of the literal irrationality-measure value. -/
theorem exists_oneOverPiMeasureStrictlyBelowEffectiveRaw_of_finiteMeasure :
    ∃ B0 : ℝ, 4 < B0 ∧ OneOverPiMeasureStrictlyBelowEffectiveRaw B0 := by
  rcases oneOverPi_hasFiniteIrrationalityMeasure with ⟨μ0, hμ0⟩
  refine ⟨max 5 (μ0 + 1), ?_, ?_⟩
  · exact lt_of_lt_of_le (by norm_num) (le_max_left 5 (μ0 + 1))
  · intro μ hμ
    have hμeq : μ = μ0 := HasIrrationalityMeasure_unique hμ hμ0
    rw [hμeq]
    exact lt_of_lt_of_le (by linarith) (le_max_right 5 (μ0 + 1))

/-- A finite irrationality-measure witness gives a project `KnownOneOverPiMeasureBound`
above `4`.

This is the same starting-bound extraction as
`exists_oneOverPiMeasureStrictlyBelowEffectiveRaw_of_finiteMeasure`, phrased in
the final-package vocabulary. -/
theorem exists_knownOneOverPiMeasureBound_above_four_of_finiteMeasure
    (hfin : HasFiniteIrrationalityMeasure (1 / Real.pi)) :
    ∃ B0 : ℝ, 4 < B0 ∧ KnownOneOverPiMeasureBound B0 := by
  rcases hfin with ⟨μ0, hμ0⟩
  refine ⟨max (μ0 + 1) 5, ?_, ?_⟩
  · exact lt_of_lt_of_le (by norm_num : (4 : ℝ) < 5)
      (le_max_right (μ0 + 1) 5)
  · intro μ hμ
    have hμeq : μ = μ0 := HasIrrationalityMeasure_unique hμ hμ0
    rw [hμeq]
    exact lt_of_lt_of_le (lt_add_one μ0) (le_max_left (μ0 + 1) 5)

/-- The isolated finite-measure input supplies a noncomputable starting cap
`B0 > 4` for the final packages. -/
theorem exists_knownOneOverPiMeasureBound_above_four :
    ∃ B0 : ℝ, 4 < B0 ∧ KnownOneOverPiMeasureBound B0 := by
  exact exists_knownOneOverPiMeasureBound_above_four_of_finiteMeasure
    oneOverPi_hasFiniteIrrationalityMeasure

/-- Therefore, after the ratio-cap reduction, the only remaining non-scalar
input is the tail-stable endpoint geometry target. -/
theorem oneOverPi_irratMeasure_le_four_of_endpointGeometry_finiteMeasure
    (hgeom : OneOverPiTailStableEndpointGeometryForShiftTarget) :
    OneOverPiMeasureAtMost 4 := by
  rcases exists_oneOverPiMeasureStrictlyBelowEffectiveRaw_of_finiteMeasure with
    ⟨B0, hB0, hStart⟩
  exact oneOverPi_irratMeasure_le_four_of_denLogRatioBounded_and_endpointGeometry
    oneOverPiContinuantDenLogRatioBoundedTarget_of_finiteMeasure hgeom hB0 hStart

