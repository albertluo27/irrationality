  exact ⟨TelescopingClippedStepDataClean.ofBudgetSplitZeroLive
    (B := B) (M := M) (nu := nu) (tau := tau) (x := x)
    (X := X) (H := H) (V := V) (Hlog := Hlog) (u := u) (vseq := vseq)
