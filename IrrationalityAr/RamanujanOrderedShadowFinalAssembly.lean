/-! ## 1. Concrete logarithmic data -/

/-- Logarithm of the next partial quotient in canonical block `j`. -/
noncomputable def partialQuotientLog (a : ℕ → ℕ) (j : ℕ) : ℝ :=
  Real.log (a (j + 1) : ℝ)

/-- A natural shell height viewed as a real number. -/
noncomputable def natShellHeightReal (H : ℕ → ℕ) (m : ℕ) : ℝ :=
  (H m : ℝ)

/-- Logarithm of a natural shell height. -/
noncomputable def natShellHeightLog (H : ℕ → ℕ) (m : ℕ) : ℝ :=
  Real.log (H m : ℝ)

/-- Visible canonical block maximum at a natural shell height, cast to `ℝ`. -/
noncomputable def visibleCanonicalBlockMaxAtNatHeight
    (a : ℕ → ℕ) (H : ℕ → ℕ) (m : ℕ) : ℝ :=
  (visibleCanonicalBlockMax a (H m) : ℝ)

/-! ## 2. A single visible spike produces a block shadow certificate -/

/-- A power-sized visible canonical block produces the exact local logarithmic
shadow certificate used by `BadShellsCoveredByShadows_of_block_certificate`.

The theorem is deliberately generic in the continued-fraction coefficient
sequence `a` and in the denominator cap `N`.
-/
theorem exists_BlockCanSpikeAt_of_visibleCanonicalBlockMax_rpow_lt
    {a : ℕ → ℕ}
    (hpos : ∀ n : ℕ, 0 < a (n + 1))
    {N : ℕ} {x : ℝ}
    (hN : 1 < N)
    (hx0 : 0 < x) (_hx1 : x < 1)
    (hspike : (N : ℝ) ^ x < (visibleCanonicalBlockMax a N : ℝ)) :
    ∃ j : ℕ,
      BlockCanSpikeAt
        (continuantQlog a j)
        (partialQuotientLog a j)
        (Real.log (N : ℝ)) x := by
  let s : Finset ℕ := Finset.range (2 * Nat.log 2 N + 3)
  let f : ℕ → ℕ := fun j : ℕ =>
    (visibleCanonicalOddDenominatorBlock a N j).card
  have hsne : s.Nonempty := by
    refine ⟨0, ?_⟩
    simp [s]
  rcases Finset.exists_mem_eq_sup s hsne f with ⟨j, hj, hsup⟩

  have hNgt1 : (1 : ℝ) < (N : ℝ) := by
    exact_mod_cast hN
  have hNpos : 0 < (N : ℝ) := lt_trans zero_lt_one hNgt1
  have hpow_gt_one : (1 : ℝ) < (N : ℝ) ^ x := by
    have hpow : (N : ℝ) ^ (0 : ℝ) < (N : ℝ) ^ x :=
      Real.rpow_lt_rpow_of_exponent_lt hNgt1 hx0
    simpa using hpow
  have hRgt1real : (1 : ℝ) < (visibleCanonicalBlockMax a N : ℝ) :=
    hpow_gt_one.trans hspike
  have hRgt1nat : 1 < visibleCanonicalBlockMax a N := by
    exact_mod_cast hRgt1real

  have hfjgt1 : 1 < f j := by
    by_contra hnot
    have hfjle : f j ≤ 1 := Nat.le_of_not_gt hnot
    have hReqOne : visibleCanonicalBlockMax a N = 1 := by
      unfold visibleCanonicalBlockMax
      change max 1 (s.sup f) = 1
      rw [hsup]
      exact max_eq_left hfjle
    omega

  have hReq : visibleCanonicalBlockMax a N = f j := by
    unfold visibleCanonicalBlockMax
    change max 1 (s.sup f) = f j
    rw [hsup]
    exact max_eq_right (by omega)

  have hcardSpike :
      (N : ℝ) ^ x <
        ((visibleCanonicalOddDenominatorBlock a N j).card : ℝ) := by
    calc
      (N : ℝ) ^ x < (visibleCanonicalBlockMax a N : ℝ) := hspike
      _ = (f j : ℝ) := by exact_mod_cast hReq
      _ = ((visibleCanonicalOddDenominatorBlock a N j).card : ℝ) := rfl

  have hcardPosNat :
      0 < (visibleCanonicalOddDenominatorBlock a N j).card := by
    dsimp [f] at hfjgt1
    omega
  have hcardPos :
      0 < ((visibleCanonicalOddDenominatorBlock a N j).card : ℝ) := by
    exact_mod_cast hcardPosNat

  have hqPosNat : 0 < continuantDen a j :=
    lt_of_lt_of_le Nat.zero_lt_one
      (one_le_continuantDen_of_partials_pos_global a hpos j)
  have hqPos : 0 < (continuantDen a j : ℝ) := by
    exact_mod_cast hqPosNat

  have hmulNat :
      (visibleCanonicalOddDenominatorBlock a N j).card *
          continuantDen a j ≤ N :=
    visibleCanonicalOddDenominatorBlock_card_mul_den_le hpos N j
  have hmul :
      ((visibleCanonicalOddDenominatorBlock a N j).card : ℝ) *
          (continuantDen a j : ℝ) ≤ (N : ℝ) := by
    exact_mod_cast hmulNat
  have hlogMul :
      Real.log ((visibleCanonicalOddDenominatorBlock a N j).card : ℝ) +
          Real.log (continuantDen a j : ℝ) ≤ Real.log (N : ℝ) := by
    have h := Real.log_le_log (mul_pos hcardPos hqPos) hmul
    simpa [Real.log_mul hcardPos.ne' hqPos.ne'] using h

  have hlogCard :
      x * Real.log (N : ℝ) <
        Real.log ((visibleCanonicalOddDenominatorBlock a N j).card : ℝ) := by
    have h := Real.log_lt_log (Real.rpow_pos_of_pos hNpos x) hcardSpike
    simpa [Real.log_rpow hNpos] using h

  have hu :
      continuantQlog a j ≤ (1 - x) * Real.log (N : ℝ) := by
    unfold continuantQlog
    nlinarith [hlogMul, hlogCard]

  have hcardSafe :
      (visibleCanonicalOddDenominatorBlock a N j).card ≤
        canonicalSafeBlockLength a j :=
    visibleCanonicalOddDenominatorBlock_card_le_safeBlockLength N j
  have hsafeA : canonicalSafeBlockLength a j ≤ a (j + 1) :=
    canonicalSafeBlockLength_le_partialQuotient a (hpos j)
  have hcardA_nat :
      (visibleCanonicalOddDenominatorBlock a N j).card ≤ a (j + 1) :=
    hcardSafe.trans hsafeA
  have hcardA :
      ((visibleCanonicalOddDenominatorBlock a N j).card : ℝ) ≤
        (a (j + 1) : ℝ) := by
    exact_mod_cast hcardA_nat
  have haPos : 0 < (a (j + 1) : ℝ) := by
    exact_mod_cast hpos j
  have hpowA : (N : ℝ) ^ x < (a (j + 1) : ℝ) :=
    hcardSpike.trans_le hcardA
  have hvStrict :
      x * Real.log (N : ℝ) < partialQuotientLog a j := by
    unfold partialQuotientLog
    have h := Real.log_lt_log (Real.rpow_pos_of_pos hNpos x) hpowA
    simpa [Real.log_rpow hNpos] using h

  exact ⟨j, hu, le_of_lt hvStrict⟩

/-! ## 3. Generic natural-height shadow cover -/

/-- For every natural height sequence bounded below by `2`, actual visible
canonical block spikes are covered by the logarithmic shadows of the same
continued-fraction blocks.

This theorem discharges `ActualSpikeShellsHaveShadowCover` for the canonical
visible-block maximum, independently of any Ramanujan analysis.
-/
theorem actualSpikeShellsHaveShadowCover_visibleCanonicalBlockMax_natHeight
    {a : ℕ → ℕ} {H : ℕ → ℕ} {x : ℝ}
    (hpos : ∀ n : ℕ, 0 < a (n + 1))
    (hH : ∀ m : ℕ, 1 < H m)
    (hx0 : 0 < x) (hx1 : x < 1) :
    ActualSpikeShellsHaveShadowCover
      (natShellHeightLog H)
      (continuantQlog a)
      (partialQuotientLog a)
      (visibleCanonicalBlockMaxAtNatHeight a H)
      (natShellHeightReal H)
      x := by
  unfold ActualSpikeShellsHaveShadowCover
  apply BadShellsCoveredByShadows_of_block_certificate hx0 hx1
  intro m hm
  have hspike :
      (H m : ℝ) ^ x < (visibleCanonicalBlockMax a (H m) : ℝ) := by
    simpa [VisibleBlockSpikeShell, natShellHeightReal,
      visibleCanonicalBlockMaxAtNatHeight] using hm
  rcases exists_BlockCanSpikeAt_of_visibleCanonicalBlockMax_rpow_lt
      hpos (hH m) hx0 hx1 hspike with ⟨j, hj⟩
  refine ⟨j, ?_⟩
  simpa [natShellHeightLog] using hj

/-- Specialization of the actual shadow-cover theorem to the simple continued
fraction of `1 / π`. -/
theorem oneOverPi_actualSpikeShellsHaveShadowCover_natHeight
    {H : ℕ → ℕ} {x : ℝ}
    (hH : ∀ m : ℕ, 1 < H m)
    (hx0 : 0 < x) (hx1 : x < 1) :
    ActualSpikeShellsHaveShadowCover
      (natShellHeightLog H)
      (continuantQlog oneOverPiCF)
      (partialQuotientLog oneOverPiCF)
      (visibleCanonicalBlockMaxAtNatHeight oneOverPiCF H)
      (natShellHeightReal H)
      x := by
  exact actualSpikeShellsHaveShadowCover_visibleCanonicalBlockMax_natHeight
    oneOverPiCF_partials_pos hH hx0 hx1

