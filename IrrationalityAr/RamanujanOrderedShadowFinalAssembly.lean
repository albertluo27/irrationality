/-!
# Endpoint witness reduction for the static split layer

This layer removes two remaining high-level static endpoint fields.

Instead of asking directly for a bad-visible-endpoint split and an
endpoint-exceptional subwindow cover, it asks for two pointwise geometric facts:

* every bad shell has some relevant denominator log below the cap;
* any relevant denominator log far enough below the cap forces a visible spike.

Those facts imply both static endpoint fields by classical dichotomy.
-/

/-! ## Pointwise witness facts -/

/-- Every bad shell has at least one relevant index whose denominator log is
below the Ramanujan denominator cap. -/
def EndpointRelevantBelowCapWitness
    (nu : ℝ) (X : ℕ → ℝ) (BaseRelevant : ℕ → ℕ → Prop) : Prop :=
  ∀ m : ℕ,
    BadRamanujanTruncation nu m →
      ∃ j : ℕ,
        BaseRelevant m j ∧ X j ≤ ramanujanDenominatorCapLog nu m

/-- A relevant index below the safe threshold forces the shell to be visible.

This is the pointwise geometric input corresponding to the informal implication
`X_j ≤ (1 - x) cap(m) -> visible block spike at m`. -/
def EndpointLowRelevantForcesVisible
    (nu x : ℝ) (X H V : ℕ → ℝ)
    (BaseRelevant : ℕ → ℕ → Prop) : Prop :=
  ∀ m j : ℕ,
    BadRamanujanTruncation nu m →
      BaseRelevant m j →
        X j ≤ (1 - x) * ramanujanDenominatorCapLog nu m →
          VisibleBlockSpikeShell H V x m

/-- The below-cap witness plus the definition of endpoint-exceptional shells
implies the endpoint-subwindow cover. -/
theorem endpointExceptionalSubwindowCover_of_belowCapWitness
    {nu x : ℝ} {X : ℕ → ℝ} {BaseRelevant : ℕ → ℕ → Prop}
    (hWitness : EndpointRelevantBelowCapWitness nu X BaseRelevant) :
    EndpointExceptionalSubwindowCover nu x X BaseRelevant := by
  intro m hExc
  rcases hExc with ⟨hBad, hOffset⟩
  rcases hWitness m hBad with ⟨j, hRel, hCap⟩
  exact ⟨j, hRel, ⟨hOffset j hRel, hCap⟩⟩

/-- If every sufficiently-low relevant index forces visibility, then every bad
shell is either visible or endpoint-exceptional by offset. -/
theorem badTruncationVisibleEndpointSplit_of_lowRelevantForcesVisible
    {nu x : ℝ} {X H V : ℕ → ℝ} {BaseRelevant : ℕ → ℕ → Prop}
    (hLow : EndpointLowRelevantForcesVisible nu x X H V BaseRelevant) :
    BadTruncationVisibleEndpointSplit nu H V x
      (EndpointExceptionalByOffset nu x X BaseRelevant) := by
  classical
  intro m hBad
  by_cases hEnd :
      ∀ j : ℕ,
        BaseRelevant m j →
          (1 - x) * ramanujanDenominatorCapLog nu m < X j
  · exact Or.inr ⟨hBad, hEnd⟩
  · push Not at hEnd
    rcases hEnd with ⟨j, hRel, hLowCap⟩
    exact Or.inl (hLow m j hBad hRel hLowCap)

