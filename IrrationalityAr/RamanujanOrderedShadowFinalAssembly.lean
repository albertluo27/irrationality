/-- Entropy of certified canonical blocks is controlled by block count plus the
subset-sum dissociated dimension of the certified difference set. -/
theorem entropy_bound_by_dissociated_difference_dimension
    {a : ℕ → ℕ}
    (hpos : ∀ n : ℕ, 0 < a (n + 1))
    (J : ℕ) :
    certifiedBlockEntropy a J ≤
      (((certifiedBlockCount a J +
          2 * subsetSumDissociatedDimension
            (nonnegativeDifferenceSet (certifiedOddBlocks a J)) + 1 : ℕ) : ℝ) *
        Real.log 2) := by
  exact certifiedBlockEntropy_le_certifiedBlockCount_add_dissDim
    (a := a) hpos J

/-- Contrapositive pressure form: large positive-block entropy forces large
subset-sum dissociated dimension in the certified difference set. -/
theorem dissociated_difference_dimension_pressure
    {a : ℕ → ℕ}
    (hpos : ∀ n : ℕ, 0 < a (n + 1))
    (J : ℕ) :
    ((certifiedPositiveBlockEntropy a J / Real.log 2) -
        (certifiedPositiveBlockCount a J : ℝ)) / 2 ≤
      (subsetSumDissociatedDimension
        (nonnegativeDifferenceSet (certifiedOddBlocks a J)) : ℝ) := by
  exact dissociatedDifferenceDimension_ge_entropy (a := a) hpos J

/-- One canonical block has the reciprocal numerator/denominator bicoloring
package. -/
theorem reciprocal_bicolor_package
    (a : ℕ → ℕ) (j : ℕ) :
    a (j + 1) / 2 ≤ (canonicalOddBlock a j).card ∧
      a (j + 1) / 2 ≤ (denominatorOddBlock a j).card ∧
        Finset.Icc 1 (a (j + 1)) ⊆
          canonicalOddBlock a j ∪ denominatorOddBlock a j := by
  exact reciprocal_bicolor_block_package a j

/-- A reciprocal block point certifies membership on one of the two reciprocal
sides. -/
theorem reciprocal_block_point_certifies_one_side_alias
    {α : ℝ} {a : ℕ → ℕ} {j t : ℕ}
    (hαpos : 0 < α)
    (hαirr : IsIrrational α)
    (hcf : IsSimpleCFExpansion α a)
    (hβpos : 0 < 1 / α)
    (hβirr : IsIrrational (1 / α))
    (hβcf : IsSimpleCFExpansion (1 / α) (reciprocalCoeff a))
    (ht1 : 1 ≤ t)
    (htle : t ≤ a (j + 1))
    (hP2 : 2 ≤ CFBlockNumerator a j t) :
    (CFBlockDenominator a j t - 1 ∈ A α) ∨
      (CFBlockNumerator a j t - 1 ∈ A (1 / α)) := by
  exact reciprocal_block_point_certifies_one_side_given_reciprocal_cf
    (α := α) (a := a) (j := j) (t := t)
    hαpos hαirr hcf hβpos hβirr hβcf ht1 htle hP2

/-- Every irrational floor-sum set has the merged logarithmic-lower/zero-density
counting package. -/
theorem A_count_log_lower_and_zeroDensity_alias
    {α : ℝ}
