    clippedIntervalBudget :=
      endpointSubwindowClippedIntervalBudgetData_of_full D.intervalBudget
    liveDensity := D.liveDensity
    bauer := D.bauer
  }

/-- Final package using clipped interval-budget live-loss geometry. -/
structure ClippedCanonicalLiveLossSubwindowClippedIntervalBudgetFinalPackage
