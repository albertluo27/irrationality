/-!
# Cutoff prefix static-split reduction

This layer fixes the next bookkeeping point in the cutoff-aware endpoint route.

A static relevance relation `BaseRelevant m j` is the natural output of the
continued-fraction/Ramanujan endpoint geometry.  The cutoff-aware counting layer,
however, needs a dynamic closed/live split at each outer cutoff `M`.

The split is canonical: closed means the static witness has index `j < K M` and
also `j ≤ M`, while live means a static endpoint-subwindow witness exists but is
not closed at the current cutoff.
-/

/-! ## Canonical dynamic split from a static relevance relation -/

/-- Closed cutoff relevance induced by a static relevance relation and a prefix
map.  The extra `i ≤ M` keeps the index inside the finite active-search range
used by the cutoff counting API. -/
def CutoffPrefixClosedRelevantAt
    (K : ℕ → ℕ) (BaseRelevant : ℕ → ℕ → Prop)
    (M m i : ℕ) : Prop :=
  BaseRelevant m i ∧ i < K M ∧ i ≤ M

/-- The live part induced by a static relevance relation and prefix map.  A
shell is live at cutoff `M` if it has an endpoint-subwindow witness which is not
closed at the current cutoff. -/
def CutoffPrefixLiveAt
    (nu x : ℝ) (X : ℕ → ℝ)
    (K : ℕ → ℕ) (BaseRelevant : ℕ → ℕ → Prop)
    (M m : ℕ) : Prop :=
  ∃ i : ℕ,
    BaseRelevant m i ∧
      ¬ (i < K M ∧ i ≤ M) ∧
        EndpointSubwindow nu x X i m

/-- Closed cutoff relevance is automatically below the outer cutoff. -/
theorem cutoffPrefixClosed_indexLeCutoff
    {S E : ℕ → ℝ} {K : ℕ → ℕ}
    {BaseRelevant : ℕ → ℕ → Prop} :
    CutoffRelevantIndexLeCutoff S E
      (CutoffPrefixClosedRelevantAt K BaseRelevant) := by
  intro _M _m _i _hm hRel _hInt
  exact hRel.2.2

/-- Closed cutoff relevance is automatically below the prefix map. -/
theorem cutoffPrefixClosed_indexLtPrefix
    {K : ℕ → ℕ} {BaseRelevant : ℕ → ℕ → Prop} :
    CutoffRelevantIndexLtPrefix K
      (CutoffPrefixClosedRelevantAt K BaseRelevant) := by
  intro M _m i hRel
  exact hRel.2.1

/-- A static endpoint-exceptional split plus a static subwindow cover produces
the cutoff-aware closed/live cover for the canonical dynamic split. -/
theorem cutoffClosedLiveInitialSegmentCover_of_staticEndpointSubwindowCover
    {X H V : ℕ → ℝ} {nu x : ℝ}
    {BaseRelevant : ℕ → ℕ → Prop} {K : ℕ → ℕ}
    (hnu : 0 < nu)
    (hSplit : ∀ m : ℕ,
      BadRamanujanTruncation nu m →
        VisibleBlockSpikeShell H V x m ∨
          EndpointExceptionalByOffset nu x X BaseRelevant m)
    (hCover : EndpointExceptionalSubwindowCover nu x X BaseRelevant)
    (hRelUpper : EndpointSubwindowRelevanceUpperBound X nu BaseRelevant) :
    CutoffClosedLiveInitialSegmentCover
      (NonVisibleBadShell nu H V x)
      (endpointSubwindowIntervalLeft nu X)
      (endpointSubwindowIntervalRight X)
      (CutoffPrefixClosedRelevantAt K BaseRelevant)
      (CutoffPrefixLiveAt nu x X K BaseRelevant) := by
  intro M m _hmM hNV
  rcases hNV with ⟨hBad, hNotVisible⟩
  rcases hSplit m hBad with hVisible | hEndpoint
  · exact False.elim (hNotVisible hVisible)
  · rcases hCover m hEndpoint with ⟨i, hBaseRel, hSub⟩
    by_cases hClosed : i < K M ∧ i ≤ M
    · left
      refine ⟨i, ?_, ?_⟩
      · exact ⟨hBaseRel, hClosed.1, hClosed.2⟩
      · exact endpointSubwindow_mem_realInterval_of_relevanceUpper
          (X := X) (nu := nu) (x := x)
          (Relevant := BaseRelevant)
          hnu hRelUpper hBaseRel hSub
    · right
      exact ⟨i, hBaseRel, hClosed, hSub⟩

/-! ## Static-split data package -/

/-- Static endpoint-split data sufficient to construct the cutoff prefix-index
package.  This is now close to the actual mathematical endpoint target. -/
structure EndpointSubwindowCutoffPrefixStaticSplitData
    (X H V : ℕ → ℝ) (nu x delta eps : ℝ) : Type where
  BaseRelevant : ℕ → ℕ → Prop
  K : ℕ → ℕ
  scaleErr : ℕ → ℝ
  LiveErr : ℕ → ℝ
  nu_pos : 0 < nu
  staticSplit : ∀ m : ℕ,
    BadRamanujanTruncation nu m →
