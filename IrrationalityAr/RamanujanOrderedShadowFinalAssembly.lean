    (clippedLayerCakeQuadraticCutoffBudgetCoreDataTarget_of_finalEndpointGeometrySmallLiveCutoffBudgetTarget
      hFinal)
    hB0 hStart mu hmu

/-- Measure-witness version of the cutoff-aware endpoint final wrapper. -/
theorem oneOverPi_irratMeasure_le_four_of_finalEndpointGeometrySmallLiveCutoffBudgetTarget
    (hFinal : OneOverPiFinalEndpointGeometrySmallLiveCutoffBudgetTarget)
    {mu : ℝ}
    (hmu : HasIrrationalityMeasure (1 / Real.pi) mu) :
