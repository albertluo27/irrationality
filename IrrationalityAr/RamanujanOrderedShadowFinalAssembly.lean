    (hrelSublinear : RelevantActiveShadowCountSublinear
      (endpointSubwindowIntervalLeft nu X)
      (endpointSubwindowIntervalRight X) Relevant)
    (hBudget : ClippedEndpointWeightedAverageBound X nu delta →
      RelevantClippedRealShadowLengthBudget
        (endpointSubwindowIntervalLeft nu X)
        (endpointSubwindowIntervalRight X) Relevant delta D.Err) :
    EndpointSubwindowRelevantClippedIntervalBudgetData X nu x delta Relevant := {
  Err := D.Err
  nu_pos := D.nu_pos
  relevanceUpper := D.relevanceUpper
  relevantActiveCover := hrelCover
  relevantActiveSublinear := hrelSublinear
  errSublinear := D.errSublinear
  relevantClippedLengthBudget := hBudget
