/-- Unit-gain data constructs the concrete step data. -/
def TelescopingClippedStepData.ofUnitGain
    {B M : ℝ} (D : TelescopingClippedUnitGainData B M) :
    TelescopingClippedStepData B M where
  nu := D.nu
  tau := D.tau
  x := D.x
  X := D.X
  H := D.H
  V := D.V
  Hlog := D.Hlog
  u := D.u
  vseq := D.vseq
  closure := D.closure
  bauer := D.bauer
  nu_gt_two := D.nu_gt_two
  nu_le_B := D.nu_le_B
  nu_lt_M := D.nu_lt_M
  tau_pos := D.tau_pos
  x_gt_contraction := D.x_gt_contraction
  x_lt_one := D.x_lt_one
  x_le_global := D.x_le_global
  gain_le_one := D.gain_le_one
  X_pos := D.X_pos
  X_mono := D.X_mono
