/-!
## Direct cover from pointwise witness and low visibility

This compatibility layer proves that the direct-cover formulation follows from
the older pointwise active-witness and low-visibility formulation.  Thus the
new direct-cover target is not stronger than the earlier active-relevant target;
it only packages the exact consequence used by the cutoff closed/live split.
-/

/-- Pointwise active witness plus low-relevant visibility gives the direct
non-visible endpoint-subwindow cover. -/
theorem nonVisibleBadActiveRelevantSubwindowCover_of_activeWitness_lowRelevant
    {nu x : ℝ} {X H V : ℕ → ℝ}
    (hWitness : EndpointActiveRelevantWitnessExistence nu X)
    (hLow : EndpointLowRelevantForcesVisible
      nu x X H V (EndpointActiveRelevant nu X)) :
    NonVisibleBadActiveRelevantSubwindowCover nu x X H V := by
  intro m hNV
  rcases hNV with ⟨hBad, hNotVisible⟩
  rcases hWitness m hBad with ⟨j, hRel⟩
  refine ⟨j, hRel, ?_⟩
  refine ⟨?_, hRel.1⟩
  by_contra hNotLower
  have hLowCap :
      X j ≤ (1 - x) * ramanujanDenominatorCapLog nu m :=
    le_of_not_gt hNotLower
  exact hNotVisible (hLow m j hBad hRel hLowCap)

