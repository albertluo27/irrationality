/-!
# Active-log-count route push

This non-telescoping route packages endpoint-active logarithmic count data
together with scalar relaxed-map convergence.  It avoids the telescoping
cutoff-budget payload by feeding the existing logarithmic active-count final
wrapper directly.
-/

/-- The relaxed bootstrap map sends every input above `4` back above `4`. -/
theorem oneThresholdBootstrapRelaxedMapAboveFour_proved :
    OneThresholdBootstrapRelaxedMapAboveFour := by
  intro B hB
  have htrial_above_four : 4 < oneThresholdStrictSlackTrialNu B := by
    have htrial_line :
        2 + B / 2 < oneThresholdStrictSlackTrialNu B :=
      oneThresholdStrictSlackTrialNu_gt_two_add_half_base_of_four_lt
        (B := B) hB
    have hBhalf : 2 < B / 2 := by linarith
    linarith
  have htrial_lt_relaxed :
      oneThresholdStrictSlackTrialNu B < oneThresholdBootstrapRelaxedMap B :=
    oneThresholdStrictSlackTrialNu_lt_relaxedMap_of_four_lt (B := B) hB
  exact lt_trans htrial_above_four htrial_lt_relaxed

/-- Scalar convergence target for the relaxed bootstrap map. -/
