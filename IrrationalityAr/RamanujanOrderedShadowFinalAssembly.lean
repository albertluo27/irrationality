/-!
# Actual-qlog controlled-prefix endpoint reduction

This replaces the abstract endpoint-log sequence `X` in the Bauer-free
controlled-prefix endpoint target by a sufficiently far tail of the actual
one-over-pi continued-fraction denominator-log sequence
`oneOverPiShiftedQlog 0`.
-/

/-! ## Automatic scalar bookkeeping -/

/-- The canonical live-loss scalar datum has trial exponent below the input
cap. -/
theorem clippedCanonicalStrictSlackScalarData_nu_le_B
    {B : ℝ} (hB : 4 < B) :
    (clippedCanonicalStrictSlackScalarData B hB).nu ≤ B :=
  clippedCanonicalStrictSlackScalarData_nu_le_base hB

/-! ## Tail-stable actual-qlog endpoint data -/

/-- Actual-qlog tail-stable endpoint data.

The sequence `X` is no longer arbitrary.  The endpoint geometry/counting data
is supplied for every finite tail of `oneOverPiShiftedQlog 0`; global positivity
and the global ratio cap are recovered by choosing a sufficiently far tail. -/
structure ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogTailData
    (B : ℝ) (hB : 4 < B) : Type where
  H : ℕ → ℝ
  V : ℕ → ℝ
  Hlog : ℕ → ℝ
  u : ℕ → ℝ
  vseq : ℕ → ℝ
  closureCert_tail : ∀ s : ℕ,
    OrderedEndpointClosureCertificate
      (tailShiftSeq Hlog s) (tailShiftSeq u s) (tailShiftSeq vseq s)
      (tailShiftSeq H s) (tailShiftSeq V s)
      (clippedCanonicalStrictSlackScalarData B hB).tau
      (clippedCanonicalStrictSlackScalarData B hB).x
  logCountData_tail : ∀ s : ℕ,
    EndpointSubwindowCutoffPrefixActiveRelevantLogCountData
      (tailShiftSeq (oneOverPiShiftedQlog 0) s)
      (tailShiftSeq H s) (tailShiftSeq V s)
      (clippedCanonicalStrictSlackScalarData B hB).nu
      (clippedCanonicalStrictSlackScalarData B hB).x
      (oneThresholdEndpointDelta B
        (clippedCanonicalStrictSlackScalarData B hB).nu)
      (clippedCanonicalStrictSlackScalarData B hB).eps
  prefixControl_tail : ∀ s : ℕ,
    EndpointPrefixControlledByBelowLeftActiveCountData
      (clippedCanonicalStrictSlackScalarData B hB).nu
      (tailShiftSeq (oneOverPiShiftedQlog 0) s)
      ((logCountData_tail s).K)

/-- A strict project-level bound is the same raw strict bound used by the
ratio-cap-from-measure bridge. -/
theorem oneOverPiMeasureStrictlyBelowEffectiveRaw_of_strictlyBelow
    {B : ℝ}
    (hB : OneOverPiMeasureStrictlyBelow B) :
    OneOverPiMeasureStrictlyBelowEffectiveRaw B := by
  simpa [OneOverPiMeasureStrictlyBelow,
    OneOverPiMeasureStrictlyBelowEffectiveRaw] using hB

/-- From a strict cap `B`, the actual one-over-pi qlog sequence has an eventual
ratio cap by the finite-measure denominator-log-ratio reduction. -/
theorem eventuallyRatioBoundedBy_actual_oneOverPiQlog_of_strictCap
    {B : ℝ}
    (hB : OneOverPiMeasureStrictlyBelow B) :
    EventuallyRatioBoundedBy (oneOverPiShiftedQlog 0) (B - 1) := by
  have hraw : OneOverPiMeasureStrictlyBelowEffectiveRaw B :=
    oneOverPiMeasureStrictlyBelowEffectiveRaw_of_strictlyBelow hB
  have hrho : denominatorRatioExponent oneOverPiCF < B - 1 :=
    denominatorRatioExponent_oneOverPiCF_lt_of_measureStrictlyBelow_of_bounded
      (B := B)
      oneOverPiContinuantDenLogRatioBoundedTarget_of_finiteMeasure
      hraw
  exact
    eventuallyRatioBoundedBy_oneOverPiShiftedQlog_zero_of_denominatorRatioExponent_lt
      (R := B - 1)
      oneOverPiContinuantDenLogRatioBoundedTarget_of_finiteMeasure
      hrho

/-- Choose a sufficiently far tail of the actual one-over-pi qlog sequence and
recover the previously integrated Bauer-free endpoint-only controlled-prefix
package. -/
def clippedCanonicalControlledPrefixEndpointOnlyData_of_actualQlogTailData
    {B : ℝ} {hB : 4 < B}
    (hBound : OneOverPiMeasureStrictlyBelow B)
    (D :
      ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixActualQlogTailData
        B hB) :
    ClippedCanonicalLiveLossPrefixActiveRelevantLogCountControlledPrefixEndpointOnlyData
      B hB := by
  let hTail := exists_tailShiftSeq_pos_and_ratioBoundedBy
    (X := oneOverPiShiftedQlog 0) (R := B - 1)
    (oneOverPiShiftedQlog_eventuallyPositiveLogScale 0)
    (eventuallyRatioBoundedBy_actual_oneOverPiQlog_of_strictCap
      (B := B) hBound)
  let s : ℕ := Classical.choose hTail
  have hs :
      (∀ j : ℕ, 0 < tailShiftSeq (oneOverPiShiftedQlog 0) s j) ∧
